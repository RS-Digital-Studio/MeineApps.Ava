{
  "rules": {
    ".read": false,
    ".write": false,

    "league": {
      "$season": {
        ".read": "auth != null",
        "$tier": {
          ".read": "auth != null",
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $uid",
            ".validate": "newData.hasChildren(['name', 'points', 'updatedUtc'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16"
            },
            "points": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999999 && (data.val() == null || newData.val() >= data.val())"
            },
            "updatedUtc": {
              ".validate": "newData.isString() && newData.val().length <= 30 && newData.val() != data.val() && newData.val() <= now"
            }
          }
        }
      }
    }
  }
}
