{
  "rules": {
    ".read": false,
    ".write": false,

    "league": {
      "$season": {
        ".read": "auth != null",

        "daily_race": {
          "$date": {
            ".read": "auth != null",
            "$tier": {
              ".indexOn": ["score"],
              ".read": "auth != null",
              "$uid": {
                ".read": "auth != null",
                ".write": "auth != null && auth.uid == $uid",
                ".validate": "newData.hasChildren(['name', 'score', 'updatedMs'])",
                "name": {
                  ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16"
                },
                "score": {
                  ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999999 && (data.val() == null || newData.val() >= data.val())"
                },
                "updatedMs": {
                  ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= now && (!data.exists() || newData.val() >= data.val() + 60000)"
                },
                "$other": {
                  ".validate": false
                }
              }
            }
          }
        },

        "$tier": {
          ".indexOn": ["points"],
          ".read": "auth != null",
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $uid",
            ".validate": "newData.hasChildren(['name', 'points', 'updatedMs'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16"
            },
            "points": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999999 && (!data.exists() || (newData.val() >= data.val() && newData.val() <= data.val() + 2000))"
            },
            "updatedMs": {
              ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= now && (!data.exists() || newData.val() >= data.val() + 60000)"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      }
    },

    "reports": {
      "$reportedUid": {
        ".read": false,
        "$reporterUid": {
          ".write": "auth != null && auth.uid == $reporterUid && auth.uid != $reportedUid && (!data.exists() || newData.child('reportedAt').val() >= data.child('reportedAt').val() + 86400000)",
          ".validate": "newData.hasChildren(['reason', 'reportedAt'])",
          "reason": {
            ".validate": "newData.isString() && (newData.val() == 'offensive_name' || newData.val() == 'cheating' || newData.val() == 'other')"
          },
          "reportedAt": {
            ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= now"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },

    "analytics": {
      "deck": {
        "$uid": {
          ".read": false,
          ".write": "auth != null && auth.uid == $uid",
          "$bombType": {
            ".validate": "newData.hasChildren(['used', 'plays', 'wins'])",
            "used": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "plays": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "wins": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      }
    },

    "clans": {
      ".read": "auth != null",
      ".indexOn": ["weeklyGoalProgress"],
      "$clanId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['clanId', 'sixDigitCode', 'name', 'members'])",
        "clanId": {
          ".validate": "newData.isString() && newData.val().length == 6 && (!data.exists() || newData.val() == data.val())"
        },
        "sixDigitCode": {
          ".validate": "newData.isString() && newData.val().length == 6 && (!data.exists() || newData.val() == data.val())"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 32"
        },
        "weeklyGoalProgress": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000"
        },
        "weeklyGoalTarget": {
          ".validate": "newData.isNumber() && newData.val() >= 1000 && newData.val() <= 1000000"
        },
        "currentBannerAssetPath": {
          ".validate": "newData.isString() && newData.val().length <= 128"
        },
        "members": {
          ".validate": "newData.val().length <= 10",
          "$index": {
            ".validate": "newData.hasChildren(['memberId', 'displayName', 'role'])",
            "memberId": {
              ".validate": "newData.isString() && newData.val().length <= 64"
            },
            "displayName": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 32"
            },
            "contributedCoins": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "lastSeenUtc": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "role": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 2"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "chat": {
          ".indexOn": ["sentUtc"],
          "$messageId": {
            ".write": "auth != null && !data.exists()",
            ".validate": "newData.hasChildren(['messageId', 'senderId', 'senderDisplayName', 'content', 'sentUtc']) && newData.child('senderId').val() == auth.uid && newData.child('content').isString() && newData.child('content').val().length >= 1 && newData.child('content').val().length <= 200",
            "messageId": {
              ".validate": "newData.isString() && newData.val().length <= 64"
            },
            "senderId": {
              ".validate": "newData.isString() && newData.val() == auth.uid"
            },
            "senderDisplayName": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 32"
            },
            "content": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200"
            },
            "sentUtc": {
              ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= now"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      }
    },

    "clan_codes": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && (!data.exists() || data.child('clan_id').val() == newData.child('clan_id').val())",
        ".validate": "newData.hasChild('clan_id')",
        "clan_id": {
          ".validate": "newData.isString() && newData.val().length == 6"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "leaderboard_clans": {
      ".read": "auth != null",
      "$weekId": {
        ".read": "auth != null",
        ".indexOn": ["weeklyGoalProgress"],
        "$clanId": {
          "//": "Client schreibt das Leaderboard nie (nur GetLeaderboardAsync liest) — Write gesperrt. Befuellung nur via Cloud-Function/Admin-SDK (umgeht Rules). Verhindert Leaderboard-Manipulation durch Clients.",
          ".write": "false",
          ".validate": "newData.hasChildren(['clanId', 'name', 'weeklyGoalProgress'])",
          "weeklyGoalProgress": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000 && (!data.exists() || newData.val() >= data.val())"
          },
          "name": {
            ".validate": "newData.isString() && newData.val().length <= 32"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    }
  }
}
