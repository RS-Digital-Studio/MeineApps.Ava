{
  "rules": {
    ".read": false,
    ".write": false,

    "auth_to_player": {
      "$authUid": {
        ".read": "auth != null && auth.uid == $authUid",
        ".write": "auth != null && auth.uid == $authUid"
      }
    },

    "guilds": {
      ".read": "auth != null",
      ".indexOn": ["level", "leaguePoints", "weeklyProgress"],
      "$guildId": {
        ".write": "auth != null && (root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists() || !data.exists())",
        "level": {
          ".validate": "newData.isNumber() && (!data.exists() || newData.val() == data.val() || newData.val() == data.val() + 1)"
        },
        "leaguePoints": {
          ".validate": "newData.isNumber()"
        },
        "maxMembers": {
          ".validate": "newData.isNumber() && (!data.exists() || newData.val() >= data.val())"
        },
        "memberCount": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50"
        },
        "weeklyGoal": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "weeklyProgress": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },

        "coopOrders": {
          "$orderId": {
            ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists() && (root.child('auth_to_player/' + auth.uid).val() == newData.child('createdBy').val() || root.child('auth_to_player/' + auth.uid).val() == newData.child('invitedPlayer').val())",
            ".validate": "newData.hasChildren(['orderId', 'createdBy', 'invitedPlayer', 'status']) && newData.child('orderId').isString() && newData.child('orderId').val().length <= 64",
            "createdBy": {
              ".validate": "newData.isString() && newData.val().length <= 64 && (!data.exists() || newData.val() == data.val())"
            },
            "invitedPlayer": {
              ".validate": "newData.isString() && newData.val().length <= 64 && (!data.exists() || newData.val() == data.val())"
            },
            "status": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3 && (!data.exists() || newData.val() >= data.val())"
            },
            "expiresAt": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "miniGameType": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20"
            },
            "player1Score": {
              ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 100 && (!data.exists() || newData.val() == data.val()) && root.child('auth_to_player/' + auth.uid).val() == newData.parent().child('createdBy').val())"
            },
            "player2Score": {
              ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 100 && (!data.exists() || newData.val() == data.val()) && root.child('auth_to_player/' + auth.uid).val() == newData.parent().child('invitedPlayer').val())"
            },
            "rewardSplit": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1"
            },
            "baseReward": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e12"
            },
            "hmac": {
              ".validate": "newData.isString() && newData.val().length <= 128"
            },
            "claimedBy": {
              "$playerId": {
                ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId && !data.exists() && newData.val() == true",
                ".validate": "newData.isBoolean() && newData.val() == true"
              }
            }
          }
        },

        "auctions": {
          "$auctionId": {
            ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
            ".validate": "newData.hasChildren(['auctionId', 'workerTier', 'status']) && newData.child('auctionId').isString() && newData.child('auctionId').val().length <= 64",
            "auctionId": {
              ".validate": "newData.isString() && newData.val().length <= 64 && (!data.exists() || newData.val() == data.val())"
            },
            "workerTier": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9 && (!data.exists() || newData.val() == data.val())"
            },
            "workerName": {
              ".validate": "newData.isString() && newData.val().length <= 64 && (!data.exists() || newData.val() == data.val())"
            },
            "status": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 2 && (!data.exists() || newData.val() >= data.val())"
            },
            "endsAt": {
              ".validate": "newData.isString() && newData.val().length <= 40 && (!data.exists() || newData.val() == data.val())"
            },
            "highestBidderId": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 64)"
            },
            "highestBid": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e12 && (!data.exists() || newData.val() >= data.val())"
            },
            "allBids": {
              "$bidderId": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e12 && ((data.exists() && newData.val() == data.val()) || $bidderId.beginsWith('npc_bot_') || (root.child('auth_to_player/' + auth.uid).val() == $bidderId && (!data.exists() || newData.val() >= data.val())))"
              }
            },
            "bidTimestamps": {
              "$bidderId": {
                ".validate": "newData.isNumber() && ($bidderId.beginsWith('npc_bot_') || (root.child('auth_to_player/' + auth.uid).val() == $bidderId && (!data.exists() || newData.val() - data.val() >= 1000)))"
              }
            },
            "hmac": {
              ".validate": "newData.isString() && newData.val().length <= 128"
            }
          }
        },

        "megaProjects": {
          "$projectId": {
            ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
            ".validate": "newData.hasChildren(['projectId', 'type', 'createdAt']) && newData.child('projectId').isString() && newData.child('projectId').val().length <= 64",
            "projectId": {
              ".validate": "newData.isString() && newData.val().length <= 64 && (!data.exists() || newData.val() == data.val())"
            },
            "type": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1 && (!data.exists() || newData.val() == data.val())"
            },
            "createdAt": {
              ".validate": "newData.isString() && newData.val().length <= 40 && (!data.exists() || newData.val() == data.val())"
            },
            "completedAt": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 40 && (!data.exists() || newData.val() == data.val()))"
            },
            "contributions": {
              "$productId": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000 && (!data.exists() || newData.val() >= data.val())"
              }
            },
            "donations": {
              "$donorId": {
                ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $donorId",
                "playerName": {
                  ".validate": "newData.isString() && newData.val().length <= 32"
                },
                "totalValue": {
                  ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e15 && (!data.exists() || newData.val() >= data.val())"
                },
                "itemCount": {
                  ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000 && (!data.exists() || newData.val() >= data.val())"
                },
                "lastDonatedAt": {
                  ".validate": "newData.isString() && newData.val().length <= 40"
                }
              }
            },
            "hmac": {
              ".validate": "newData.isString() && newData.val().length <= 128 && (!data.exists() || newData.val() == data.val())"
            }
          }
        }
      }
    },

    "guild_members": {
      "$guildId": {
        ".read": "auth != null",
        "$playerId": {
          ".write": "auth != null && (root.child('auth_to_player/' + auth.uid).val() == $playerId || root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val() + '/role').val() == 'leader' || root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val() + '/role').val() == 'officer')",
          "role": {
            ".validate": "newData.isString() && (root.child('auth_to_player/' + auth.uid).val() != $playerId || newData.val() == data.val() || !data.exists())"
          }
        }
      }
    },

    "player_guilds": {
      "$playerId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId"
      }
    },

    "guild_wars": {
      ".read": "auth != null",
      ".indexOn": ["endDate", "status"],
      "$warId": {
        ".write": "auth != null && (!data.exists() ? (newData.child('guildAId').val() == root.child('player_guilds/' + root.child('auth_to_player/' + auth.uid).val()).val()) : (root.child('guild_members/' + data.child('guildAId').val() + '/' + root.child('auth_to_player/' + auth.uid).val()).exists() || root.child('guild_members/' + data.child('guildBId').val() + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()))",
        "guildAId": {
          ".validate": "newData.isString() && (!data.exists() || newData.val() == data.val())"
        },
        "guildBId": {
          ".validate": "newData.isString() && (!data.exists() || newData.val() == data.val())"
        },
        "guildALevel": {
          ".validate": "newData.isNumber() && (!data.exists() || newData.val() == data.val())"
        },
        "guildBLevel": {
          ".validate": "newData.isNumber() && (!data.exists() || newData.val() == data.val())"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'pending' || newData.val() == 'active' || newData.val() == 'attack' || newData.val() == 'defend' || newData.val() == 'endgame' || newData.val() == 'completed')"
        },
        "startDate": {
          ".validate": "newData.isString() && (!data.exists() || newData.val() == data.val())"
        },
        "endDate": {
          ".validate": "newData.isString()"
        },
        "phase": {
          ".validate": "newData.isString() && (newData.val() == 'attack' || newData.val() == 'defend' || newData.val() == 'endgame')"
        }
      }
    },

    "guild_war_scores": {
      "$warId": {
        ".read": "auth != null",
        "$guildId": {
          "$playerId": {
            ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId && root.child('player_guilds/' + root.child('auth_to_player/' + auth.uid).val()).val() == $guildId",
            "attackScore": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e12 && (!data.exists() || newData.val() >= data.val())"
            },
            "defenseScore": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e12 && (!data.exists() || newData.val() >= data.val())"
            },
            "updatedAt": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "$other": { ".validate": false }
          }
        }
      }
    },

    "guild_war_seasons": {
      ".read": "auth != null",
      ".indexOn": ["status"],
      "$seasonId": {
        ".write": "auth != null && root.child('player_guilds/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
        "leagues": {
          "$leagueKey": {
            ".indexOn": ["points", "rank"],
            "$guildId": {
              ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
              "points": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || (newData.val() >= data.val() && newData.val() <= data.val() + 10000))"
              },
              "wins": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || (newData.val() >= data.val() && newData.val() <= data.val() + 10))"
              },
              "losses": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || (newData.val() >= data.val() && newData.val() <= data.val() + 10))"
              },
              "rank": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
              }
            }
          }
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'active' || newData.val() == 'completed')"
        },
        "startDate": {
          ".validate": "newData.isString() && (!data.exists() || newData.val() == data.val())"
        },
        "endDate": {
          ".validate": "newData.isString() && (!data.exists() || newData.val() == data.val())"
        },
        "week": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
        }
      }
    },

    "guild_war_log": {
      "$warId": {
        ".read": "auth != null",
        ".indexOn": ["timestamp"],
        "$entryId": {
          ".write": "auth != null && !data.exists() && root.child('player_guilds/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
          ".validate": "newData.hasChildren(['type', 'timestamp'])"
        }
      }
    },

    "guild_chat": {
      "$guildId": {
        ".read": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
        "messages": {
          ".indexOn": ["timestamp"],
          "$messageId": {
            ".write": "auth != null && !data.exists() && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
            ".validate": "newData.hasChildren(['uid', 'name', 'text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 200 && newData.child('name').isString() && newData.child('name').val().length <= 50 && newData.child('uid').isString() && newData.child('uid').val() == root.child('auth_to_player/' + auth.uid).val()"
          }
        }
      }
    },

    "guild_invite_codes": {
      "$guildId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()"
      }
    },

    "invite_code_to_guild": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('player_guilds/' + root.child('auth_to_player/' + auth.uid).val()).exists()"
      }
    },

    "available_players": {
      ".read": "auth != null",
      ".indexOn": ["lastActive"],
      "$playerId": {
        ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId",
        ".validate": "newData.hasChildren(['playerName', 'lastActive']) && newData.child('playerName').isString() && newData.child('playerName').val().length >= 1 && newData.child('playerName').val().length <= 32 && newData.child('lastActive').isString()"
      }
    },

    "guild_research": {
      "$guildId": {
        ".read": "auth != null",
        "$researchId": {
          ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()"
        }
      }
    },

    "guild_hall": {
      "$guildId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
        "buildings": {
          "$buildingId": {
            ".validate": "newData.hasChildren(['level'])",
            "level": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50 && (!data.exists() || newData.val() == data.val() || newData.val() == data.val() + 1)"
            },
            "upgradingUntil": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "unlockedAt": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      }
    },

    "guild_bosses": {
      "$guildId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
        "bossId": {
          ".validate": "newData.isString() && newData.val().length <= 64"
        },
        "bossHp": {
          ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 1e15"
        },
        "currentHp": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e15"
        },
        "bossLevel": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 1000"
        },
        "startedAt": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "expiresAt": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'active' || newData.val() == 'defeated' || newData.val() == 'expired')"
        },
        "damage_log": {
          "$playerId": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && root.child('auth_to_player/' + auth.uid).val() == $playerId"
          }
        }
      }
    },

    "guild_boss_damage": {
      "$guildId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
        "$playerId": {
          ".validate": "root.child('auth_to_player/' + auth.uid).val() == $playerId",
          "totalDamage": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e15"
          },
          "hits": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e9"
          },
          "lastHitAt": {
            ".validate": "newData.isString() && newData.val().length <= 40"
          },
          "$other": { ".validate": false }
        }
      }
    },

    "guild_achievements": {
      "$guildId": {
        ".read": "auth != null",
        "$achievementId": {
          ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()"
        }
      }
    },

    "player_invites": {
      "$playerId": {
        ".read": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId",
        "$guildId": {
          ".write": "auth != null && (root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists() || root.child('auth_to_player/' + auth.uid).val() == $playerId)"
        }
      }
    },

    "cloud_saves": {
      "$playerId": {
        ".read":  "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId",
        ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId",
        "metadata": {
          ".validate": "newData.hasChildren(['level', 'savedAt']) && newData.child('level').isNumber() && newData.child('savedAt').isString() && newData.child('savedAt').val().length <= 40",
          "level": {".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000"},
          "money": {".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e15"},
          "goldenScrews": {".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"},
          "prestigePoints": {".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1e9"},
          "ascensionLevel": {".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"},
          "savedAt": {".validate": "newData.isString() && newData.val().length <= 40 && (!data.exists() || newData.val() >= data.val())"},
          "version": {".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100 && (!data.exists() || newData.val() >= data.val())"},
          "appVersion": {".validate": "newData.isString() && newData.val().length <= 20"}
        },
        "data": {
          ".validate": "newData.isString() && newData.val().length <= 1048576"
        }
      }
    },

    "remote_config": {
      ".read": "auth != null",
      ".write": false
    },

    "analytics_events": {
      "$dateKey": {
        ".read": false,
        "$pushId": {
          ".write": "auth != null && !data.exists()",
          ".validate": "newData.hasChildren(['eventName', 'timestamp', 'playerId']) && newData.child('eventName').isString() && newData.child('eventName').val().length <= 64 && newData.child('playerId').val() == root.child('auth_to_player/' + auth.uid).val() && newData.child('timestamp').isString()"
        }
      }
    }
  }
}
