{
  "rules": {
    ".read": false,
    ".write": false,

    "auth_to_player": {
      "$authUid": {
        ".read": "auth != null && auth.uid == $authUid",
        ".write": "auth != null && auth.uid == $authUid"
      }
    },

    "guilds": {
      ".read": "auth != null",
      "$guildId": {
        ".write": "auth != null"
      }
    },

    "guild_members": {
      "$guildId": {
        ".read": "auth != null",
        "$playerId": {
          ".write": "auth != null && (root.child('auth_to_player/' + auth.uid).val() == $playerId || root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val() + '/role').val() == 'leader')"
        }
      }
    },

    "player_guilds": {
      "$playerId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId"
      }
    },

    "leaderboards": {
      "$boardId": {
        ".read": "auth != null",
        "entries": {
          ".indexOn": ["score", "updatedAt"],
          "$playerId": {
            ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId"
          }
        }
      }
    },

    "guild_wars": {
      ".read": "auth != null",
      ".indexOn": ["endDate", "status"],
      "$warId": {
        ".write": "auth != null"
      }
    },

    "guild_war_scores": {
      "$warId": {
        ".read": "auth != null",
        "$guildId": {
          "$playerId": {
            ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId && root.child('player_guilds/' + root.child('auth_to_player/' + auth.uid).val()).val() == $guildId"
          }
        }
      }
    },

    "guild_war_seasons": {
      ".read": "auth != null",
      "$seasonId": {
        ".write": "auth != null"
      }
    },

    "guild_war_log": {
      "$warId": {
        ".read": "auth != null",
        ".indexOn": ["timestamp"],
        ".write": "auth != null"
      }
    },

    "bounties": {
      ".read": "auth != null",
      ".indexOn": ["endDate", "status"],
      "$bountyId": {
        ".write": "auth != null",
        "current": {
          ".validate": "newData.isNumber() && newData.val() >= data.val()"
        },
        "target": {
          ".validate": "newData.isNumber()"
        },
        "contributions": {
          "$playerId": {
            ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId"
          }
        }
      }
    },

    "friends": {
      "$playerId": {
        ".read": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId",
        "$friendPlayerId": {
          ".write": "auth != null && (root.child('auth_to_player/' + auth.uid).val() == $playerId || root.child('auth_to_player/' + auth.uid).val() == $friendPlayerId)"
        }
      }
    },

    "friend_requests": {
      "$playerId": {
        ".read": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId",
        "$fromPlayerId": {
          ".write": "auth != null && (root.child('auth_to_player/' + auth.uid).val() == $fromPlayerId || root.child('auth_to_player/' + auth.uid).val() == $playerId)"
        }
      }
    },

    "gifts": {
      "$playerId": {
        ".read": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId",
        "$giftId": {
          ".write": "auth != null && (!data.exists() || root.child('auth_to_player/' + auth.uid).val() == $playerId)"
        }
      }
    },

    "guild_chat": {
      "$guildId": {
        ".read": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
        "messages": {
          ".indexOn": ["timestamp"],
          ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()"
        }
      }
    },

    "player_profiles": {
      ".read": "auth != null",
      "$playerId": {
        ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId"
      }
    },

    "guild_invite_codes": {
      "$guildId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "invite_code_to_guild": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "guild_invites": {
      "$guildId": {
        ".read": "auth != null",
        "$recipientPlayerId": {
          ".write": "auth != null"
        }
      }
    },

    "available_players": {
      ".read": "auth != null",
      ".indexOn": ["lastActive"],
      "$playerId": {
        ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId"
      }
    },

    "guild_research": {
      "$guildId": {
        ".read": "auth != null",
        "$researchId": {
          ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()"
        }
      }
    },

    "guild_hall": {
      "$guildId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()"
      }
    },

    "guild_bosses": {
      "$guildId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()"
      }
    },

    "guild_boss_damage": {
      "$guildId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('guild_members/' + $guildId + '/' + root.child('auth_to_player/' + auth.uid).val()).exists()",
        "$playerId": {
          ".write": "auth != null && root.child('auth_to_player/' + auth.uid).val() == $playerId"
        }
      }
    }
  }
}
