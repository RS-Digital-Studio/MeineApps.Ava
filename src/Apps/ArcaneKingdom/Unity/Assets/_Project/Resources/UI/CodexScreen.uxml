<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements"
         editor-extension-mode="False">

    <ui:VisualElement class="ak-fill ak-col" style="background-color: var(--ak-bg-base);">

        <ui:VisualElement class="ak-app-header">
            <ui:Button name="codex-back-button" text="‹ Zurueck"
                       class="ak-btn ak-btn--sm ak-btn--ghost" style="margin-right: 12;" />
            <ui:Label text="Codex" class="ak-h3" style="flex-grow: 1;" />
            <ui:Label name="codex-completion" text="0 / 0 entdeckt"
                      class="ak-h4 ak-text--accent" />
        </ui:VisualElement>

        <!-- Filter -->
        <ui:VisualElement class="ak-row" style="padding: 12; align-items: center;">
            <ui:TextField name="codex-search" class="ak-input"
                          style="flex-grow: 1; margin-right: 8; height: 34;" />
            <ui:DropdownField name="codex-element-filter" label="" style="min-width: 120;" />
            <ui:Toggle name="codex-owned-only" label="Nur entdeckte"
                       style="margin-left: 12;" />
        </ui:VisualElement>

        <!-- Karten-Grid -->
        <ui:ScrollView style="flex-grow: 1;">
            <ui:VisualElement name="codex-grid"
                              style="flex-direction: row; flex-wrap: wrap;
                                     justify-content: center; padding: 8;" />
        </ui:ScrollView>
    </ui:VisualElement>
</ui:UXML>
