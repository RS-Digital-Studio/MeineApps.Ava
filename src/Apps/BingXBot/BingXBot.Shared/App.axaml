<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             x:Class="BingXBot.App">

  <Application.Styles>
    <!-- Avalonia Fluent Theme (Dark-Mode wird in App.axaml.cs via RequestedThemeVariant gesetzt) -->
    <FluentTheme />

    <!-- Material Icons -->
    <materialIcons:MaterialIconStyles />

    <!-- App-spezifische Farbpalette -->
    <StyleInclude Source="/Themes/AppPalette.axaml" />
  </Application.Styles>

</Application>
