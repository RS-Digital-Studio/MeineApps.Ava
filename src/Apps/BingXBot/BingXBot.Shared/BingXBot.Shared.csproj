<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>BingXBot</RootNamespace>
    <Version>1.8.1</Version>
  </PropertyGroup>

  <ItemGroup>
    <!-- Projekt-Referenzen -->
    <ProjectReference Include="..\..\..\Libraries\MeineApps.Core.Ava\MeineApps.Core.Ava.csproj" />
    <ProjectReference Include="..\BingXBot.Core\BingXBot.Core.csproj" />
    <ProjectReference Include="..\BingXBot.Contracts\BingXBot.Contracts.csproj" />
    <ProjectReference Include="..\BingXBot.ClientApi\BingXBot.ClientApi.csproj" />
    <ProjectReference Include="..\BingXBot.Trading\BingXBot.Trading.csproj" />
    <ProjectReference Include="..\BingXBot.Exchange\BingXBot.Exchange.csproj" />
    <ProjectReference Include="..\BingXBot.Engine\BingXBot.Engine.csproj" />
    <ProjectReference Include="..\BingXBot.Backtest\BingXBot.Backtest.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Avalonia -->
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Material.Icons.Avalonia" />

    <!-- MVVM -->
    <PackageReference Include="CommunityToolkit.Mvvm" />

    <!-- DI + Logging -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging" />

    <!-- Database -->
    <PackageReference Include="sqlite-net-pcl" />
    <PackageReference Include="SQLitePCLRaw.bundle_green" />

    <!-- Graphics -->
    <PackageReference Include="SkiaSharp" />
    <PackageReference Include="Avalonia.Labs.Controls" />

    <!-- Verschlüsselung (DPAPI auf Windows) -->
    <PackageReference Include="System.Security.Cryptography.ProtectedData" />
  </ItemGroup>

  <ItemGroup>
    <!-- DI-Container-Validation-Tests brauchen Zugriff auf internal ConfigureServices -->
    <InternalsVisibleTo Include="BingXBot.Tests" />
  </ItemGroup>

</Project>
