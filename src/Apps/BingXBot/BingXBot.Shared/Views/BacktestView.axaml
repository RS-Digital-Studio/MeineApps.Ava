<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:bt="using:BingXBot.Backtest"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.BacktestView"
             x:DataType="vm:BacktestViewModel"
             x:CompileBindings="True">

  <DockPanel>

    <!-- Titel + Erklärung -->
    <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,20">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <mi:MaterialIcon Kind="History" Width="28" Height="28"
                         Foreground="{DynamicResource AppPrimaryBrush}" />
        <TextBlock Text="Backtest" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock Text="Teste eine Strategie gegen historische Marktdaten, um zu sehen wie sie performt hätte."
                 FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap" Margin="40,0,0,0" />
    </StackPanel>

    <!-- Trade-Liste unten -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource CardBrush}"
            CornerRadius="8" Margin="0,16,0,0"
            BoxShadow="{DynamicResource CardShadow}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1"
            IsVisible="{Binding HasResult}"
            MaxHeight="220">
      <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="8,8,0,0"
                Padding="16,10">
          <Grid ColumnDefinitions="*,80,100,100,80">
            <TextBlock Grid.Column="0" Text="Symbol" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="1" Text="Seite" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="Entry" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
            <TextBlock Grid.Column="3" Text="Exit" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
            <TextBlock Grid.Column="4" Text="P&amp;L" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
          </Grid>
        </Border>

        <!-- Trade-Zeilen (virtualisiert) -->
        <ListBox ItemsSource="{Binding Trades}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="MinHeight" Value="0" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:BacktestTradeItem">
              <Border Padding="16,8"
                      BorderBrush="{DynamicResource BorderSubtleBrush}"
                      BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,80,100,100,80">
                  <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" />
                  <!-- Seite (Long/Short) -->
                  <Border Grid.Column="1" CornerRadius="4" Padding="8,2"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="{DynamicResource InfoBackgroundColor}" />
                    </Border.Background>
                    <TextBlock Text="{Binding Side}" FontSize="11"
                               Foreground="{DynamicResource InfoBrush}"
                               HorizontalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding Entry, StringFormat={}{0:N2}}"
                             FontSize="12"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding Exit, StringFormat={}{0:N2}}"
                             FontSize="12"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center" />
                  <!-- P&L farbcodiert: Gewinn grün, Verlust rot -->
                  <TextBlock Grid.Column="4"
                             Text="{Binding Pnl, StringFormat={}{0:+0.00;-0.00}}"
                             FontSize="12" FontWeight="SemiBold"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource SuccessBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             IsVisible="{Binding IsWin}" />
                  <TextBlock Grid.Column="4"
                             Text="{Binding Pnl, StringFormat={}{0:+0.00;-0.00}}"
                             FontSize="12" FontWeight="SemiBold"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource ErrorBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             IsVisible="{Binding !IsWin}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Hauptbereich: Settings links, Ergebnis-Cards rechts -->
    <Grid ColumnDefinitions="280,16,*">

      <!-- ═══ Settings (links) ═══ -->
      <Border Grid.Column="0"
              Background="{DynamicResource CardBrush}"
              CornerRadius="8" Padding="20"
              BoxShadow="{DynamicResource CardShadow}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="Cog" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Konfiguration" FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>

            <!-- Symbol (editierbare ComboBox mit verfügbaren Symbolen von BingX) -->
            <StackPanel Spacing="4">
              <TextBlock Text="Symbol" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox ItemsSource="{Binding AvailableSymbols}"
                        SelectedItem="{Binding Symbol, Mode=TwoWay}"
                        IsEditable="True"
                        PlaceholderText="BTC-USDT"
                        HorizontalAlignment="Stretch"
                        FontSize="13"
                        Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- Strategie -->
            <StackPanel Spacing="4">
              <TextBlock Text="Strategie" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox ItemsSource="{Binding Strategies}"
                        SelectedItem="{Binding SelectedStrategy}"
                        HorizontalAlignment="Stretch"
                        Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- Zeitrahmen -->
            <StackPanel Spacing="4">
              <TextBlock Text="Zeitrahmen" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox ItemsSource="{Binding TimeFrames}"
                        SelectedItem="{Binding SelectedTimeFrame}"
                        HorizontalAlignment="Stretch"
                        Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- Zeitraum -->
            <StackPanel Spacing="4">
              <TextBlock Text="Start-Datum" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <CalendarDatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="End-Datum" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <CalendarDatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- Start-Balance -->
            <StackPanel Spacing="4">
              <TextBlock Text="Start-Balance ($)" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <NumericUpDown Value="{Binding InitialBalance, Mode=TwoWay}"
                            Minimum="100" Maximum="1000000" Increment="500"
                            FormatString="N0" FontSize="13"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Leverage -->
            <StackPanel Spacing="4">
              <TextBlock Text="Hebel (x)" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <NumericUpDown Value="{Binding Leverage, Mode=TwoWay}"
                            Minimum="1" Maximum="125" Increment="1"
                            FormatString="0" FontSize="13"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Multi-TF Standalone: Backtest pro TF sequenziell -->
            <StackPanel Spacing="6">
              <CheckBox Content="Alle TFs testen (sequenziell)"
                        IsChecked="{Binding BacktestAllTimeframes}"
                        IsEnabled="{Binding !IsRunning}"
                        Foreground="{DynamicResource TextPrimaryBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="10"
                          IsVisible="{Binding BacktestAllTimeframes}"
                          Margin="24,0,0,0">
                <CheckBox Content="1D" IsChecked="{Binding TfD1InBacktest}" IsEnabled="{Binding !IsRunning}" />
                <CheckBox Content="4H" IsChecked="{Binding TfH4InBacktest}" IsEnabled="{Binding !IsRunning}" />
                <CheckBox Content="1H" IsChecked="{Binding TfH1InBacktest}" IsEnabled="{Binding !IsRunning}" />
                <CheckBox Content="15m" IsChecked="{Binding TfM15InBacktest}" IsEnabled="{Binding !IsRunning}" />
              </StackPanel>
              <TextBlock Text="{Binding PerTfSummary}" FontSize="10"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         IsVisible="{Binding PerTfSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

            <!-- v1.6.0 Phase 10C — Walk-Forward (überlappende Fenster für Robustheits-Test) -->
            <StackPanel Spacing="6">
              <CheckBox Content="Walk-Forward (Robustheit)"
                        IsChecked="{Binding EnableWalkForward}"
                        IsEnabled="{Binding !IsRunning}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        ToolTip.Tip="Teilt Zeitraum in überlappende Fenster, prüft Konsistenz der Strategie über Markt-Regimes" />
              <StackPanel Spacing="6" IsVisible="{Binding EnableWalkForward}" Margin="24,0,0,0">
                <Grid ColumnDefinitions="*,8,*">
                  <StackPanel Grid.Column="0" Spacing="3">
                    <TextBlock Text="Window (Tage)" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <NumericUpDown Value="{Binding WalkForwardWindowDays}"
                                   Minimum="3" Maximum="365" Increment="1"
                                   FormatString="0" FontSize="12"
                                   IsEnabled="{Binding !IsRunning}"
                                   HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="3">
                    <TextBlock Text="Step (Tage)" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <NumericUpDown Value="{Binding WalkForwardStepDays}"
                                   Minimum="1" Maximum="180" Increment="1"
                                   FormatString="0" FontSize="12"
                                   IsEnabled="{Binding !IsRunning}"
                                   HorizontalAlignment="Stretch" />
                  </StackPanel>
                </Grid>
                <TextBlock Text="Robustheits-Score = StdDev der WinRate. Niedrig = konsistent, hoch = Overfitting-Verdacht."
                           FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>

            <!-- Start-Button -->
            <Button Command="{Binding RunBacktestCommand}"
                    IsEnabled="{Binding !IsRunning}"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"
                    CornerRadius="6"
                    Cursor="Hand"
                    HorizontalContentAlignment="Center">
              <Button.Background>
                <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
              </Button.Background>
              <StackPanel Orientation="Horizontal" Spacing="8"
                          HorizontalAlignment="Center">
                <mi:MaterialIcon Kind="PlayCircleOutline" Width="18" Height="18"
                                 Foreground="{DynamicResource PrimaryContrastBrush}" />
                <TextBlock Text="Backtest starten" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryContrastBrush}" />
              </StackPanel>
            </Button>

            <!-- Progress -->
            <StackPanel Spacing="4" IsVisible="{Binding IsRunning}">
              <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100"
                           Foreground="{DynamicResource AppPrimaryBrush}"
                           Background="{DynamicResource SurfaceBrush}"
                           Height="6" CornerRadius="3" />
              <TextBlock Text="{Binding StatusText}" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Status (wenn nicht laufend) -->
            <TextBlock Text="{Binding StatusText}" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding !IsRunning}" />
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ═══ Ergebnis-Cards (rechts) ═══ -->
      <Border Grid.Column="2"
              Background="{DynamicResource CardBrush}"
              CornerRadius="8" Padding="20"
              BoxShadow="{DynamicResource CardShadow}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="1">
        <Panel>

        <!-- Kein Ergebnis: Platzhalter -->
        <StackPanel IsVisible="{Binding !HasResult}"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="12">
          <mi:MaterialIcon Kind="ChartBoxOutline" Width="48" Height="48"
                           Foreground="{DynamicResource TextMutedBrush}" Opacity="0.4"
                           HorizontalAlignment="Center" />
          <TextBlock Text="Starte einen Backtest um Ergebnisse zu sehen"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Wähle links ein Symbol, eine Strategie und einen Zeitraum aus."
                     FontSize="12"
                     Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Ergebnis-Grid -->
        <ScrollViewer IsVisible="{Binding HasResult}" VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,16,Auto,16,Auto,16,Auto,16,Auto"
              ColumnDefinitions="*,12,*,12,*,12,*">

          <!-- Zeile 1: P&L, WinRate, Max DD, Sharpe -->
          <!-- P&L (grün bei Gewinn, rot bei Verlust) -->
          <Border Grid.Row="0" Grid.Column="0"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12">
            <StackPanel Spacing="4">
              <TextBlock Text="Gesamt-P&amp;L" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <!-- Gewinn (grün) -->
              <TextBlock Text="{Binding TotalPnl, StringFormat={}{0:+0.00;-0.00} $}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource SuccessBrush}"
                         IsVisible="{Binding IsPnlPositive}" />
              <!-- Verlust (rot) -->
              <TextBlock Text="{Binding TotalPnl, StringFormat={}{0:+0.00;-0.00} $}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource ErrorBrush}"
                         IsVisible="{Binding !IsPnlPositive}" />
              <TextBlock Text="Gewinn / Verlust über alle Trades"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7" />
            </StackPanel>
          </Border>

          <!-- WinRate (grün wenn >50%, sonst rot) -->
          <Border Grid.Row="0" Grid.Column="2"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  ToolTip.Tip="Anteil der profitablen Trades">
            <StackPanel Spacing="4">
              <TextBlock Text="Win-Rate" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource SuccessBrush}"
                         IsVisible="{Binding IsWinRateGood}" />
              <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource ErrorBrush}"
                         IsVisible="{Binding !IsWinRateGood}" />
              <TextBlock Text="Anteil der Trades mit Gewinn"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7" />
            </StackPanel>
          </Border>

          <!-- Max Drawdown -->
          <Border Grid.Row="0" Grid.Column="4"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  ToolTip.Tip="Größter Rückgang vom Höchststand in Prozent">
            <StackPanel Spacing="4">
              <TextBlock Text="Max. Drawdown" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding MaxDrawdown, StringFormat={}{0:F1}%}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource ErrorBrush}" />
              <TextBlock Text="Größter Rückgang vom Höchststand"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7" />
            </StackPanel>
          </Border>

          <!-- Sharpe Ratio -->
          <Border Grid.Row="0" Grid.Column="6"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  ToolTip.Tip="Risiko-adjustierte Rendite. Über 1.0 ist gut, über 2.0 ist exzellent">
            <StackPanel Spacing="4">
              <TextBlock Text="Sharpe Ratio" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SharpeRatio, StringFormat={}{0:F2}}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Risiko-adjustierte Rendite (>1 = gut)"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7" />
            </StackPanel>
          </Border>

          <!-- Zeile 2: Profit Factor, Trades, Avg Win, Avg Loss -->
          <!-- Profit Factor -->
          <Border Grid.Row="2" Grid.Column="0"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  ToolTip.Tip="Verhältnis von Bruttogewinn zu Bruttoverlust. Über 1.5 ist gut">
            <StackPanel Spacing="4">
              <TextBlock Text="Profit Factor" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding ProfitFactor, StringFormat={}{0:F2}}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Verhältnis Gewinn / Verlust (>1 = profitabel)"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7" />
            </StackPanel>
          </Border>

          <!-- Total Trades -->
          <Border Grid.Row="2" Grid.Column="2"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12">
            <StackPanel Spacing="4">
              <TextBlock Text="Trades" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding TotalTrades}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Anzahl ausgeführter Trades"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7" />
            </StackPanel>
          </Border>

          <!-- Avg Win -->
          <Border Grid.Row="2" Grid.Column="4"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12">
            <StackPanel Spacing="4">
              <TextBlock Text="Durchschn. Gewinn" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding AverageWin, StringFormat={}{0:+0.00} $}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource SuccessBrush}" />
              <TextBlock Text="Mittelwert der Gewinn-Trades"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7" />
            </StackPanel>
          </Border>

          <!-- Avg Loss -->
          <Border Grid.Row="2" Grid.Column="6"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12">
            <StackPanel Spacing="4">
              <TextBlock Text="Durchschn. Verlust" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding AverageLoss, StringFormat={}{0:-0.00} $}"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource ErrorBrush}" />
              <TextBlock Text="Mittelwert der Verlust-Trades"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7" />
            </StackPanel>
          </Border>

          <!-- ═══ Zeile 3: Erweiterte Metriken ═══ -->
          <Border Grid.Row="4" Grid.Column="0"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  ToolTip.Tip="Annualisierte Rendite / Max. Drawdown">
            <StackPanel Spacing="4">
              <TextBlock Text="Calmar Ratio" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding CalmarRatio, StringFormat={}{0:F2}}"
                         FontSize="20" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="4" Grid.Column="2"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  ToolTip.Tip="Wie Sharpe, aber nur Downside-Volatilität">
            <StackPanel Spacing="4">
              <TextBlock Text="Sortino Ratio" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SortinoRatio, StringFormat={}{0:F2}}"
                         FontSize="20" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="4" Grid.Column="4"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  ToolTip.Tip="Netto-Gewinn / Max. Drawdown">
            <StackPanel Spacing="4">
              <TextBlock Text="Recovery Factor" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding RecoveryFactor, StringFormat={}{0:F2}}"
                         FontSize="20" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="4" Grid.Column="6"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12">
            <StackPanel Spacing="4">
              <TextBlock Text="Max. Verlust-Serie" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding MaxConsecutiveLosses}"
                         FontSize="20" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource ErrorBrush}" />
            </StackPanel>
          </Border>

          <!-- ═══ Zeile 4: Monte Carlo (nur sichtbar wenn Ergebnis vorhanden) ═══ -->
          <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  IsVisible="{Binding HasMonteCarloResult}">
            <StackPanel Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <mi:MaterialIcon Kind="ChartBellCurveCumulative" Width="16" Height="16"
                                 Foreground="{DynamicResource AppPrimaryBrush}" />
                <TextBlock Text="Monte Carlo (1000 Simulationen)" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
              <Grid ColumnDefinitions="*,*,*,*" Margin="0,4,0,0">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="Max DD 95%" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding McMaxDrawdown95, StringFormat={}{0:F1}%}"
                             FontSize="15" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource ErrorBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="Return 5%" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding McReturn5, StringFormat={}{0:F1}%}"
                             FontSize="15" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="2">
                  <TextBlock Text="Return Median" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding McReturn50, StringFormat={}{0:F1}%}"
                             FontSize="15" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="2">
                  <TextBlock Text="Ruin-Risiko" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding McRuinProbability, StringFormat={}{0:F1}%}"
                             FontSize="15" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource WarningBrush}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <!-- CPCV Overfitting-Check -->
          <Border Grid.Row="6" Grid.Column="4" Grid.ColumnSpan="3"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="16,12"
                  IsVisible="{Binding HasCpcvResult}">
            <StackPanel Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <mi:MaterialIcon Kind="ShieldCheck" Width="16" Height="16"
                                 Foreground="{DynamicResource AppPrimaryBrush}" />
                <TextBlock Text="CPCV Overfitting-Check" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
              <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="PBO" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding CpcvPbo, StringFormat={}{0:F1}%}"
                             FontSize="15" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource WarningBrush}" />
                  <TextBlock Text="&lt;30% = akzeptabel" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="Degradation" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding CpcvDegradation, StringFormat={}{0:F1}%}"
                             FontSize="15" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="IS → OOS Verlust" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="2">
                  <TextBlock Text="OOS Return" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding CpcvAvgOosReturn, StringFormat={}{0:F2}%}"
                             FontSize="15" FontWeight="Bold" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

        </Grid>
        </ScrollViewer>

        <!-- v1.6.0 Phase 10C — Walk-Forward-Ergebnis -->
        <ScrollViewer IsVisible="{Binding HasWalkForwardResult}" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="14" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <mi:MaterialIcon Kind="ChartTimelineVariant" Width="22" Height="22"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Walk-Forward Robustheit" FontSize="16" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Aggregat-Karten -->
            <Grid ColumnDefinitions="*,12,*,12,*,12,*">
              <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                      CornerRadius="8" Padding="14,10">
                <StackPanel Spacing="3">
                  <TextBlock Text="Fenster" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding WalkForwardWindowCount}"
                             FontSize="20" FontWeight="Bold"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                      CornerRadius="8" Padding="14,10">
                <StackPanel Spacing="3">
                  <TextBlock Text="Ø WinRate" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding WalkForwardAvgWinRate, StringFormat='{}{0:P1}'}"
                             FontSize="20" FontWeight="Bold"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource SuccessBrush}" />
                </StackPanel>
              </Border>
              <Border Grid.Column="4" Background="{DynamicResource SurfaceBrush}"
                      CornerRadius="8" Padding="14,10">
                <StackPanel Spacing="3">
                  <TextBlock Text="Robustheit (StdDev)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                             ToolTip.Tip="StdDev der WinRate über alle Fenster — niedrig = konsistent, hoch = Overfitting-Verdacht" />
                  <TextBlock Text="{Binding WalkForwardRobustnessScore, StringFormat='{}{0:F4}'}"
                             FontSize="20" FontWeight="Bold"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource WarningBrush}" />
                </StackPanel>
              </Border>
              <Border Grid.Column="6" Background="{DynamicResource SurfaceBrush}"
                      CornerRadius="8" Padding="14,10">
                <StackPanel Spacing="3">
                  <TextBlock Text="Σ Net-PnL" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding WalkForwardTotalPnl, StringFormat='{}{0:+0.00;-0.00;0.00}'}"
                             FontSize="20" FontWeight="Bold"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- Pro-Window-Tabelle -->
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="0">
              <DockPanel>
                <Border DockPanel.Dock="Top" Background="{DynamicResource AppBackgroundAltBrush}"
                        CornerRadius="8,8,0,0" Padding="14,8">
                  <Grid ColumnDefinitions="40,160,160,80,80,90,90">
                    <TextBlock Grid.Column="0" Text="#" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="Von (UTC)" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="2" Text="Bis (UTC)" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="3" Text="Trades" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="WinRate" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="5" Text="Net PnL" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="6" Text="Max DD" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
                  </Grid>
                </Border>
                <ListBox ItemsSource="{Binding WalkForwardWindows}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         MaxHeight="280">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="MinHeight" Value="0" />
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                  </ListBox.ItemsPanel>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="bt:WalkForwardWindowResult">
                      <Border Padding="14,6"
                              BorderBrush="{DynamicResource BorderSubtleBrush}"
                              BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="40,160,160,80,80,90,90">
                          <TextBlock Grid.Column="0" Text="{Binding Index}" FontSize="11"
                                     FontFamily="Consolas, Courier New, monospace"
                                     Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Grid.Column="1" Text="{Binding From, StringFormat=yyyy-MM-dd HH:mm}"
                                     FontSize="11" FontFamily="Consolas, Courier New, monospace"
                                     Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Grid.Column="2" Text="{Binding To, StringFormat=yyyy-MM-dd HH:mm}"
                                     FontSize="11" FontFamily="Consolas, Courier New, monospace"
                                     Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Grid.Column="3" Text="{Binding TotalTrades}" FontSize="11"
                                     FontFamily="Consolas, Courier New, monospace"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     HorizontalAlignment="Right" />
                          <TextBlock Grid.Column="4"
                                     Text="{Binding WinRate, StringFormat='{}{0:P0}'}"
                                     FontSize="11" FontWeight="SemiBold"
                                     FontFamily="Consolas, Courier New, monospace"
                                     Foreground="{DynamicResource SuccessBrush}"
                                     HorizontalAlignment="Right" />
                          <TextBlock Grid.Column="5"
                                     Text="{Binding NetPnl, StringFormat='{}{0:+0.00;-0.00;0.00}'}"
                                     FontSize="11" FontWeight="SemiBold"
                                     FontFamily="Consolas, Courier New, monospace"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     HorizontalAlignment="Right" />
                          <TextBlock Grid.Column="6"
                                     Text="{Binding MaxDrawdown, StringFormat='{}{0:F2}'}"
                                     FontSize="11" FontFamily="Consolas, Courier New, monospace"
                                     Foreground="{DynamicResource ErrorBrush}"
                                     HorizontalAlignment="Right" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </DockPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
        </Panel>
      </Border>

    </Grid>
  </DockPanel>

</UserControl>
