<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:skia="using:Avalonia.Labs.Controls"
             xmlns:conv="using:BingXBot.Converters"
             x:Class="BingXBot.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             x:CompileBindings="True">

  <UserControl.Resources>
    <conv:NullableDecimalConverter x:Key="NullableDecimalConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- P&L-Farbe: Positiv = Gruen, Negativ = Rot -->
    <Style Selector="TextBlock.PnlPositive">
      <Setter Property="Foreground" Value="{DynamicResource AppProfitBrush}" />
    </Style>
    <Style Selector="TextBlock.PnlNegative">
      <Setter Property="Foreground" Value="{DynamicResource AppLossBrush}" />
    </Style>

    <!-- Bot-Button Styles -->
    <Style Selector="Button.BotButton">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="MinWidth" Value="100" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.BotStart">
      <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.BotStart:pointerover">
      <Setter Property="Background" Value="{DynamicResource SuccessHoverBrush}" />
    </Style>
    <Style Selector="Button.BotPause">
      <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.BotPause:pointerover">
      <Setter Property="Background" Value="{DynamicResource WarningHoverBrush}" />
    </Style>
    <Style Selector="Button.BotStop">
      <Setter Property="Background" Value="{DynamicResource StopSurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.BotStop:pointerover">
      <Setter Property="Background" Value="{DynamicResource StopHoverBrush}" />
    </Style>
    <Style Selector="Button.BotEmergency">
      <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.BotEmergency:pointerover">
      <Setter Property="Background" Value="{DynamicResource ErrorHoverBrush}" />
    </Style>

    <!-- Modus-Button Styles -->
    <Style Selector="Button.ModeButton">
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="MinWidth" Value="80" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.ModeButton:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
    </Style>

    <!-- Sektion-Ueberschrift -->
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Roter Rand wenn Live-Trading aktiv -->
    <Style Selector="Border.LiveActive">
      <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Activity-Feed expandiert: MaxHeight aufheben -->
    <Style Selector="ScrollViewer.Expanded">
      <Setter Property="MaxHeight" Value="500" />
    </Style>
  </UserControl.Styles>

  <UserControl.KeyBindings>
    <!-- Bot-Kontrolle: F5=Start, F6=Pause, F7=Stop, F12=Notfall-Stop -->
    <KeyBinding Gesture="F5" Command="{Binding StartBotCommand}" />
    <KeyBinding Gesture="F6" Command="{Binding PauseBotCommand}" />
    <KeyBinding Gesture="F7" Command="{Binding StopBotCommand}" />
    <KeyBinding Gesture="F12" Command="{Binding EmergencyStopCommand}" />
  </UserControl.KeyBindings>

  <Grid>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" Margin="0,0,0,24">

      <!-- ================================================================= -->
      <!-- LIVE-TRADING WARNUNG (nur wenn IsLiveActive=true)                 -->
      <!-- ================================================================= -->
      <Border IsVisible="{Binding IsLiveActive}"
              Background="{DynamicResource ErrorOverlayBrush}" BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="2"
              CornerRadius="8" Padding="16">
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
          <mi:MaterialIcon Kind="AlertCircle" Width="22" Height="22"
                           Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center" />
          <TextBlock Text="LIVE-TRADING AKTIV - Echtes Geld wird gehandelt!"
                     FontSize="15" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"
                     VerticalAlignment="Center" />
          <mi:MaterialIcon Kind="AlertCircle" Width="22" Height="22"
                           Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- ================================================================= -->
      <!-- Willkommens-Hinweis (nur wenn ShowWelcomeHint=true)               -->
      <!-- ================================================================= -->
      <Border IsVisible="{Binding ShowWelcomeHint}"
              Background="{DynamicResource InfoSurfaceBrush}" CornerRadius="8" Padding="16">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <mi:MaterialIcon Grid.Column="0" Kind="InformationOutline" Width="20" Height="20"
                           Foreground="{DynamicResource AppPrimaryBrush}"
                           VerticalAlignment="Top" Margin="0,2,0,0" />
          <TextBlock Grid.Column="1" Text="{Binding WelcomeHintText}" TextWrapping="Wrap"
                     Foreground="{DynamicResource AppTextBrush}" FontSize="13"
                     Margin="12,0,12,0" />
          <Button Grid.Column="2" Command="{Binding DismissWelcomeHintCommand}"
                  Background="Transparent" BorderThickness="0" Padding="4"
                  Cursor="Hand" VerticalAlignment="Top">
            <mi:MaterialIcon Kind="Close" Width="16" Height="16"
                             Foreground="{DynamicResource AppTextSecondaryBrush}" />
          </Button>
        </Grid>
      </Border>

      <!-- ================================================================= -->
      <!-- Bot-Kontrolle + Modus (nebeneinander)                             -->
      <!-- ================================================================= -->
      <Grid ColumnDefinitions="*,Auto">

        <!-- Bot-Kontrolle (roter Rand wenn Live aktiv) -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="20,16" Margin="0,0,12,0"
                BoxShadow="{DynamicResource CardShadow}"
                Classes.LiveActive="{Binding IsLiveActive}">
          <StackPanel Spacing="12">
            <!-- Ueberschrift mit Status-Badge -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="RobotOutline" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Bot-Steuerung" Classes="SectionTitle" />
              <!-- Status-Badge -->
              <Border CornerRadius="10" Padding="10,4" Margin="8,0,0,0"
                      Background="{DynamicResource CardBrush}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse x:Name="StatusDot" Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding StatusDotColor}" />
                  <TextBlock Text="{Binding BotStatusText}" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource AppTextSecondaryBrush}" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Strategie-Auswahl + Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12">
              <!-- Strategie-Dropdown -->
              <StackPanel Spacing="2">
                <TextBlock Text="Strategie" FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                <ComboBox ItemsSource="{Binding AvailableStrategies}"
                          SelectedItem="{Binding SelectedStrategy}"
                          IsEnabled="{Binding !IsRunning}"
                          MinWidth="180" FontSize="12" />
              </StackPanel>

              <!-- Buttons -->
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <Button Classes="BotButton BotStart" Content="Start"
                        Command="{Binding StartBotCommand}"
                        IsEnabled="{Binding CanStart}"
                        ToolTip.Tip="Bot starten" />
                <Button Classes="BotButton BotPause" Content="Pause"
                        Command="{Binding PauseBotCommand}"
                        IsEnabled="{Binding IsRunning}"
                        ToolTip.Tip="Bot pausieren" />
                <Button Classes="BotButton BotStop" Content="Stop"
                        Command="{Binding StopBotCommand}"
                        IsEnabled="{Binding IsRunning}"
                        ToolTip.Tip="Bot stoppen" />
                <Border Width="1" Background="{DynamicResource AppBorderBrush}" Margin="8,4" />
                <Button Classes="BotButton BotEmergency" Content="NOTFALL-STOP"
                        Command="{Binding EmergencyStopCommand}"
                        IsEnabled="{Binding IsRunning}"
                        ToolTip.Tip="Notfall-Stop: Alle Positionen sofort schließen (Escape)" />
              </StackPanel>
            </StackPanel>

            <!-- Strategie-Beschreibung -->
            <TextBlock Text="{Binding StrategyDescription}" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap" MaxWidth="500" />
          </StackPanel>
        </Border>

        <!-- Modus-Toggle -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="20,16" MinWidth="220"
                BoxShadow="{DynamicResource CardShadow}">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="SwapHorizontal" Width="18" Height="18"
                               Foreground="{DynamicResource AppWarningBrush}" />
              <TextBlock Text="Trading-Modus" Classes="SectionTitle" />
            </StackPanel>

            <!-- Paper / Live Toggle-Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
              <!-- Paper-Button: aktiv wenn IsPaperMode=true -->
              <Button x:Name="PaperButton" Classes="ModeButton"
                      Command="{Binding ToggleModeCommand}"
                      IsEnabled="{Binding !IsRunning}"
                      ToolTip.Tip="Simuliertes Trading ohne echtes Geld">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="TestTube" Width="14" Height="14" />
                  <TextBlock Text="Paper" />
                </StackPanel>
              </Button>
              <!-- Live-Button: aktiv wenn IsPaperMode=false -->
              <Button x:Name="LiveButton" Classes="ModeButton"
                      Command="{Binding ToggleModeCommand}"
                      IsEnabled="{Binding !IsRunning}"
                      ToolTip.Tip="Echtes Trading mit BingX-Konto (API-Keys erforderlich)">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="CurrencyUsd" Width="14" Height="14" />
                  <TextBlock Text="Live" />
                </StackPanel>
              </Button>
            </StackPanel>

            <TextBlock Text="{Binding ModeDescription}" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap"
                       TextAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- ================================================================= -->
      <!-- Account-Karten (nur sichtbar wenn HasAccountData=true)            -->
      <!-- ================================================================= -->
      <!-- Zustand: Account vorhanden -->
      <UniformGrid Columns="4" Rows="1" IsVisible="{Binding HasAccountData}">

        <!-- Balance -->
        <Border CornerRadius="10" Padding="20,16" Margin="0,0,8,0"
                BoxShadow="{DynamicResource CardShadow}"
                ToolTip.Tip="Gesamter Kontostand inkl. unrealisierter Positionen">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#2A2A44" Offset="0" />
              <GradientStop Color="#1E2A40" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#263B82" CornerRadius="8" Padding="6" Width="32" Height="32">
                <mi:MaterialIcon Kind="Wallet" Width="18" Height="18"
                                 Foreground="{DynamicResource AppPrimaryBrush}" />
              </Border>
              <TextBlock Text="Balance" FontSize="12"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding Balance, StringFormat='{}{0:N2}'}"
                       FontSize="24" FontWeight="Bold"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="USDT" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,-4,0,0" />
          </StackPanel>
        </Border>

        <!-- Verfügbar -->
        <Border CornerRadius="10" Padding="20,16" Margin="4,0"
                BoxShadow="{DynamicResource CardShadow}"
                ToolTip.Tip="Verfügbare Margin für neue Positionen">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#2A2A44" Offset="0" />
              <GradientStop Color="#1E3A2A" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#1E4A3A" CornerRadius="8" Padding="6" Width="32" Height="32">
                <mi:MaterialIcon Kind="CashMultiple" Width="18" Height="18"
                                 Foreground="{DynamicResource AccentBrush}" />
              </Border>
              <TextBlock Text="Verfügbar" FontSize="12"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding AvailableBalance, StringFormat='{}{0:N2}'}"
                       FontSize="24" FontWeight="Bold"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="USDT" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,-4,0,0" />
          </StackPanel>
        </Border>

        <!-- Unrealisiert P&L -->
        <Border CornerRadius="10" Padding="20,16" Margin="4,0"
                BoxShadow="{DynamicResource CardShadow}"
                ToolTip.Tip="Unrealisierter Gewinn/Verlust offener Positionen">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#2A2A44" Offset="0" />
              <GradientStop Color="#2A3A1E" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#2A4A1E" CornerRadius="8" Padding="6" Width="32" Height="32">
                <mi:MaterialIcon Kind="TrendingUp" Width="18" Height="18"
                                 Foreground="{DynamicResource AppProfitBrush}" />
              </Border>
              <TextBlock Text="Unrealisiert" FontSize="12"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <!-- Positiv (grün) -->
              <TextBlock x:Name="UnrealizedPnlText"
                         Text="{Binding UnrealizedPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                         FontSize="24" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource AppProfitBrush}"
                         IsVisible="{Binding IsUnrealizedPnlPositive}" />
              <!-- Negativ (rot) -->
              <TextBlock Text="{Binding UnrealizedPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                         FontSize="24" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource AppLossBrush}"
                         IsVisible="{Binding !IsUnrealizedPnlPositive}" />
              <mi:MaterialIcon Kind="ArrowUp" Width="16" Height="16"
                               Foreground="{DynamicResource AppProfitBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsUnrealizedPnlPositive}" />
              <mi:MaterialIcon Kind="ArrowDown" Width="16" Height="16"
                               Foreground="{DynamicResource AppLossBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsUnrealizedPnlPositive}" />
            </StackPanel>
            <TextBlock Text="USDT" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,-4,0,0" />
          </StackPanel>
        </Border>

        <!-- Gesamt-PnL -->
        <Border CornerRadius="10" Padding="20,16" Margin="8,0,0,0"
                BoxShadow="{DynamicResource CardShadow}"
                ToolTip.Tip="Realisierter Gewinn/Verlust aller geschlossenen Trades">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#2A2A44" Offset="0" />
              <GradientStop Color="#3A2A1E" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#4A2A1E" CornerRadius="8" Padding="6" Width="32" Height="32">
                <mi:MaterialIcon Kind="ChartAreaspline" Width="18" Height="18"
                                 Foreground="{DynamicResource AppWarningBrush}" />
              </Border>
              <TextBlock Text="Gesamt-PnL" FontSize="12"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <!-- Positiv (grün) -->
              <TextBlock x:Name="TotalPnlText"
                         Text="{Binding TotalPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                         FontSize="24" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource AppProfitBrush}"
                         IsVisible="{Binding IsTotalPnlPositive}" />
              <!-- Negativ (rot) -->
              <TextBlock Text="{Binding TotalPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                         FontSize="24" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource AppLossBrush}"
                         IsVisible="{Binding !IsTotalPnlPositive}" />
              <mi:MaterialIcon Kind="ArrowUp" Width="16" Height="16"
                               Foreground="{DynamicResource AppProfitBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsTotalPnlPositive}" />
              <mi:MaterialIcon Kind="ArrowDown" Width="16" Height="16"
                               Foreground="{DynamicResource AppLossBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsTotalPnlPositive}" />
            </StackPanel>
            <TextBlock Text="USDT" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,-4,0,0" />
          </StackPanel>
        </Border>

      </UniformGrid>

      <!-- Zustand: Kein Account -->
      <Border IsVisible="{Binding !HasAccountData}"
              Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="24,20"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
          <mi:MaterialIcon Kind="WalletOutline" Width="20" Height="20"
                           Foreground="{DynamicResource TextMutedBrush}" />
          <TextBlock Text="Bot starten um Account-Daten zu sehen"
                     FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- ================================================================= -->
      <!-- Offene Positionen                                                 -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="12">

          <!-- Header mit "Alle schliessen" Button -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="FormatListBulleted" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Offene Positionen" Classes="SectionTitle" />
              <Border Background="{DynamicResource AppPrimaryBrush}" CornerRadius="10" Padding="8,2"
                      IsVisible="{Binding HasOpenPositions}" VerticalAlignment="Center" Margin="8,0,0,0">
                <TextBlock Text="{Binding OpenPositions.Count}" FontSize="11"
                           Foreground="{DynamicResource PrimaryContrastBrush}" FontWeight="Bold" />
              </Border>
            </StackPanel>

            <Button Grid.Column="2" Content="Alle schliessen"
                    Command="{Binding CloseAllPositionsCommand}"
                    IsVisible="{Binding HasOpenPositions}"
                    Background="{DynamicResource ErrorSurfaceBrush}" Foreground="{DynamicResource AppLossBrush}"
                    CornerRadius="6" Padding="12,6" FontSize="12" Cursor="Hand"
                    BorderThickness="1" BorderBrush="{DynamicResource AppLossBrush}" />
          </Grid>

          <!-- Positions-Cards -->
          <ItemsControl ItemsSource="{Binding OpenPositions}"
                        IsVisible="{Binding HasOpenPositions}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:PositionDisplayItem">
                <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                        Padding="16,12" Margin="0,4"
                        BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
                  <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                    <!-- Zeile 1: Symbol + Side + Leverage | P&L + Close-Button -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="10">
                      <TextBlock Text="{Binding Symbol}" FontSize="15" FontWeight="Bold"
                                 Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                      <Border Background="{Binding SideColor}" CornerRadius="4" Padding="8,2"
                              VerticalAlignment="Center">
                        <TextBlock Text="{Binding SideText}" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryContrastBrush}" />
                      </Border>
                      <TextBlock Text="{Binding Leverage, StringFormat='{}{0:F0}x'}" FontSize="12"
                                 FontFamily="Consolas, Courier New, monospace"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                      <!-- P&L mit Prozent -->
                      <StackPanel HorizontalAlignment="Right">
                        <TextBlock Text="{Binding PnlText}" FontSize="16" FontWeight="Bold"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{Binding PnlColor}" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding PnlPercentText}" FontSize="11"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{Binding PnlColor}" HorizontalAlignment="Right" />
                      </StackPanel>

                      <!-- Close-Button -->
                      <Button Command="{Binding RequestCloseCommand}"
                              Background="Transparent" Padding="6"
                              CornerRadius="4" ToolTip.Tip="Position schliessen" Cursor="Hand"
                              BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
                        <mi:MaterialIcon Kind="Close" Width="14" Height="14"
                                         Foreground="{DynamicResource AppLossBrush}" />
                      </Button>
                    </StackPanel>

                    <!-- Zeile 2: Einstieg / Aktuell / Menge -->
                    <!-- G8 statt N4: Krypto-Preise haben variable Dezimalstellen (Micro-Cap Tokens) -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="20" Margin="0,10,0,0">
                      <StackPanel>
                        <TextBlock Text="Einstieg" FontSize="10" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <TextBlock Text="{Binding EntryPrice, StringFormat='{}{0:G8}'}" FontSize="13"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{DynamicResource AppTextBrush}" />
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Text="Aktuell" FontSize="10" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <TextBlock Text="{Binding MarkPrice, StringFormat='{}{0:G8}'}" FontSize="13"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{DynamicResource AppTextBrush}" />
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Text="Menge" FontSize="10" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <TextBlock Text="{Binding Quantity, StringFormat='{}{0:N2}'}" FontSize="13"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{DynamicResource AppTextBrush}" />
                      </StackPanel>
                    </StackPanel>

                    <!-- Zeile 3: SL / TP / Trailing (editierbar) -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">
                      <StackPanel>
                        <TextBlock Text="Stop-Loss" FontSize="10" Foreground="{DynamicResource AppLossBrush}" />
                        <TextBox Text="{Binding StopLoss, Converter={StaticResource NullableDecimalConverter}}"
                                 MinWidth="100" FontSize="11" Padding="6,4"
                                 Background="{DynamicResource SurfaceBrush}"
                                 BorderBrush="{DynamicResource AppBorderBrush}"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 Watermark="Kein SL" CornerRadius="4" />
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Text="Take-Profit" FontSize="10" Foreground="{DynamicResource AppProfitBrush}" />
                        <TextBox Text="{Binding TakeProfit, Converter={StaticResource NullableDecimalConverter}}"
                                 MinWidth="100" FontSize="11" Padding="6,4"
                                 Background="{DynamicResource SurfaceBrush}"
                                 BorderBrush="{DynamicResource AppBorderBrush}"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 Watermark="Kein TP" CornerRadius="4" />
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Text="Trailing %" FontSize="10" Foreground="{DynamicResource AppWarningBrush}" />
                        <TextBox Text="{Binding TrailingStop, Converter={StaticResource NullableDecimalConverter}}"
                                 MinWidth="80" FontSize="11" Padding="6,4"
                                 Background="{DynamicResource SurfaceBrush}"
                                 BorderBrush="{DynamicResource AppBorderBrush}"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 Watermark="Aus" CornerRadius="4" />
                      </StackPanel>
                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Leerer Zustand: Keine Positionen -->
          <StackPanel IsVisible="{Binding !HasOpenPositions}" HorizontalAlignment="Center"
                      Margin="0,12">
            <mi:MaterialIcon Kind="ChartBoxOutline" Width="32" Height="32"
                             Foreground="{DynamicResource AppTextSecondaryBrush}"
                             HorizontalAlignment="Center" />
            <TextBlock Text="Keine offenen Positionen" FontSize="13"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Text="Der Bot eröffnet Trades automatisch wenn Signale erkannt werden"
                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300"
                       TextAlignment="Center" />
          </StackPanel>

        </StackPanel>
      </Border>

      <!-- ================================================================= -->
      <!-- Bot-Aktivität (Activity-Feed)                                     -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="Pulse" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Bot-Aktivität" Classes="SectionTitle" />
              <Border CornerRadius="10" Padding="8,3" Margin="8,0,0,0"
                      Background="{DynamicResource CardBrush}">
                <TextBlock Text="{Binding Activity.RecentActivity.Count, StringFormat='{}{0}'}"
                           FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}" />
              </Border>
            </StackPanel>
            <!-- Expand/Collapse Toggle -->
            <Button Grid.Column="2" Command="{Binding ToggleActivityExpandedCommand}"
                    Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand"
                    ToolTip.Tip="Aktivität ein-/ausklappen">
              <Panel>
                <mi:MaterialIcon Kind="ChevronDown" Width="16" Height="16"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 IsVisible="{Binding !IsActivityExpanded}" />
                <mi:MaterialIcon Kind="ChevronUp" Width="16" Height="16"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 IsVisible="{Binding IsActivityExpanded}" />
              </Panel>
            </Button>
          </Grid>

          <!-- Leerer Zustand: Bot gestoppt -->
          <TextBlock Grid.Row="1" Text="Bot ist gestoppt - keine Aktivität"
                     IsVisible="{Binding !IsRunning}"
                     Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                     HorizontalAlignment="Center" Margin="0,8" />

          <!-- Activity-Liste (scrollbar, expandierbar) -->
          <ScrollViewer Grid.Row="1"
                        Classes.Expanded="{Binding IsActivityExpanded}"
                        MaxHeight="200"
                        VerticalScrollBarVisibility="Auto"
                        IsVisible="{Binding IsRunning}">
            <ItemsControl ItemsSource="{Binding Activity.RecentActivity}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ActivityItem">
                  <Border Padding="4,3" Margin="0,1">
                    <Grid ColumnDefinitions="58,Auto,*">
                      <TextBlock Grid.Column="0" Text="{Binding TimeText}" FontSize="11"
                                 FontFamily="Consolas,monospace"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 VerticalAlignment="Center" />
                      <Border Grid.Column="1" Background="{Binding LevelColor}" CornerRadius="3"
                              Padding="6,1" Margin="4,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryContrastBrush}" />
                      </Border>
                      <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 TextTrimming="CharacterEllipsis" Margin="6,0,0,0"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- ================================================================= -->
      <!-- BTC-USDT Live-Chart                                               -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <Grid RowDefinitions="Auto,*">
          <!-- Header: BTC-USDT + Preis + Änderung -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="CurrencyBtc" Width="20" Height="20"
                               Foreground="{DynamicResource AppWarningBrush}" />
              <TextBlock Text="BTC-USDT" FontWeight="Bold" FontSize="16"
                         Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Preis (nur sichtbar wenn geladen) -->
            <TextBlock Text="{Binding BtcTicker.BtcPrice, StringFormat='{}{0:N2} USDT'}"
                       FontWeight="Bold" FontSize="16"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center"
                       IsVisible="{Binding !BtcTicker.IsBtcLoading}" />

            <!-- Änderung (nur sichtbar wenn geladen) -->
            <TextBlock x:Name="BtcChangeText"
                       Text="{Binding BtcTicker.BtcPriceChange, StringFormat='{}{0:+0.00;-0.00}%'}"
                       FontSize="14" FontFamily="Consolas, Courier New, monospace"
                       VerticalAlignment="Center"
                       IsVisible="{Binding !BtcTicker.IsBtcLoading}" />

            <!-- Status-Text -->
            <TextBlock Text="{Binding BtcTicker.BtcStatusText}" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />

            <!-- Lade-Indikator -->
            <mi:MaterialIcon Kind="Loading" Width="16" Height="16"
                             Foreground="{DynamicResource AppPrimaryBrush}"
                             IsVisible="{Binding BtcTicker.IsBtcLoading}" />
          </StackPanel>

          <!-- Candlestick Chart -->
          <skia:SKCanvasView Grid.Row="1" x:Name="BtcChartCanvas"
                              PaintSurface="OnBtcChartPaintSurface"
                              MinHeight="280" />
        </Grid>
      </Border>

      <!-- ================================================================= -->
      <!-- Equity-Kurve (nur sichtbar wenn Account aktiv)                    -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16" MinHeight="200"
              BoxShadow="{DynamicResource CardShadow}"
              IsVisible="{Binding HasAccountData}">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="ChartAreaspline" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Equity-Kurve" Classes="SectionTitle" />
          </StackPanel>

          <!-- Equity-Chart (SkiaSharp) -->
          <skia:SKCanvasView x:Name="EquityCanvas" PaintSurface="OnEquityPaintSurface"
                             MinHeight="200" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

  <!-- Bestätigungs-Dialog Overlay -->
  <Border IsVisible="{Binding ShowConfirmDialog}"
          Background="{DynamicResource OverlayBrush}"
          HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Border Background="{DynamicResource CardBrush}"
            CornerRadius="12" Padding="24" MaxWidth="400"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            BoxShadow="0 8 32 0 #60000000">
      <StackPanel Spacing="16">
        <TextBlock Text="{Binding ConfirmDialogTitle}"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource AppTextBrush}" />
        <TextBlock Text="{Binding ConfirmDialogMessage}"
                   FontSize="14" TextWrapping="Wrap"
                   Foreground="{DynamicResource AppTextSecondaryBrush}" />
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,8,0,0">
          <Button Content="Abbrechen" Command="{Binding ConfirmDialogCancelCommand}"
                  Background="Transparent" Foreground="{DynamicResource AppTextSecondaryBrush}"
                  Padding="16,8" CornerRadius="6" />
          <Button Content="Ja, schließen" Command="{Binding ConfirmDialogYesCommand}"
                  Background="{DynamicResource ErrorBrush}" Foreground="{DynamicResource PrimaryContrastBrush}"
                  Padding="16,8" CornerRadius="6" FontWeight="SemiBold" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>
  </Grid>
</UserControl>
