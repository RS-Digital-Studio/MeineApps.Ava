<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:dto="using:BingXBot.Contracts.Dto"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:skia="using:Avalonia.Labs.Controls"
             xmlns:conv="using:BingXBot.Converters"
             x:Class="BingXBot.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             x:CompileBindings="True">

  <UserControl.Resources>
    <conv:NullableDecimalConverter x:Key="NullableDecimalConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- P&L-Farbe: Positiv = Gruen, Negativ = Rot -->
    <Style Selector="TextBlock.PnlPositive">
      <Setter Property="Foreground" Value="{DynamicResource AppProfitBrush}" />
    </Style>
    <Style Selector="TextBlock.PnlNegative">
      <Setter Property="Foreground" Value="{DynamicResource AppLossBrush}" />
    </Style>

    <!-- Bot-Button Styles -->
    <Style Selector="Button.BotButton">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="MinWidth" Value="100" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.BotStart">
      <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.BotStart:pointerover">
      <Setter Property="Background" Value="{DynamicResource SuccessHoverBrush}" />
    </Style>
    <Style Selector="Button.BotPause">
      <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.BotPause:pointerover">
      <Setter Property="Background" Value="{DynamicResource WarningHoverBrush}" />
    </Style>
    <Style Selector="Button.BotStop">
      <Setter Property="Background" Value="{DynamicResource StopSurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.BotStop:pointerover">
      <Setter Property="Background" Value="{DynamicResource StopHoverBrush}" />
    </Style>
    <Style Selector="Button.BotEmergency">
      <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.BotEmergency:pointerover">
      <Setter Property="Background" Value="{DynamicResource ErrorHoverBrush}" />
    </Style>

    <!-- Modus-Button Styles -->
    <Style Selector="Button.ModeButton">
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="MinWidth" Value="80" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.ModeButton:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
    </Style>

    <!-- Sektion-Ueberschrift -->
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Roter Rand wenn Live-Trading aktiv -->
    <Style Selector="Border.LiveActive">
      <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Activity-Feed expandiert: MaxHeight aufheben -->
    <Style Selector="ScrollViewer.Expanded">
      <Setter Property="MaxHeight" Value="500" />
    </Style>
  </UserControl.Styles>

  <UserControl.KeyBindings>
    <!-- Bot-Kontrolle: F5=Start, F6=Pause, F7=Stop, F12=Notfall-Stop -->
    <KeyBinding Gesture="F5" Command="{Binding StartBotCommand}" />
    <KeyBinding Gesture="F6" Command="{Binding PauseBotCommand}" />
    <KeyBinding Gesture="F7" Command="{Binding StopBotCommand}" />
    <KeyBinding Gesture="F12" Command="{Binding EmergencyStopCommand}" />
  </UserControl.KeyBindings>

  <Grid>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" Margin="0,0,0,24">

      <!-- ================================================================= -->
      <!-- LIVE-TRADING WARNUNG (nur wenn IsLiveActive=true)                 -->
      <!-- ================================================================= -->
      <Border IsVisible="{Binding IsLiveActive}"
              Background="{DynamicResource ErrorOverlayBrush}" BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="2"
              CornerRadius="8" Padding="16">
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
          <mi:MaterialIcon Kind="AlertCircle" Width="22" Height="22"
                           Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center" />
          <TextBlock Text="LIVE-TRADING AKTIV - Echtes Geld wird gehandelt!"
                     FontSize="15" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"
                     VerticalAlignment="Center" />
          <mi:MaterialIcon Kind="AlertCircle" Width="22" Height="22"
                           Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- ================================================================= -->
      <!-- Willkommens-Hinweis (nur wenn ShowWelcomeHint=true)               -->
      <!-- ================================================================= -->
      <Border IsVisible="{Binding ShowWelcomeHint}"
              Background="{DynamicResource InfoSurfaceBrush}" CornerRadius="8" Padding="16">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <mi:MaterialIcon Grid.Column="0" Kind="InformationOutline" Width="20" Height="20"
                           Foreground="{DynamicResource AppPrimaryBrush}"
                           VerticalAlignment="Top" Margin="0,2,0,0" />
          <TextBlock Grid.Column="1" Text="{Binding WelcomeHintText}" TextWrapping="Wrap"
                     Foreground="{DynamicResource AppTextBrush}" FontSize="13"
                     Margin="12,0,12,0" />
          <Button Grid.Column="2" Command="{Binding DismissWelcomeHintCommand}"
                  Background="Transparent" BorderThickness="0" Padding="4"
                  Cursor="Hand" VerticalAlignment="Top">
            <mi:MaterialIcon Kind="Close" Width="16" Height="16"
                             Foreground="{DynamicResource AppTextSecondaryBrush}" />
          </Button>
        </Grid>
      </Border>

      <!-- ================================================================= -->
      <!-- Bot-Kontrolle + Modus (nebeneinander)                             -->
      <!-- ================================================================= -->
      <Grid ColumnDefinitions="*,Auto">

        <!-- Bot-Kontrolle (roter Rand wenn Live aktiv) -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="20,16" Margin="0,0,12,0"
                BoxShadow="{DynamicResource CardShadow}"
                Classes.LiveActive="{Binding IsLiveActive}">
          <StackPanel Spacing="12">
            <!-- Ueberschrift mit Status-Badge -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="RobotOutline" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Bot-Steuerung" Classes="SectionTitle" />
              <!-- Status-Badge -->
              <Border CornerRadius="10" Padding="10,4" Margin="8,0,0,0"
                      Background="{DynamicResource CardBrush}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse x:Name="StatusDot" Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding StatusDotColor}" />
                  <TextBlock Text="{Binding BotStatusText}" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource AppTextSecondaryBrush}" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Strategie-Auswahl + Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12">
              <!-- Strategie-Dropdown -->
              <StackPanel Spacing="2">
                <TextBlock Text="Strategie" FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                <ComboBox ItemsSource="{Binding AvailableStrategies}"
                          SelectedItem="{Binding SelectedStrategy}"
                          IsEnabled="{Binding !IsRunning}"
                          MinWidth="180" FontSize="12" />
              </StackPanel>

              <!-- Multi-TF Standalone: TF-Checkboxen (D1/H4/H1/M15) -->
              <StackPanel Spacing="4">
                <TextBlock Text="Aktive TFs" FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <CheckBox Content="1D" IsChecked="{Binding TfD1Active}" IsEnabled="{Binding !IsRunning}" FontSize="11" />
                  <CheckBox Content="4H" IsChecked="{Binding TfH4Active}" IsEnabled="{Binding !IsRunning}" FontSize="11" />
                  <CheckBox Content="1H" IsChecked="{Binding TfH1Active}" IsEnabled="{Binding !IsRunning}" FontSize="11" />
                  <CheckBox Content="15m" IsChecked="{Binding TfM15Active}" IsEnabled="{Binding !IsRunning}" FontSize="11" />
                </StackPanel>
              </StackPanel>

              <!-- Buttons -->
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <Button Classes="BotButton BotStart" Content="Start"
                        Command="{Binding StartBotCommand}"
                        IsEnabled="{Binding CanStart}"
                        ToolTip.Tip="Bot starten" />
                <Button Classes="BotButton BotPause" Content="Pause"
                        Command="{Binding PauseBotCommand}"
                        IsEnabled="{Binding IsRunning}"
                        ToolTip.Tip="Bot pausieren" />
                <Button Classes="BotButton BotStop" Content="Stop"
                        Command="{Binding StopBotCommand}"
                        IsEnabled="{Binding IsRunning}"
                        ToolTip.Tip="Bot stoppen" />
                <Border Width="1" Background="{DynamicResource AppBorderBrush}" Margin="8,4" />
                <Button Classes="BotButton BotEmergency" Content="NOTFALL-STOP"
                        Command="{Binding EmergencyStopCommand}"
                        IsEnabled="{Binding IsRunning}"
                        ToolTip.Tip="Notfall-Stop: Alle Positionen sofort schließen (Escape)" />
              </StackPanel>

              <!-- Markt-Kategorien (welche Asset-Klassen gescannt werden) -->
              <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <CheckBox Content="Krypto (Top 100)" IsChecked="{Binding IsCryptoEnabled}"
                          IsEnabled="False" FontSize="12"
                          Foreground="{DynamicResource AppTextBrush}"
                          ToolTip.Tip="Kryptowährungen sind immer aktiviert (Hauptmarkt)" />
                <CheckBox Content="Rohstoffe" IsChecked="{Binding IsCommodityEnabled}"
                          IsEnabled="{Binding !IsRunning}" FontSize="12"
                          Foreground="{DynamicResource AppTextSecondaryBrush}"
                          ToolTip.Tip="Gold, Silber, Öl (NCCO-Prefix, Mo-Fr)" />
                <CheckBox Content="Indices" IsChecked="{Binding IsIndexEnabled}"
                          IsEnabled="{Binding !IsRunning}" FontSize="12"
                          Foreground="{DynamicResource AppTextSecondaryBrush}"
                          ToolTip.Tip="Nasdaq100, S&amp;P500, Dow Jones (NCSI-Prefix, Mo-Fr)" />
                <CheckBox Content="Forex" IsChecked="{Binding IsForexEnabled}"
                          IsEnabled="{Binding !IsRunning}" FontSize="12"
                          Foreground="{DynamicResource AppTextSecondaryBrush}"
                          ToolTip.Tip="EUR/USD, GBP/USD (NCFX-Prefix, 24/5)" />
                <CheckBox Content="Aktien" IsChecked="{Binding IsStockEnabled}"
                          IsEnabled="{Binding !IsRunning}" FontSize="12"
                          Foreground="{DynamicResource AppTextSecondaryBrush}"
                          ToolTip.Tip="TSLA, AAPL, NVDA (NCSK-Prefix, US-Marktzeiten)" />
              </StackPanel>
            </StackPanel>

            <!-- Strategie-Beschreibung -->
            <TextBlock Text="{Binding StrategyDescription}" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap" MaxWidth="500" />

            <!-- v1.6.0 Phase 10B — Stats-Breakdown (TF × Category × Mode) -->
            <Border Background="{DynamicResource AppBackgroundAltBrush}" CornerRadius="6"
                    Padding="10,8" Margin="0,8,0,0"
                    IsVisible="{Binding StatsBreakdown.Count}">
              <StackPanel Spacing="4">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Trade-Stats (TF × Markt × Modus)" FontSize="10" FontWeight="SemiBold"
                             Foreground="{DynamicResource AppTextSecondaryBrush}"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="1" Command="{Binding RefreshStatsCommand}"
                          Background="Transparent" BorderThickness="0"
                          Padding="4,2" Cursor="Hand"
                          ToolTip.Tip="Aggregat neu laden">
                    <mi:MaterialIcon Kind="Refresh" Width="14" Height="14"
                                     Foreground="{DynamicResource AppTextSecondaryBrush}" />
                  </Button>
                </Grid>
                <Grid ColumnDefinitions="40,80,60,60,80,80" Margin="0,2,0,2">
                  <TextBlock Grid.Column="0" Text="TF" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Grid.Column="1" Text="Markt" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Grid.Column="2" Text="Modus" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Grid.Column="3" Text="Trades" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="4" Text="WinRate" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="5" Text="PnL ges." FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
                </Grid>
                <ItemsControl ItemsSource="{Binding StatsBreakdown}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="dto:TradeStatsBreakdownRowDto">
                      <Grid ColumnDefinitions="40,80,60,60,80,80" Margin="0,1">
                        <TextBlock Grid.Column="0" Text="{Binding Tf}" FontSize="10"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{DynamicResource AppTextBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="10"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2" Text="{Binding Mode}" FontSize="10"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <TextBlock Grid.Column="3" Text="{Binding TotalTrades}" FontSize="10"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="4"
                                   Text="{Binding WinRate, StringFormat='{}{0:P0}'}"
                                   FontSize="10"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="5"
                                   Text="{Binding TotalPnl, StringFormat='{}{0:+0.00;-0.00;0.00}'}"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Consolas, Courier New, monospace"
                                   HorizontalAlignment="Right" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding StatsStatusText}" FontSize="9" FontStyle="Italic"
                           Foreground="{DynamicResource TextMutedBrush}"
                           IsVisible="{Binding StatsStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- Modus-Toggle -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="20,16" MinWidth="220"
                BoxShadow="{DynamicResource CardShadow}">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="SwapHorizontal" Width="18" Height="18"
                               Foreground="{DynamicResource AppWarningBrush}" />
              <TextBlock Text="Trading-Modus" Classes="SectionTitle" />
            </StackPanel>

            <!-- Paper / Live Toggle-Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
              <!-- Paper-Button: aktiv wenn IsPaperMode=true -->
              <Button x:Name="PaperButton" Classes="ModeButton"
                      Command="{Binding ToggleModeCommand}"
                      IsEnabled="{Binding !IsRunning}"
                      ToolTip.Tip="Simuliertes Trading ohne echtes Geld">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="TestTube" Width="14" Height="14" />
                  <TextBlock Text="Paper" />
                </StackPanel>
              </Button>
              <!-- Live-Button: aktiv wenn IsPaperMode=false -->
              <Button x:Name="LiveButton" Classes="ModeButton"
                      Command="{Binding ToggleModeCommand}"
                      IsEnabled="{Binding !IsRunning}"
                      ToolTip.Tip="Echtes Trading mit BingX-Konto (API-Keys erforderlich)">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="CurrencyUsd" Width="14" Height="14" />
                  <TextBlock Text="Live" />
                </StackPanel>
              </Button>
            </StackPanel>

            <TextBlock Text="{Binding ModeDescription}" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap"
                       TextAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- ================================================================= -->
      <!-- Watchlist (Crypto-Auswahl fuer Scanner)                          -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="16,12" BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="8">
          <!-- Eingabezeile: AutoComplete + Hinzufügen -->
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <mi:MaterialIcon Kind="FilterVariant" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Watchlist:" FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <AutoCompleteBox Grid.Column="1" Text="{Binding WatchlistInput, Mode=TwoWay}"
                             ItemsSource="{Binding AvailableSymbols}"
                             FilterMode="ContainsOrdinal"
                             Watermark="Symbol eingeben (z.B. BTC-USDT)"
                             FontSize="12" Margin="10,0" MinimumPrefixLength="1"
                             ToolTip.Tip="Verfügbare Symbole werden automatisch vorgeschlagen" />
            <Button Grid.Column="2" Content="Hinzufügen" Command="{Binding AddToWatchlistCommand}"
                    Padding="12,6" FontSize="12" CornerRadius="4" Cursor="Hand" Margin="0,0,4,0"
                    Background="{DynamicResource AppPrimaryBrush}" Foreground="White" BorderThickness="0" />
            <Button Grid.Column="3" Command="{Binding ClearWatchlistCommand}"
                    Padding="6" CornerRadius="4" Cursor="Hand"
                    Background="Transparent" BorderThickness="0"
                    ToolTip.Tip="Watchlist leeren (alle Symbole scannen)"
                    IsVisible="{Binding IsWatchlistActive}">
              <mi:MaterialIcon Kind="DeleteSweep" Width="16" Height="16"
                               Foreground="{DynamicResource TextMutedBrush}" />
            </Button>
          </Grid>

          <!-- Aktive Watchlist-Symbole als Chips -->
          <ItemsControl ItemsSource="{Binding WatchlistSymbols}" x:CompileBindings="False"
                        IsVisible="{Binding IsWatchlistActive}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource AppPrimaryBrush}" CornerRadius="12"
                        Padding="10,4,6,4" Margin="0,0,6,4" Opacity="0.9">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center" />
                    <Button Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).RemoveFromWatchlistCommand}"
                            CommandParameter="{Binding}"
                            Padding="2" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" CornerRadius="10" VerticalAlignment="Center">
                      <mi:MaterialIcon Kind="CloseCircle" Width="14" Height="14" Foreground="White" Opacity="0.7" />
                    </Button>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Hinweis wenn keine Watchlist aktiv -->
          <TextBlock Text="Alle Symbole werden gescannt (keine Einschränkung)"
                     FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6"
                     IsVisible="{Binding !IsWatchlistActive}" />
        </StackPanel>
      </Border>

      <!-- ================================================================= -->
      <!-- Account-Karten (nur sichtbar wenn HasAccountData=true)            -->
      <!-- ================================================================= -->
      <!-- Zustand: Account vorhanden -->
      <UniformGrid Columns="4" Rows="1" IsVisible="{Binding HasAccountData}">

        <!-- Balance -->
        <Border CornerRadius="10" Padding="20,16" Margin="0,0,8,0"
                BoxShadow="{DynamicResource CardShadow}"
                ToolTip.Tip="Gesamter Kontostand inkl. unrealisierter Positionen">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#2A2A44" Offset="0" />
              <GradientStop Color="#1E2A40" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#263B82" CornerRadius="8" Padding="6" Width="32" Height="32">
                <mi:MaterialIcon Kind="Wallet" Width="18" Height="18"
                                 Foreground="{DynamicResource AppPrimaryBrush}" />
              </Border>
              <TextBlock Text="Balance" FontSize="12"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding Balance, StringFormat='{}{0:N2}'}"
                       FontSize="24" FontWeight="Bold"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="USDT" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,-4,0,0" />
          </StackPanel>
        </Border>

        <!-- Verfügbar -->
        <Border CornerRadius="10" Padding="20,16" Margin="4,0"
                BoxShadow="{DynamicResource CardShadow}"
                ToolTip.Tip="Verfügbare Margin für neue Positionen">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#2A2A44" Offset="0" />
              <GradientStop Color="#1E3A2A" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#1E4A3A" CornerRadius="8" Padding="6" Width="32" Height="32">
                <mi:MaterialIcon Kind="CashMultiple" Width="18" Height="18"
                                 Foreground="{DynamicResource AccentBrush}" />
              </Border>
              <TextBlock Text="Verfügbar" FontSize="12"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding AvailableBalance, StringFormat='{}{0:N2}'}"
                       FontSize="24" FontWeight="Bold"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="USDT" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,-4,0,0" />
          </StackPanel>
        </Border>

        <!-- Unrealisiert P&L -->
        <Border CornerRadius="10" Padding="20,16" Margin="4,0"
                BoxShadow="{DynamicResource CardShadow}"
                ToolTip.Tip="Unrealisierter Gewinn/Verlust offener Positionen">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#2A2A44" Offset="0" />
              <GradientStop Color="#2A3A1E" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#2A4A1E" CornerRadius="8" Padding="6" Width="32" Height="32">
                <mi:MaterialIcon Kind="TrendingUp" Width="18" Height="18"
                                 Foreground="{DynamicResource AppProfitBrush}" />
              </Border>
              <TextBlock Text="Unrealisiert" FontSize="12"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <!-- Positiv (grün) -->
              <TextBlock x:Name="UnrealizedPnlText"
                         Text="{Binding UnrealizedPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                         FontSize="24" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource AppProfitBrush}"
                         IsVisible="{Binding IsUnrealizedPnlPositive}" />
              <!-- Negativ (rot) -->
              <TextBlock Text="{Binding UnrealizedPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                         FontSize="24" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource AppLossBrush}"
                         IsVisible="{Binding !IsUnrealizedPnlPositive}" />
              <mi:MaterialIcon Kind="ArrowUp" Width="16" Height="16"
                               Foreground="{DynamicResource AppProfitBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsUnrealizedPnlPositive}" />
              <mi:MaterialIcon Kind="ArrowDown" Width="16" Height="16"
                               Foreground="{DynamicResource AppLossBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsUnrealizedPnlPositive}" />
            </StackPanel>
            <TextBlock Text="USDT" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,-4,0,0" />
          </StackPanel>
        </Border>

        <!-- Gesamt-PnL -->
        <Border CornerRadius="10" Padding="20,16" Margin="8,0,0,0"
                BoxShadow="{DynamicResource CardShadow}"
                ToolTip.Tip="Realisierter Gewinn/Verlust aller geschlossenen Trades">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#2A2A44" Offset="0" />
              <GradientStop Color="#3A2A1E" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="#4A2A1E" CornerRadius="8" Padding="6" Width="32" Height="32">
                <mi:MaterialIcon Kind="ChartAreaspline" Width="18" Height="18"
                                 Foreground="{DynamicResource AppWarningBrush}" />
              </Border>
              <TextBlock Text="Gesamt-PnL" FontSize="12"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <!-- Positiv (grün) -->
              <TextBlock x:Name="TotalPnlText"
                         Text="{Binding TotalPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                         FontSize="24" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource AppProfitBrush}"
                         IsVisible="{Binding IsTotalPnlPositive}" />
              <!-- Negativ (rot) -->
              <TextBlock Text="{Binding TotalPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                         FontSize="24" FontWeight="Bold"
                         FontFamily="Consolas, Courier New, monospace"
                         Foreground="{DynamicResource AppLossBrush}"
                         IsVisible="{Binding !IsTotalPnlPositive}" />
              <mi:MaterialIcon Kind="ArrowUp" Width="16" Height="16"
                               Foreground="{DynamicResource AppProfitBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsTotalPnlPositive}" />
              <mi:MaterialIcon Kind="ArrowDown" Width="16" Height="16"
                               Foreground="{DynamicResource AppLossBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsTotalPnlPositive}" />
            </StackPanel>
            <TextBlock Text="USDT" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,-4,0,0" />
          </StackPanel>
        </Border>

      </UniformGrid>

      <!-- Zustand: Kein Account -->
      <Border IsVisible="{Binding !HasAccountData}"
              Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="24,20"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
          <mi:MaterialIcon Kind="WalletOutline" Width="20" Height="20"
                           Foreground="{DynamicResource TextMutedBrush}" />
          <TextBlock Text="Bot starten um Account-Daten zu sehen"
                     FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- ================================================================= -->
      <!-- Strategy-Health-Warnung (nur sichtbar bei Problemen)              -->
      <!-- ================================================================= -->
      <Border IsVisible="{Binding HasStrategyWarning}"
              Background="#2EEF4444" CornerRadius="8"
              Padding="16,12" BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <mi:MaterialIcon Kind="AlertCircle" Width="20" Height="20"
                           Foreground="{DynamicResource ErrorBrush}" />
          <TextBlock Text="{Binding StrategyHealthText}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource ErrorBrush}"
                     VerticalAlignment="Center" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- ================================================================= -->
      <!-- Rolling Live-Metriken (30 Trades)                                 -->
      <!-- ================================================================= -->
      <UniformGrid Columns="3" IsVisible="{Binding IsRunning}">

        <!-- Rolling Win-Rate -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16,12" Margin="0,0,6,0"
                BoxShadow="{DynamicResource CardShadow}">
          <StackPanel Spacing="4">
            <TextBlock Text="ROLLING WIN-RATE" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding RollingWinRate, StringFormat={}{0:F1}%}"
                       FontSize="18" FontWeight="Bold"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Letzte 30 Trades" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6" />
          </StackPanel>
        </Border>

        <!-- Rolling Sharpe -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16,12" Margin="3,0"
                BoxShadow="{DynamicResource CardShadow}">
          <StackPanel Spacing="4">
            <TextBlock Text="ROLLING SHARPE" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding RollingSharpe, StringFormat={}{0:F2}}"
                       FontSize="18" FontWeight="Bold"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Annualisiert (>1 = gut)" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6" />
          </StackPanel>
        </Border>

        <!-- Rolling Profit Factor -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16,12" Margin="6,0,0,0"
                BoxShadow="{DynamicResource CardShadow}">
          <StackPanel Spacing="4">
            <TextBlock Text="ROLLING PF" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding RollingProfitFactor, StringFormat={}{0:F2}}"
                       FontSize="18" FontWeight="Bold"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Gewinn/Verlust Ratio" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6" />
          </StackPanel>
        </Border>

      </UniformGrid>

      <!-- ================================================================= -->
      <!-- Offene Positionen                                                 -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="12">

          <!-- Header mit "Alle schliessen" Button -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="FormatListBulleted" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Offene Positionen" Classes="SectionTitle" />
              <Border Background="{DynamicResource AppPrimaryBrush}" CornerRadius="10" Padding="8,2"
                      IsVisible="{Binding HasOpenPositions}" VerticalAlignment="Center" Margin="8,0,0,0">
                <TextBlock Text="{Binding OpenPositions.Count}" FontSize="11"
                           Foreground="{DynamicResource PrimaryContrastBrush}" FontWeight="Bold" />
              </Border>
            </StackPanel>

            <Button Grid.Column="2" Content="Alle schliessen"
                    Command="{Binding CloseAllPositionsCommand}"
                    IsVisible="{Binding HasOpenPositions}"
                    Background="{DynamicResource ErrorSurfaceBrush}" Foreground="{DynamicResource AppLossBrush}"
                    CornerRadius="6" Padding="12,6" FontSize="12" Cursor="Hand"
                    BorderThickness="1" BorderBrush="{DynamicResource AppLossBrush}" />
          </Grid>

          <!-- Positions-Cards (2 Spalten, kompakt, klickbar) -->
          <ItemsControl ItemsSource="{Binding OpenPositions}"
                        IsVisible="{Binding HasOpenPositions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:PositionDisplayItem">
                <Panel MinWidth="320" MaxWidth="500" Margin="2">
                  <!-- Selektions-Highlight: Blauer Rand + dunkler Hintergrund wenn ausgewählt -->
                  <Border CornerRadius="6" BorderThickness="2"
                          BorderBrush="{DynamicResource AppPrimaryBrush}"
                          Background="{DynamicResource SurfaceBrush}"
                          IsVisible="{Binding IsSelected}" />
                  <Border Background="{DynamicResource CardBrush}" CornerRadius="6"
                          Padding="10,8"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource AppBorderBrush}"
                          Cursor="Hand"
                          PointerPressed="PositionCard_PointerPressed">
                  <Border.Styles>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                    </Style>
                  </Border.Styles>
                  <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                    <!-- Zeile 1: Symbol + Side + Lev + Strategie | PnL + Close -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="Bold"
                                 Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                      <Border Background="{Binding SideColor}" CornerRadius="3" Padding="5,1"
                              VerticalAlignment="Center">
                        <TextBlock Text="{Binding SideText}" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryContrastBrush}" />
                      </Border>
                      <TextBlock Text="{Binding Leverage, StringFormat='{}{0:F0}x'}" FontSize="11"
                                 FontFamily="Consolas, Courier New, monospace"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center" />
                      <!-- TF-Badge (Multi-TF Standalone) -->
                      <Border Background="{DynamicResource AppAccentBrush}" CornerRadius="3" Padding="4,1"
                              VerticalAlignment="Center" IsVisible="{Binding TimeframeBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                              ToolTip.Tip="Navigator-Timeframe des auslösenden Signals">
                        <TextBlock Text="{Binding TimeframeBadge}" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryContrastBrush}" />
                      </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                      <StackPanel HorizontalAlignment="Right">
                        <TextBlock Text="{Binding PnlText}" FontSize="14" FontWeight="Bold"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{Binding PnlColor}" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding PnlPercentText}" FontSize="10"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{Binding PnlColor}" HorizontalAlignment="Right" />
                      </StackPanel>
                      <Button Command="{Binding RequestCloseCommand}"
                              Background="Transparent" Padding="4"
                              CornerRadius="3" ToolTip.Tip="Position schließen" Cursor="Hand"
                              BorderThickness="0">
                        <mi:MaterialIcon Kind="Close" Width="12" Height="12"
                                         Foreground="{DynamicResource AppLossBrush}" />
                      </Button>
                    </StackPanel>

                    <!-- Zeile 2: Entry → Aktuell | Menge | SL | TP -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                      <TextBlock FontSize="11" FontFamily="Consolas, Courier New, monospace"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}">
                        <Run Text="E:" /><Run Text="{Binding EntryPrice, Converter={StaticResource NullableDecimalConverter}}" Foreground="{DynamicResource AppTextBrush}" />
                        <Run Text=" →" /><Run Text="{Binding MarkPrice, Converter={StaticResource NullableDecimalConverter}}" Foreground="{Binding PnlColor}" />
                      </TextBlock>
                      <TextBlock FontSize="11" FontFamily="Consolas, Courier New, monospace"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}">
                        <Run Text="Q:" /><Run Text="{Binding Quantity, StringFormat='{}{0:N2}'}" Foreground="{DynamicResource AppTextBrush}" />
                      </TextBlock>
                      <TextBlock FontSize="11" FontFamily="Consolas, Courier New, monospace"
                                 Foreground="{DynamicResource AppLossBrush}" IsVisible="{Binding StopLoss, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Run Text="SL:" /><Run Text="{Binding StopLoss, Converter={StaticResource NullableDecimalConverter}}" />
                      </TextBlock>
                      <TextBlock FontSize="11" FontFamily="Consolas, Courier New, monospace"
                                 Foreground="{DynamicResource AppProfitBrush}" IsVisible="{Binding TakeProfit, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Run Text="TP:" /><Run Text="{Binding TakeProfit, Converter={StaticResource NullableDecimalConverter}}" />
                      </TextBlock>
                    </StackPanel>

                    <!-- Zeile 3: Info-Chips (Haltezeit) -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                      <!-- Haltezeit -->
                      <TextBlock Text="{Binding HoldTimeText}" FontSize="9"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 IsVisible="{Binding HoldTimeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>

                  </Grid>
                </Border>
                </Panel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Leerer Zustand: Keine Positionen -->
          <StackPanel IsVisible="{Binding !HasOpenPositions}" HorizontalAlignment="Center"
                      Margin="0,12">
            <mi:MaterialIcon Kind="ChartBoxOutline" Width="32" Height="32"
                             Foreground="{DynamicResource AppTextSecondaryBrush}"
                             HorizontalAlignment="Center" />
            <TextBlock Text="Keine offenen Positionen" FontSize="13"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Text="Der Bot eröffnet Trades automatisch wenn Signale erkannt werden"
                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300"
                       TextAlignment="Center" />
          </StackPanel>

        </StackPanel>
      </Border>

      <!-- ================================================================= -->
      <!-- Bot-Aktivität (Activity-Feed)                                     -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="Pulse" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Bot-Aktivität" Classes="SectionTitle" />
              <Border CornerRadius="10" Padding="8,3" Margin="8,0,0,0"
                      Background="{DynamicResource CardBrush}">
                <TextBlock Text="{Binding Activity.RecentActivity.Count, StringFormat='{}{0}'}"
                           FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}" />
              </Border>
            </StackPanel>
            <!-- Expand/Collapse Toggle -->
            <Button Grid.Column="2" Command="{Binding ToggleActivityExpandedCommand}"
                    Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand"
                    ToolTip.Tip="Aktivität ein-/ausklappen">
              <Panel>
                <mi:MaterialIcon Kind="ChevronDown" Width="16" Height="16"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 IsVisible="{Binding !IsActivityExpanded}" />
                <mi:MaterialIcon Kind="ChevronUp" Width="16" Height="16"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 IsVisible="{Binding IsActivityExpanded}" />
              </Panel>
            </Button>
          </Grid>

          <!-- Leerer Zustand: Bot gestoppt -->
          <TextBlock Grid.Row="1" Text="Bot ist gestoppt - keine Aktivität"
                     IsVisible="{Binding !IsRunning}"
                     Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                     HorizontalAlignment="Center" Margin="0,8" />

          <!-- Activity-Liste (scrollbar, expandierbar) -->
          <ScrollViewer Grid.Row="1"
                        Classes.Expanded="{Binding IsActivityExpanded}"
                        MaxHeight="300"
                        VerticalScrollBarVisibility="Auto"
                        IsVisible="{Binding IsRunning}">
            <ItemsControl ItemsSource="{Binding Activity.RecentActivity}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ActivityItem">
                  <Border Padding="4,3" Margin="0,1">
                    <Grid ColumnDefinitions="58,Auto,*">
                      <TextBlock Grid.Column="0" Text="{Binding TimeText}" FontSize="11"
                                 FontFamily="Consolas,monospace"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 VerticalAlignment="Center" />
                      <Border Grid.Column="1" Background="{Binding LevelColor}" CornerRadius="3"
                              Padding="6,1" Margin="4,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryContrastBrush}" />
                      </Border>
                      <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 TextTrimming="CharacterEllipsis" Margin="6,0,0,0"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- ================================================================= -->
      <!-- BTC-USDT Live-Chart                                               -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <Grid RowDefinitions="Auto,*">
          <!-- Header: Symbol + Preis + Timeframe + Indikatoren -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="ChartLine" Width="20" Height="20"
                               Foreground="{DynamicResource AppWarningBrush}" />
              <!-- Symbol-Schnellwahl -->
              <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Content="BTC" Command="{Binding BtcTicker.SwitchSymbolCommand}" CommandParameter="BTC-USDT"
                        Padding="6,2" FontSize="11" CornerRadius="3" MinWidth="0" Cursor="Hand"
                        Background="Transparent" Foreground="{DynamicResource AppTextBrush}" BorderThickness="0" FontWeight="Bold" />
                <Button Content="ETH" Command="{Binding BtcTicker.SwitchSymbolCommand}" CommandParameter="ETH-USDT"
                        Padding="6,2" FontSize="11" CornerRadius="3" MinWidth="0" Cursor="Hand"
                        Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0" />
                <Button Content="SOL" Command="{Binding BtcTicker.SwitchSymbolCommand}" CommandParameter="SOL-USDT"
                        Padding="6,2" FontSize="11" CornerRadius="3" MinWidth="0" Cursor="Hand"
                        Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0" />
              </StackPanel>
            </StackPanel>

            <!-- Preis (nur sichtbar wenn geladen) -->
            <TextBlock Text="{Binding BtcTicker.BtcPrice, StringFormat='{}{0:N2} USDT'}"
                       FontWeight="Bold" FontSize="16"
                       FontFamily="Consolas, Courier New, monospace"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center"
                       IsVisible="{Binding !BtcTicker.IsBtcLoading}" />

            <!-- Änderung (nur sichtbar wenn geladen) -->
            <TextBlock x:Name="BtcChangeText"
                       Text="{Binding BtcTicker.BtcPriceChange, StringFormat='{}{0:+0.00;-0.00}%'}"
                       FontSize="14" FontFamily="Consolas, Courier New, monospace"
                       VerticalAlignment="Center"
                       IsVisible="{Binding !BtcTicker.IsBtcLoading}" />

            <!-- Status-Text -->
            <TextBlock Text="{Binding BtcTicker.BtcStatusText}" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />

            <!-- Lade-Indikator -->
            <mi:MaterialIcon Kind="Loading" Width="16" Height="16"
                             Foreground="{DynamicResource AppPrimaryBrush}"
                             IsVisible="{Binding BtcTicker.IsBtcLoading}" />

            <!-- Timeframe-Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="16,0,0,0">
              <Button Content="1h" Command="{Binding BtcTicker.SwitchTimeframeCommand}" CommandParameter="1h"
                      Padding="8,4" FontSize="11" CornerRadius="4" MinWidth="32" Cursor="Hand"
                      Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextMutedBrush}"
                      BorderThickness="0" />
              <Button Content="4h" Command="{Binding BtcTicker.SwitchTimeframeCommand}" CommandParameter="4h"
                      Padding="8,4" FontSize="11" CornerRadius="4" MinWidth="32" Cursor="Hand"
                      Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextMutedBrush}"
                      BorderThickness="0" />
              <Button Content="1D" Command="{Binding BtcTicker.SwitchTimeframeCommand}" CommandParameter="1D"
                      Padding="8,4" FontSize="11" CornerRadius="4" MinWidth="32" Cursor="Hand"
                      Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextMutedBrush}"
                      BorderThickness="0" />
            </StackPanel>
          </StackPanel>

          <!-- Interaktiver Candlestick Chart (Crosshair, Zoom/Pan) -->
          <skia:SKCanvasView Grid.Row="1" x:Name="BtcChartCanvas"
                              PaintSurface="OnBtcChartPaintSurface"
                              PointerMoved="OnChartPointerMoved"
                              PointerExited="OnChartPointerExited"
                              PointerPressed="OnChartPointerPressed"
                              PointerReleased="OnChartPointerReleased"
                              PointerWheelChanged="OnChartPointerWheelChanged"
                              MinHeight="280" Cursor="Cross" />
        </Grid>
      </Border>

      <!-- ================================================================= -->
      <!-- Equity-Kurve (nur sichtbar wenn Account aktiv)                    -->
      <!-- ================================================================= -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16" MinHeight="200"
              BoxShadow="{DynamicResource CardShadow}"
              IsVisible="{Binding HasAccountData}">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="ChartAreaspline" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Equity-Kurve" Classes="SectionTitle" />
          </StackPanel>

          <!-- Equity-Chart (SkiaSharp) -->
          <skia:SKCanvasView x:Name="EquityCanvas" PaintSurface="OnEquityPaintSurface"
                             MinHeight="200" />
        </StackPanel>
      </Border>

      <!-- Drawdown-Chart (volle Breite) -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="12,8" MinHeight="180"
              BoxShadow="{DynamicResource CardShadow}"
              IsVisible="{Binding IsRunning}">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
            <mi:MaterialIcon Kind="TrendingDown" Width="16" Height="16"
                             Foreground="{DynamicResource ErrorBrush}" />
            <TextBlock Text="Drawdown" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" />
          </StackPanel>
          <skia:SKCanvasView Grid.Row="1" x:Name="DrawdownCanvas"
                              PaintSurface="OnDrawdownPaintSurface" MinHeight="150" />
        </Grid>
      </Border>

      <!-- PnL-Kalender (volle Breite) -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="12,8" MinHeight="180"
              BoxShadow="{DynamicResource CardShadow}"
              IsVisible="{Binding IsRunning}">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
            <mi:MaterialIcon Kind="CalendarMonth" Width="16" Height="16"
                             Foreground="{DynamicResource SuccessBrush}" />
            <TextBlock Text="PnL-Kalender" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" />
          </StackPanel>
          <skia:SKCanvasView Grid.Row="1" x:Name="PnlCalendarCanvas"
                              PaintSurface="OnPnlCalendarPaintSurface" MinHeight="150" />
        </Grid>
      </Border>

      <!-- Korrelations-Matrix (volle Breite) -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="12,8" MinHeight="200"
              BoxShadow="{DynamicResource CardShadow}"
              IsVisible="{Binding IsRunning}">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
            <mi:MaterialIcon Kind="Grid" Width="16" Height="16"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Korrelations-Matrix" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" />
          </StackPanel>
          <skia:SKCanvasView Grid.Row="1" x:Name="CorrelationCanvas"
                              PaintSurface="OnCorrelationPaintSurface" MinHeight="180" />
        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>

  <!-- Bestätigungs-Dialog Overlay -->
  <Border IsVisible="{Binding ShowConfirmDialog}"
          Background="{DynamicResource OverlayBrush}"
          HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Border Background="{DynamicResource CardBrush}"
            CornerRadius="12" Padding="24" MaxWidth="400"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            BoxShadow="0 8 32 0 #60000000">
      <StackPanel Spacing="16">
        <TextBlock Text="{Binding ConfirmDialogTitle}"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource AppTextBrush}" />
        <TextBlock Text="{Binding ConfirmDialogMessage}"
                   FontSize="14" TextWrapping="Wrap"
                   Foreground="{DynamicResource AppTextSecondaryBrush}" />
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,8,0,0">
          <Button Content="Abbrechen" Command="{Binding ConfirmDialogCancelCommand}"
                  Background="Transparent" Foreground="{DynamicResource AppTextSecondaryBrush}"
                  Padding="16,8" CornerRadius="6" />
          <Button Content="Ja, schließen" Command="{Binding ConfirmDialogYesCommand}"
                  Background="{DynamicResource ErrorBrush}" Foreground="{DynamicResource PrimaryContrastBrush}"
                  Padding="16,8" CornerRadius="6" FontWeight="SemiBold" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>
  </Grid>
</UserControl>
