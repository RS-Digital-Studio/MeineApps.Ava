<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:dto="using:BingXBot.Contracts.Dto"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.DecisionTrailView"
             x:DataType="vm:DecisionTrailViewModel"
             x:CompileBindings="True">

  <DockPanel>

    <!-- Titel -->
    <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,16">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <mi:MaterialIcon Kind="MagnifyScan" Width="28" Height="28"
                         Foreground="{DynamicResource AppPrimaryBrush}" />
        <TextBlock Text="Entscheidungs-Log" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center" />
        <Border Background="{DynamicResource InfoBackgroundBrush}" CornerRadius="6"
                Padding="8,3" VerticalAlignment="Center" Margin="8,0,0,0">
          <TextBlock Text="{Binding DisplayedCount, StringFormat='{}{0} Einträge'}"
                     FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource InfoBrush}" />
        </Border>
      </StackPanel>
      <TextBlock Text="Live-Trail aller Strategy-Evaluationen. Pro Symbol/TF wird festgehalten ob ein Signal gefeuert hat oder warum es verworfen wurde (mit Reject-Code). Filterbar nach Symbol, Timeframe und Reject-Reason."
                 FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap" Margin="40,0,0,0" />
    </StackPanel>

    <!-- Filter-Card -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource CardBrush}"
            CornerRadius="8" Padding="16,14" Margin="0,0,0,12"
            BoxShadow="{DynamicResource CardShadow}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <Grid ColumnDefinitions="Auto,12,Auto,12,*,12,Auto"
            VerticalAlignment="Center">
        <StackPanel Grid.Column="0" Spacing="3">
          <TextBlock Text="Symbol-Filter" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <TextBox Text="{Binding SelectedSymbol, Mode=TwoWay}"
                   Watermark="z.B. BTC-USDT"
                   FontSize="13" MinWidth="160" />
        </StackPanel>

        <StackPanel Grid.Column="2" Spacing="3">
          <TextBlock Text="Reject-Reason" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <ComboBox ItemsSource="{Binding AvailableReasons}"
                    SelectedItem="{Binding SelectedRejectionReason}"
                    MinWidth="220" />
        </StackPanel>

        <StackPanel Grid.Column="4" Spacing="3" VerticalAlignment="Bottom">
          <CheckBox IsChecked="{Binding OnlyRejected, Mode=TwoWay}"
                    Content="Nur abgelehnte Signale anzeigen" FontSize="12" />
        </StackPanel>

        <Button Grid.Column="6" Command="{Binding RefreshFilterCommand}"
                Background="{DynamicResource AppPrimaryBrush}"
                Foreground="{DynamicResource PrimaryContrastBrush}"
                CornerRadius="6" Padding="14,8" BorderThickness="0"
                VerticalAlignment="Bottom" FontWeight="SemiBold">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="FilterCheck" Width="16" Height="16" />
            <TextBlock Text="Filter anwenden" FontSize="13" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Decisions-Liste -->
    <Border Background="{DynamicResource CardBrush}"
            CornerRadius="8" Padding="0"
            BoxShadow="{DynamicResource CardShadow}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="8,8,0,0" Padding="14,8">
          <Grid ColumnDefinitions="140,120,60,*,80,200">
            <TextBlock Grid.Column="0" Text="Zeit (UTC)" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="1" Text="Symbol" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="2" Text="TF" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="Status / Reason" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="4" Text="Score" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
            <TextBlock Grid.Column="5" Text="State + Punkte" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </Grid>
        </Border>

        <StackPanel IsVisible="{Binding !FilteredDecisions.Count}"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="10" Margin="24">
          <mi:MaterialIcon Kind="MagnifyScan" Width="48" Height="48"
                           Foreground="{DynamicResource TextMutedBrush}" Opacity="0.4"
                           HorizontalAlignment="Center" />
          <TextBlock Text="Keine Decisions im aktuellen Filter"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Sobald die Engine läuft, erscheinen Live-Decisions hier."
                     FontSize="11"
                     Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <ListBox ItemsSource="{Binding FilteredDecisions}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 IsVisible="{Binding FilteredDecisions.Count}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="MinHeight" Value="0" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="dto:EvaluationDecisionDto">
              <Border Padding="14,8"
                      BorderBrush="{DynamicResource BorderSubtleBrush}"
                      BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="140,120,60,*,80,200">
                  <TextBlock Grid.Column="0"
                             Text="{Binding UtcTimestamp, StringFormat=yyyy-MM-dd HH:mm:ss}"
                             FontSize="11" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding Symbol}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource AppPrimaryBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" Text="{Binding Tf}"
                             FontSize="11" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                              VerticalAlignment="Center">
                    <!-- Triggered=true → grüner CheckCircle, false → roter Cancel -->
                    <mi:MaterialIcon Width="14" Height="14" VerticalAlignment="Center"
                                     Kind="CheckCircle"
                                     IsVisible="{Binding Triggered}"
                                     Foreground="{DynamicResource SuccessBrush}" />
                    <mi:MaterialIcon Width="14" Height="14" VerticalAlignment="Center"
                                     Kind="CloseCircle"
                                     IsVisible="{Binding !Triggered}"
                                     Foreground="{DynamicResource ErrorBrush}" />
                    <TextBlock Text="{Binding RejectionReason}" FontSize="11"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <TextBlock Grid.Column="4"
                             Text="{Binding ConfluenceScore}"
                             FontSize="12" FontWeight="SemiBold"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource SuccessBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="5" Text="{Binding SequenceState}"
                             FontSize="11"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextMutedBrush}"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </DockPanel>
</UserControl>
