<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:dto="using:BingXBot.Contracts.Dto"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.DecisionTrailViewMobile"
             x:DataType="vm:DecisionTrailViewModel"
             x:CompileBindings="True"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Spacing="10" Margin="12,10,12,6">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <mi:MaterialIcon Kind="MagnifyScan" Width="20" Height="20"
                           Foreground="{DynamicResource AppPrimaryBrush}" />
          <TextBlock Text="Entscheidungs-Log" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
        </StackPanel>
        <Border Grid.Column="1" Background="{DynamicResource InfoBackgroundBrush}"
                CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
          <TextBlock Text="{Binding DisplayedCount, StringFormat='{}{0}'}"
                     FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource InfoBrush}" />
        </Border>
      </Grid>

      <Expander Header="Filter">
        <StackPanel Spacing="10" Margin="14,6,14,14">
          <StackPanel Spacing="3">
            <TextBlock Text="Symbol" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            <TextBox Text="{Binding SelectedSymbol, Mode=TwoWay}"
                     Watermark="z.B. BTC-USDT" FontSize="13" />
          </StackPanel>
          <StackPanel Spacing="3">
            <TextBlock Text="Reject-Reason" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            <ComboBox ItemsSource="{Binding AvailableReasons}"
                      SelectedItem="{Binding SelectedRejectionReason}"
                      HorizontalAlignment="Stretch" />
          </StackPanel>
          <CheckBox IsChecked="{Binding OnlyRejected, Mode=TwoWay}"
                    Content="Nur abgelehnte Signale" FontSize="12" />
          <Button Command="{Binding RefreshFilterCommand}"
                  Background="{DynamicResource AppPrimaryBrush}"
                  Foreground="{DynamicResource PrimaryContrastBrush}"
                  CornerRadius="10" Padding="0,10"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  BorderThickness="0" FontWeight="SemiBold">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <mi:MaterialIcon Kind="FilterCheck" Width="16" Height="16" />
              <TextBlock Text="Filter anwenden" FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Expander>
    </StackPanel>

    <Border Grid.Row="1"
            Background="{DynamicResource CardBrush}"
            CornerRadius="12"
            Margin="12,6,12,12"
            ClipToBounds="True">
      <Panel>
        <StackPanel IsVisible="{Binding !FilteredDecisions.Count}"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="10" Margin="24">
          <mi:MaterialIcon Kind="MagnifyScan" Width="56" Height="56"
                           Foreground="{DynamicResource TextMutedBrush}" Opacity="0.35"
                           HorizontalAlignment="Center" />
          <TextBlock Text="Keine Decisions im Filter"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <ListBox ItemsSource="{Binding FilteredDecisions}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 IsVisible="{Binding FilteredDecisions.Count}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="MinHeight" Value="0" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="dto:EvaluationDecisionDto">
              <Border Padding="12,10"
                      BorderBrush="{DynamicResource BorderSubtleBrush}"
                      BorderThickness="0,0,0,1">
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                      <mi:MaterialIcon Width="14" Height="14" VerticalAlignment="Center"
                                       Kind="CheckCircle"
                                       IsVisible="{Binding Triggered}"
                                       Foreground="{DynamicResource SuccessBrush}" />
                      <mi:MaterialIcon Width="14" Height="14" VerticalAlignment="Center"
                                       Kind="CloseCircle"
                                       IsVisible="{Binding !Triggered}"
                                       Foreground="{DynamicResource ErrorBrush}" />
                      <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AppPrimaryBrush}" />
                      <Border Background="{DynamicResource SurfaceBrush}"
                              CornerRadius="4" Padding="5,1">
                        <TextBlock Text="{Binding Tf}" FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontFamily="Consolas, Courier New, monospace" />
                      </Border>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding ConfluenceScore}"
                               FontSize="14" FontWeight="Bold"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{DynamicResource SuccessBrush}" />
                  </Grid>
                  <TextBlock Text="{Binding UtcTimestamp, StringFormat=yyyy-MM-dd HH:mm:ss}"
                             FontSize="10" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding RejectionReason}" FontSize="11"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             IsVisible="{Binding RejectionReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  <TextBlock Text="{Binding SequenceState}" FontSize="10"
                             FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Panel>
    </Border>
  </Grid>
</UserControl>
