<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.LogView"
             x:DataType="vm:LogViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Titelzeile                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,20">
      <!-- Titel -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
        <mi:MaterialIcon Kind="Console" Width="28" Height="28"
                         Foreground="{DynamicResource AppPrimaryBrush}" />
        <TextBlock Text="Log" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Einträge-Zähler -->
      <Border Grid.Column="2"
              Background="{DynamicResource SurfaceBrush}"
              CornerRadius="12" Padding="12,4"
              Margin="0,0,12,0"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="Einträge:" FontSize="12"
                     Foreground="{DynamicResource TextMutedBrush}"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding EntryCount}" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- Clear-Button -->
      <Button Grid.Column="3"
              Command="{Binding ClearCommand}"
              Background="{DynamicResource ErrorBackgroundBrush}"
              Foreground="{DynamicResource ErrorBrush}"
              CornerRadius="6" Padding="12,6"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <mi:MaterialIcon Kind="DeleteOutline" Width="16" Height="16" />
          <TextBlock Text="Leeren" FontSize="12" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Filter + Log-Einträge                                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" ColumnDefinitions="180,*">

      <!-- Filter-Panel (links) -->
      <Border Grid.Column="0"
              Background="{DynamicResource CardBrush}"
              CornerRadius="8" Padding="16"
              Margin="0,0,16,0"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <TextBlock Text="Level" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />

          <!-- Level-Checkboxen -->
          <StackPanel Spacing="8">
            <CheckBox IsChecked="{Binding ShowDebug}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="8" Height="8" Fill="#6B7280" VerticalAlignment="Center" />
                <TextBlock Text="Debug" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
            </CheckBox>

            <CheckBox IsChecked="{Binding ShowInfo}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Info" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
            </CheckBox>

            <CheckBox IsChecked="{Binding ShowTrade}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Trade" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
            </CheckBox>

            <CheckBox IsChecked="{Binding ShowWarning}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Warning" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
            </CheckBox>

            <CheckBox IsChecked="{Binding ShowError}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource ErrorBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Error" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
            </CheckBox>
          </StackPanel>

          <!-- Trennlinie -->
          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <!-- Kategorie-Filter -->
          <StackPanel Spacing="4">
            <TextBlock Text="Kategorie" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      HorizontalAlignment="Stretch" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Log-Einträge (rechts) -->
      <Border Grid.Column="1"
              Background="{DynamicResource CardBrush}"
              CornerRadius="8"
              BoxShadow="{DynamicResource CardShadow}"
              ClipToBounds="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      x:Name="LogScrollViewer">
          <ItemsControl ItemsSource="{Binding LogEntries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:LogDisplayItem">
                <Border Padding="12,8"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="70,70,80,*">
                    <!-- Timestamp (Monospace) -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding TimeText}"
                               FontSize="12"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" />

                    <!-- Level (farbcodiert) -->
                    <Border Grid.Column="1"
                            CornerRadius="4" Padding="6,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SurfaceBrush}">
                      <TextBlock Text="{Binding Level}"
                                 FontSize="11" FontWeight="SemiBold"
                                 Foreground="{Binding LevelColor}" />
                    </Border>

                    <!-- Kategorie -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding Category}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />

                    <!-- Nachricht -->
                    <TextBlock Grid.Column="3"
                               Text="{Binding Message}"
                               FontSize="12"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

    </Grid>

  </Grid>

</UserControl>
