<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:views="using:BingXBot.Views"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.MainViewMobile"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="True"
             Background="{DynamicResource AppBackgroundBrush}">

  <UserControl.Styles>
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- Tab-Content Fade-Transition                                       -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <Style Selector="Border.TabContent">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.TabContent:not(.Active)">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="Border.TabContent.Active">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
      <Setter Property="IsVisible" Value="True" />
    </Style>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- Bottom-Nav Buttons (große Touch-Targets, 64dp Höhe)               -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.BottomNavButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="4,6" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.BottomNavButton:pressed">
      <Setter Property="Background" Value="#18FFFFFF" />
    </Style>
    <Style Selector="Button.BottomNavButton.Active">
      <Setter Property="Foreground" Value="{DynamicResource AppPrimaryBrush}" />
    </Style>
    <Style Selector="Button.BottomNavButton mi|MaterialIcon">
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
      <Setter Property="RenderTransformOrigin" Value="50%,50%" />
      <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>
    <Style Selector="Button.BottomNavButton.Active mi|MaterialIcon">
      <Setter Property="RenderTransform" Value="scale(1.15)" />
    </Style>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- Drawer-Item (Bottom-Sheet "Mehr")                                 -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.DrawerItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="16,14" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.DrawerItem:pressed">
      <Setter Property="Background" Value="#18FFFFFF" />
    </Style>
    <Style Selector="Button.DrawerItem.Active">
      <Setter Property="Background" Value="{DynamicResource ActiveNavGradientBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AppPrimaryBrush}" />
    </Style>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- Scrim + Drawer-Fade                                               -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <Style Selector="Border.Scrim">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.DrawerSheet">
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.22" />
        </Transitions>
      </Setter>
      <Setter Property="RenderTransform" Value="translateY(100%)" />
    </Style>
    <Style Selector="Border.DrawerSheet.Open">
      <Setter Property="RenderTransform" Value="translateY(0)" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- Top App Bar (56dp)                                                -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,0" Height="56">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <!-- Logo + Titel -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center">
          <mi:MaterialIcon Kind="RobotOutline" Width="26" Height="26"
                           Foreground="{DynamicResource AppPrimaryBrush}" />
          <StackPanel Spacing="-2" VerticalAlignment="Center">
            <TextBlock Text="BingX Bot" FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="{Binding CurrentPage}" FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
          </StackPanel>
        </StackPanel>

        <!-- Status-Chips rechts: Mode + Bot-Status + Connection-Dot -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
          <!-- Mode-Badge -->
          <Border Background="{DynamicResource CardBrush}" CornerRadius="10"
                  Padding="8,4" VerticalAlignment="Center">
            <TextBlock Text="{Binding TradingMode}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppWarningBrush}" />
          </Border>
          <!-- Bot-Status -->
          <Border Background="{DynamicResource CardBrush}" CornerRadius="10"
                  Padding="8,4" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                       Fill="{Binding BotStatusColor}" />
              <TextBlock Text="{Binding BotStatus}" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource AppTextBrush}" />
            </StackPanel>
          </Border>
          <!-- Connection-Dot -->
          <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                   Fill="{Binding ConnectionDotColor}"
                   ToolTip.Tip="{Binding ConnectionStatus}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- Content Area (ContentControl rendert CurrentPageViewModel via ViewLocator) -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" Background="{DynamicResource AppBackgroundBrush}">
      <!-- Nur EIN Sub-ViewModel aktiv gleichzeitig. ViewLocator löst VM → View-Instanz
           (z.B. DashboardViewModel → DashboardViewMobile). Keine 8 parallel instanziierten Views mehr. -->
      <ContentControl Content="{Binding CurrentPageViewModel}" />

      <!-- ─── "Mehr"-Bottom-Sheet (Drawer) ─────────────────────────────── -->
      <!-- Scrim (dunkler Hintergrund) -->
      <Border Classes="Scrim"
              Background="{DynamicResource OverlayBrush}"
              IsVisible="{Binding IsMoreDrawerOpen}"
              Opacity="0.55"
              PointerPressed="OnScrimTapped" />

      <!-- Drawer-Sheet (gleitet von unten ein) -->
      <Border Classes="DrawerSheet"
              Classes.Open="{Binding IsMoreDrawerOpen}"
              IsVisible="{Binding IsMoreDrawerOpen}"
              VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
              Background="{DynamicResource AppSurfaceBrush}"
              BorderBrush="{DynamicResource AppBorderBrush}"
              BorderThickness="0,1,0,0"
              CornerRadius="20,20,0,0"
              Padding="16,12,16,24"
              BoxShadow="{DynamicResource ModalShadow}">
        <StackPanel Spacing="4">
          <!-- Drag-Handle -->
          <Border Width="40" Height="4" CornerRadius="2"
                  Background="{DynamicResource AppBorderBrush}"
                  HorizontalAlignment="Center" Margin="0,2,0,10" />
          <TextBlock Text="Mehr" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"
                     Margin="4,0,0,6" />

          <Button Classes="DrawerItem"
                  Classes.Active="{Binding IsStrategyActive}"
                  Command="{Binding NavigateToCommand}"
                  CommandParameter="Strategie">
            <StackPanel Orientation="Horizontal" Spacing="14">
              <mi:MaterialIcon Kind="ChartLine" Width="22" Height="22" />
              <TextBlock Text="Strategie" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button Classes="DrawerItem"
                  Classes.Active="{Binding IsBacktestActive}"
                  Command="{Binding NavigateToCommand}"
                  CommandParameter="Backtest">
            <StackPanel Orientation="Horizontal" Spacing="14">
              <mi:MaterialIcon Kind="History" Width="22" Height="22" />
              <TextBlock Text="Backtest" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button Classes="DrawerItem"
                  Classes.Active="{Binding IsRiskSettingsActive}"
                  Command="{Binding NavigateToCommand}"
                  CommandParameter="RiskSettings">
            <StackPanel Orientation="Horizontal" Spacing="14">
              <mi:MaterialIcon Kind="ShieldCheck" Width="22" Height="22" />
              <TextBlock Text="Risk-Management" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Border Height="1" Background="{DynamicResource AppBorderBrush}"
                  Margin="8,6" />

          <Button Classes="DrawerItem"
                  Classes.Active="{Binding IsSettingsActive}"
                  Command="{Binding NavigateToCommand}"
                  CommandParameter="Settings">
            <StackPanel Orientation="Horizontal" Spacing="14">
              <mi:MaterialIcon Kind="Cog" Width="22" Height="22" />
              <TextBlock Text="Einstellungen" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>
    </Grid>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- Bottom Navigation (5 Tabs, 68dp)                                  -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="2"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="0,1,0,0"
            Height="68">
      <Grid ColumnDefinitions="*,*,*,*,*">

        <!-- Dashboard -->
        <Button Grid.Column="0" Classes="BottomNavButton"
                Classes.Active="{Binding IsDashboardActive}"
                Command="{Binding NavigateToCommand}"
                CommandParameter="Dashboard">
          <StackPanel Spacing="3" HorizontalAlignment="Center">
            <mi:MaterialIcon Kind="ViewDashboard" Width="24" Height="24" />
            <TextBlock Text="Dashboard" FontSize="10" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Scanner -->
        <Button Grid.Column="1" Classes="BottomNavButton"
                Classes.Active="{Binding IsScannerActive}"
                Command="{Binding NavigateToCommand}"
                CommandParameter="Scanner">
          <StackPanel Spacing="3" HorizontalAlignment="Center">
            <mi:MaterialIcon Kind="Radar" Width="24" Height="24" />
            <TextBlock Text="Scanner" FontSize="10" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Trade-History -->
        <Button Grid.Column="2" Classes="BottomNavButton"
                Classes.Active="{Binding IsTradeHistoryActive}"
                Command="{Binding NavigateToCommand}"
                CommandParameter="TradeHistory">
          <StackPanel Spacing="3" HorizontalAlignment="Center">
            <mi:MaterialIcon Kind="FormatListBulleted" Width="24" Height="24" />
            <TextBlock Text="Trades" FontSize="10" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Log -->
        <Button Grid.Column="3" Classes="BottomNavButton"
                Classes.Active="{Binding IsLogActive}"
                Command="{Binding NavigateToCommand}"
                CommandParameter="Log">
          <StackPanel Spacing="3" HorizontalAlignment="Center">
            <mi:MaterialIcon Kind="Console" Width="24" Height="24" />
            <TextBlock Text="Log" FontSize="10" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Mehr (öffnet Drawer; aktiv wenn eine Drawer-Seite sichtbar ist) -->
        <Button Grid.Column="4" Classes="BottomNavButton"
                Classes.Active="{Binding IsMoreSectionActive}"
                Command="{Binding ToggleMoreDrawerCommand}">
          <StackPanel Spacing="3" HorizontalAlignment="Center">
            <mi:MaterialIcon Kind="DotsHorizontal" Width="24" Height="24" />
            <TextBlock Text="Mehr" FontSize="10" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>

      </Grid>
    </Border>

  </Grid>
</UserControl>
