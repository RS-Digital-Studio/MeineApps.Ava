<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.RiskSettingsView"
             x:DataType="vm:RiskSettingsViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <!-- Einheitliches TextBox-Styling für numerische Eingaben -->
    <Style Selector="TextBox.NumericInput">
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="MinWidth" Value="100" />
      <Setter Property="MaxWidth" Value="140" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="TextBox.NumericInput:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryBrush}" />
    </Style>

    <!-- NumericUpDown-Styling -->
    <Style Selector="NumericUpDown.RiskNumeric">
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="MinWidth" Value="140" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!-- ToggleSwitch -->
    <Style Selector="ToggleSwitch.RiskToggle">
      <Setter Property="OnContent" Value="An" />
      <Setter Property="OffContent" Value="Aus" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Settings-Row: Label links, Input rechts -->
    <Style Selector="Grid.SettingsRow">
      <Setter Property="Margin" Value="0,4" />
    </Style>

    <!-- Buttons -->
    <Style Selector="Button.RiskButton">
      <Setter Property="Padding" Value="20,10" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="20" Margin="0,0,0,24" MaxWidth="700">

      <!-- Titel -->
      <StackPanel Orientation="Horizontal" Spacing="10">
        <mi:MaterialIcon Kind="ShieldCheck" Width="24" Height="24"
                         Foreground="{DynamicResource AppPrimaryBrush}" />
        <TextBlock Text="Risk-Management" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
      </StackPanel>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: Position-Sizing                                        -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="ChartPie" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Position-Sizing" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Max Position Size -->
          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. Positionsgröße" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Maximaler Anteil des Kontostands pro Position" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <TextBox Classes="NumericInput" Text="{Binding MaxPositionSizePercent}"
                       ToolTip.Tip="Empfohlen: 1-5% pro Trade" />
              <TextBlock Text="%" FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <!-- Max Leverage -->
          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. Hebel" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Maximaler erlaubter Leverage (1-125)" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <TextBox Classes="NumericInput" Text="{Binding MaxLeverage}"
                       ToolTip.Tip="Höherer Hebel = höheres Risiko. Empfohlen: 3-10x" />
              <TextBlock Text="x" FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <!-- Marktspezifische Hebel -->
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="ChartMultiple" Width="16" Height="16"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Marktspezifische Hebel" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Maximaler Leverage pro Asset-Klasse (überschreibt den globalen Wert)"
                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" />
          </StackPanel>

          <UniformGrid Columns="3" Margin="0,0,0,4">
            <StackPanel Margin="0,0,12,8">
              <TextBlock Text="Krypto" FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4" />
              <NumericUpDown Classes="RiskNumeric" Value="{Binding CryptoMaxLeverage}"
                             Minimum="1" Maximum="125" Increment="1" FormatString="0x"
                             ToolTip.Tip="BTC, ETH, SOL etc. (1-125x). Empfohlen: 3-10x" />
            </StackPanel>
            <StackPanel Margin="0,0,12,8">
              <TextBlock Text="Rohstoffe" FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4" />
              <NumericUpDown Classes="RiskNumeric" Value="{Binding CommodityMaxLeverage}"
                             Minimum="1" Maximum="500" Increment="1" FormatString="0x"
                             ToolTip.Tip="Gold, Silber, Öl (1-500x). Empfohlen: 10-50x" />
            </StackPanel>
            <StackPanel Margin="0,0,12,8">
              <TextBlock Text="Indices" FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4" />
              <NumericUpDown Classes="RiskNumeric" Value="{Binding IndexMaxLeverage}"
                             Minimum="1" Maximum="500" Increment="1" FormatString="0x"
                             ToolTip.Tip="Nasdaq, S&amp;P500, DAX (1-500x). Empfohlen: 10-50x" />
            </StackPanel>
            <StackPanel Margin="0,0,12,8">
              <TextBlock Text="Forex" FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4" />
              <NumericUpDown Classes="RiskNumeric" Value="{Binding ForexMaxLeverage}"
                             Minimum="1" Maximum="500" Increment="1" FormatString="0x"
                             ToolTip.Tip="EUR/USD, GBP/USD etc. (1-500x). Empfohlen: 20-50x" />
            </StackPanel>
            <StackPanel Margin="0,0,12,8">
              <TextBlock Text="Aktien" FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4" />
              <NumericUpDown Classes="RiskNumeric" Value="{Binding StockMaxLeverage}"
                             Minimum="1" Maximum="25" Increment="1" FormatString="0x"
                             ToolTip.Tip="TSLA, AAPL, NVDA (1-25x). Empfohlen: 2-5x" />
            </StackPanel>
          </UniformGrid>

        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: Drawdown-Limits                                        -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="TrendingDown" Width="18" Height="18"
                             Foreground="{DynamicResource AppLossBrush}" />
            <TextBlock Text="Drawdown-Limits" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Max Daily Drawdown -->
          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. täglicher Drawdown" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Bot pausiert bei Überschreitung (täglicher Verlust)" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <TextBox Classes="NumericInput" Text="{Binding MaxDailyDrawdownPercent}"
                       ToolTip.Tip="Bot pausiert automatisch bei Überschreitung" />
              <TextBlock Text="%" FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <!-- Max Total Drawdown -->
          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. Gesamt-Drawdown" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Bot stoppt vollständig bei Überschreitung" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <TextBox Classes="NumericInput" Text="{Binding MaxTotalDrawdownPercent}"
                       ToolTip.Tip="Bot stoppt vollständig bei Überschreitung" />
              <TextBlock Text="%" FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: Positionen                                              -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="FormatListNumbered" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Positionen" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Max Open Positions -->
          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. offene Positionen" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Maximale Anzahl gleichzeitig offener Positionen" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <NumericUpDown Grid.Column="1" Classes="RiskNumeric"
                           Value="{Binding MaxOpenPositions}"
                           Minimum="1" Maximum="20" Increment="1"
                           FormatString="0" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <!-- Max Open Positions Per Symbol -->
          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. Positionen pro Symbol" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Maximale Positionen für das gleiche Handelspaar" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <NumericUpDown Grid.Column="1" Classes="RiskNumeric"
                           Value="{Binding MaxOpenPositionsPerSymbol}"
                           Minimum="1" Maximum="5" Increment="1"
                           FormatString="0" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- v1.5.x — Optimization-Plan-Toggles (opt-in, Default aus)         -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Classes="RiskCard">
        <StackPanel Spacing="14">
          <TextBlock Text="Erweiterte Filter (opt-in)" FontWeight="SemiBold" FontSize="14"
                     Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,4" />

          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="HTF-Confluence Hard-Gate" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Phase 1: Signale nur mit GKL-Hit oder HTF-Zone-Overlap (W1/D1)."
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding RequireHtfConfluenceForEntry}" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Min. Confluence-Score" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Phase 1: Hard-Gate auf Confluence-Score 0-11 (0 = aus, 4-6 empfohlen)."
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <NumericUpDown Grid.Column="1" Classes="RiskNumeric"
                           Value="{Binding MinConfluenceScore}"
                           Minimum="0" Maximum="11" Increment="1" FormatString="0" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Asymmetrisches CRV (TP aus HTF)" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Phase 2: SL bleibt LTF, TP1/TP2 kommen aus HTF-Sequenz (nur GKL-Setups)."
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding UseAsymmetricCrv}" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- v1.7.0 Phase 16 — Cross-TF-Pyramiding (User-Ausnahme)            -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="LayersTriple" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Cross-TF-Pyramiding (Phase 16)" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock Text="Bei laufendem TF-A-Trade darf ein zweites TF-B-Signal eine Add-On-Position öffnen. NICHT Buch-konform — bewusste User-Ausnahme."
                     FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />

          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Cross-TF-Pyramiding aktiv" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Default: aus. Erst aktivieren wenn Backtest auf eigenen Setups grün ist."
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableCrossTfPyramiding}" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. Add-Ons" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Wieviele zusätzliche Pyramid-Entries pro Basis-Trade (1-3 empfohlen)."
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <NumericUpDown Grid.Column="1" Classes="RiskNumeric"
                           Value="{Binding PyramidMaxAddOns}"
                           Minimum="1" Maximum="5" Increment="1" FormatString="0" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <Grid Classes="SettingsRow" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Add-On Positions-Skala" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Add-On-Größe relativ zur Basis (0.5 = halb so groß, 1.0 = gleich)."
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <NumericUpDown Grid.Column="1" Classes="RiskNumeric"
                           Value="{Binding PyramidScalePercent}"
                           Minimum="0.1" Maximum="2.0" Increment="0.1"
                           FormatString="0.0" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Buttons: Speichern + Reset                                      -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Classes="RiskButton" Command="{Binding SaveCommand}"
                Background="{DynamicResource AppPrimaryBrush}"
                Foreground="{DynamicResource PrimaryContrastBrush}"
                ToolTip.Tip="Risk-Einstellungen speichern">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16" />
            <TextBlock Text="Speichern" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Classes="RiskButton" Command="{Binding ResetToDefaultsCommand}"
                Background="{DynamicResource CardBrush}"
                Foreground="{DynamicResource AppTextBrush}"
                BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}"
                ToolTip.Tip="Alle Werte auf Standardeinstellungen zurücksetzen">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="Undo" Width="16" Height="16" />
            <TextBlock Text="Zurücksetzen" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Ungespeicherte Änderungen Hinweis -->
        <Border IsVisible="{Binding HasUnsavedChanges}"
                Background="{DynamicResource WarningBackgroundBrush}"
                CornerRadius="6" Padding="10,6" VerticalAlignment="Center" Margin="8,0,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="AlertOutline" Width="14" Height="14"
                             Foreground="{DynamicResource WarningBrush}" />
            <TextBlock Text="Ungespeicherte Änderungen" FontSize="12"
                       Foreground="{DynamicResource WarningBrush}" />
          </StackPanel>
        </Border>

        <!-- Status-Anzeige -->
        <TextBlock Text="{Binding SaveStatus}" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"
                   Margin="8,0,0,0"
                   IsVisible="{Binding SaveStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
