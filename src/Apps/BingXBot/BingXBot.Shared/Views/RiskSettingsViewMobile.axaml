<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.RiskSettingsViewMobile"
             x:DataType="vm:RiskSettingsViewModel"
             x:CompileBindings="True"
             Background="{DynamicResource AppBackgroundBrush}">

  <UserControl.Styles>
    <Style Selector="TextBox.MobileNumeric">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="MinWidth" Value="90" />
      <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>
    <Style Selector="NumericUpDown.MobileNumeric">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="MinWidth" Value="130" />
    </Style>
    <Style Selector="Border.SectionCard">
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="14,12" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="12" Margin="12,10,12,16">

      <!-- Titel -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <mi:MaterialIcon Kind="ShieldCheck" Width="20" Height="20"
                         Foreground="{DynamicResource AppPrimaryBrush}" />
        <TextBlock Text="Risk-Management" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
      </StackPanel>

      <!-- Action-Buttons (oben für einfachen Zugriff nach Scroll) -->
      <Grid ColumnDefinitions="*,8,*">
        <Button Grid.Column="0" Command="{Binding SaveCommand}"
                Background="{DynamicResource AppPrimaryBrush}"
                Foreground="{DynamicResource PrimaryContrastBrush}"
                CornerRadius="10" Padding="0,12"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                BorderThickness="0" FontWeight="SemiBold">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <mi:MaterialIcon Kind="ContentSave" Width="18" Height="18" />
            <TextBlock Text="Speichern" FontSize="14" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Grid.Column="2" Command="{Binding ResetToDefaultsCommand}"
                Background="{DynamicResource SurfaceBrush}"
                Foreground="{DynamicResource AppTextBrush}"
                CornerRadius="10" Padding="0,12"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                BorderThickness="1"
                BorderBrush="{DynamicResource AppBorderBrush}">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <mi:MaterialIcon Kind="Undo" Width="18" Height="18" />
            <TextBlock Text="Zurücksetzen" FontSize="14" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>

      <Border IsVisible="{Binding HasUnsavedChanges}"
              Background="{DynamicResource WarningBackgroundBrush}"
              CornerRadius="8" Padding="10,8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <mi:MaterialIcon Kind="AlertOutline" Width="16" Height="16"
                           Foreground="{DynamicResource WarningBrush}" />
          <TextBlock Text="Ungespeicherte Änderungen" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
        </StackPanel>
      </Border>
      <TextBlock Text="{Binding SaveStatus}" FontSize="13" FontWeight="SemiBold"
                 Foreground="{DynamicResource SuccessBrush}"
                 HorizontalAlignment="Center"
                 IsVisible="{Binding SaveStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

      <!-- ═════ Position-Sizing ═════ -->
      <Border Classes="SectionCard">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="ChartPie" Width="16" Height="16"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Position-Sizing" FontSize="13" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. Positionsgröße" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Anteil Kontostand pro Position" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBox Classes="MobileNumeric" Text="{Binding MaxPositionSizePercent}" />
              <TextBlock Text="%" FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. Hebel" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Globaler Leverage (1-125)" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBox Classes="MobileNumeric" Text="{Binding MaxLeverage}" />
              <TextBlock Text="x" FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <TextBlock Text="Marktspezifische Hebel" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextSecondaryBrush}" />

          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Krypto" FontSize="13"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,4" />
            <NumericUpDown Grid.Row="0" Grid.Column="1" Classes="MobileNumeric"
                           Value="{Binding CryptoMaxLeverage}"
                           Minimum="1" Maximum="125" Increment="1" FormatString="0x" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Rohstoffe" FontSize="13"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,4" />
            <NumericUpDown Grid.Row="1" Grid.Column="1" Classes="MobileNumeric"
                           Value="{Binding CommodityMaxLeverage}"
                           Minimum="1" Maximum="500" Increment="1" FormatString="0x" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Indices" FontSize="13"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,4" />
            <NumericUpDown Grid.Row="2" Grid.Column="1" Classes="MobileNumeric"
                           Value="{Binding IndexMaxLeverage}"
                           Minimum="1" Maximum="500" Increment="1" FormatString="0x" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Forex" FontSize="13"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,4" />
            <NumericUpDown Grid.Row="3" Grid.Column="1" Classes="MobileNumeric"
                           Value="{Binding ForexMaxLeverage}"
                           Minimum="1" Maximum="500" Increment="1" FormatString="0x" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Aktien" FontSize="13"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,4" />
            <NumericUpDown Grid.Row="4" Grid.Column="1" Classes="MobileNumeric"
                           Value="{Binding StockMaxLeverage}"
                           Minimum="1" Maximum="25" Increment="1" FormatString="0x" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═════ Drawdown-Limits ═════ -->
      <Border Classes="SectionCard">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="TrendingDown" Width="16" Height="16"
                             Foreground="{DynamicResource AppLossBrush}" />
            <TextBlock Text="Drawdown-Limits" FontSize="13" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Täglicher Drawdown" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Bot pausiert bei Überschreitung" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBox Classes="MobileNumeric" Text="{Binding MaxDailyDrawdownPercent}" />
              <TextBlock Text="%" FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Gesamt-Drawdown" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Bot stoppt vollständig" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBox Classes="MobileNumeric" Text="{Binding MaxTotalDrawdownPercent}" />
              <TextBlock Text="%" FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═════ Positionen ═════ -->
      <Border Classes="SectionCard">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="FormatListNumbered" Width="16" Height="16"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Positionen" FontSize="13" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. offen" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Gleichzeitig offene Positionen" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <NumericUpDown Grid.Column="1" Classes="MobileNumeric"
                           Value="{Binding MaxOpenPositions}"
                           Minimum="1" Maximum="20" Increment="1" FormatString="0" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" />

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Max. pro Symbol" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Positionen gleiches Paar" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <NumericUpDown Grid.Column="1" Classes="MobileNumeric"
                           Value="{Binding MaxOpenPositionsPerSymbol}"
                           Minimum="1" Maximum="5" Increment="1" FormatString="0" />
          </Grid>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
