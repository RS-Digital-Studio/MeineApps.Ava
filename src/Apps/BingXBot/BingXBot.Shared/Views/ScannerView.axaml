<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.ScannerView"
             x:DataType="vm:ScannerViewModel">

  <DockPanel>

    <!-- Titel -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="0,0,0,20">
      <mi:MaterialIcon Kind="Radar" Width="28" Height="28"
                       Foreground="{DynamicResource AppPrimaryBrush}" />
      <TextBlock Text="Scanner" FontSize="22" FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 VerticalAlignment="Center" />
    </StackPanel>

    <!-- Blacklist / Whitelist unten -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource CardBrush}"
            CornerRadius="8" Padding="20" Margin="0,16,0,0"
            BoxShadow="{DynamicResource CardShadow}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <Grid ColumnDefinitions="*,16,*">
        <StackPanel Grid.Column="0" Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="Cancel" Width="16" Height="16"
                             Foreground="{DynamicResource ErrorBrush}" />
            <TextBlock Text="Blacklist (kommagetrennt)" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <TextBox Text="{Binding BlacklistText, Mode=TwoWay}"
                   Watermark="z.B. SHIB,DOGE"
                   FontSize="13"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Background="{DynamicResource SurfaceBrush}"
                   BorderBrush="{DynamicResource BorderBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                             Foreground="{DynamicResource SuccessBrush}" />
            <TextBlock Text="Whitelist (kommagetrennt)" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <TextBox Text="{Binding WhitelistText, Mode=TwoWay}"
                   Watermark="z.B. BTC,ETH,SOL"
                   FontSize="13"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Background="{DynamicResource SurfaceBrush}"
                   BorderBrush="{DynamicResource BorderBrush}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Hauptbereich: Settings links, Ergebnisse rechts -->
    <Grid ColumnDefinitions="250,16,*">

      <!-- ═══ Settings (links) ═══ -->
      <Border Grid.Column="0"
              Background="{DynamicResource CardBrush}"
              CornerRadius="8" Padding="20"
              BoxShadow="{DynamicResource CardShadow}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="FilterVariant" Width="18" Height="18"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
              <TextBlock Text="Filter" FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>

            <!-- Min. Volumen -->
            <StackPanel Spacing="4">
              <TextBlock Text="Min. Volumen 24h ($)" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBox Text="{Binding MinVolume, Mode=TwoWay}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Background="{DynamicResource SurfaceBrush}"
                       BorderBrush="{DynamicResource BorderBrush}" />
            </StackPanel>

            <!-- Min. Preisänderung -->
            <StackPanel Spacing="4">
              <TextBlock Text="Min. Preisänderung (%)" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBox Text="{Binding MinPriceChange, Mode=TwoWay}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Background="{DynamicResource SurfaceBrush}"
                       BorderBrush="{DynamicResource BorderBrush}" />
            </StackPanel>

            <!-- Zeitrahmen -->
            <StackPanel Spacing="4">
              <TextBlock Text="Zeitrahmen" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox ItemsSource="{Binding TimeFrames}"
                        SelectedItem="{Binding SelectedTimeFrame}"
                        HorizontalAlignment="Stretch"
                        Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- Scan-Modus -->
            <StackPanel Spacing="4">
              <TextBlock Text="Scan-Modus" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox ItemsSource="{Binding ScanModes}"
                        SelectedItem="{Binding SelectedScanMode}"
                        HorizontalAlignment="Stretch"
                        Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- Max. Ergebnisse -->
            <StackPanel Spacing="4">
              <TextBlock Text="Max. Ergebnisse" FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBox Text="{Binding MaxResults, Mode=TwoWay}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Background="{DynamicResource SurfaceBrush}"
                       BorderBrush="{DynamicResource BorderBrush}" />
            </StackPanel>

            <!-- Scan-Button -->
            <Button Command="{Binding ScanCommand}"
                    IsEnabled="{Binding !IsScanning}"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"
                    CornerRadius="6"
                    Cursor="Hand"
                    HorizontalContentAlignment="Center">
              <Button.Background>
                <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
              </Button.Background>
              <StackPanel Orientation="Horizontal" Spacing="8"
                          HorizontalAlignment="Center">
                <mi:MaterialIcon Kind="Magnify" Width="18" Height="18"
                                 Foreground="{DynamicResource PrimaryContrastBrush}" />
                <TextBlock Text="Scannen" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryContrastBrush}" />
              </StackPanel>
            </Button>

            <!-- Status -->
            <TextBlock Text="{Binding ScanStatus}" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ═══ Ergebnis-Tabelle (rechts) ═══ -->
      <Border Grid.Column="2"
              Background="{DynamicResource CardBrush}"
              CornerRadius="8" Padding="0"
              BoxShadow="{DynamicResource CardShadow}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="1">
        <DockPanel>
          <!-- Tabellen-Header -->
          <Border DockPanel.Dock="Top"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8,8,0,0"
                  Padding="16,10">
            <Grid ColumnDefinitions="*,80,100,120,80">
              <TextBlock Grid.Column="0" Text="Symbol" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Grid.Column="1" Text="Score" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
              <TextBlock Grid.Column="2" Text="Setup" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
              <TextBlock Grid.Column="3" Text="Volumen 24h" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
              <TextBlock Grid.Column="4" Text="Change" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
            </Grid>
          </Border>

          <!-- Keine Ergebnisse -->
          <StackPanel IsVisible="{Binding !Results.Count}"
                      VerticalAlignment="Center" HorizontalAlignment="Center"
                      Spacing="8">
            <mi:MaterialIcon Kind="DatabaseSearchOutline" Width="40" Height="40"
                             Foreground="{DynamicResource TextMutedBrush}" Opacity="0.5"
                             HorizontalAlignment="Center" />
            <TextBlock Text="Keine Ergebnisse" FontSize="13"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <!-- Ergebnis-Zeilen -->
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Results}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ScanResultItem">
                  <Border Padding="16,10"
                          BorderBrush="{DynamicResource BorderSubtleBrush}"
                          BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,80,100,120,80">
                      <!-- Symbol -->
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Symbol}"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalAlignment="Center" />
                      <!-- Score -->
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Score, StringFormat={}{0:F1}}"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource SuccessBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center" />
                      <!-- Setup-Typ -->
                      <Border Grid.Column="2"
                              Background="{DynamicResource InfoBackgroundBrush}"
                              CornerRadius="4" Padding="8,3"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                        <TextBlock Text="{Binding SetupType}"
                                   FontSize="11"
                                   Foreground="{DynamicResource InfoBrush}" />
                      </Border>
                      <!-- Volumen -->
                      <TextBlock Grid.Column="3"
                                 Text="{Binding Volume24h, StringFormat={}{0:N0}}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center" />
                      <!-- Preisänderung -->
                      <TextBlock Grid.Column="4"
                                 Text="{Binding PriceChange, StringFormat={}{0:+0.0;-0.0}%}"
                                 FontSize="12" FontWeight="SemiBold"
                                 Foreground="{DynamicResource SuccessBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

    </Grid>
  </DockPanel>

</UserControl>
