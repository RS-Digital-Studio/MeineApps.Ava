<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:dto="using:BingXBot.Contracts.Dto"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.SettingsHistoryView"
             x:DataType="vm:SettingsHistoryViewModel"
             x:CompileBindings="True">

  <DockPanel>

    <!-- Titel -->
    <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,16">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <mi:MaterialIcon Kind="History" Width="28" Height="28"
                         Foreground="{DynamicResource AppPrimaryBrush}" />
        <TextBlock Text="Settings-Audit-Trail" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock Text="Wer hat wann welche Einstellung geändert? Alle Änderungen seit v1.6.3 werden mit Source-Tag, Old-/New-Value und JSON-Snapshot persistiert."
                 FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap" Margin="40,0,0,0" />
    </StackPanel>

    <!-- Filter-Card -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource CardBrush}"
            CornerRadius="8" Padding="16,14" Margin="0,0,0,12"
            BoxShadow="{DynamicResource CardShadow}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <Grid ColumnDefinitions="Auto,12,Auto,12,Auto,12,Auto,12,*,Auto"
            VerticalAlignment="Center">
        <StackPanel Grid.Column="0" Spacing="3">
          <TextBlock Text="Block" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <ComboBox ItemsSource="{Binding AvailableFields}"
                    SelectedItem="{Binding SelectedField}"
                    MinWidth="120" />
        </StackPanel>

        <StackPanel Grid.Column="2" Spacing="3">
          <TextBlock Text="Seit" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <DatePicker SelectedDate="{Binding SinceDate}" MinWidth="160" />
        </StackPanel>

        <StackPanel Grid.Column="4" Spacing="3">
          <TextBlock Text="Limit" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <ComboBox ItemsSource="{Binding AvailableLimits}"
                    SelectedItem="{Binding SelectedLimit}" MinWidth="100" />
        </StackPanel>

        <Button Grid.Column="6" Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsLoading}"
                Background="{DynamicResource AppPrimaryBrush}"
                Foreground="{DynamicResource PrimaryContrastBrush}"
                CornerRadius="6" Padding="14,8" BorderThickness="0"
                VerticalAlignment="Bottom" FontWeight="SemiBold">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="Refresh" Width="16" Height="16" />
            <TextBlock Text="Laden" FontSize="13" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Grid.Column="8" Command="{Binding ClearFilterCommand}"
                Background="{DynamicResource SurfaceBrush}"
                Foreground="{DynamicResource AppTextBrush}"
                CornerRadius="6" Padding="14,8"
                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                VerticalAlignment="Bottom" HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="FilterRemoveOutline" Width="16" Height="16" />
            <TextBlock Text="Filter zurücksetzen" FontSize="13" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <TextBlock Grid.Column="9" Text="{Binding StatusText}"
                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                   VerticalAlignment="Center" Margin="12,0,0,0" />
      </Grid>
    </Border>

    <!-- Ergebnis-Liste -->
    <Border Background="{DynamicResource CardBrush}"
            CornerRadius="8" Padding="0"
            BoxShadow="{DynamicResource CardShadow}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="8,8,0,0" Padding="14,8">
          <Grid ColumnDefinitions="160,200,*,200,90">
            <TextBlock Grid.Column="0" Text="Zeit (UTC)" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="1" Text="Feld" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="2" Text="Alt → Neu" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="3" Text="Snapshot" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="4" Text="Source" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" />
          </Grid>
        </Border>

        <StackPanel IsVisible="{Binding !Changes.Count}"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="10" Margin="24">
          <mi:MaterialIcon Kind="ClockOutline" Width="48" Height="48"
                           Foreground="{DynamicResource TextMutedBrush}" Opacity="0.4"
                           HorizontalAlignment="Center" />
          <TextBlock Text="Drücke 'Laden' um die Änderungs-History abzurufen"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <ListBox ItemsSource="{Binding Changes}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 IsVisible="{Binding Changes.Count}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="MinHeight" Value="0" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="dto:SettingsChangeDto">
              <Border Padding="14,8"
                      BorderBrush="{DynamicResource BorderSubtleBrush}"
                      BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="160,200,*,200,90">
                  <TextBlock Grid.Column="0"
                             Text="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}"
                             FontSize="11" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding Field}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource AppPrimaryBrush}"
                             VerticalAlignment="Center" TextWrapping="Wrap" />
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                              VerticalAlignment="Center">
                    <TextBlock Text="{Binding OldValue}" FontSize="11"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{DynamicResource ErrorBrush}"
                               TextTrimming="CharacterEllipsis" MaxWidth="240" />
                    <mi:MaterialIcon Kind="ArrowRight" Width="14" Height="14"
                                     Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="{Binding NewValue}" FontSize="11"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{DynamicResource SuccessBrush}"
                               TextTrimming="CharacterEllipsis" MaxWidth="240" />
                  </StackPanel>
                  <TextBlock Grid.Column="3"
                             Text="{Binding Snapshot}"
                             FontSize="10" FontFamily="Consolas, Courier New, monospace"
                             Foreground="{DynamicResource TextMutedBrush}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"
                             IsVisible="{Binding Snapshot, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                             ToolTip.Tip="{Binding Snapshot}" />
                  <Border Grid.Column="4"
                          Background="{DynamicResource InfoBackgroundBrush}"
                          CornerRadius="4" Padding="6,2"
                          HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source}" FontSize="10"
                               Foreground="{DynamicResource InfoBrush}"
                               FontWeight="SemiBold" />
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </DockPanel>
</UserControl>
