<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <!-- Einheitliches TextBox-Styling -->
    <Style Selector="TextBox.SettingsInput">
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBox.SettingsInput:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryBrush}" />
    </Style>

    <!-- Einheitliche Buttons -->
    <Style Selector="Button.SettingsButton">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.Primary">
      <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.Primary:pointerover">
      <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
    </Style>
    <Style Selector="Button.Danger">
      <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.Danger:pointerover">
      <Setter Property="Background" Value="{DynamicResource ErrorLightBrush}" />
    </Style>
    <Style Selector="Button.Secondary">
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    </Style>
    <Style Selector="Button.Secondary:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="20" Margin="0,0,0,24" MaxWidth="700">

      <!-- Titel -->
      <StackPanel Orientation="Horizontal" Spacing="10">
        <mi:MaterialIcon Kind="Cog" Width="24" Height="24"
                         Foreground="{DynamicResource AppPrimaryBrush}" />
        <TextBlock Text="Einstellungen" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
      </StackPanel>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: API-Konfiguration                                      -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="Key" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="API-Konfiguration" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <!-- API-Key -->
          <StackPanel Spacing="6">
            <TextBlock Text="API-Key" FontSize="12"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <TextBox Classes="SettingsInput" Text="{Binding ApiKey}"
                     Watermark="BingX API-Key eingeben..."
                     ToolTip.Tip="BingX API-Key (nicht der Secret)" />
          </StackPanel>

          <!-- API-Secret -->
          <StackPanel Spacing="6">
            <TextBlock Text="API-Secret" FontSize="12"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <TextBox Classes="SettingsInput" Text="{Binding ApiSecret}"
                     PasswordChar="*"
                     Watermark="BingX API-Secret eingeben..."
                     ToolTip.Tip="BingX API-Secret (wird verschlüsselt gespeichert)" />
          </StackPanel>

          <!-- Buttons -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Button Classes="SettingsButton Primary"
                    Command="{Binding SaveCredentialsCommand}"
                    ToolTip.Tip="API-Keys verschlüsselt auf diesem Gerät speichern">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16" />
                <TextBlock Text="Speichern" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="SettingsButton Danger"
                    Command="{Binding DeleteCredentialsCommand}"
                    ToolTip.Tip="Gespeicherte API-Keys unwiderruflich löschen">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <mi:MaterialIcon Kind="Delete" Width="16" Height="16" />
                <TextBlock Text="Löschen" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: Verbindung                                              -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="LanConnect" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Verbindung" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Status-Anzeige -->
          <Border Background="{DynamicResource CardBrush}" CornerRadius="6"
                  Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                <Ellipse.Fill>
                  <SolidColorBrush Color="{DynamicResource WarningColor}" />
                </Ellipse.Fill>
              </Ellipse>
              <TextBlock Text="{Binding ConnectionStatus}" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Test-Button -->
          <Button Classes="SettingsButton Secondary"
                  Command="{Binding TestConnectionCommand}"
                  IsEnabled="{Binding !IsConnecting}"
                  ToolTip.Tip="Verbindung zu BingX mit den gespeicherten API-Keys testen">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <!-- Spinner wenn verbindend -->
              <mi:MaterialIcon Kind="Loading" Width="16" Height="16"
                               IsVisible="{Binding IsConnecting}"
                               Foreground="{DynamicResource AppPrimaryBrush}">
                <mi:MaterialIcon.RenderTransform>
                  <RotateTransform />
                </mi:MaterialIcon.RenderTransform>
              </mi:MaterialIcon>
              <mi:MaterialIcon Kind="LanCheck" Width="16" Height="16"
                               IsVisible="{Binding !IsConnecting}" />
              <TextBlock Text="Verbindung testen" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: Remote-Server (Raspberry Pi)                           -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="RaspberryPi" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Remote-Server (Pi)" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Text="Verbinde zu einem 24/7-laufenden BingXBot-Server auf einem Raspberry Pi. Beim ersten Pairing erzeugt der Pi einen 6-stelligen Code (im Terminal/SSH mit 'journalctl -u bingxbot' sichtbar oder unter /var/lib/bingxbot/pairing-code.txt)." />

          <!-- Status-Anzeige -->
          <Border Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="12,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                <Ellipse.Fill>
                  <SolidColorBrush Color="{DynamicResource SuccessColor}" />
                </Ellipse.Fill>
              </Ellipse>
              <TextBlock Text="{Binding PairingStatus}" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <!-- Server-URL -->
          <StackPanel Spacing="6">
            <TextBlock Text="Server-URL" FontSize="12"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <TextBox Classes="SettingsInput" Text="{Binding ServerUrl}"
                     Watermark="http://bingxbot.local:5050"
                     IsEnabled="{Binding !ServerPaired}"
                     ToolTip.Tip="mDNS-Name oder Tailscale/LAN-IP + Port des Pi-Servers" />
          </StackPanel>

          <!-- Device-Name (optional, wird dem Server als Label gemeldet) -->
          <StackPanel Spacing="6">
            <TextBlock Text="Geräte-Name (für Server-Log)" FontSize="12"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <TextBox Classes="SettingsInput" Text="{Binding PairedDeviceName}"
                     Watermark="z.B. Desktop-Robert"
                     IsEnabled="{Binding !ServerPaired}" />
          </StackPanel>

          <!-- Pairing: Schritt 1 (Code anfordern) -->
          <Button Classes="SettingsButton Primary"
                  Command="{Binding InitiatePairingCommand}"
                  IsVisible="{Binding !ServerPaired}"
                  IsEnabled="{Binding !PairingInProgress}"
                  ToolTip.Tip="Server bittet um 6-stelligen Code. Den Code danach vom Pi ablesen.">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <mi:MaterialIcon Kind="Connection" Width="16" Height="16" />
              <TextBlock Text="1. Pairing starten" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- Pairing: Schritt 2 (Code eingeben) -->
          <StackPanel Spacing="6" IsVisible="{Binding PairingInProgress}">
            <TextBlock Text="Pairing-Code (vom Pi ablesen)" FontSize="12"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <TextBox Classes="SettingsInput" Text="{Binding PairingCode}"
                     Watermark="6-stelliger Code"
                     MaxLength="6"
                     FontSize="18" FontWeight="Bold"
                     HorizontalContentAlignment="Center" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
              <Button Classes="SettingsButton Primary"
                      Command="{Binding CompletePairingCommand}"
                      IsEnabled="{Binding !IsCompletingPairing}"
                      ToolTip.Tip="Code zum Server senden. Bei Tippfehler einfach Code im Feld korrigieren und erneut klicken.">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <!-- Loading-Icon während POST läuft — verhindert dass User doppelt klickt -->
                  <mi:MaterialIcon Kind="Loading" Width="16" Height="16"
                                   IsVisible="{Binding IsCompletingPairing}"
                                   Foreground="{DynamicResource PrimaryContrastBrush}" />
                  <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                                   IsVisible="{Binding !IsCompletingPairing}" />
                  <TextBlock Text="2. Code bestätigen" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Classes="SettingsButton Secondary"
                      Command="{Binding CancelPairingCommand}"
                      IsEnabled="{Binding !IsCompletingPairing}"
                      ToolTip.Tip="Pairing-Vorgang am Server und Client abbrechen">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="Close" Width="16" Height="16" />
                  <TextBlock Text="Abbrechen" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>

          <!-- Trennen (nur wenn gepairt) -->
          <Button Classes="SettingsButton Danger"
                  Command="{Binding DisconnectServerCommand}"
                  IsVisible="{Binding ServerPaired}"
                  ToolTip.Tip="Token löschen, Standalone-Modus nach Neustart">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <mi:MaterialIcon Kind="LinkOff" Width="16" Height="16" />
              <TextBlock Text="Verbindung trennen" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: Darstellung                                             -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="ThemeLightDark" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Darstellung" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="Theme" FontSize="12"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <ComboBox ItemsSource="{Binding AvailableThemes}"
                      SelectedItem="{Binding Theme, Mode=TwoWay}"
                      Background="{DynamicResource CardBrush}"
                      Foreground="{DynamicResource AppTextBrush}"
                      BorderBrush="{DynamicResource AppBorderBrush}"
                      BorderThickness="1" CornerRadius="6"
                      Padding="12,8" FontSize="13"
                      MinWidth="200" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: Diagnose + Push (v1.5.x Optimization-Plan)              -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16" BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="Cogs" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Diagnose &amp; Benachrichtigungen" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>


          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Trade-Push-Notifications" FontSize="13"
                         Foreground="{DynamicResource AppTextBrush}" />
              <TextBlock Text="Phase 9: FCM-Push bei TradeOpened / TradeClosed / SL-Hit (Mobile)."
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableTradePushNotifications}" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- Sektion: Logging                                                 -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
              Padding="20,16"
              BoxShadow="{DynamicResource CardShadow}">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="Console" Width="18" Height="18"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Logging" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="Log-Level" FontSize="12"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <ComboBox ItemsSource="{Binding LogLevels}"
                      SelectedItem="{Binding SelectedLogLevel}"
                      Background="{DynamicResource CardBrush}"
                      Foreground="{DynamicResource AppTextBrush}"
                      BorderBrush="{DynamicResource AppBorderBrush}"
                      BorderThickness="1" CornerRadius="6"
                      Padding="12,8" FontSize="13"
                      MinWidth="200" />
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
