<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BingXBot.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="BingXBot.Views.StrategyViewMobile"
             x:DataType="vm:StrategyViewModel"
             x:CompileBindings="True"
             Background="{DynamicResource AppBackgroundBrush}">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="12" Margin="12,10,12,16">

      <!-- Titel -->
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <mi:MaterialIcon Kind="ChartLine" Width="20" Height="20"
                         Foreground="{DynamicResource AppPrimaryBrush}" />
        <TextBlock Text="Strategie" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource AppTextBrush}"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Strategie-Auswahl + Beschreibung -->
      <Border Background="{DynamicResource CardBrush}"
              CornerRadius="12" Padding="14">
        <StackPanel Spacing="10">
          <TextBlock Text="Strategie-Typ" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding AvailableStrategies}"
                    SelectedItem="{Binding SelectedStrategy}"
                    HorizontalAlignment="Stretch" />

          <Border Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="8" Padding="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="InformationOutline" Width="16" Height="16"
                               Foreground="{DynamicResource InfoBrush}"
                               VerticalAlignment="Top" Margin="0,2,0,0" />
              <TextBlock Text="{Binding StrategyDescription}"
                         FontSize="12" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- Parameter -->
      <Border Background="{DynamicResource CardBrush}"
              CornerRadius="12" Padding="14">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="TuneVariant" Width="16" Height="16"
                             Foreground="{DynamicResource AppPrimaryBrush}" />
            <TextBlock Text="Parameter" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <ItemsControl ItemsSource="{Binding Parameters}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:StrategyParameterItem">
                <Grid ColumnDefinitions="*,140" Margin="0,6">
                  <TextBlock Grid.Column="0" Text="{Binding Name}"
                             FontSize="13"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"
                             TextWrapping="Wrap" />
                  <TextBox Grid.Column="1"
                           Text="{Binding Value, Mode=TwoWay}"
                           FontSize="13"
                           HorizontalContentAlignment="Right"
                           Padding="10,8" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Aktivierung -->
      <Border Background="{DynamicResource CardBrush}"
              CornerRadius="12" Padding="14">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="Auto,*">
            <Ellipse Grid.Column="0" Width="12" Height="12" VerticalAlignment="Center">
              <Ellipse.Fill>
                <SolidColorBrush Color="{DynamicResource ProfitColor}" />
              </Ellipse.Fill>
              <Ellipse.IsVisible>
                <Binding Path="IsActive" />
              </Ellipse.IsVisible>
            </Ellipse>
            <Ellipse Grid.Column="0" Width="12" Height="12" VerticalAlignment="Center"
                     IsVisible="{Binding !IsActive}">
              <Ellipse.Fill>
                <SolidColorBrush Color="{DynamicResource TextMutedColor}" />
              </Ellipse.Fill>
            </Ellipse>
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="10,0,0,0" />
          </Grid>

          <Button Command="{Binding ToggleActiveCommand}"
                  Padding="0,14"
                  CornerRadius="10"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  BorderThickness="0">
            <Button.Background>
              <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
            </Button.Background>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <mi:MaterialIcon Kind="Play" Width="20" Height="20"
                               Foreground="{DynamicResource PrimaryContrastBrush}"
                               IsVisible="{Binding !IsActive}" />
              <mi:MaterialIcon Kind="Stop" Width="20" Height="20"
                               Foreground="{DynamicResource PrimaryContrastBrush}"
                               IsVisible="{Binding IsActive}" />
              <TextBlock Text="{Binding ToggleButtonText}"
                         FontSize="14" FontWeight="Bold"
                         Foreground="{DynamicResource PrimaryContrastBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
