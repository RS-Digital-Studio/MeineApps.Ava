<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BomberBlast.ViewModels"
             xmlns:icons="using:BomberBlast.Icons"
             xmlns:conv="using:BomberBlast.Converters"
             xmlns:controls="using:BomberBlast.Controls"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             x:Class="BomberBlast.Views.LeagueView"
             x:DataType="vm:LeagueViewModel"
             x:CompileBindings="True"
             x:Name="League_Root">

  <!-- Liga-System: Landscape 2-Spalten Layout mit Firebase Online-Rangliste -->
  <Panel AutomationProperties.AutomationId="League_Root">
    <controls:MenuBackgroundCanvas BackgroundTheme="League" />

    <Grid ColumnDefinitions="*,2*" Margin="16,12,16,80">

      <!-- ═══════════════════════════════════════════════════════════
           LINKE SPALTE (260px) - Liga-Info + Belohnungen + Stats
           ═══════════════════════════════════════════════════════════ -->
      <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,0,12,0">

        <!-- Header: Zurück + Titel + Online-Status -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
          <Button Grid.Column="0" Classes="Secondary GameButton"
                  Command="{Binding GoBackCommand}"
                  Width="44" Height="44"
                  Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  AutomationProperties.AutomationId="League_BtnBack">
            <icons:GameIcon Kind="ArrowLeft" Width="22" Height="22"
                                        Foreground="{DynamicResource TextPrimaryBrush}" />
          </Button>
          <TextBlock Grid.Column="1"
                     Text="{Binding Title}"
                     FontSize="22" FontWeight="Bold"
                     Foreground="{DynamicResource AccentBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     AutomationProperties.AutomationId="League_TxtTitle" />
          <!-- Online/Offline Indikator -->
          <Panel Grid.Column="2" VerticalAlignment="Center">
            <icons:GameIcon Kind="CloudCheck" Width="18" Height="18"
                                        Foreground="#22C55E"
                                        IsVisible="{Binding IsOnline}" />
            <icons:GameIcon Kind="CloudOffOutline" Width="18" Height="18"
                                        Foreground="#EF4444"
                                        IsVisible="{Binding !IsOnline}" />
          </Panel>
        </Grid>

        <!-- Liga-Tier Emblem - Subtiler Cyan-Tint Gradient als Blickfang -->
        <Border Grid.Row="1"
                CornerRadius="12" Padding="16,12" Margin="0,0,0,12" BoxShadow="0 2 8 0 #25000000">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
              <GradientStop Color="#20006064" Offset="0" />
              <GradientStop Color="{DynamicResource SurfaceColor}" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <!-- Tier-Icon -->
            <icons:GameIcon
                Kind="{Binding TierIconName, Converter={x:Static conv:StringToGameIconKindConverter.Instance}}"
                Width="44" Height="44"
                Foreground="{Binding TierColor}"
                HorizontalAlignment="Center" />
            <!-- Tier-Name -->
            <TextBlock Text="{Binding TierName}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{Binding TierColor}"
                       HorizontalAlignment="Center" />
            <!-- Punkte -->
            <TextBlock Text="{Binding PointsText}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" />
            <!-- Rang -->
            <TextBlock Text="{Binding RankText}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center" />
            <!-- Nächste Liga -->
            <TextBlock Text="{Binding NextTierText}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Saison-Countdown -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10" Padding="12,8" Margin="0,0,0,12" BoxShadow="0 2 8 0 #25000000">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding SeasonCountdown}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource GoldAccentBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding SeasonDisplayText}"
                       FontSize="13"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Saison-Belohnung -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10" Padding="12,8" Margin="0,0,0,12" BoxShadow="0 2 8 0 #25000000">
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding RewardText}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- Belohnung abholen -->
            <Panel MinHeight="44" IsVisible="{Binding CanClaimReward}" HorizontalAlignment="Center">
              <controls:GameButtonCanvas ButtonColor="#22C55E" DamageLevel="0.3" ButtonSeed="180" />
              <Button Classes="Primary GameButton"
                      Command="{Binding ClaimRewardCommand}"
                      MinHeight="44" Padding="12,8" Background="Transparent" Foreground="White">
                <TextBlock Text="{Binding ClaimRewardText}"
                           FontSize="12" FontWeight="Bold" Foreground="White" />
              </Button>
            </Panel>
            <!-- Bereits abgeholt -->
            <StackPanel Orientation="Horizontal" Spacing="6"
                        IsVisible="{Binding IsRewardClaimed}"
                        HorizontalAlignment="Center">
              <icons:GameIcon Kind="CheckCircle"
                                          Width="20" Height="20" Foreground="#22C55E" />
              <TextBlock Text="{Binding RewardClaimedText}"
                         FontSize="12" Foreground="#22C55E" VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Stats -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10" Padding="12,8" VerticalAlignment="Top"
                BoxShadow="0 2 8 0 #25000000">
          <TextBlock Text="{Binding StatsText}"
                     FontSize="12"
                     Foreground="{DynamicResource TextMutedBrush}"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>

      <!-- ═══════════════════════════════════════════════════════════
           RECHTE SPALTE (*) - Tab-Switcher: Saison-Liga ODER Daily Race
           ═══════════════════════════════════════════════════════════ -->
      <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">

        <!-- Tab-Switcher (v2.0.42, Plan Task 3.1) -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10" Padding="6" Margin="0,0,0,8"
                BoxShadow="0 2 8 0 #25000000">
          <Grid ColumnDefinitions="*,*">
            <Button Grid.Column="0" Classes="GameButton"
                    Command="{Binding SelectSeasonTabCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="10,8" CornerRadius="8"
                    AutomationProperties.AutomationId="League_BtnTabSeason">
              <Button.Background>
                <SolidColorBrush Color="{DynamicResource AccentColor}"
                                  Opacity="{Binding IsSeasonTabActive, Converter={x:Static conv:BoolToOpacityConverter.Instance}}" />
              </Button.Background>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <icons:GameIcon Kind="Trophy" Width="16" Height="16"
                                            Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding SeasonTabText}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Grid.Column="1" Classes="GameButton"
                    Command="{Binding SelectDailyRaceTabCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="10,8" CornerRadius="8"
                    AutomationProperties.AutomationId="League_BtnTabDailyRace">
              <Button.Background>
                <SolidColorBrush Color="{DynamicResource AccentColor}"
                                  Opacity="{Binding IsDailyRaceTabActive, Converter={x:Static conv:BoolToOpacityConverter.Instance}}" />
              </Button.Background>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <icons:GameIcon Kind="Bomb" Width="16" Height="16"
                                            Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding DailyRaceTabText}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </Grid>
        </Border>

        <!-- ═════════════ SAISON-TAB ═════════════ -->
        <!-- Rangliste Header + Refresh-Button -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10" Padding="12,8" Margin="0,0,0,8"
                BoxShadow="0 2 8 0 #25000000"
                IsVisible="{Binding IsSeasonTabActive}">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <TextBlock Grid.Column="0" Text="#"
                       FontSize="14" FontWeight="Bold" Width="40"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Grid.Column="1" Text="{Binding PlayerHeaderText}"
                       FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Grid.Column="2" Text="{Binding PointsHeaderText}"
                       FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"
                       Margin="0,0,8,0" />
            <!-- Refresh-Button -->
            <Panel Grid.Column="3" MinHeight="44" MinWidth="44">
              <controls:GameButtonCanvas ButtonColor="#607D8B" DamageLevel="0.2" ButtonSeed="181" />
              <Button Classes="Secondary GameButton"
                      Command="{Binding RefreshLeaderboardCommand}"
                      Width="44" Height="44" Padding="0"
                      Background="Transparent" Foreground="White"
                      HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                      AutomationProperties.AutomationId="League_BtnRefresh">
                <icons:GameIcon Kind="Refresh" Width="18" Height="18"
                                            Foreground="White" />
              </Button>
            </Panel>
          </Grid>
        </Border>

        <!-- Lade-Indikator (Saison) -->
        <Border Grid.Row="2" IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="8" Padding="16,8" Margin="0,4,0,0" Opacity="0.9">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <icons:GameIcon Kind="CloudSync" Width="16" Height="16"
                                        Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="{Binding LoadingLeaderboardText}" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Border>

        <!-- Saison-Leaderboard-Liste -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                       IsVisible="{Binding IsSeasonTabActive}">
          <ItemsControl ItemsSource="{Binding LeaderboardEntries}"
                        AutomationProperties.AutomationId="League_Leaderboard"
                        Margin="0,0,0,8">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="3" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:LeagueDisplayEntry">
                <!-- Leaderboard-Eintrag mit farbigem linken Akzent-Rand -->
                <Border CornerRadius="8" Padding="12,8"
                        BorderThickness="3,0,0,0">
                  <Border.BorderBrush>
                    <SolidColorBrush Color="{Binding NameColor}" />
                  </Border.BorderBrush>
                  <Border.Background>
                    <SolidColorBrush Color="#FFFFFF" Opacity="{Binding BackgroundOpacity}" />
                  </Border.Background>
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <!-- Rang -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding RankText}"
                               FontSize="13" FontWeight="Bold" Width="40"
                               VerticalAlignment="Center">
                      <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding NameColor}" />
                      </TextBlock.Foreground>
                    </TextBlock>

                    <!-- Name + Echtspieler-Indikator -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="13" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis">
                        <TextBlock.Foreground>
                          <SolidColorBrush Color="{Binding NameColor}" />
                        </TextBlock.Foreground>
                      </TextBlock>
                      <!-- Online-Spieler-Indikator (kleiner Punkt) -->
                      <Ellipse Width="6" Height="6"
                               Fill="#00CED1" VerticalAlignment="Center"
                               IsVisible="{Binding IsRealPlayer}"
                               Opacity="0.7" />
                    </StackPanel>

                    <!-- Punkte -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding PointsText}"
                               FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}" />

                    <!-- Report-Button (nur für andere echte Spieler, v2.0.34) -->
                    <Button Grid.Column="3"
                            Command="{Binding $parent[ItemsControl].((vm:LeagueViewModel)DataContext).ReportPlayerCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding CanReport}"
                            Background="Transparent" Padding="6,2"
                            Margin="6,0,0,0" MinHeight="44" MinWidth="44"
                            ToolTip.Tip="{loc:Translate ReportPlayer}"
                            AutomationProperties.AutomationId="League_BtnReport">
                      <icons:GameIcon Kind="AlertCircle" Width="14" Height="14"
                                       Foreground="#FF4D4D" />
                    </Button>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- ═════════════ DAILY-RACE-TAB ═════════════ -->
        <ScrollViewer Grid.Row="1" Grid.RowSpan="2"
                       VerticalScrollBarVisibility="Auto"
                       IsVisible="{Binding IsDailyRaceTabActive}">
          <StackPanel Spacing="10">

            <!-- Hero-Card: Beschreibung + Heute-Bestwert + Start-Button -->
            <Border CornerRadius="12" Padding="16,14" BoxShadow="0 2 8 0 #25000000">
              <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                  <GradientStop Color="#206F1B6F" Offset="0" />
                  <GradientStop Color="{DynamicResource SurfaceColor}" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <StackPanel Spacing="10">
                <TextBlock Text="{Binding DailyRaceTitleText}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding DailyRaceDescText}"
                           FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" />

                <!-- Heutiger Bestwert + Reset-Countdown -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Border Grid.Column="0" Background="#15FFD700" CornerRadius="8" Padding="8,6">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <icons:GameIcon Kind="Trophy" Width="16" Height="16" Foreground="{DynamicResource GoldAccentBrush}" />
                      <TextBlock Text="{Binding DailyRaceTodayBestText}"
                                 FontSize="12" FontWeight="SemiBold"
                                 Foreground="{DynamicResource GoldAccentBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="1" Background="#1500CED1" CornerRadius="8" Padding="8,6">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <icons:GameIcon Kind="ClockOutline" Width="16" Height="16" Foreground="#00CED1" />
                      <TextBlock Text="{Binding DailyRaceCountdownText}"
                                 FontSize="12" FontWeight="SemiBold"
                                 Foreground="#00CED1" VerticalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Grid>

                <!-- Start-Button -->
                <Panel MinHeight="48">
                  <controls:GameButtonCanvas ButtonColor="#7A1FA2" DamageLevel="0.4" ButtonSeed="182" />
                  <Button Classes="Primary GameButton"
                          Command="{Binding StartDailyRaceCommand}"
                          Background="Transparent" Foreground="White"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                          Padding="14,10"
                          AutomationProperties.AutomationId="League_BtnStartDailyRace">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <icons:GameIcon Kind="Bomb" Width="18" Height="18" Foreground="White" />
                      <TextBlock Text="{Binding DailyRaceStartButtonText}"
                                 FontSize="14" FontWeight="Bold"
                                 Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                </Panel>
              </StackPanel>
            </Border>

            <!-- My-Tier vs Global Cross-Tier Scope-Toggle (v2.0.42 Fix: Cross-Tier-Leaderboard) -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10" Padding="6">
              <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Classes="GameButton"
                        Command="{Binding ToggleDailyRaceScopeCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="8,6" CornerRadius="8"
                        AutomationProperties.AutomationId="DailyRace_BtnTierScope">
                  <Button.Background>
                    <SolidColorBrush Color="{DynamicResource AccentColor}"
                                      Opacity="{Binding !IsDailyRaceGlobalView, Converter={x:Static conv:BoolToOpacityConverter.Instance}}" />
                  </Button.Background>
                  <TextBlock Text="{Binding DailyRaceTierTabText}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="1" Classes="GameButton"
                        Command="{Binding ToggleDailyRaceScopeCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="8,6" CornerRadius="8"
                        AutomationProperties.AutomationId="DailyRace_BtnGlobalScope">
                  <Button.Background>
                    <SolidColorBrush Color="{DynamicResource AccentColor}"
                                      Opacity="{Binding IsDailyRaceGlobalView, Converter={x:Static conv:BoolToOpacityConverter.Instance}}" />
                  </Button.Background>
                  <TextBlock Text="{Binding DailyRaceGlobalTabText}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" />
                </Button>
              </Grid>
            </Border>

            <!-- Daily-Race-Leaderboard Header + Refresh -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10" Padding="12,8"
                    BoxShadow="0 2 8 0 #25000000">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="#"
                           FontSize="14" FontWeight="Bold" Width="40"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Grid.Column="1" Text="{Binding PlayerHeaderText}"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Grid.Column="2" Text="{Binding PointsHeaderText}"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,8,0" />
                <Panel Grid.Column="3" MinHeight="44" MinWidth="44">
                  <controls:GameButtonCanvas ButtonColor="#607D8B" DamageLevel="0.2" ButtonSeed="183" />
                  <Button Classes="Secondary GameButton"
                          Command="{Binding RefreshDailyRaceLeaderboardCommand}"
                          Width="44" Height="44" Padding="0"
                          Background="Transparent" Foreground="White"
                          HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                          AutomationProperties.AutomationId="League_BtnRefreshDailyRace">
                    <icons:GameIcon Kind="Refresh" Width="18" Height="18"
                                                Foreground="White" />
                  </Button>
                </Panel>
              </Grid>
            </Border>

            <!-- Lade-Indikator Daily Race -->
            <Border IsVisible="{Binding IsDailyRaceLeaderboardLoading}"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8" Padding="16,8" Opacity="0.9">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <icons:GameIcon Kind="CloudSync" Width="16" Height="16"
                                            Foreground="{DynamicResource AccentBrush}" />
                <TextBlock Text="{Binding LoadingLeaderboardText}" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </Border>

            <!-- Daily-Race-Leaderboard-Liste -->
            <ItemsControl ItemsSource="{Binding DailyRaceLeaderboardEntries}"
                          AutomationProperties.AutomationId="League_DailyRaceLeaderboard">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="3" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:LeagueDisplayEntry">
                  <Border CornerRadius="8" Padding="12,8"
                          BorderThickness="3,0,0,0">
                    <Border.BorderBrush>
                      <SolidColorBrush Color="{Binding NameColor}" />
                    </Border.BorderBrush>
                    <Border.Background>
                      <SolidColorBrush Color="#FFFFFF" Opacity="{Binding BackgroundOpacity}" />
                    </Border.Background>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding RankText}"
                                 FontSize="13" FontWeight="Bold" Width="40"
                                 VerticalAlignment="Center">
                        <TextBlock.Foreground>
                          <SolidColorBrush Color="{Binding NameColor}" />
                        </TextBlock.Foreground>
                      </TextBlock>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis">
                          <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding NameColor}" />
                          </TextBlock.Foreground>
                        </TextBlock>
                        <Ellipse Width="6" Height="6"
                                 Fill="#00CED1" VerticalAlignment="Center"
                                 IsVisible="{Binding IsRealPlayer}"
                                 Opacity="0.7" />
                      </StackPanel>
                      <TextBlock Grid.Column="2"
                                 Text="{Binding PointsText}"
                                 FontSize="13" FontWeight="Bold"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource AccentBrush}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Panel>

</UserControl>
