<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BomberBlast.ViewModels"
             xmlns:icons="using:BomberBlast.Icons"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:controls="using:BomberBlast.Controls"
             x:Class="BomberBlast.Views.LevelSelectView"
             x:DataType="vm:LevelSelectViewModel"
             x:CompileBindings="True">

  <!-- Animierter Menü-Hintergrund -->
  <Panel AutomationProperties.AutomationId="LevelSelect_Root">
    <controls:MenuBackgroundCanvas />

    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <Border Grid.Row="0"
              Classes="CardElevated"
              Padding="16,12"
              CornerRadius="0,0,12,12">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- Zurueck-Button -->
          <Button Classes="Text"
                  AutomationProperties.AutomationId="LevelSelect_BtnBack"
                  Command="{Binding GoBackCommand}">
            <icons:GameIcon Kind="ArrowLeft" Width="24" Height="24" />
          </Button>

          <!-- Titel + Master-Mode-Toggle (ab L100 Unlock) -->
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="8">
            <icons:GameIcon Kind="ViewGrid" Width="24" Height="24"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             IsVisible="{Binding !IsMasterModeActive}" />
            <icons:GameIcon Kind="Crown" Width="24" Height="24"
                             Foreground="#FFD700"
                             IsVisible="{Binding IsMasterModeActive}" />
            <TextBlock AutomationProperties.AutomationId="LevelSelect_TxtTitle"
                       Text="{loc:Translate SelectLevel}"
                       FontSize="22" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       IsVisible="{Binding !IsMasterModeActive}" />
            <TextBlock AutomationProperties.AutomationId="LevelSelect_TxtMasterTitle"
                       Text="{loc:Translate MasterModeTitle}"
                       FontSize="22" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="#FFD700"
                       IsVisible="{Binding IsMasterModeActive}" />
            <!-- Master-Mode-Toggle (nur sichtbar nach L100-Unlock) -->
            <Button Classes="Text"
                    Command="{Binding ToggleMasterModeCommand}"
                    IsVisible="{Binding IsMasterModeUnlocked}"
                    Padding="8,4"
                    Margin="8,0,0,0"
                    ToolTip.Tip="{loc:Translate MasterModeToggleTooltip}"
                    AutomationProperties.AutomationId="LevelSelect_BtnToggleMaster">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <icons:GameIcon Kind="SwapHorizontal" Width="14" Height="14"
                                 Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Text="{Binding MasterModeStatusText}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- Coin-Badge mit goldenem Rand -->
          <Border Grid.Column="2"
                  AutomationProperties.AutomationId="LevelSelect_CoinBadge"
                  Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="16"
                  Padding="12,6"
                  BorderThickness="1" BorderBrush="#40FFD700">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <icons:GameIcon Kind="CircleMultiple" Width="18" Height="18"
                               Foreground="#FFD700" />
              <TextBlock AutomationProperties.AutomationId="LevelSelect_TxtCoins"
                         Text="{Binding CoinsText}"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="#FFD700"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- Welt-Sektionen -->
      <ScrollViewer Grid.Row="1"
                    AutomationProperties.AutomationId="LevelSelect_Scroll"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <ItemsControl AutomationProperties.AutomationId="LevelSelect_WorldList"
                      ItemsSource="{Binding WorldGroups}" Margin="4,4,4,80">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="6" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:WorldGroup">
              <!-- Welt-Sektion -->
              <Panel>
                <!-- Content-Bereich -->
                <Border CornerRadius="10"
                        Padding="6,4,6,6"
                        Opacity="{Binding SectionOpacity}"
                        Background="{Binding HeaderBackgroundColor, Converter={StaticResource ColorToBrush}}">
                  <StackPanel Spacing="4">

                    <!-- Welt-Header mit subtiler Trennung -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,2">
                      <!-- Icon + Name -->
                      <StackPanel Grid.Column="0"
                                  Orientation="Horizontal" Spacing="8"
                                  VerticalAlignment="Center">
                        <icons:GameIcon Kind="{Binding LockIcon}"
                                         Width="20" Height="20"
                                         Foreground="{Binding HeaderTextColor, Converter={StaticResource ColorToBrush}}" />
                        <TextBlock Text="{Binding WorldLockText}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{Binding HeaderTextColor, Converter={StaticResource ColorToBrush}}" />
                      </StackPanel>

                      <!-- Sterne-Fortschritt (rechts) -->
                      <TextBlock Grid.Column="2"
                                 Text="{Binding ProgressText}"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" />
                    </Grid>

                    <!-- Level-Buttons: 10 Spalten x 1 Reihe (Landscape-optimiert) -->
                    <ItemsControl ItemsSource="{Binding Levels}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <UniformGrid Columns="10" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LevelDisplayItem">
                          <!-- Border stretcht automatisch auf volle UniformGrid-Zelle -->
                          <Border Margin="1" CornerRadius="8"
                                  Background="{Binding BackgroundColor, Converter={StaticResource ColorToBrush}}"
                                  BorderBrush="#40FFFFFF"
                                  BorderThickness="1"
                                  MinHeight="56"
                                  MinWidth="48">
                            <Panel>
                              <Button Command="{Binding SelectCommand}"
                                      Classes="GameButton"
                                      Padding="0"
                                      Background="Transparent"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch">
                                <Grid RowDefinitions="*,Auto,Auto">
                                  <!-- Level-Nummer (größer für bessere Lesbarkeit) -->
                                  <TextBlock Grid.Row="0"
                                             Text="{Binding LevelNumber}"
                                             FontSize="20"
                                             FontWeight="Bold"
                                             Foreground="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />

                                  <!-- Sterne oder Schloss -->
                                  <TextBlock Grid.Row="1"
                                             Text="{Binding StarsDisplay}"
                                             FontSize="10"
                                             Foreground="Gold"
                                             HorizontalAlignment="Center"
                                             IsVisible="{Binding IsCompleted}" />

                                  <icons:GameIcon Grid.Row="1"
                                                   Kind="Lock"
                                                   Width="12" Height="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"
                                                   IsVisible="{Binding IsLocked}" />

                                  <!-- Best Score (klein, unter den Sternen) -->
                                  <TextBlock Grid.Row="2"
                                             Text="{Binding BestScoreText}"
                                             FontSize="10"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             HorizontalAlignment="Center"
                                             Margin="0,0,0,1"
                                             IsVisible="{Binding IsCompleted}" />
                                </Grid>
                              </Button>
                              <!-- Master-Crown-Badge oben rechts (v2.0.35) — wenn dieses Level
                                   im Master-Modus geclear wurde, unabhängig vom aktiven Toggle -->
                              <icons:GameIcon Kind="Crown"
                                               Width="11" Height="11"
                                               Foreground="#FFD700"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Top"
                                               Margin="0,2,2,0"
                                               IsHitTestVisible="False"
                                               IsVisible="{Binding HasMasterClear}" />
                            </Panel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                  </StackPanel>
                </Border>

                <!-- Lock-Overlay (nur fuer gesperrte Welten) -->
                <Border IsVisible="{Binding IsLocked}"
                        Background="#60000000"
                        CornerRadius="12"
                        IsHitTestVisible="False">
                  <StackPanel HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Spacing="4">
                    <icons:GameIcon Kind="Lock" Width="28" Height="28"
                                     Foreground="#888888" />
                    <TextBlock Text="{Binding WorldLockText}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#FFD700"
                               HorizontalAlignment="Center" />
                    <!-- Welt-Gate-Hint (v2.0.36): Empfehlung welches Level zu wiederholen ist -->
                    <TextBlock Text="{Binding WorldLockHint}"
                               IsVisible="{Binding HasLockHint}"
                               FontSize="12"
                               Foreground="#CCCCCC"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Panel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Footer: Fortschritt -->
      <Border Grid.Row="2"
              AutomationProperties.AutomationId="LevelSelect_Footer"
              Background="{DynamicResource SurfaceBrush}"
              CornerRadius="12,12,0,0"
              BoxShadow="0 -2 8 0 #25000000"
              Padding="12,8">
        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <TextBlock AutomationProperties.AutomationId="LevelSelect_TxtProgress"
                     Text="{Binding ProgressText}"
                     FontSize="13"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock AutomationProperties.AutomationId="LevelSelect_TxtStars"
                     Text="{Binding StarsText}"
                     FontSize="13"
                     Foreground="{DynamicResource AccentBrush}" />
        </StackPanel>
      </Border>

    </Grid>

    <!-- Power-Up Boost Overlay -->
    <Border AutomationProperties.AutomationId="LevelSelect_BoostOverlay"
            IsVisible="{Binding ShowBoostOverlay}"
            Background="#CC000000"
            ZIndex="50">
      <Border Background="{DynamicResource CardBrush}"
              CornerRadius="16"
              Padding="24"
              MaxWidth="340"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="16" HorizontalAlignment="Center">
          <TextBlock AutomationProperties.AutomationId="LevelSelect_TxtBoostTitle"
                     Text="{Binding BoostTitleText}"
                     FontSize="22" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     HorizontalAlignment="Center" />

          <Border Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="30"
                  Width="60" Height="60"
                  HorizontalAlignment="Center">
            <icons:GameIcon Kind="{Binding BoostPowerUpIcon}"
                             Width="32" Height="32"
                             Foreground="{DynamicResource AccentBrush}" />
          </Border>

          <TextBlock AutomationProperties.AutomationId="LevelSelect_TxtBoostPowerUp"
                     Text="{Binding BoostPowerUpName}"
                     FontSize="18" FontWeight="SemiBold"
                     Foreground="{DynamicResource AccentBrush}"
                     HorizontalAlignment="Center" />

          <TextBlock AutomationProperties.AutomationId="LevelSelect_TxtBoostDesc"
                     Text="{Binding BoostDescText}"
                     FontSize="14"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap"
                     TextAlignment="Center" />

          <StackPanel Spacing="8">
            <Panel MinHeight="48">
              <controls:GameButtonCanvas ButtonColor="#00BCD4" DamageLevel="0.5" ButtonSeed="120" />
              <Button Classes="Filled GameButton"
                      AutomationProperties.AutomationId="LevelSelect_BtnAcceptBoost"
                      Command="{Binding AcceptBoostCommand}"
                      Background="Transparent"
                      Foreground="White"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Padding="16,12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <icons:GameIcon Kind="Flash" Width="20" Height="20"
                                   Foreground="White" />
                  <TextBlock Text="{Binding BoostAcceptText}"
                             FontSize="15" FontWeight="SemiBold"
                             Foreground="White" />
                </StackPanel>
              </Button>
            </Panel>

            <Button Classes="Text"
                    AutomationProperties.AutomationId="LevelSelect_BtnDeclineBoost"
                    Command="{Binding DeclineBoostCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="12,10">
              <TextBlock Text="{Binding BoostDeclineText}"
                         FontSize="14"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

  </Panel>

</UserControl>
