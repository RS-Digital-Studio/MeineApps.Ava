<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BomberBlast.ViewModels"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:conv="using:BomberBlast.Converters"
             xmlns:controls="using:MeineApps.UI.Controls"
             xmlns:components="using:BomberBlast.Views.Components"
             x:Class="BomberBlast.Views.MainView"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <!-- PageView: Default unsichtbar, mit Fade-Transition. v2.0.37: Active-Class wird per Binding +
         ActiveViewEqualsConverter gesetzt (kein Code-Behind FindControl mehr). -->
    <Style Selector="Border.PageView">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="IsVisible" Value="False" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.PageView.Active">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <!-- Audit M21: Tab-Header Hover-Affordance fuer inactive Tabs (Settings/Help/Shop/Spin/Achievements/...). -->
    <Style Selector="Button.TabHeaderInactive:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#22FFFFFF" />
    </Style>
    <Style Selector="Button.TabHeaderInactive:pointerover">
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </UserControl.Styles>

  <Panel>
  <Grid AutomationProperties.AutomationId="MainView_Root">
    <!-- Alle Page-Views — Audit M18: Hit-Test deaktiviert wenn modaler Dialog offen
         (verhindert dass Taps durch das Overlay auf die darunterliegende View durchgehen). -->
    <Panel IsHitTestVisible="{Binding !IsAnyDialogOpen}">
      <!-- Main Menu -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=MainMenu}"
              AutomationProperties.AutomationId="MainView_PageMainMenu">
        <ContentControl Content="{Binding MenuVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Game -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=Game}"
              AutomationProperties.AutomationId="MainView_PageGame">
        <ContentControl Content="{Binding GameVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Level Select -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=LevelSelect}"
              AutomationProperties.AutomationId="MainView_PageLevelSelect">
        <ContentControl Content="{Binding LevelSelectVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Einstellungen + Hilfe (kombiniert mit Tab-Bar) -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=Settings}"
              AutomationProperties.AutomationId="MainView_PageSettings">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="#CC0D0D1A" Padding="60,4,60,2">
            <Grid ColumnDefinitions="*,*" MinHeight="44">
              <Panel Grid.Column="0">
                <Border IsVisible="{Binding !IsSettingsHelpTab}" Background="{DynamicResource PrimaryBrush}" CornerRadius="6">
                  <TextBlock Text="{loc:Translate Settings}" FontSize="12" FontWeight="SemiBold"
                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Button IsVisible="{Binding IsSettingsHelpTab}" Command="{Binding SwitchToSettingsTabCommand}"
                        Classes="TabHeaderInactive" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,4" MinHeight="44">
                  <TextBlock Text="{loc:Translate Settings}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
              </Panel>
              <Panel Grid.Column="1">
                <Border IsVisible="{Binding IsSettingsHelpTab}" Background="{DynamicResource PrimaryBrush}" CornerRadius="6">
                  <TextBlock Text="{loc:Translate Help}" FontSize="12" FontWeight="SemiBold"
                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Button IsVisible="{Binding !IsSettingsHelpTab}" Command="{Binding SwitchToHelpTabCommand}"
                        Classes="TabHeaderInactive" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,4" MinHeight="44">
                  <TextBlock Text="{loc:Translate Help}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
              </Panel>
            </Grid>
          </Border>
          <Panel Grid.Row="1">
            <Border IsVisible="{Binding !IsSettingsHelpTab}">
              <ContentControl Content="{Binding SettingsVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
            </Border>
            <Border IsVisible="{Binding IsSettingsHelpTab}">
              <ContentControl Content="{Binding HelpVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
            </Border>
          </Panel>
        </Grid>
      </Border>

      <!-- High Scores -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=HighScores}"
              AutomationProperties.AutomationId="MainView_PageHighScores">
        <ContentControl Content="{Binding HighScoresVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Game Over -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=GameOver}"
              AutomationProperties.AutomationId="MainView_PageGameOver">
        <ContentControl Content="{Binding GameOverVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Shop + Glücksrad (kombiniert mit Tab-Bar) -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=Shop}"
              AutomationProperties.AutomationId="MainView_PageShop">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="#CC0D0D1A" Padding="60,4,60,2">
            <Grid ColumnDefinitions="*,*" MinHeight="44">
              <Panel Grid.Column="0">
                <Border IsVisible="{Binding !IsShopSpinTab}" Background="{DynamicResource PrimaryBrush}" CornerRadius="6">
                  <TextBlock Text="{loc:Translate ShopTitle}" FontSize="12" FontWeight="SemiBold"
                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Button IsVisible="{Binding IsShopSpinTab}" Command="{Binding SwitchToShopTabCommand}"
                        Classes="TabHeaderInactive" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,4" MinHeight="44">
                  <TextBlock Text="{loc:Translate ShopTitle}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
              </Panel>
              <Panel Grid.Column="1">
                <Border IsVisible="{Binding IsShopSpinTab}" Background="{DynamicResource PrimaryBrush}" CornerRadius="6">
                  <TextBlock Text="{loc:Translate LuckySpinTitle}" FontSize="12" FontWeight="SemiBold"
                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Button IsVisible="{Binding !IsShopSpinTab}" Command="{Binding SwitchToSpinTabCommand}"
                        Classes="TabHeaderInactive" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,4" MinHeight="44">
                  <TextBlock Text="{loc:Translate LuckySpinTitle}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
              </Panel>
            </Grid>
          </Border>
          <Panel Grid.Row="1">
            <Border IsVisible="{Binding !IsShopSpinTab}">
              <ContentControl Content="{Binding ShopVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
            </Border>
            <Border IsVisible="{Binding IsShopSpinTab}">
              <ContentControl Content="{Binding LuckySpinVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
            </Border>
          </Panel>
        </Grid>
      </Border>

      <!-- Profile-Hub (v2.0.43): 5 Tabs intern in ProfileView (Übersicht/Statistik/Achievements/Sammlung/Customize) -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=Profile}"
              AutomationProperties.AutomationId="MainView_PageProfile">
        <ContentControl Content="{Binding ProfileVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Victory (alle 50 Level geschafft) -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=Victory}"
              AutomationProperties.AutomationId="MainView_PageVictory">
        <ContentControl Content="{Binding VictoryVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Herausforderungen: Daily Challenge + Missionen (kombiniert mit Tab-Bar) -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=Challenges}"
              AutomationProperties.AutomationId="MainView_PageChallenges">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="#CC0D0D1A" Padding="60,4,60,2">
            <Grid ColumnDefinitions="*,*" MinHeight="44">
              <Panel Grid.Column="0">
                <Border IsVisible="{Binding !IsChallengesMissionsTab}" Background="{DynamicResource PrimaryBrush}" CornerRadius="6">
                  <TextBlock Text="{loc:Translate DailyChallengeTitle}" FontSize="12" FontWeight="SemiBold"
                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Button IsVisible="{Binding IsChallengesMissionsTab}" Command="{Binding SwitchToDailyChallengeTabCommand}"
                        Classes="TabHeaderInactive" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,4" MinHeight="44">
                  <TextBlock Text="{loc:Translate DailyChallengeTitle}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
              </Panel>
              <Panel Grid.Column="1">
                <Border IsVisible="{Binding IsChallengesMissionsTab}" Background="{DynamicResource PrimaryBrush}" CornerRadius="6">
                  <TextBlock Text="{loc:Translate MissionsButton}" FontSize="12" FontWeight="SemiBold"
                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Button IsVisible="{Binding !IsChallengesMissionsTab}" Command="{Binding SwitchToMissionsTabCommand}"
                        Classes="TabHeaderInactive" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,4" MinHeight="44">
                  <TextBlock Text="{loc:Translate MissionsButton}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
              </Panel>
            </Grid>
          </Border>
          <Panel Grid.Row="1">
            <Border IsVisible="{Binding !IsChallengesMissionsTab}">
              <ContentControl Content="{Binding DailyChallengeVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
            </Border>
            <Border IsVisible="{Binding IsChallengesMissionsTab}">
              <ContentControl Content="{Binding WeeklyChallengeVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
            </Border>
          </Panel>
        </Grid>
      </Border>

      <!-- Quick Play (Zufalls-Level) -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=QuickPlay}"
              AutomationProperties.AutomationId="MainView_PageQuickPlay">
        <ContentControl Content="{Binding QuickPlayVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Karten/Deck (v2.0.43): Sammlung wandert in den Profile-Hub, Cards-Bereich zeigt nur noch Deck -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=Cards}"
              AutomationProperties.AutomationId="MainView_PageCards">
        <ContentControl Content="{Binding DeckVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Dungeon Run (Roguelike-Modus) -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=Dungeon}"
              AutomationProperties.AutomationId="MainView_PageDungeon">
        <ContentControl Content="{Binding DungeonVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Battle Pass -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=BattlePass}"
              AutomationProperties.AutomationId="MainView_PageBattlePass">
        <ContentControl Content="{Binding BattlePassVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Liga -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=League}"
              AutomationProperties.AutomationId="MainView_PageLeague">
        <ContentControl Content="{Binding LeagueVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Gem-Shop -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=GemShop}"
              AutomationProperties.AutomationId="MainView_PageGemShop">
        <ContentControl Content="{Binding GemShopVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Boss-Rush (v2.0.42, Plan Task 3.3) -->
      <Border Classes="PageView"
              Classes.Active="{Binding ActiveView, Converter={x:Static conv:ActiveViewEqualsConverter.Instance}, ConverterParameter=BossRush}"
              AutomationProperties.AutomationId="MainView_PageBossRush">
        <ContentControl Content="{Binding BossRushVm}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>
    </Panel>

    <!-- Kein Ad-Banner in BomberBlast (Landscape-Spiel, nur Rewarded Ads) -->

    <!-- Dialog-Overlays + Game Juice: über beide Rows gespannt -->
    <!-- Alert Dialog Overlay -->
    <Border IsVisible="{Binding IsAlertDialogVisible}"
            AutomationProperties.AutomationId="MainView_AlertOverlay"
            Background="#80000000" ZIndex="100"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="16" Padding="24" MaxWidth="360"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              BoxShadow="0 8 24 0 #40000000">
        <StackPanel Spacing="16">
          <TextBlock Text="{Binding AlertDialogTitle}"
                     AutomationProperties.AutomationId="MainView_AlertTitle"
                     Classes="TitleMedium"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="{Binding AlertDialogMessage}"
                     AutomationProperties.AutomationId="MainView_AlertMessage"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <Button Classes="Primary" HorizontalAlignment="Right"
                  AutomationProperties.AutomationId="MainView_BtnAlertDismiss"
                  Content="{Binding AlertDialogButtonText}"
                  Command="{Binding DismissAlertCommand}" />
        </StackPanel>
      </Border>
    </Border>

    <!-- Confirm Dialog Overlay -->
    <Border IsVisible="{Binding IsConfirmDialogVisible}"
            AutomationProperties.AutomationId="MainView_ConfirmOverlay"
            Background="#80000000" ZIndex="100"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="16" Padding="24" MaxWidth="360"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              BoxShadow="0 8 24 0 #40000000">
        <StackPanel Spacing="16">
          <TextBlock Text="{Binding ConfirmDialogTitle}"
                     AutomationProperties.AutomationId="MainView_ConfirmTitle"
                     Classes="TitleMedium"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="{Binding ConfirmDialogMessage}"
                     AutomationProperties.AutomationId="MainView_ConfirmMessage"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="Secondary"
                    AutomationProperties.AutomationId="MainView_BtnConfirmCancel"
                    Content="{Binding ConfirmDialogCancelText}"
                    Command="{Binding CancelConfirmCommand}" />
            <Button Classes="Danger"
                    AutomationProperties.AutomationId="MainView_BtnConfirmAccept"
                    Content="{Binding ConfirmDialogAcceptText}"
                    Command="{Binding AcceptConfirmCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- Game Juice Overlays -->
    <controls:FloatingTextOverlay x:Name="FloatingTextCanvas"
                                   AutomationProperties.AutomationId="MainView_FloatingText"
                                   ZIndex="15"
                                   IsHitTestVisible="False" />
    <controls:SkiaCelebrationOverlay x:Name="CelebrationCanvas"
                                      AutomationProperties.AutomationId="MainView_Celebration"
                                      ZIndex="16"
                                      IsHitTestVisible="False" />

    <!-- Sprint 3.1 AAA-Audit #4: Bottom-Tab-Bar — wird angezeigt im MainMenu-Modus.
         Konsolidiert 15+ Navigations-Punkte auf 4 Tabs (Home/Play/Shop/Profile).
         Die existierenden Page-Views bleiben — BottomTabBar dient zukünftig
         als zentrale Navigation, MainMenuView-Refactor folgt in eigenem Sprint. -->
    <components:BottomTabBar IsVisible="{Binding IsMainMenuActive}"
                              VerticalAlignment="Bottom"
                              ZIndex="14"
                              AutomationProperties.AutomationId="MainView_BottomTabBar" />
  </Grid>

  <!-- Ladebildschirm (Shader-Preloading) -->
  <controls:SplashOverlay x:Name="Splash"
                           AppName="BomberBlast"
                           IconSource="avares://BomberBlast.Shared/Assets/icon.png" />
  </Panel>

</UserControl>
