{
  "rules": {
    ".read": false,
    ".write": false,

    "league": {
      "$seasonKey": {
        "$tier": {
          ".indexOn": ["points"],
          ".read": "auth != null",

          "$uid": {
            ".write": "auth != null && $uid === auth.uid && newData.exists() && (!data.exists() || !data.child('updatedMs').exists() || (now - data.child('updatedMs').val()) >= 60000)",

            ".validate": "newData.hasChildren(['name', 'points', 'updatedUtc', 'updatedMs'])",

            "name": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16"
            },

            "points": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 500000 && (!data.exists() || newData.val() <= data.val() + 2000)"
            },

            "updatedUtc": {
              ".validate": "newData.isString() && newData.val().length >= 20 && newData.val().length <= 40 && newData.val().endsWith('Z') && (!data.exists() || newData.val() > data.val())"
            },

            "updatedMs": {
              ".validate": "newData.val() == now && (!data.exists() || newData.val() > data.val())"
            },

            "$other": {
              ".validate": false
            }
          }
        }
      }
    }
  }
}
