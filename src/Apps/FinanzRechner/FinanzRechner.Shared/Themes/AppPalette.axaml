<Styles xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- FinanzRechner - "Living Finance"                                       -->
  <!-- Seriöses Dunkelblau mit Smaragdgrün (Geld/Wachstum)                   -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->

  <Style>
    <Style.Resources>
      <!-- Primary Colors -->
      <Color x:Key="PrimaryColor">#10B981</Color>
      <Color x:Key="PrimaryHoverColor">#34D399</Color>
      <Color x:Key="PrimaryPressedColor">#059669</Color>
      <Color x:Key="PrimaryContrastColor">#FFFFFF</Color>

      <!-- Secondary Colors -->
      <Color x:Key="SecondaryColor">#6366F1</Color>
      <Color x:Key="SecondaryHoverColor">#818CF8</Color>
      <Color x:Key="SecondaryPressedColor">#4F46E5</Color>

      <!-- Accent Colors -->
      <Color x:Key="AccentColor">#F59E0B</Color>
      <Color x:Key="AccentHoverColor">#FBBF24</Color>

      <!-- Feature Accent Colors -->
      <Color x:Key="TimerAccentColor">#F59E0B</Color>
      <Color x:Key="StopwatchAccentColor">#22D3EE</Color>
      <Color x:Key="AlarmAccentColor">#A78BFA</Color>
      <Color x:Key="PomodoroAccentColor">#EF4444</Color>

      <!-- Background Colors -->
      <Color x:Key="BackgroundColor">#182030</Color>
      <Color x:Key="SurfaceColor">#222E3E</Color>
      <Color x:Key="CardColor">#2E3E50</Color>
      <Color x:Key="CardHoverColor">#3A4D62</Color>

      <!-- Text Colors -->
      <Color x:Key="TextPrimaryColor">#F0F4F8</Color>
      <Color x:Key="TextSecondaryColor">#B0C0D0</Color>
      <Color x:Key="TextMutedColor">#8898AA</Color>
      <Color x:Key="TextDisabledColor">#64748B</Color>

      <!-- Border Colors -->
      <Color x:Key="BorderColor">#405570</Color>
      <Color x:Key="BorderSubtleColor">#2E3E50</Color>
      <Color x:Key="BorderFocusColor">#10B981</Color>

      <!-- Semantic Colors -->
      <Color x:Key="SuccessColor">#22C55E</Color>
      <Color x:Key="SuccessBackgroundColor">#14532D</Color>
      <Color x:Key="WarningColor">#F59E0B</Color>
      <Color x:Key="WarningBackgroundColor">#78350F</Color>
      <Color x:Key="ErrorColor">#EF4444</Color>
      <Color x:Key="ErrorBackgroundColor">#7F1D1D</Color>
      <Color x:Key="InfoColor">#3B82F6</Color>
      <Color x:Key="InfoBackgroundColor">#1E3A8A</Color>

      <!-- Shadow / Overlay -->
      <Color x:Key="ShadowColor">#000000</Color>
      <Color x:Key="OverlayColor">#80000000</Color>
      <Color x:Key="RippleColor">#20FFFFFF</Color>

      <!-- Gradient -->
      <Color x:Key="GradientStartColor">#222E3E</Color>
      <Color x:Key="GradientMidColor">#182030</Color>
      <Color x:Key="GradientEndColor">#0D2818</Color>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- BRUSHES                                                        -->
      <!-- ═══════════════════════════════════════════════════════════════ -->

      <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
      <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{DynamicResource PrimaryHoverColor}" />
      <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{DynamicResource PrimaryPressedColor}" />
      <SolidColorBrush x:Key="PrimaryContrastBrush" Color="{DynamicResource PrimaryContrastColor}" />

      <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource SecondaryColor}" />
      <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />

      <SolidColorBrush x:Key="TimerAccentBrush" Color="{DynamicResource TimerAccentColor}" />
      <SolidColorBrush x:Key="StopwatchAccentBrush" Color="{DynamicResource StopwatchAccentColor}" />
      <SolidColorBrush x:Key="AlarmAccentBrush" Color="{DynamicResource AlarmAccentColor}" />
      <SolidColorBrush x:Key="PomodoroAccentBrush" Color="{DynamicResource PomodoroAccentColor}" />

      <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
      <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
      <SolidColorBrush x:Key="CardBrush" Color="{DynamicResource CardColor}" />
      <SolidColorBrush x:Key="CardHoverBrush" Color="{DynamicResource CardHoverColor}" />

      <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
      <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMutedColor}" />
      <SolidColorBrush x:Key="TextDisabledBrush" Color="{DynamicResource TextDisabledColor}" />

      <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="{DynamicResource BorderSubtleColor}" />
      <SolidColorBrush x:Key="BorderFocusBrush" Color="{DynamicResource BorderFocusColor}" />

      <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
      <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="{DynamicResource SuccessBackgroundColor}" />
      <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
      <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{DynamicResource WarningBackgroundColor}" />
      <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}" />
      <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{DynamicResource ErrorBackgroundColor}" />
      <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}" />
      <SolidColorBrush x:Key="InfoBackgroundBrush" Color="{DynamicResource InfoBackgroundColor}" />

      <SolidColorBrush x:Key="OverlayBrush" Color="{DynamicResource OverlayColor}" />
      <SolidColorBrush x:Key="RippleBrush" Color="{DynamicResource RippleColor}" />

      <!-- Box Shadows -->
      <BoxShadows x:Key="CardShadow">0 1 3 0 #1A000000, 0 1 2 0 #26000000</BoxShadows>
      <BoxShadows x:Key="CardShadowHover">0 4 6 -1 #1A000000, 0 2 4 -1 #26000000</BoxShadows>
      <BoxShadows x:Key="ElevatedShadow">0 10 15 -3 #1A000000, 0 4 6 -2 #26000000</BoxShadows>
      <BoxShadows x:Key="ModalShadow">0 20 25 -5 #1A000000, 0 10 10 -5 #26000000</BoxShadows>

      <!-- Calculator-spezifische Ressourcen (für Kompatibilität) -->
      <LinearGradientBrush x:Key="EqualsGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#10B981" Offset="0" />
        <GradientStop Color="#34D399" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="DisplayGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#222E3E" Offset="0" />
        <GradientStop Color="#182030" Offset="1" />
      </LinearGradientBrush>
      <BoxShadows x:Key="OperatorGlowShadow">0 0 12 2 #4010B981</BoxShadows>
      <SolidColorBrush x:Key="DigitButtonBrush" Color="#15FFFFFF" />
      <SolidColorBrush x:Key="DigitButtonHoverBrush" Color="#25FFFFFF" />

      <!-- Theme Identifier -->
      <x:String x:Key="ThemeName">FinanzRechner</x:String>
      <x:Boolean x:Key="IsDarkTheme">True</x:Boolean>
    </Style.Resources>
  </Style>

</Styles>
