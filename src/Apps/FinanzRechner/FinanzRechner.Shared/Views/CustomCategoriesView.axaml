<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FinanzRechner.ViewModels"
             xmlns:models="using:FinanzRechner.Models"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:uiBehaviors="using:MeineApps.UI.Behaviors"
             x:Class="FinanzRechner.Views.CustomCategoriesView"
             x:DataType="vm:CustomCategoriesViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="16,12">
            <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                    Classes="icon" Padding="8"
                    RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                <i:Interaction.Behaviors>
                    <uiBehaviors:TapScaleBehavior PressedScale="0.88" />
                </i:Interaction.Behaviors>
                <materialIcons:MaterialIcon Kind="ArrowLeft" Width="24" Height="24" />
            </Button>
            <TextBlock Grid.Column="1" Text="{Binding TitleText}"
                       FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="12,0,0,0" />
            <Button Grid.Column="2" Command="{Binding OpenAddDialogCommand}"
                    Classes="icon" Padding="8"
                    RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                <i:Interaction.Behaviors>
                    <uiBehaviors:TapScaleBehavior PressedScale="0.92" />
                </i:Interaction.Behaviors>
                <materialIcons:MaterialIcon Kind="Plus" Width="24" Height="24" />
            </Button>
        </Grid>

        <!-- Inhalt -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Margin="16,0,16,80">
                <i:Interaction.Behaviors>
                    <uiBehaviors:FadeInBehavior Duration="250" SlideFromBottom="True" SlideDistance="12" />
                </i:Interaction.Behaviors>

                <!-- Ausgaben-Kategorien -->
                <StackPanel Spacing="8" IsVisible="{Binding HasCategories}">
                    <TextBlock Text="{Binding ExpenseCategoriesText}"
                               FontSize="14" FontWeight="SemiBold" Opacity="0.7"
                               Margin="0,4,0,0" />
                    <ItemsControl ItemsSource="{Binding ExpenseCategories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="0">
                                    <i:Interaction.Behaviors>
                                        <uiBehaviors:StaggerFadeInBehavior StaggerDelay="40" BaseDuration="300" />
                                    </i:Interaction.Behaviors>
                                </StackPanel>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:CustomCategory">
                                <Panel Margin="0,0,0,6">
                                    <Border Background="{DynamicResource CardBrush}"
                                            CornerRadius="10" Padding="14"
                                            BoxShadow="0 1 4 0 #10000000"
                                            RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                                        <i:Interaction.Behaviors>
                                            <uiBehaviors:TapScaleBehavior PressedScale="0.97" />
                                        </i:Interaction.Behaviors>
                                        <Border.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuItem Header="{Binding $parent[UserControl].((vm:CustomCategoriesViewModel)DataContext).EditText}"
                                                          Command="{Binding $parent[UserControl].((vm:CustomCategoriesViewModel)DataContext).EditCategoryCommand}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Icon>
                                                        <materialIcons:MaterialIcon Kind="Pencil" Width="18" Height="18" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding $parent[UserControl].((vm:CustomCategoriesViewModel)DataContext).DeleteText}"
                                                          Command="{Binding $parent[UserControl].((vm:CustomCategoriesViewModel)DataContext).DeleteCategoryCommand}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Icon>
                                                        <materialIcons:MaterialIcon Kind="Delete" Width="18" Height="18" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </MenuFlyout>
                                        </Border.ContextFlyout>
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                       FontSize="22" VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ColorHex}"
                                                       FontSize="11" Opacity="0.4"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Einnahmen-Kategorien -->
                <StackPanel Spacing="8" IsVisible="{Binding HasCategories}">
                    <TextBlock Text="{Binding IncomeCategoriesText}"
                               FontSize="14" FontWeight="SemiBold" Opacity="0.7"
                               Margin="0,4,0,0" />
                    <ItemsControl ItemsSource="{Binding IncomeCategories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="0">
                                    <i:Interaction.Behaviors>
                                        <uiBehaviors:StaggerFadeInBehavior StaggerDelay="40" BaseDuration="300" />
                                    </i:Interaction.Behaviors>
                                </StackPanel>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:CustomCategory">
                                <Panel Margin="0,0,0,6">
                                    <Border Background="{DynamicResource CardBrush}"
                                            CornerRadius="10" Padding="14"
                                            BoxShadow="0 1 4 0 #10000000"
                                            RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                                        <i:Interaction.Behaviors>
                                            <uiBehaviors:TapScaleBehavior PressedScale="0.97" />
                                        </i:Interaction.Behaviors>
                                        <Border.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuItem Header="{Binding $parent[UserControl].((vm:CustomCategoriesViewModel)DataContext).EditText}"
                                                          Command="{Binding $parent[UserControl].((vm:CustomCategoriesViewModel)DataContext).EditCategoryCommand}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Icon>
                                                        <materialIcons:MaterialIcon Kind="Pencil" Width="18" Height="18" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding $parent[UserControl].((vm:CustomCategoriesViewModel)DataContext).DeleteText}"
                                                          Command="{Binding $parent[UserControl].((vm:CustomCategoriesViewModel)DataContext).DeleteCategoryCommand}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Icon>
                                                        <materialIcons:MaterialIcon Kind="Delete" Width="18" Height="18" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </MenuFlyout>
                                        </Border.ContextFlyout>
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                       FontSize="22" VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ColorHex}"
                                                       FontSize="11" Opacity="0.4"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Leerer Zustand -->
                <StackPanel IsVisible="{Binding !HasCategories}"
                            HorizontalAlignment="Center" Spacing="8" Margin="0,40"
                            Classes="EmptyPulse">
                    <materialIcons:MaterialIcon Kind="TagPlusOutline" Width="48" Height="48"
                                                 Opacity="0.3" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding EmptyText}"
                               Opacity="0.5" HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Add/Edit Dialog Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding ShowAddDialog}"
                Background="#80000000" Classes="DialogOverlay">
            <Border Background="{DynamicResource CardBrush}"
                    CornerRadius="20" Padding="24" Margin="20"
                    MaxWidth="400" VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    BoxShadow="0 8 32 0 #40000000">
                <StackPanel Spacing="16">
                    <TextBlock Text="{Binding AddCategoryText}" FontSize="20" FontWeight="Bold" />
                    <TextBox Text="{Binding EditName}" Watermark="{Binding CategoryNameText}" />
                    <ComboBox SelectedIndex="{Binding EditTypeIndex}" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="{Binding ExpenseCategoriesText}" />
                        <ComboBoxItem Content="{Binding IncomeCategoriesText}" />
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding IconLabelText}" FontSize="13" Opacity="0.7"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding EditIcon}" FontSize="28"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0" Content="{Binding CancelText}"
                                Command="{Binding CancelDialogCommand}"
                                HorizontalAlignment="Stretch"
                                RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                            <i:Interaction.Behaviors>
                                <uiBehaviors:TapScaleBehavior PressedScale="0.95" />
                            </i:Interaction.Behaviors>
                        </Button>
                        <Button Grid.Column="1" Content="{Binding SaveText}"
                                Command="{Binding SaveCategoryCommand}"
                                Classes="Primary" HorizontalAlignment="Stretch"
                                RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                            <i:Interaction.Behaviors>
                                <uiBehaviors:TapScaleBehavior PressedScale="0.95" />
                            </i:Interaction.Behaviors>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
