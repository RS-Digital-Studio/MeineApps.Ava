<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FinanzRechner.ViewModels"
             xmlns:models="using:FinanzRechner.Models"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:conv="using:FinanzRechner.Converters"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:uiBehaviors="using:MeineApps.UI.Behaviors"
             x:Class="FinanzRechner.Views.SavingsGoalsView"
             x:DataType="vm:SavingsGoalsViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="16,12">
            <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                    Classes="icon" Padding="8"
                    RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                <i:Interaction.Behaviors>
                    <uiBehaviors:TapScaleBehavior PressedScale="0.88" />
                </i:Interaction.Behaviors>
                <materialIcons:MaterialIcon Kind="ArrowLeft" Width="24" Height="24" />
            </Button>
            <TextBlock Grid.Column="1" Text="{Binding TitleText}"
                       FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="12,0,0,0" />
            <Button Grid.Column="2" Command="{Binding OpenAddDialogCommand}"
                    Classes="icon" Padding="8"
                    RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                <i:Interaction.Behaviors>
                    <uiBehaviors:TapScaleBehavior PressedScale="0.92" />
                </i:Interaction.Behaviors>
                <materialIcons:MaterialIcon Kind="Plus" Width="24" Height="24" />
            </Button>
        </Grid>

        <!-- Inhalt -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="16,0,16,80">
                <i:Interaction.Behaviors>
                    <uiBehaviors:FadeInBehavior Duration="250" SlideFromBottom="True" SlideDistance="12" />
                </i:Interaction.Behaviors>

                <!-- Gesamt gespart -->
                <Border Background="{DynamicResource CardBrush}"
                        CornerRadius="16" Padding="20"
                        BoxShadow="0 2 8 0 #20000000">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding TotalSavedDisplay}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding TotalSavedLabelText}"
                                   FontSize="13" Opacity="0.6"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Sparziele -->
                <ItemsControl ItemsSource="{Binding Goals}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="0">
                                <i:Interaction.Behaviors>
                                    <uiBehaviors:StaggerFadeInBehavior StaggerDelay="50" BaseDuration="300" />
                                </i:Interaction.Behaviors>
                            </StackPanel>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:SavingsGoal">
                            <Panel Margin="0,0,0,8">
                                <Border Background="{DynamicResource CardBrush}"
                                        CornerRadius="12" Padding="16"
                                        BoxShadow="0 1 4 0 #10000000"
                                        Opacity="{Binding IsCompleted, Converter={x:Static conv:BoolToDoubleConverter.Instance}, ConverterParameter='0.6,1'}"
                                        RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                                    <i:Interaction.Behaviors>
                                        <uiBehaviors:TapScaleBehavior PressedScale="0.97" />
                                    </i:Interaction.Behaviors>
                                    <Border.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="{Binding $parent[UserControl].((vm:SavingsGoalsViewModel)DataContext).AdjustAmountText}"
                                                      Command="{Binding $parent[UserControl].((vm:SavingsGoalsViewModel)DataContext).OpenAdjustDialogCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialIcons:MaterialIcon Kind="CashPlus" Width="18" Height="18" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding $parent[UserControl].((vm:SavingsGoalsViewModel)DataContext).EditText}"
                                                      Command="{Binding $parent[UserControl].((vm:SavingsGoalsViewModel)DataContext).EditGoalCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialIcons:MaterialIcon Kind="Pencil" Width="18" Height="18" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding $parent[UserControl].((vm:SavingsGoalsViewModel)DataContext).DeleteText}"
                                                      Command="{Binding $parent[UserControl].((vm:SavingsGoalsViewModel)DataContext).DeleteGoalCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialIcons:MaterialIcon Kind="Delete" Width="18" Height="18" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </MenuFlyout>
                                    </Border.ContextFlyout>
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                       FontSize="24" VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="16" FontWeight="SemiBold" />
                                                <TextBlock FontSize="12" Opacity="0.6">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} / {1}">
                                                            <Binding Path="CurrentDisplay" />
                                                            <Binding Path="TargetDisplay" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding ProgressDisplay}"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                        <ProgressBar Value="{Binding ProgressPercent}"
                                                     Maximum="100" Height="8"
                                                     CornerRadius="4"
                                                     Foreground="{DynamicResource PrimaryBrush}" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" FontSize="12" Opacity="0.5"
                                                       Text="{Binding RemainingDisplay}" />
                                            <!-- Einzahlen-Button -->
                                            <Button Grid.Column="1"
                                                    Command="{Binding $parent[UserControl].((vm:SavingsGoalsViewModel)DataContext).OpenAdjustDialogCommand}"
                                                    CommandParameter="{Binding}"
                                                    Classes="icon" Padding="4"
                                                    IsVisible="{Binding !IsCompleted}"
                                                    RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                                                <i:Interaction.Behaviors>
                                                    <uiBehaviors:TapScaleBehavior PressedScale="0.88" />
                                                </i:Interaction.Behaviors>
                                                <materialIcons:MaterialIcon Kind="CashPlus" Width="20" Height="20"
                                                                             Foreground="{DynamicResource PrimaryBrush}" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Leerer Zustand -->
                <StackPanel IsVisible="{Binding !HasGoals}"
                            HorizontalAlignment="Center" Spacing="8" Margin="0,40"
                            Classes="EmptyPulse">
                    <materialIcons:MaterialIcon Kind="FlagOutline" Width="48" Height="48"
                                                 Opacity="0.3" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding EmptyText}"
                               Opacity="0.5" HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Add/Edit Dialog Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding ShowAddDialog}"
                Background="#80000000" Classes="DialogOverlay">
            <Border Background="{DynamicResource CardBrush}"
                    CornerRadius="20" Padding="24" Margin="20"
                    MaxWidth="400" VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    BoxShadow="0 8 32 0 #40000000">
                <StackPanel Spacing="16">
                    <TextBlock Text="{Binding AddGoalText}" FontSize="20" FontWeight="Bold" />
                    <TextBox Text="{Binding EditName}" Watermark="{Binding GoalNameHintText}" />
                    <TextBox Text="{Binding EditTargetAmount}" Watermark="{Binding TargetAmountText}" />
                    <TextBox Text="{Binding EditCurrentAmount}" Watermark="{Binding AlreadySavedText}" />
                    <CalendarDatePicker SelectedDate="{Binding EditDeadline}"
                                        Watermark="{Binding DeadlineOptionalText}"
                                        HorizontalAlignment="Stretch" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0" Content="{Binding CancelText}"
                                Command="{Binding CancelDialogCommand}"
                                HorizontalAlignment="Stretch"
                                RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                            <i:Interaction.Behaviors>
                                <uiBehaviors:TapScaleBehavior PressedScale="0.95" />
                            </i:Interaction.Behaviors>
                        </Button>
                        <Button Grid.Column="1" Content="{Binding SaveText}"
                                Command="{Binding SaveGoalCommand}"
                                Classes="Primary" HorizontalAlignment="Stretch"
                                RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                            <i:Interaction.Behaviors>
                                <uiBehaviors:TapScaleBehavior PressedScale="0.95" />
                            </i:Interaction.Behaviors>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Adjust Dialog Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding ShowAdjustDialog}"
                Background="#80000000" Classes="DialogOverlay">
            <Border Background="{DynamicResource CardBrush}"
                    CornerRadius="20" Padding="24" Margin="20"
                    MaxWidth="400" VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    BoxShadow="0 8 32 0 #40000000">
                <StackPanel Spacing="16">
                    <TextBlock Text="{Binding AdjustAmountText}" FontSize="20" FontWeight="Bold" />
                    <TextBox Text="{Binding AdjustAmount}" Watermark="{Binding AmountText}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <RadioButton Content="{Binding DepositText}" IsChecked="{Binding AdjustIsDeposit}" />
                        <RadioButton Content="{Binding WithdrawalText}" IsChecked="{Binding !AdjustIsDeposit}" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0" Content="{Binding CancelText}"
                                Command="{Binding CancelDialogCommand}"
                                HorizontalAlignment="Stretch"
                                RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                            <i:Interaction.Behaviors>
                                <uiBehaviors:TapScaleBehavior PressedScale="0.95" />
                            </i:Interaction.Behaviors>
                        </Button>
                        <Button Grid.Column="1" Content="{Binding ConfirmText}"
                                Command="{Binding ConfirmAdjustCommand}"
                                Classes="Primary" HorizontalAlignment="Stretch"
                                RenderTransform="scale(1)" RenderTransformOrigin="50%,50%">
                            <i:Interaction.Behaviors>
                                <uiBehaviors:TapScaleBehavior PressedScale="0.95" />
                            </i:Interaction.Behaviors>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
