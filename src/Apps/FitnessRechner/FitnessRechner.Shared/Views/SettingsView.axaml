<UserControl xmlns="https://github.com/avaloniaui"
     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     xmlns:vm="using:FitnessRechner.ViewModels"
     xmlns:mi="using:Material.Icons.Avalonia"
     xmlns:loc="using:MeineApps.Core.Ava.Localization"
     x:Class="FitnessRechner.Views.SettingsView"
     x:DataType="vm:SettingsViewModel"
     x:CompileBindings="True"
     Background="Transparent">

  <!-- Medical-Styling: MedicalBackground scheint durch das transparente UserControl -->
  <UserControl.Styles>
    <!-- SettingsCard-Override: Medical Surface mit Cyan-Rand -->
    <Style Selector="Border.SettingsCard">
      <Setter Property="Background" Value="#D91E3844" />
      <Setter Property="BorderBrush" Value="#1A06B6D4" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer AutomationProperties.AutomationId="Settings_ScrollViewer" VerticalScrollBarVisibility="Auto">
    <StackPanel AutomationProperties.AutomationId="Settings_RootPanel" Spacing="12" Margin="16">

      <!-- Header -->
      <TextBlock AutomationProperties.AutomationId="Settings_TxtTitle" Text="{loc:Translate SettingsTitle}"
                 FontSize="22" FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 Margin="0,4,0,4" />

      <!-- ==================== Language Selection Card ==================== -->
      <Border AutomationProperties.AutomationId="Settings_CardLanguage" Classes="SettingsCard">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <!-- Medical Cyan-Akzent fuer Section-Header-Icon -->
            <mi:MaterialIcon Kind="Translate" Width="24" Height="24"
                             Foreground="#06B6D4" />
            <TextBlock Text="{loc:Translate SettingsLanguage}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <WrapPanel Orientation="Horizontal">
            <!-- Deutsch -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangDe" Classes="Primary Small" Content="Deutsch"
                      IsVisible="{Binding IsGermanSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="de"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangDeOff" Classes="Outlined Small" Content="Deutsch"
                      IsVisible="{Binding !IsGermanSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="de"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- English -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangEn" Classes="Primary Small" Content="English"
                      IsVisible="{Binding IsEnglishSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="en"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangEnOff" Classes="Outlined Small" Content="English"
                      IsVisible="{Binding !IsEnglishSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="en"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Espanol -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangEs" Classes="Primary Small" Content="Espa&#241;ol"
                      IsVisible="{Binding IsSpanishSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="es"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangEsOff" Classes="Outlined Small" Content="Espa&#241;ol"
                      IsVisible="{Binding !IsSpanishSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="es"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Francais -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangFr" Classes="Primary Small" Content="Fran&#231;ais"
                      IsVisible="{Binding IsFrenchSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="fr"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangFrOff" Classes="Outlined Small" Content="Fran&#231;ais"
                      IsVisible="{Binding !IsFrenchSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="fr"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Italiano -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangIt" Classes="Primary Small" Content="Italiano"
                      IsVisible="{Binding IsItalianSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="it"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangItOff" Classes="Outlined Small" Content="Italiano"
                      IsVisible="{Binding !IsItalianSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="it"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Portugues -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangPt" Classes="Primary Small" Content="Portugu&#234;s"
                      IsVisible="{Binding IsPortugueseSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="pt"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangPtOff" Classes="Outlined Small" Content="Portugu&#234;s"
                      IsVisible="{Binding !IsPortugueseSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="pt"
                      Margin="0,0,8,8" />
            </Panel>
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- ==================== Premium Section ==================== -->
      <Border AutomationProperties.AutomationId="Settings_CardPremium" Classes="SettingsCard"
              IsVisible="{Binding IsNotPremium}">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <!-- Crown-Icon in Gold/Cyan-Akzent fuer Premium-Bereich -->
            <mi:MaterialIcon Kind="Crown" Width="24" Height="24"
                             Foreground="#06B6D4" />
            <TextBlock Text="{loc:Translate Premium}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <!-- Premium-Beschreibung in TextMuted -->
          <TextBlock AutomationProperties.AutomationId="Settings_TxtPremiumDesc" Text="{loc:Translate PremiumDescription}"
                     FontSize="14"
                     Foreground="#64748B"
                     TextWrapping="Wrap" />

          <Button AutomationProperties.AutomationId="Settings_BtnPurchase" Content="{loc:Translate PurchasePremium}"
                  Command="{Binding PurchasePremiumCommand}"
                  Classes="Primary"
                  CornerRadius="8" />

          <Button AutomationProperties.AutomationId="Settings_BtnRestore" Content="{loc:Translate RestorePurchases}"
                  Command="{Binding RestorePurchasesCommand}"
                  Classes="Secondary"
                  CornerRadius="8" />
        </StackPanel>
      </Border>

      <!-- ==================== Feedback & Notifications Section ==================== -->
      <Border AutomationProperties.AutomationId="Settings_CardNotifications" Classes="SettingsCard">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <!-- Medical Cyan-Akzent fuer Section-Header-Icon -->
            <mi:MaterialIcon Kind="BellOutline" Width="24" Height="24"
                             Foreground="#06B6D4" />
            <TextBlock Text="{loc:Translate SettingsNotifications}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Haptic Feedback Toggle -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <mi:MaterialIcon Grid.Column="0" Kind="Vibrate" Width="20" Height="20"
                             Foreground="#64748B"
                             VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Grid.Column="1" Text="{loc:Translate HapticFeedback}"
                       FontSize="14" Foreground="#E2E8F0"
                       VerticalAlignment="Center" />
            <ToggleSwitch AutomationProperties.AutomationId="Settings_ToggleHaptic" Grid.Column="2" IsChecked="{Binding IsHapticEnabled}"
                          OnContent="" OffContent=""
                          VerticalAlignment="Center" />
          </Grid>

          <!-- Sound Toggle -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <mi:MaterialIcon Grid.Column="0" Kind="VolumeHigh" Width="20" Height="20"
                             Foreground="#64748B"
                             VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Grid.Column="1" Text="{loc:Translate SoundEffects}"
                       FontSize="14" Foreground="#E2E8F0"
                       VerticalAlignment="Center" />
            <ToggleSwitch AutomationProperties.AutomationId="Settings_ToggleSound" Grid.Column="2" IsChecked="{Binding IsSoundEnabled}"
                          OnContent="" OffContent=""
                          VerticalAlignment="Center" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,4" />

          <!-- Wasser-Erinnerung Toggle -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <mi:MaterialIcon Grid.Column="0" Kind="WaterOutline" Width="20" Height="20"
                             Foreground="#64748B"
                             VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Grid.Column="1" Text="{loc:Translate WaterReminder}"
                       FontSize="14" Foreground="#E2E8F0"
                       VerticalAlignment="Center" />
            <ToggleSwitch AutomationProperties.AutomationId="Settings_ToggleWaterReminder" Grid.Column="2" IsChecked="{Binding IsWaterReminderEnabled}"
                          OnContent="" OffContent=""
                          VerticalAlignment="Center" />
          </Grid>

          <!-- Gewicht-Erinnerung Toggle -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <mi:MaterialIcon Grid.Column="0" Kind="ScaleBathroom" Width="20" Height="20"
                             Foreground="#64748B"
                             VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Grid.Column="1" Text="{loc:Translate WeightReminder}"
                       FontSize="14" Foreground="#E2E8F0"
                       VerticalAlignment="Center" />
            <ToggleSwitch AutomationProperties.AutomationId="Settings_ToggleWeightReminder" Grid.Column="2" IsChecked="{Binding IsWeightReminderEnabled}"
                          OnContent="" OffContent=""
                          VerticalAlignment="Center" />
          </Grid>

          <!-- Abend-Zusammenfassung Toggle -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <mi:MaterialIcon Grid.Column="0" Kind="WeatherNight" Width="20" Height="20"
                             Foreground="#64748B"
                             VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Grid.Column="1" Text="{loc:Translate EveningReminder}"
                       FontSize="14" Foreground="#E2E8F0"
                       VerticalAlignment="Center" />
            <ToggleSwitch AutomationProperties.AutomationId="Settings_ToggleEveningReminder" Grid.Column="2" IsChecked="{Binding IsEveningSummaryEnabled}"
                          OnContent="" OffContent=""
                          VerticalAlignment="Center" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- ==================== About Section ==================== -->
      <Border AutomationProperties.AutomationId="Settings_CardAbout" Classes="SettingsCard">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <!-- Medical Cyan-Akzent fuer Section-Header-Icon -->
            <mi:MaterialIcon Kind="InformationOutline" Width="24" Height="24"
                             Foreground="#06B6D4" />
            <TextBlock Text="{loc:Translate SettingsAboutApp}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock Text="FitnessRechner" FontSize="16" FontWeight="Bold"
                     Foreground="#E2E8F0" />
          <!-- Versions-Info in TextMuted -->
          <TextBlock AutomationProperties.AutomationId="Settings_TxtVersion" Text="{Binding AppVersion}"
                     FontSize="14"
                     Foreground="#64748B" />

          <Button AutomationProperties.AutomationId="Settings_BtnFeedback" Content="{loc:Translate FeedbackButton}"
                  Command="{Binding SendFeedbackCommand}"
                  Classes="Outlined"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  CornerRadius="8" />

          <Button AutomationProperties.AutomationId="Settings_BtnPrivacyPolicy"
                  Command="{Binding OpenPrivacyPolicyCommand}"
                  Classes="Text"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="ShieldCheck" Width="20" Height="20" />
              <TextBlock Text="{loc:Translate PrivacyPolicy}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <!-- Bottom Spacer (80dp fuer Ad-Banner Overlay, konsistent mit allen Views) -->
      <Border Height="80" />

    </StackPanel>
  </ScrollViewer>

</UserControl>
