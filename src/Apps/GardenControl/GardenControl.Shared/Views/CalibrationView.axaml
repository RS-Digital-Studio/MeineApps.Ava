<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GardenControl.Shared.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="GardenControl.Shared.Views.CalibrationView"
             x:DataType="vm:CalibrationViewModel"
             Loaded="OnLoaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Margin="16,12">

            <TextBlock Text="Sensor-Kalibrierung" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- Anleitung -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="16" BorderBrush="#15FFFFFF" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="40" Height="40" CornerRadius="20" Background="#201E88E5">
                        <mi:MaterialIcon Kind="InformationOutline" Width="22" Height="22"
                                         Foreground="{DynamicResource WaterLightBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Text="Stecke den Sensor in trockene Erde und drücke 'Trocken'. Dann in nasse Erde und drücke 'Nass'. Die Prozentwerte werden aus diesen Referenzwerten berechnet." />
                </StackPanel>
            </Border>

            <!-- Nicht verbunden Hinweis (wenn keine Zonen geladen) -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="32" BorderBrush="#15FFFFFF" BorderThickness="1"
                    IsVisible="{Binding !Items.Count}"
                    HorizontalAlignment="Stretch">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32" Background="#15FFFFFF"
                            HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="ServerNetworkOff" Width="32" Height="32"
                                         Foreground="{DynamicResource TextMutedBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Keine Verbindung zum Server" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock TextWrapping="Wrap" FontSize="13" TextAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center">
                        <Run Text="Starte den GardenControl-Server auf dem Raspberry Pi" />
                        <LineBreak />
                        <Run Text="und verbinde dich über Einstellungen." />
                    </TextBlock>
                    <TextBlock Text="Die Zonen und Sensorwerte werden dann hier angezeigt."
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Zonen-Kalibrierung -->
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CalibrationItem">
                        <Border Background="{DynamicResource CardGradientBrush}"
                                CornerRadius="{DynamicResource CardRadius}"
                                Padding="16" Margin="0,4"
                                BorderBrush="#15FFFFFF" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <!-- Zone-Header -->
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="36" Height="36" CornerRadius="18" Background="#20FFFFFF">
                                        <mi:MaterialIcon Kind="Flower" Width="20" Height="20"
                                                         Foreground="{DynamicResource PrimaryLightBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Live-Werte (groß, prominent) -->
                                <Border Background="#10FFFFFF" CornerRadius="12" Padding="16,12">
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="AKTUELLER ADC-WERT" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding CurrentRawValue}" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center" FontFamily="Consolas" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="FEUCHTIGKEIT" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryLightBrush}"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:F1}%">
                                                        <Binding Path="CurrentMoisturePercent" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Kalibrierungswerte (3 Spalten) -->
                                <Grid ColumnDefinitions="*,*,*">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="TROCKEN-WERT" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding DryValue}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="NASS-WERT" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding WetValue}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WaterLightBrush}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="KALIBRIERT AM" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding CalibratedAt}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <!-- Kalibrierungs-Buttons (Premium-Gradient) -->
                                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                                    <Button Grid.Column="0" Padding="14,10" Margin="0,0,4,0"
                                            CornerRadius="{DynamicResource ButtonRadius}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].((vm:CalibrationViewModel)DataContext).CalibrateDryCommand}"
                                            CommandParameter="{Binding ZoneId}">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#795548" Offset="0" />
                                                <GradientStop Color="#A1887F" Offset="1" />
                                            </LinearGradientBrush>
                                        </Button.Background>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <mi:MaterialIcon Kind="WeatherSunny" Width="20" Height="20"
                                                             Foreground="White" />
                                            <TextBlock Text="Trocken kalibrieren" FontWeight="SemiBold"
                                                       Foreground="White" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Padding="14,10" Margin="4,0,0,0"
                                            CornerRadius="{DynamicResource ButtonRadius}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].((vm:CalibrationViewModel)DataContext).CalibrateWetCommand}"
                                            CommandParameter="{Binding ZoneId}">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#1565C0" Offset="0" />
                                                <GradientStop Color="#42A5F5" Offset="1" />
                                            </LinearGradientBrush>
                                        </Button.Background>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <mi:MaterialIcon Kind="Water" Width="20" Height="20"
                                                             Foreground="White" />
                                            <TextBlock Text="Nass kalibrieren" FontWeight="SemiBold"
                                                       Foreground="White" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Status-Nachricht -->
            <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                       Foreground="{DynamicResource PrimaryLightBrush}"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Margin="0,4,0,0" />

            <Border Height="60" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
