<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GardenControl.Shared.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:views="using:GardenControl.Shared.Views"
             xmlns:controls="using:GardenControl.Shared.Controls"
             x:Class="GardenControl.Shared.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Margin="16,12">

            <!-- ═══ System-Status + Wetter ═══ -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="20" BorderBrush="#20FFFFFF" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <!-- Modus -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="BETRIEBSMODUS" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="2" />
                            <TextBlock Text="{Binding SystemMode}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryLightBrush}" />
                        </StackPanel>

                        <!-- Pumpe -->
                        <Border Grid.Column="1" CornerRadius="12" Padding="12,8" Margin="12,0"
                                Background="{Binding IsPumpActive, Converter={x:Static views:DashboardView.PumpBgConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="WaterPump" Width="20" Height="20" Foreground="White" />
                                <TextBlock Text="{Binding IsPumpActive, Converter={x:Static views:DashboardView.PumpTextConverter}}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="White"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Uptime -->
                        <StackPanel Grid.Column="2" Margin="12,0" VerticalAlignment="Center">
                            <TextBlock Text="LAUFZEIT" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1" />
                            <TextBlock Text="{Binding UptimeText}" FontSize="13" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>

                        <!-- NOTSTOPP -->
                        <Button Grid.Column="3" Command="{Binding EmergencyStopCommand}"
                                Background="{DynamicResource DangerGradientBrush}"
                                Foreground="White" Padding="16,10"
                                CornerRadius="{DynamicResource ButtonRadius}"
                                VerticalAlignment="Center" MinHeight="46">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="AlertOctagon" Width="20" Height="20" />
                                <TextBlock Text="STOPP" FontWeight="Bold" FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Wetter-Leiste (wenn verfügbar) -->
                    <Border Grid.Row="1" Margin="0,12,0,0" Padding="12,8" CornerRadius="10"
                            Background="#10FFFFFF"
                            IsVisible="{Binding HasWeatherData}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="WeatherPartlyCloudy" Width="22" Height="22"
                                                 Foreground="{DynamicResource WaterLightBrush}" />
                                <TextBlock Text="{Binding WeatherDescription}" FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0}°C | {1}% Luft">
                                            <Binding Path="Temperature" />
                                            <Binding Path="Humidity" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <!-- Wetter-Warnung -->
                            <Border Grid.Column="2" CornerRadius="8" Padding="8,4"
                                    Background="{Binding WeatherPaused, Converter={x:Static views:DashboardView.PauseBgConverter}}"
                                    IsVisible="{Binding WeatherPaused}">
                                <TextBlock Text="{Binding WeatherPauseReason}" FontSize="11"
                                           FontWeight="SemiBold" Foreground="White" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ Modus-Umschalter ═══ -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="12" BorderBrush="#10FFFFFF" BorderThickness="1">
                <Grid ColumnDefinitions="*,*,*">
                    <Button Grid.Column="0" Command="{Binding SetModeCommand}" CommandParameter="Off"
                            HorizontalAlignment="Stretch" Margin="2" Padding="0,10"
                            CornerRadius="{DynamicResource ButtonRadius}"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="PowerOff" Width="18" Height="18" />
                            <TextBlock Text="Aus" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Command="{Binding SetModeCommand}" CommandParameter="Manual"
                            HorizontalAlignment="Stretch" Margin="2" Padding="0,10"
                            CornerRadius="{DynamicResource ButtonRadius}"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="HandBackRight" Width="18" Height="18" />
                            <TextBlock Text="Manuell" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Command="{Binding SetModeCommand}" CommandParameter="Automatic"
                            HorizontalAlignment="Stretch" Margin="2" Padding="0,10"
                            Background="{DynamicResource PrimaryGradientBrush}"
                            CornerRadius="{DynamicResource ButtonRadius}"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="AutoFix" Width="18" Height="18" />
                            <TextBlock Text="Automatik" VerticalAlignment="Center" FontWeight="SemiBold"
                                       Foreground="White" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Nicht verbunden -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="32" BorderBrush="#15FFFFFF" BorderThickness="1"
                    IsVisible="{Binding !Zones.Count}">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <Border Width="72" Height="72" CornerRadius="36" Background="#15FFFFFF"
                            HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="Sprinkler" Width="36" Height="36"
                                         Foreground="{DynamicResource TextMutedBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Warte auf Verbindung..." FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock TextWrapping="Wrap" FontSize="13" TextAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}">
                        <Run Text="Starte den Server auf dem Raspberry Pi" />
                        <LineBreak />
                        <Run Text="oder prüfe die Verbindung in den Einstellungen." />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ═══ Zonen mit Gauges ═══ -->
            <ItemsControl ItemsSource="{Binding Zones}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ZoneDisplayItem">
                        <Border Background="{DynamicResource CardGradientBrush}"
                                CornerRadius="{DynamicResource CardRadius}"
                                Padding="16" Margin="0,4"
                                BorderBrush="#15FFFFFF" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*">

                                <!-- Links: Gauge -->
                                <controls:MoistureGaugeControl
                                    Width="140" Height="140"
                                    MoisturePercent="{Binding MoisturePercent}"
                                    ThresholdPercent="{Binding ThresholdPercent}"
                                    ZoneName="{Binding Name}"
                                    IsWatering="{Binding IsWatering}"
                                    StatusText="{Binding StateText}" />

                                <!-- Rechts: Details + Aktionen -->
                                <StackPanel Grid.Column="1" Margin="16,0,0,0"
                                            VerticalAlignment="Center" Spacing="8">

                                    <!-- Name + Status -->
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding StateText}" FontSize="12"
                                                   Foreground="{Binding StateColor, Converter={x:Static views:DashboardView.StringToBrush}}" />
                                    </StackPanel>

                                    <!-- Feuchtigkeitsbalken -->
                                    <Grid Height="10">
                                        <Border CornerRadius="5" Background="#15FFFFFF" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding MoisturePercent, Converter={x:Static views:DashboardView.MoistureToGridLength}}" />
                                                <ColumnDefinition Width="{Binding MoisturePercent, Converter={x:Static views:DashboardView.MoistureToRestGridLength}}" />
                                            </Grid.ColumnDefinitions>
                                            <Border CornerRadius="5"
                                                    Background="{Binding MoistureColor, Converter={x:Static views:DashboardView.StringToBrush}}" />
                                        </Grid>
                                    </Grid>

                                    <!-- Info-Zeile -->
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel>
                                            <TextBlock Text="SCHWELLE" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1" />
                                            <TextBlock Text="{Binding ThresholdPercent, StringFormat='{}{0}%'}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WarningBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="ZULETZT" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1" />
                                            <TextBlock Text="{Binding LastWatered}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Aktions-Buttons -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).QuickWaterCommand}"
                                                CommandParameter="{Binding ZoneId}"
                                                Background="{DynamicResource WaterGradientBrush}"
                                                Foreground="White" Padding="14,6"
                                                CornerRadius="{DynamicResource SmallRadius}"
                                                IsVisible="{Binding !IsWatering}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="WaterOutline" Width="16" Height="16" />
                                                <TextBlock Text="Gießen" FontSize="12" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).StopWateringCommand}"
                                                CommandParameter="{Binding ZoneId}"
                                                Background="{DynamicResource DangerGradientBrush}"
                                                Foreground="White" Padding="14,6"
                                                CornerRadius="{DynamicResource SmallRadius}"
                                                IsVisible="{Binding IsWatering}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="Stop" Width="16" Height="16" />
                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                           Text="{Binding RemainingSeconds, StringFormat='Stopp ({0}s)'}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Height="60" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
