<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GardenControl.Shared.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:models="using:GardenControl.Core.Models"
             xmlns:controls="using:GardenControl.Shared.Controls"
             x:Class="GardenControl.Shared.Views.HistoryView"
             x:DataType="vm:HistoryViewModel"
             Loaded="OnLoaded">

    <Grid RowDefinitions="Auto,*">

        <!-- Filter-Leiste -->
        <Border Background="{DynamicResource CardGradientBrush}" Padding="16,12"
                CornerRadius="0,0,12,12" BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1">
            <StackPanel Spacing="8">
                <TextBlock Text="Verlauf und Statistiken" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />

                <!-- Zeitraum-Filter -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="1h" Command="{Binding SetPeriodCommand}" CommandParameter="1h"
                            Padding="12,6" CornerRadius="{DynamicResource SmallRadius}" />
                    <Button Content="6h" Command="{Binding SetPeriodCommand}" CommandParameter="6h"
                            Padding="12,6" CornerRadius="{DynamicResource SmallRadius}" />
                    <Button Content="24h" Command="{Binding SetPeriodCommand}" CommandParameter="24h"
                            Padding="12,6" CornerRadius="{DynamicResource SmallRadius}"
                            Background="{DynamicResource PrimaryBrush}" />
                    <Button Content="7 Tage" Command="{Binding SetPeriodCommand}" CommandParameter="7d"
                            Padding="12,6" CornerRadius="{DynamicResource SmallRadius}" />
                    <Button Content="30 Tage" Command="{Binding SetPeriodCommand}" CommandParameter="30d"
                            Padding="12,6" CornerRadius="{DynamicResource SmallRadius}" />
                </StackPanel>

                <!-- Zonen-Filter -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Zone:" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                    <Button Content="Alle" Command="{Binding FilterZoneCommand}" CommandParameter=""
                            Padding="10,4" CornerRadius="6" />
                    <Button Content="1" Command="{Binding FilterZoneCommand}" CommandParameter="1"
                            Padding="10,4" CornerRadius="6" />
                    <Button Content="2" Command="{Binding FilterZoneCommand}" CommandParameter="2"
                            Padding="10,4" CornerRadius="6" />
                    <Button Content="3" Command="{Binding FilterZoneCommand}" CommandParameter="3"
                            Padding="10,4" CornerRadius="6" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Hauptbereich -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14" Margin="16,12">

                <!-- ═══ Feuchtigkeitsverlauf-Chart (SkiaSharp) ═══ -->
                <Border Background="{DynamicResource CardGradientBrush}"
                        CornerRadius="{DynamicResource CardRadius}"
                        BorderBrush="#15FFFFFF" BorderThickness="1"
                        IsVisible="{Binding ChartDataPoints, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <controls:MoistureChartControl
                        Height="220"
                        DataPoints="{Binding ChartDataPoints}"
                        ThresholdPercent="{Binding ChartThreshold}"
                        Title="{Binding ChartTitle}"
                        Margin="4" />
                </Border>

                <!-- ═══ Statistiken ═══ -->
                <Border Background="{DynamicResource CardGradientBrush}"
                        CornerRadius="{DynamicResource CardRadius}"
                        Padding="16" BorderBrush="#15FFFFFF" BorderThickness="1">
                    <Grid ColumnDefinitions="*,*,*,*">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="BEWÄSSERUNGEN" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalWateringCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource WaterLightBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="GESAMTDAUER" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalWateringDurationFormatted}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryLightBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="FEUCHT. BEI START" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                       HorizontalAlignment="Center" />
                            <TextBlock FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource WarningBrush}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0}%">
                                        <Binding Path="AvgMoistureAtStart" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="MESSWERTE" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ReadingCount}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ Bewässerungsereignisse ═══ -->
                <TextBlock Text="Bewässerungsereignisse" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />

                <ItemsControl ItemsSource="{Binding Events}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:IrrigationEvent">
                            <Border Background="{DynamicResource CardGradientBrush}"
                                    CornerRadius="{DynamicResource SmallRadius}"
                                    Padding="14" Margin="0,3" BorderBrush="#10FFFFFF" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Wasser-Icon -->
                                    <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,12,0"
                                            Background="#201E88E5">
                                        <mi:MaterialIcon Kind="Water" Width="20" Height="20"
                                                         Foreground="{DynamicResource WaterLightBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <!-- Details -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="Zone {0} | {1}">
                                                    <Binding Path="ZoneId" />
                                                    <Binding Path="Trigger" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F0}% → {1:F0}% | {2}s Dauer">
                                                    <Binding Path="MoistureAtStart" />
                                                    <Binding Path="MoistureAtEnd" />
                                                    <Binding Path="ActualDurationSeconds" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <!-- Zeitstempel -->
                                    <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Text="{Binding StartedAtUtc, StringFormat='{}{0:dd.MM HH:mm}'}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Leere Liste -->
                <TextBlock Text="Keine Ereignisse im gewählten Zeitraum"
                           IsVisible="{Binding !Events.Count}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,20" />

                <Border Height="60" />
            </StackPanel>
        </ScrollViewer>

        <!-- Loading-Overlay -->
        <Border Grid.Row="1" Background="#80000000" IsVisible="{Binding IsLoading}"
                CornerRadius="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <mi:MaterialIcon Kind="Loading" Width="36" Height="36"
                                 Foreground="{DynamicResource PrimaryLightBrush}" />
                <TextBlock Text="Daten werden geladen..." Foreground="White" FontSize="14" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
