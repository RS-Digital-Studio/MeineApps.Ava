<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GardenControl.Shared.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="GardenControl.Shared.Views.ScheduleView"
             x:DataType="vm:ScheduleViewModel"
             Loaded="OnLoaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Margin="16,12">

            <TextBlock Text="Automatik-Einstellungen" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- ═══ Nicht verbunden ═══ -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="32" BorderBrush="#15FFFFFF" BorderThickness="1"
                    IsVisible="{Binding !HasData}">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32" Background="#15FFFFFF"
                            HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="CalendarClock" Width="32" Height="32"
                                         Foreground="{DynamicResource TextMutedBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Keine Verbindung zum Server" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Verbinde dich zuerst über die Einstellungen." FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ═══ Betriebsmodus ═══ -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="16" BorderBrush="#15FFFFFF" BorderThickness="1"
                    IsVisible="{Binding HasData}">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="ToggleSwitch" Width="20" Height="20"
                                         Foreground="{DynamicResource PrimaryLightBrush}" />
                        <TextBlock Text="BETRIEBSMODUS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="2"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*,*">
                        <Button Grid.Column="0" Command="{Binding SetModeCommand}" CommandParameter="Off"
                                HorizontalAlignment="Stretch" Margin="0,0,4,0" Padding="0,10"
                                CornerRadius="{DynamicResource ButtonRadius}"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <mi:MaterialIcon Kind="PowerOff" Width="18" Height="18" />
                                <TextBlock Text="Aus" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Command="{Binding SetModeCommand}" CommandParameter="Manual"
                                HorizontalAlignment="Stretch" Margin="2,0" Padding="0,10"
                                CornerRadius="{DynamicResource ButtonRadius}"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <mi:MaterialIcon Kind="HandBackRight" Width="18" Height="18" />
                                <TextBlock Text="Manuell" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding SetModeCommand}" CommandParameter="Automatic"
                                HorizontalAlignment="Stretch" Margin="4,0,0,0" Padding="0,10"
                                Background="{DynamicResource PrimaryGradientBrush}"
                                CornerRadius="{DynamicResource ButtonRadius}"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <mi:MaterialIcon Kind="AutoFix" Width="18" Height="18" />
                                <TextBlock Text="Automatik" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Foreground="White" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding CurrentMode, StringFormat='Aktueller Modus: {0}'}"
                               FontSize="12" Foreground="{DynamicResource PrimaryLightBrush}" />
                </StackPanel>
            </Border>

            <!-- ═══ Abfrageintervall ═══ -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="16" BorderBrush="#15FFFFFF" BorderThickness="1"
                    IsVisible="{Binding HasData}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="TimerOutline" Width="20" Height="20"
                                             Foreground="{DynamicResource WaterLightBrush}" />
                            <TextBlock Text="SENSOR-ABFRAGEINTERVALL" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="2"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumericUpDown Value="{Binding PollIntervalSeconds}"
                                           Minimum="5" Maximum="3600" Increment="5"
                                           Width="120" />
                            <TextBlock Text="Sekunden" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding SavePollIntervalCommand}"
                            Padding="14,10" CornerRadius="{DynamicResource ButtonRadius}"
                            Background="{DynamicResource PrimaryGradientBrush}"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="ContentSave" Width="18" Height="18" Foreground="White" />
                            <TextBlock Text="Speichern" FontWeight="SemiBold" Foreground="White" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ Zonen-Konfiguration ═══ -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0"
                        IsVisible="{Binding HasData}">
                <mi:MaterialIcon Kind="Flower" Width="20" Height="20"
                                 Foreground="{DynamicResource PrimaryLightBrush}" />
                <TextBlock Text="Zonen-Konfiguration" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <ItemsControl ItemsSource="{Binding ZoneConfigs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ZoneConfigItem">
                        <Border Background="{DynamicResource CardGradientBrush}"
                                CornerRadius="{DynamicResource CardRadius}"
                                Padding="16" Margin="0,4"
                                BorderBrush="#15FFFFFF" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <!-- Header: Name + Toggle -->
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border Width="36" Height="36" CornerRadius="18" Background="#20FFFFFF"
                                            Margin="0,0,10,0">
                                        <mi:MaterialIcon Kind="Flower" Width="20" Height="20"
                                                         Foreground="{DynamicResource PrimaryLightBrush}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBox Grid.Column="1" Text="{Binding Name}" FontSize="16"
                                             FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                                  OnContent="Aktiv" OffContent="Aus" />
                                </Grid>

                                <!-- Einstellungen Grid -->
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Margin="0,4">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SCHWELLENWERT" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1" />
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <NumericUpDown Value="{Binding ThresholdPercent}"
                                                           Minimum="5" Maximum="95" Increment="5" Width="100" />
                                            <TextBlock Text="%" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       FontWeight="Bold" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                                        <TextBlock Text="BEWÄSSERUNGSDAUER" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1" />
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <NumericUpDown Value="{Binding WateringDurationSeconds}"
                                                           Minimum="5" Maximum="3600" Increment="5" Width="100" />
                                            <TextBlock Text="Sek" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Spacing="4" Margin="0,8,0,0">
                                        <TextBlock Text="ABKÜHLZEIT" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1" />
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <NumericUpDown Value="{Binding CooldownSeconds}"
                                                           Minimum="60" Maximum="7200" Increment="60" Width="100" />
                                            <TextBlock Text="Sek" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="8,8,0,0">
                                        <TextBlock Text="SENSOR-KANAL" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1" />
                                        <TextBlock Text="{Binding SensorChannel, StringFormat='ADS1115 Kanal A{0}'}"
                                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>

                                <!-- Speichern -->
                                <Button HorizontalAlignment="Right"
                                        Command="{Binding $parent[ItemsControl].((vm:ScheduleViewModel)DataContext).SaveZoneConfigCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="14,8" CornerRadius="{DynamicResource ButtonRadius}"
                                        Background="{DynamicResource PrimaryGradientBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16" Foreground="White" />
                                        <TextBlock Text="Speichern" FontWeight="SemiBold" Foreground="White" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                       Foreground="{DynamicResource PrimaryLightBrush}"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <Border Height="60" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
