<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GardenControl.Shared.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:views="using:GardenControl.Shared.Views"
             x:Class="GardenControl.Shared.Views.ZoneControlView"
             x:DataType="vm:ZoneControlViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Margin="16,12">

            <TextBlock Text="Manuelle Steuerung" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- NOTSTOPP -->
            <Button Command="{Binding EmergencyStopCommand}"
                    Background="{DynamicResource DangerGradientBrush}" Foreground="White"
                    Padding="16,14" CornerRadius="{DynamicResource ButtonRadius}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="AlertOctagon" Width="24" Height="24" />
                    <TextBlock Text="NOTSTOPP - Alles sofort aus" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Pumpen-Status -->
            <Border Background="{DynamicResource CardGradientBrush}" CornerRadius="{DynamicResource CardRadius}"
                    Padding="16" BorderBrush="#15FFFFFF" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="44" Height="44" CornerRadius="22"
                            Background="{Binding IsPumpActive, Converter={x:Static views:DashboardView.PumpBgConverter}}">
                        <mi:MaterialIcon Kind="WaterPump" Width="24" Height="24" Foreground="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Wasserpumpe" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding IsPumpActive, Converter={x:Static views:DashboardView.PumpTextConverter}}"
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Bewässerungsdauer-Auswahl -->
            <Border Background="{DynamicResource CardGradientBrush}" CornerRadius="{DynamicResource CardRadius}"
                    Padding="16" BorderBrush="#15FFFFFF" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="BEWÄSSERUNGSDAUER" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="2" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="15s" Command="{Binding SetDurationCommand}" CommandParameter="15"
                                Padding="14,8" CornerRadius="{DynamicResource SmallRadius}" />
                        <Button Content="30s" Command="{Binding SetDurationCommand}" CommandParameter="30"
                                Padding="14,8" CornerRadius="{DynamicResource SmallRadius}" />
                        <Button Content="1 Min" Command="{Binding SetDurationCommand}" CommandParameter="60"
                                Padding="14,8" CornerRadius="{DynamicResource SmallRadius}" />
                        <Button Content="2 Min" Command="{Binding SetDurationCommand}" CommandParameter="120"
                                Padding="14,8" CornerRadius="{DynamicResource SmallRadius}" />
                        <Button Content="5 Min" Command="{Binding SetDurationCommand}" CommandParameter="300"
                                Padding="14,8" CornerRadius="{DynamicResource SmallRadius}" />
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <NumericUpDown Value="{Binding CustomDurationSeconds}" Minimum="5" Maximum="3600"
                                           Increment="5" Width="90" />
                            <TextBlock Text="s" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="{DynamicResource PrimaryLightBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Gewählt: {0} Sekunden">
                                <Binding Path="SelectedDurationSeconds" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Zone-Steuerungen -->
            <ItemsControl ItemsSource="{Binding Zones}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ZoneDisplayItem">
                        <Border Background="{DynamicResource CardGradientBrush}" CornerRadius="{DynamicResource CardRadius}"
                                Padding="16" Margin="0,4" BorderBrush="#15FFFFFF" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Zone-Icon -->
                                <Border Width="44" Height="44" CornerRadius="22" Margin="0,0,12,0"
                                        Background="{Binding MoistureColor, Converter={x:Static views:DashboardView.StringToBrush}}"
                                        Opacity="0.2">
                                    <mi:MaterialIcon Kind="Flower" Width="24" Height="24"
                                                     Foreground="{Binding MoistureColor, Converter={x:Static views:DashboardView.StringToBrush}}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- Zone-Info -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="Feuchtigkeit: {0:F0}% | Schwelle: {1}%">
                                                <Binding Path="MoisturePercent" />
                                                <Binding Path="ThresholdPercent" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="{Binding StateText}" FontSize="12"
                                               Foreground="{Binding StateColor, Converter={x:Static views:DashboardView.StringToBrush}}" />
                                </StackPanel>

                                <!-- Start/Stop Button -->
                                <Button Grid.Column="2" Padding="18,12" CornerRadius="{DynamicResource ButtonRadius}"
                                        VerticalAlignment="Center"
                                        Command="{Binding $parent[ItemsControl].((vm:ZoneControlViewModel)DataContext).ToggleWateringCommand}"
                                        CommandParameter="{Binding ZoneId}"
                                        Background="{Binding IsWatering, Converter={x:Static views:DashboardView.PumpBgConverter}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <mi:MaterialIcon Width="20" Height="20" Foreground="White"
                                                         Kind="{Binding IsWatering, Converter={x:Static views:ZoneControlView.WateringIconConverter}}" />
                                        <TextBlock VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold"
                                                   Text="{Binding IsWatering, Converter={x:Static views:ZoneControlView.WateringTextConverter}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Alle Zonen nacheinander testen -->
            <Button Command="{Binding TestAllZonesCommand}"
                    Background="{DynamicResource PrimaryGradientBrush}" Foreground="White"
                    Padding="16,12" CornerRadius="{DynamicResource ButtonRadius}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="PlaylistCheck" Width="20" Height="20" />
                    <TextBlock Text="Alle Zonen nacheinander testen" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Border Height="60" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
