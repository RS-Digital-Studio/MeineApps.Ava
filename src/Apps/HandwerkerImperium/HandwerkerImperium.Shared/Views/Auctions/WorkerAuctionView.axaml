<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels.Auctions"
             xmlns:icons="using:HandwerkerImperium.Icons"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             x:Class="HandwerkerImperium.Views.Auctions.WorkerAuctionView"
             x:DataType="vm:WorkerAuctionViewModel"
             x:CompileBindings="True"
             AutomationProperties.AutomationId="Auction_Root">

  <Border Classes="Card" Padding="14,12"
          IsVisible="{Binding HasActiveAuction}">
    <StackPanel Spacing="10">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <icons:GameIcon Grid.Column="0"
                       Kind="Hammer"
                       Width="22" Height="22"
                       Foreground="{StaticResource CraftGoldBrush}" />
        <StackPanel Grid.Column="1" Margin="10,0" Spacing="2">
          <TextBlock Text="{loc:Translate AuctionTitle}"
                     FontSize="14" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="{Binding WorkerNameDisplay}"
                     FontSize="12"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
        <Border Grid.Column="2"
                Background="{StaticResource CraftPrimaryBrush}"
                CornerRadius="8" Padding="8,4">
          <TextBlock Text="{Binding CountdownText}"
                     FontSize="13" FontWeight="Bold"
                     Foreground="White" />
        </Border>
      </Grid>

      <!-- Hoechstgebot -->
      <Grid ColumnDefinitions="*,*">
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="{loc:Translate AuctionHighestBid}"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock Text="{Binding HighestBidDisplay}"
                     FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource CraftGoldBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="{loc:Translate AuctionMinBid}"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock Text="{Binding MinBidDisplay}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>
      </Grid>

      <!-- Bid-Form -->
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding BidInput, Mode=TwoWay}"
                 PlaceholderText="{loc:Translate AuctionBidPlaceholder}"
                 MinHeight="44"
                 AutomationProperties.AutomationId="Auction_Tx_BidInput" />
        <Button Grid.Column="1"
                Classes="Primary"
                Margin="8,0,0,0"
                MinHeight="44" Padding="14,6"
                Content="{loc:Translate AuctionPlaceBid}"
                Command="{Binding PlaceBidCommand}"
                AutomationProperties.AutomationId="Auction_Btn_PlaceBid" />
      </Grid>

      <!-- Error -->
      <TextBlock Text="{Binding BidError}"
                 FontSize="12"
                 Foreground="{DynamicResource ErrorBrush}"
                 IsVisible="{Binding BidError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>
  </Border>
</UserControl>
