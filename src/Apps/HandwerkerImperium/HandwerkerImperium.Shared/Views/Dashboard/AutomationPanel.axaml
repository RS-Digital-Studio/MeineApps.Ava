<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels"
             xmlns:icons="using:HandwerkerImperium.Icons"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             x:Class="HandwerkerImperium.Views.Dashboard.AutomationPanel"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="True">

        <Border Classes="Card" Padding="10,8" Margin="0,0,0,4"
                AutomationProperties.AutomationId="Dashboard_Border_Automation">
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">

            <!-- AutoCollect (Lv15+) -->
            <Border Grid.Column="0" CornerRadius="8" Padding="6,4"
                    Background="{DynamicResource SurfaceBrush}"
                    AutomationProperties.AutomationId="Dashboard_Border_AutoCollect">
              <StackPanel Spacing="2" HorizontalAlignment="Center">
                <icons:GameIcon Kind="PackageDown" Width="20" Height="20"
                                 Foreground="{StaticResource CraftPrimaryLightBrush}"
                                 HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Translate AutoCollectDesc}" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="80" />
                <ToggleSwitch IsChecked="{Binding AutoCollectDelivery}"
                              OnContent="" OffContent=""
                              HorizontalAlignment="Center"
                              Margin="0,-4,0,-4"
                              IsVisible="{Binding IsAutoCollectUnlocked}" />
                <Border IsVisible="{Binding !IsAutoCollectUnlocked}"
                        Background="#10D97706" CornerRadius="6" Padding="6,3" Margin="0,2,0,0">
                  <TextBlock Text="{loc:Translate AutoCollectLocked}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{StaticResource CraftGoldBrush}" Opacity="0.7"
                             TextAlignment="Center" TextWrapping="Wrap" MaxWidth="80" />
                </Border>
              </StackPanel>
            </Border>

            <!-- AutoAccept (Lv25+) -->
            <Border Grid.Column="1" CornerRadius="8" Padding="6,4"
                    Background="{DynamicResource SurfaceBrush}"
                    AutomationProperties.AutomationId="Dashboard_Border_AutoAccept">
              <StackPanel Spacing="2" HorizontalAlignment="Center">
                <icons:GameIcon Kind="FileDocumentCheck" Width="20" Height="20"
                                 Foreground="{StaticResource CraftPrimaryLightBrush}"
                                 HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Translate AutoAcceptDesc}" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="80" />
                <ToggleSwitch IsChecked="{Binding AutoAcceptOrder}"
                              OnContent="" OffContent=""
                              HorizontalAlignment="Center"
                              Margin="0,-4,0,-4"
                              IsVisible="{Binding IsAutoAcceptUnlocked}" />
                <Border IsVisible="{Binding !IsAutoAcceptUnlocked}"
                        Background="#10D97706" CornerRadius="6" Padding="6,3" Margin="0,2,0,0">
                  <TextBlock Text="{loc:Translate AutoAcceptLocked}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{StaticResource CraftGoldBrush}" Opacity="0.7"
                             TextAlignment="Center" TextWrapping="Wrap" MaxWidth="80" />
                </Border>
              </StackPanel>
            </Border>

            <!-- AutoClaimDaily (Premium) -->
            <Border Grid.Row="1" Grid.Column="0" CornerRadius="8" Padding="6,4"
                    Background="{DynamicResource SurfaceBrush}"
                    AutomationProperties.AutomationId="Dashboard_Border_AutoClaimDaily">
              <StackPanel Spacing="2" HorizontalAlignment="Center">
                <icons:GameIcon Kind="Gift" Width="20" Height="20"
                                 Foreground="{StaticResource CraftGoldBrush}"
                                 HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Translate AutoClaimDailyDesc}" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="80" />
                <ToggleSwitch IsChecked="{Binding AutoClaimDaily}"
                              OnContent="" OffContent=""
                              HorizontalAlignment="Center"
                              Margin="0,-4,0,-4"
                              IsVisible="{Binding IsAutoClaimUnlocked}" />
                <Border IsVisible="{Binding !IsAutoClaimUnlocked}"
                        Background="#10D97706" CornerRadius="6" Padding="6,3" Margin="0,2,0,0">
                  <TextBlock Text="{loc:Translate AutoClaimDailyLocked}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{StaticResource CraftGoldBrush}" Opacity="0.7"
                             TextAlignment="Center" TextWrapping="Wrap" MaxWidth="80" />
                </Border>
              </StackPanel>
            </Border>

            <!-- AutoAssign (Lv20+) -->
            <Border Grid.Row="1" Grid.Column="1" CornerRadius="8" Padding="6,4"
                    Background="{DynamicResource SurfaceBrush}"
                    AutomationProperties.AutomationId="Dashboard_Border_AutoAssign">
              <StackPanel Spacing="2" HorizontalAlignment="Center">
                <icons:GameIcon Kind="AccountGroup" Width="20" Height="20"
                                 Foreground="{StaticResource CraftPrimaryLightBrush}"
                                 HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Translate AutoAssignDesc}" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="80" />
                <ToggleSwitch IsChecked="{Binding AutoAssignWorkers}"
                              OnContent="" OffContent=""
                              HorizontalAlignment="Center"
                              Margin="0,-4,0,-4"
                              IsVisible="{Binding IsAutoAssignUnlocked}" />
                <Border IsVisible="{Binding !IsAutoAssignUnlocked}"
                        Background="#10D97706" CornerRadius="6" Padding="6,3" Margin="0,2,0,0">
                  <TextBlock Text="{loc:Translate AutoAssignLocked}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{StaticResource CraftGoldBrush}" Opacity="0.7"
                             TextAlignment="Center" TextWrapping="Wrap" MaxWidth="80" />
                </Border>
              </StackPanel>
            </Border>

          </Grid>
        </Border>

</UserControl>
