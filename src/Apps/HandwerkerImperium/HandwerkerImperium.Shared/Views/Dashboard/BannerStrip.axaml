<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels"
             xmlns:icons="using:HandwerkerImperium.Icons"
             x:Class="HandwerkerImperium.Views.Dashboard.BannerStrip"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="True">

  <!-- TOUCH-3: Fade-Edge Scroll-Indikator -->
  <Panel>
  <ScrollViewer HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled">
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,4,24,4">

      <!-- Rush-Chip (verfügbar, noch nicht aktiv) -->
      <Button IsVisible="{Binding CanActivateRush}"
              Command="{Binding ActivateRushCommand}"
              Classes="Text" Padding="0" CornerRadius="22"
              AutomationProperties.AutomationId="Dashboard_Btn_RushChip">
        <Border CornerRadius="22" Padding="12,6" Height="44">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
              <GradientStop Color="#D97706" Offset="0" />
              <GradientStop Color="#FFD700" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <icons:GameIcon Kind="Flash" Width="20" Height="20" Foreground="{DynamicResource PrimaryContrastBrush}" />
            <TextBlock Text="{Binding RushButtonText}" FontSize="12"
                       FontWeight="Bold" Foreground="{DynamicResource PrimaryContrastBrush}" />
          </StackPanel>
        </Border>
      </Button>

      <!-- Rush-Aktiv-Chip (Timer läuft) -->
      <Border IsVisible="{Binding IsRushActive}"
              CornerRadius="22" Padding="12,6" Height="44"
              Background="#30FFD700" BorderBrush="{StaticResource CraftGoldBrush}"
              BorderThickness="1"
              AutomationProperties.AutomationId="Dashboard_Border_RushActiveChip">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <icons:GameIcon Kind="Flash" Width="20" Height="20"
                           Foreground="{StaticResource CraftGoldBrush}" />
          <TextBlock Text="{Binding RushTimeRemaining}" FontSize="12"
                     FontWeight="Bold" Foreground="{StaticResource CraftGoldBrush}" />
        </StackPanel>
      </Border>

      <!-- Lieferant-Chip -->
      <Button IsVisible="{Binding HasPendingDelivery}"
              Command="{Binding ClaimDeliveryCommand}"
              Classes="Text" Padding="0" CornerRadius="22"
              AutomationProperties.AutomationId="Dashboard_Btn_DeliveryChip">
        <Border CornerRadius="22" Padding="12,6" Height="44">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
              <GradientStop Color="#065F46" Offset="0" />
              <GradientStop Color="#10B981" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <icons:GameIcon Kind="PackageDown" Width="20" Height="20" Foreground="{DynamicResource PrimaryContrastBrush}" />
            <TextBlock Text="{Binding DeliveryDescription}" FontSize="12"
                       FontWeight="Bold" Foreground="{DynamicResource PrimaryContrastBrush}"
                       MaxWidth="120" TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Border>
      </Button>

      <!-- F-21: Daily-Reward-Chip im Dashboard — sichtbar wenn Missionen Belohnungen warten. -->
      <Button IsVisible="{Binding MissionsVM.HasClaimableMissions}"
              Command="{Binding SelectMissionsTabCommand}"
              Classes="Text" Padding="0" CornerRadius="22"
              AutomationProperties.AutomationId="Dashboard_Btn_DailyRewardsChip">
        <Border CornerRadius="22" Padding="12,6" Height="44">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
              <GradientStop Color="#10B981" Offset="0" />
              <GradientStop Color="#34D399" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <icons:GameIcon Kind="Trophy" Width="20" Height="20"
                             Foreground="{DynamicResource PrimaryContrastBrush}" />
            <TextBlock Text="{Binding MissionsVM.ClaimableMissionsCount, StringFormat={loc:Translate DailyRewardsChipFormat}}"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryContrastBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Border>
      </Button>

      <!-- F-16: Live-Event-Chip (RemoteConfig-getrieben, Score + Countdown + Tap-to-Claim) -->
      <Button IsVisible="{Binding LiveEventBannerVM.HasActiveLiveEvent}"
              Command="{Binding LiveEventBannerVM.TapChipCommand}"
              Classes="Text" Padding="0" CornerRadius="22"
              AutomationProperties.AutomationId="Dashboard_Btn_LiveEventChip">
        <Border CornerRadius="22" Padding="12,6" Height="44">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
              <GradientStop Color="#7C3AED" Offset="0" />
              <GradientStop Color="#A78BFA" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <icons:GameIcon Kind="Star" Width="20" Height="20"
                             Foreground="{DynamicResource PrimaryContrastBrush}" />
            <TextBlock Text="{Binding LiveEventBannerVM.LiveEventTitle}"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryContrastBrush}"
                       MaxWidth="120" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       AutomationProperties.AutomationId="Dashboard_Txt_LiveEventTitle" />
            <TextBlock Text="{Binding LiveEventBannerVM.LiveEventScoreDisplay}"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryContrastBrush}" Opacity="0.85"
                       VerticalAlignment="Center"
                       AutomationProperties.AutomationId="Dashboard_Txt_LiveEventScore" />
            <TextBlock Text="{Binding LiveEventBannerVM.LiveEventTimeRemaining}"
                       FontSize="11"
                       Foreground="{DynamicResource PrimaryContrastBrush}" Opacity="0.75"
                       VerticalAlignment="Center"
                       AutomationProperties.AutomationId="Dashboard_Txt_LiveEventTime" />
          </StackPanel>
        </Border>
      </Button>

      <!-- Event-Chip -->
      <Border IsVisible="{Binding HasActiveEvent}"
              CornerRadius="22" Padding="12,6" Height="44"
              Background="#20D97706" BorderBrush="{StaticResource CraftPrimaryBrush}"
              BorderThickness="1"
              AutomationProperties.AutomationId="Dashboard_Border_EventChip">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <icons:GameIcon Kind="{Binding ActiveEventIcon, Converter={StaticResource IconKindConverter}}"
                           Width="20" Height="20"
                           Foreground="{StaticResource CraftPrimaryLightBrush}" />
          <TextBlock Text="{Binding ActiveEventName}" FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     MaxWidth="100" TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding ActiveEventTimeRemaining}" FontSize="11"
                     Foreground="{StaticResource CraftPrimaryLightBrush}" />
        </StackPanel>
      </Border>

      <!-- NAV-1: Worker-Warnung-Chip als Button → navigiert direkt zum betroffenen Worker -->
      <Button IsVisible="{Binding HeaderVM.HasWorkerWarning}"
              Command="{Binding NavigateToWorkerWarningCommand}"
              Classes="Text" Padding="0" CornerRadius="22"
              AutomationProperties.AutomationId="Dashboard_Btn_WorkerWarningChip">
        <Border CornerRadius="22" Padding="12,6" Height="44"
                Background="#33FF5722">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <icons:GameIcon Kind="AlertCircleOutline" Width="20" Height="20"
                             Foreground="{DynamicResource WarningBrush}" />
            <TextBlock Text="{Binding HeaderVM.WorkerWarningText}" FontSize="11"
                       Foreground="{DynamicResource WarningBrush}" MaxWidth="140"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Border>
      </Button>

    </StackPanel>
  </ScrollViewer>
  <Border HorizontalAlignment="Right" Width="24" IsHitTestVisible="False">
    <Border.Background>
      <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
        <GradientStop Color="#00000000" Offset="0" />
        <GradientStop Color="{DynamicResource BackgroundColor}" Offset="1" />
      </LinearGradientBrush>
    </Border.Background>
  </Border>
  </Panel>
</UserControl>
