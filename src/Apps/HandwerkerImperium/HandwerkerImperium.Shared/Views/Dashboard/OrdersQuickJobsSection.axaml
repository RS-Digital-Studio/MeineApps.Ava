<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels"
             xmlns:icons="using:HandwerkerImperium.Icons"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:models="using:HandwerkerImperium.Models"
             xmlns:conv="using:HandwerkerImperium.Converters"
             xmlns:coreConv="using:MeineApps.Core.Ava.Converters"
             x:Class="HandwerkerImperium.Views.Dashboard.OrdersQuickJobsSection"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="True">

  <UserControl.Resources>
    <conv:GreaterThanZeroConverter x:Key="GreaterThanZero" />
  </UserControl.Resources>

  <StackPanel Spacing="8"
              AutomationProperties.AutomationId="Dashboard_Panel_OrdersQuickJobs">
    <!-- Tab-Header mit Unterstreichung -->
    <Grid ColumnDefinitions="*,*,Auto" RowDefinitions="Auto,2">
      <Button Grid.Column="0" Classes="Text" Padding="8,6"
              Command="{Binding ShowOrdersTabCommand}"
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              AutomationProperties.AutomationId="Dashboard_Btn_OrdersTab">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{loc:Translate Orders}" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <Border Background="{StaticResource CraftPrimaryBrush}"
                  CornerRadius="10" Padding="6,2"
                  IsVisible="{Binding AvailableOrders.Count, Converter={StaticResource GreaterThanZero}}">
            <TextBlock Text="{Binding AvailableOrders.Count}" FontSize="11"
                       FontWeight="Bold" Foreground="{DynamicResource PrimaryContrastBrush}" />
          </Border>
        </StackPanel>
      </Button>
      <Button Grid.Column="1" Classes="Text" Padding="8,6"
              Command="{Binding ShowQuickJobsTabCommand}"
              IsVisible="{Binding IsQuickJobsUnlocked}"
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              AutomationProperties.AutomationId="Dashboard_Btn_QuickJobsTab">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{loc:Translate QuickJobs}" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <Border Background="{StaticResource CraftPrimaryLightBrush}"
                  CornerRadius="10" Padding="6,2">
            <TextBlock Text="{Binding MissionsVM.QuickJobs.Count}" FontSize="11"
                       FontWeight="Bold" Foreground="{DynamicResource PrimaryContrastBrush}" />
          </Border>
        </StackPanel>
      </Button>
      <Button Grid.Column="2" Classes="Text"
              MinHeight="44" MinWidth="44"
              Command="{Binding RefreshOrdersCommand}"
              IsVisible="{Binding IsOrdersTabActive}"
              AutomationProperties.AutomationId="Dashboard_Btn_RefreshOrders">
        <icons:GameIcon Kind="Refresh" Width="26" Height="26" />
      </Button>
      <!-- Unterstreichung für aktiven Tab -->
      <Border Grid.Row="1" Grid.Column="0" Height="2"
              Background="{StaticResource CraftPrimaryBrush}"
              IsVisible="{Binding IsOrdersTabActive}" />
      <Border Grid.Row="1" Grid.Column="1" Height="2"
              Background="{StaticResource CraftPrimaryLightBrush}"
              IsVisible="{Binding IsQuickJobsTabActive}" />
    </Grid>

    <!-- ============ Orders-Liste (wenn Orders-Tab aktiv) ============ -->
    <StackPanel IsVisible="{Binding IsOrdersTabActive}" Spacing="8">
      <!-- Aktiver Auftrag Hinweis -->
      <Border IsVisible="{Binding HasActiveOrder}"
              Background="#15D97706" CornerRadius="8" Padding="10,8"
              AutomationProperties.AutomationId="Dashboard_Border_ActiveOrderHint">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <icons:GameIcon Kind="PlayCircle" Width="18" Height="18"
                           Foreground="{StaticResource CraftPrimaryLightBrush}"
                           VerticalAlignment="Center" />
          <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
            <Run Text="{loc:Translate ActiveOrderHint}" /><Run Text=": " /><Run Text="{Binding ActiveOrder.DisplayTitle}" />
          </TextBlock>
        </StackPanel>
      </Border>
      <!-- Parallele Auftraege: Fortsetzen-Banner -->
      <Border Classes="Card" Padding="12,10"
              IsVisible="{Binding HasParallelOrders}"
              HorizontalAlignment="Stretch"
              Margin="0,0,0,8"
              Background="{StaticResource CraftHeaderGradientBrush}"
              AutomationProperties.AutomationId="Dashboard_Border_ParallelOrders">
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <icons:GameIcon Kind="PlayCircle" Width="20" Height="20"
                             Foreground="{DynamicResource PrimaryContrastBrush}" />
            <TextBlock Text="{loc:Translate ParallelOrdersTitle}"
                       FontSize="13" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryContrastBrush}"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding ParallelOrders.Count}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource CraftGoldBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <ItemsControl ItemsSource="{Binding ParallelOrders}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="Text" Padding="6,4" CornerRadius="6"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Margin="0,2,0,0" MinHeight="44"
                        Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ResumeParallelOrderCommand}"
                        CommandParameter="{Binding WorkshopType}">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <StackPanel VerticalAlignment="Center" Spacing="0">
                      <TextBlock Text="{Binding DisplayTitle}"
                                 FontSize="12" FontWeight="SemiBold"
                                 Foreground="{DynamicResource PrimaryContrastBrush}"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding DisplayWorkshopName}"
                                 FontSize="10"
                                 Foreground="{DynamicResource PrimaryContrastBrush}"
                                 Opacity="0.8" />
                    </StackPanel>
                    <icons:GameIcon Grid.Column="1" Kind="ChevronRight" Width="18" Height="18"
                                     Foreground="{DynamicResource PrimaryContrastBrush}"
                                     VerticalAlignment="Center" />
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Empty State -->
      <Border Classes="Card" Padding="24"
              IsVisible="{Binding HasNoOrders}"
              HorizontalAlignment="Stretch"
              AutomationProperties.AutomationId="Dashboard_Border_NoOrders">
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <icons:GameIcon Kind="ClipboardTextOutline" Width="40" Height="40"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Opacity="0.5" HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Translate NoOrdersAvailable}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Translate OrdersComingSoon}"
                     FontSize="12"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- Virtualisierte Auftrags-Liste -->
      <ListBox ItemsSource="{Binding AvailableOrders}"
               Background="Transparent" BorderThickness="0"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               AutomationProperties.AutomationId="Dashboard_Items_Orders">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
          </Style>
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
          </Style>
          <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
          </Style>
        </ListBox.Styles>
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Classes="Card" Margin="0,0,0,12" Padding="16"
                    AutomationProperties.AutomationId="Dashboard_Border_OrderItem">
              <Grid ColumnDefinitions="*,Auto"
                    RowDefinitions="Auto,Auto,Auto,Auto">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="{Binding DisplayTitle}"
                             FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <!-- LIVE-Badge -->
                  <Border Background="{StaticResource CraftLiveBadgeBrush}" CornerRadius="4" Padding="5,1"
                          IsVisible="{Binding IsLive}"
                          VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <icons:GameIcon Kind="Flash" Width="12" Height="12"
                                       Foreground="{DynamicResource PrimaryContrastBrush}" />
                      <TextBlock Text="{loc:Translate OrderLiveBadge}"
                                 FontSize="10" FontWeight="Bold"
                                 Foreground="{DynamicResource PrimaryContrastBrush}" />
                      <TextBlock Text="{Binding LiveCountdownText}"
                                 FontSize="10" FontWeight="SemiBold"
                                 Foreground="{DynamicResource PrimaryContrastBrush}" />
                    </StackPanel>
                  </Border>
                  <!-- PREMIUM-Badge -->
                  <Border Background="{StaticResource CraftPremiumBadgeBrush}" CornerRadius="4" Padding="5,1"
                          IsVisible="{Binding IsPremium}"
                          VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <icons:GameIcon Kind="Crown" Width="12" Height="12"
                                       Foreground="{DynamicResource PrimaryContrastBrush}" />
                      <TextBlock Text="{loc:Translate OrderPremiumBadge}"
                                 FontSize="10" FontWeight="Bold"
                                 Foreground="{DynamicResource PrimaryContrastBrush}" />
                    </StackPanel>
                  </Border>
                  <Border Background="#20FFD700" CornerRadius="4" Padding="4,1"
                          IsVisible="{Binding IsRegularCustomerOrder}"
                          VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                      <icons:GameIcon Kind="Heart" Width="12" Height="12" Foreground="{StaticResource CraftGoldBrush}" />
                      <TextBlock Text="{loc:Translate RegularCustomerBonus}"
                                 FontSize="11" Foreground="{StaticResource CraftGoldBrush}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayWorkshopName}"
                           FontSize="12"
                           Foreground="{StaticResource CraftPrimaryLightBrush}"
                           VerticalAlignment="Center" />
                <Border Grid.Row="1" Grid.ColumnSpan="2"
                        IsVisible="{Binding ShowOrderTypeBadge}"
                        Background="{Binding OrderTypeBadgeColor, Converter={x:Static coreConv:StringToColorBrushConverter.Instance}}"
                        Opacity="0.9"
                        CornerRadius="4" Padding="6,2"
                        HorizontalAlignment="Left"
                        Margin="0,4,0,0">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <icons:GameIcon Kind="{Binding OrderTypeIcon, Converter={StaticResource IconKindConverter}}"
                                     Width="12" Height="12"
                                     Foreground="{DynamicResource PrimaryContrastBrush}" />
                    <TextBlock Text="{Binding DisplayOrderType}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryContrastBrush}" />
                  </StackPanel>
                </Border>
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,8">
                  <Run Text="{Binding Tasks.Count}" /><Run Text=" " /><Run Text="{loc:Translate MiniGamesLabel}" />
                </TextBlock>
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="4">
                  <icons:GameIcon Kind="CashMultiple" Width="24" Height="24"
                                   Foreground="{DynamicResource SuccessBrush}" />
                  <TextBlock Text="{Binding EstimatedReward, Converter={StaticResource MoneyDisplay}, ConverterParameter='~'}"
                             FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource SuccessBrush}"
                             VerticalAlignment="Center" />
                  <icons:GameIcon Kind="Star" Width="18" Height="18"
                                   Foreground="{StaticResource CraftGoldBrush}"
                                   Margin="8,0,0,0" />
                  <TextBlock Text="{Binding EstimatedXp, StringFormat='~{0} XP'}"
                             FontSize="12"
                             Foreground="{StaticResource CraftGoldBrush}"
                             VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Row="3" Grid.Column="1"
                        Content="{loc:Translate Start}"
                        Classes="Primary" Padding="16,8"
                        Background="{StaticResource CraftPrimaryBrush}"
                        Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).StartOrderCommand}"
                        CommandParameter="{Binding .}"
                        IsEnabled="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).HasActiveOrder, Converter={x:Static BoolConverters.Not}}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <!-- ============ QuickJobs-Liste (wenn QuickJobs-Tab aktiv) ============ -->
    <StackPanel IsVisible="{Binding IsQuickJobsTabActive}" Spacing="8">
      <!-- Timer-Anzeige -->
      <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" Margin="0,0,0,4">
        <icons:GameIcon Kind="TimerRefresh" Width="18" Height="18"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBlock Text="{Binding MissionsVM.QuickJobTimerDisplay}" FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
      </StackPanel>

      <!-- QuickJobs-Liste -->
      <ListBox ItemsSource="{Binding MissionsVM.QuickJobs}"
               Background="Transparent" BorderThickness="0"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               AutomationProperties.AutomationId="Dashboard_Items_QuickJobs">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
          </Style>
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
          </Style>
          <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
          </Style>
        </ListBox.Styles>
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="models:QuickJob">
            <Border Margin="0,4" Padding="8" CornerRadius="8"
                    Background="{DynamicResource SurfaceBrush}"
                    AutomationProperties.AutomationId="Dashboard_Border_QuickJobItem">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding DisplayTitle}" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding DisplayWorkshopName}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding RewardDisplay}" FontSize="11"
                               Foreground="{DynamicResource SuccessBrush}" />
                  </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Classes="Primary" Padding="12,8"
                        MinHeight="44" MinWidth="44"
                        Background="{StaticResource CraftPrimaryBrush}"
                        Content="{loc:Translate Start}"
                        IsVisible="{Binding !IsCompleted}"
                        Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).MissionsVM.StartQuickJobCommand}"
                        CommandParameter="{Binding .}" />
                <icons:GameIcon Grid.Column="1" Kind="Check" Width="24" Height="24"
                                 Foreground="{DynamicResource SuccessBrush}"
                                 IsVisible="{Binding IsCompleted}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>
  </StackPanel>
</UserControl>
