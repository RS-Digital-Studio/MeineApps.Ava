<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels"
             xmlns:icons="using:HandwerkerImperium.Icons"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:models="using:HandwerkerImperium.Models"
             xmlns:conv="using:HandwerkerImperium.Converters"
             xmlns:controls="using:MeineApps.UI.Controls"
             xmlns:skia="using:Avalonia.Labs.Controls"
             xmlns:views="using:HandwerkerImperium.Views"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:MeineApps.UI.Behaviors"
             xmlns:dashboard="using:HandwerkerImperium.Views.Dashboard"
             xmlns:coreConv="using:MeineApps.Core.Ava.Converters"
             x:Class="HandwerkerImperium.Views.DashboardView"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="True"
             AutomationProperties.AutomationId="Dashboard_Root">

  <UserControl.Resources>
    <conv:WorkshopColorConverter x:Key="WorkshopColor" />
    <conv:GreaterThanZeroConverter x:Key="GreaterThanZero" />
  </UserControl.Resources>

  <!-- Animationen -->
  <UserControl.Styles>
    <!-- Income-Puls -->
    <Style Selector="TextBlock.IncomePulse">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.6"/></KeyFrame>
          <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.6"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Goldschrauben-Badge Glow (Opacity statt BoxShadow - GPU-beschleunigt auf Android) -->
    <Style Selector="Border.GoldenBadge">
      <!-- BoxShadow entfernt: CPU-Blur bei jedem Opacity-Frame verursacht Stutter auf Android -->
      <Style.Animations>
        <Animation Duration="0:0:3" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.75"/></KeyFrame>
          <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.75"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Onboarding: Pulsierender Hint-Rahmen -->
    <Style Selector="Border.TutorialHint">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
          <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Phase 12.2: "Fast geschafft" Puls auf Upgrade-Button -->
    <Style Selector="Button.UpgradePulse">
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.7"/></KeyFrame>
          <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.7"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Phase 5.4: Goldschrauben-Badge Shimmer-Pulse -->
    <Style Selector="Border#GoldenScrewBadge">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
          <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Boost-Indikator Puls (Rush/SpeedBoost aktiv) -->
    <Style Selector="Border.BoostPulse">
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.7"/></KeyFrame>
          <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.7"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Game Juice: FadeIn auf Haupt-Content -->
    <Style Selector="ScrollViewer#DashboardScrollViewer">
      <Setter Property="(i:Interaction.Behaviors)">
        <i:BehaviorCollection>
          <behaviors:FadeInBehavior Duration="250" SlideFromBottom="True" SlideDistance="12" />
        </i:BehaviorCollection>
      </Setter>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" AutomationProperties.AutomationId="Dashboard_Grid_Root">

    <!-- ================================================================= -->
    <!-- HEADER: Handwerker-Gradient + Parallax                            -->
    <!-- ================================================================= -->
    <Border Grid.Row="0" CornerRadius="0,0,12,12"
            BoxShadow="0 4 16 0 #40D97706"
            Name="HeaderBorder"
            ClipToBounds="True"
            AutomationProperties.AutomationId="Dashboard_Border_Header">
      <Panel>
        <!-- City-Skyline SkiaSharp Layer (unterste Schicht, 2.5D isometrisch) -->
        <skia:SKCanvasView x:Name="CityCanvas" MinHeight="240"
                           AutomationProperties.AutomationId="Dashboard_Canvas_CitySkyline" />

        <!-- Gradient-Overlay (semi-transparent, damit City durchscheint) -->
        <Border Padding="16,12"
                AutomationProperties.AutomationId="Dashboard_Border_HeaderOverlay">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
              <GradientStop Color="#C0181210" Offset="0" />
              <GradientStop Color="#80281A0A" Offset="0.35" />
              <GradientStop Color="#20181210" Offset="0.55" />
              <GradientStop Color="#00000000" Offset="0.75" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel Spacing="6" AutomationProperties.AutomationId="Dashboard_Panel_HeaderContent">

            <!-- Zeile 1: Geld + Goldschrauben + Daily Reward -->
            <Grid ColumnDefinitions="*,Auto" AutomationProperties.AutomationId="Dashboard_Grid_MoneyRow">
              <StackPanel Spacing="2">
                <TextBlock x:Name="MoneyText" Text="{Binding MoneyDisplay}"
                           FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryContrastBrush}"
                           AutomationProperties.AutomationId="Dashboard_Txt_Money" />
                <TextBlock Text="{Binding IncomeDisplay}"
                           FontSize="13" Classes="IncomePulse"
                           Foreground="{DynamicResource PrimaryContrastBrush}" Opacity="0.8"
                           AutomationProperties.AutomationId="Dashboard_Txt_Income" />
                <TextBlock Text="{Binding NetIncomeHeaderDisplay}"
                           FontSize="11" Opacity="0.8"
                           IsVisible="{Binding IsNetIncomeNegative}"
                           Foreground="{Binding NetIncomeColor, Converter={x:Static coreConv:StringToColorBrushConverter.Instance}}"
                           AutomationProperties.AutomationId="Dashboard_Txt_NetIncome" />
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                          VerticalAlignment="Center">
                <!-- CL-1: MasterTools entfernt -->
                <!-- Goldschrauben-Badge mit Glow -->
                <Border x:Name="GoldenScrewBadge" Classes="GoldenBadge"
                        Background="#30000000" CornerRadius="12" Padding="8,4"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="Dashboard_Border_GoldenScrews">
                  <StackPanel Orientation="Horizontal" Spacing="4"
                              VerticalAlignment="Center">
                    <icons:GameIcon Kind="ScrewFlatTop" Width="20" Height="20"
                                     Foreground="{StaticResource CraftGoldBrush}"
                                     VerticalAlignment="Center"
                                     AutomationProperties.AutomationId="Dashboard_Icon_GoldenScrews" />
                    <TextBlock Text="{Binding GoldenScrewsDisplay}" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource CraftGoldBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.AutomationId="Dashboard_Txt_GoldenScrews" />
                  </StackPanel>
                </Border>

                <!-- Daily Reward Badge -->
                <Button Classes="Primary"
                        Padding="8,4"
                        MinHeight="44"
                        Background="#FFFFFF30"
                        IsVisible="{Binding HasDailyReward}"
                        Command="{Binding ClaimDailyRewardCommand}"
                        AutomationProperties.AutomationId="Dashboard_Btn_DailyReward">
                  <icons:GameIcon Kind="Gift" Width="24" Height="24" Foreground="#3D1C00"
                                   AutomationProperties.AutomationId="Dashboard_Icon_DailyReward" />
                </Button>
                <!-- Einstellungen (Zahnrad) -->
                <Button Classes="Text" Padding="6"
                        MinWidth="44" MinHeight="44"
                        Background="#30000000" CornerRadius="22"
                        Command="{Binding SelectSettingsTabCommand}"
                        AutomationProperties.AutomationId="Dashboard_Btn_Settings">
                  <icons:GameIcon Kind="Cog" Width="24" Height="24"
                                   Foreground="{DynamicResource PrimaryContrastBrush}" Opacity="0.8"
                                   AutomationProperties.AutomationId="Dashboard_Icon_Settings" />
                </Button>
              </StackPanel>
            </Grid>

            <!-- Zeile 2: Level + Prestige-Badge + XP + Boost-Indikator + Reputation + Streak -->
            <Grid ColumnDefinitions="Auto,*,Auto" AutomationProperties.AutomationId="Dashboard_Grid_LevelRow">
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <icons:GameIcon Kind="Star" Width="18" Height="18" Foreground="{StaticResource CraftGoldBrush}"
                                 AutomationProperties.AutomationId="Dashboard_Icon_Level" />
                <TextBlock FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryContrastBrush}"
                           AutomationProperties.AutomationId="Dashboard_Txt_PlayerLevel">
                  <Run Text="{loc:Translate LevelPrefix}" /><Run Text="{Binding PlayerLevel}" />
                </TextBlock>
                <!-- Prestige-Tier Badge (nur sichtbar nach erstem Prestige) -->
                <Border IsVisible="{Binding ShowPrestigeBadge}"
                        CornerRadius="8" Padding="5,2"
                        Background="{Binding PrestigeTierBadgeColor, Converter={x:Static coreConv:StringToColorBrushConverter.Instance}}"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="Dashboard_Border_PrestigeBadge">
                  <TextBlock Text="{Binding PrestigeTierBadgeText}"
                             FontSize="11" FontWeight="Bold"
                             Foreground="{StaticResource CraftDarkTextBrush}"
                             AutomationProperties.AutomationId="Dashboard_Txt_PrestigeTier" />
                </Border>
              </StackPanel>

              <!-- XP-Leiste: volle Breite, prominent, SkiaSharp Gradient+Glow -->
              <skia:SKCanvasView Grid.Column="1" Height="8"
                                 VerticalAlignment="Center" Margin="8,0"
                                 PaintSurface="OnPaintLevelProgress"
                                 AutomationProperties.AutomationId="Dashboard_Canvas_LevelProgress" />

              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <!-- Boost-Indikator (Rush/SpeedBoost aktiv) -->
                <Border IsVisible="{Binding ShowBoostIndicator}"
                        Classes="BoostPulse"
                        CornerRadius="10" Padding="6,2"
                        Background="{StaticResource CraftPrimaryBrush}"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="Dashboard_Border_BoostIndicator">
                  <StackPanel Orientation="Horizontal" Spacing="3">
                    <icons:GameIcon Kind="Flash" Width="13" Height="13"
                                     Foreground="{DynamicResource PrimaryContrastBrush}"
                                     AutomationProperties.AutomationId="Dashboard_Icon_Boost" />
                    <TextBlock Text="{Binding BoostIndicatorText}"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryContrastBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.AutomationId="Dashboard_Txt_BoostMultiplier" />
                  </StackPanel>
                </Border>
                <!-- Reputation nur bei Warnung (<50) oder Highlight (>=80) -->
                <Button Classes="Text" Padding="4,2"
                        MinHeight="44"
                        Command="{Binding DialogVM.ShowReputationInfoCommand}"
                        IsVisible="{Binding ShowReputationBadge}"
                        AutomationProperties.AutomationId="Dashboard_Btn_Reputation">
                  <StackPanel Orientation="Horizontal" Spacing="2">
                    <icons:GameIcon Kind="Star" Width="13" Height="13"
                                     Foreground="{Binding ReputationColor, Converter={x:Static coreConv:StringToColorBrushConverter.Instance}}"
                                     AutomationProperties.AutomationId="Dashboard_Icon_Reputation" />
                    <TextBlock Text="{Binding ReputationScore}"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{Binding ReputationColor, Converter={x:Static coreConv:StringToColorBrushConverter.Instance}}"
                               VerticalAlignment="Center"
                               AutomationProperties.AutomationId="Dashboard_Txt_ReputationScore" />
                  </StackPanel>
                </Button>
                <!-- Streak nur bei >= 5 Tagen -->
                <StackPanel Orientation="Horizontal" Spacing="2"
                            IsVisible="{Binding ShowStreakBadge}"
                            AutomationProperties.AutomationId="Dashboard_Panel_LoginStreak">
                  <icons:GameIcon Kind="Fire" Width="18" Height="18" Foreground="{StaticResource CraftStreakBrush}"
                                   AutomationProperties.AutomationId="Dashboard_Icon_LoginStreak" />
                  <TextBlock Text="{Binding LoginStreak}" FontSize="11" FontWeight="Bold"
                             Foreground="{StaticResource CraftStreakBrush}" VerticalAlignment="Center"
                             AutomationProperties.AutomationId="Dashboard_Txt_LoginStreak" />
                </StackPanel>
              </StackPanel>
            </Grid>

          </StackPanel>
        </Border>
      </Panel>
    </Border>

    <!-- ================================================================= -->
    <!-- MAIN CONTENT                                                      -->
    <!-- ================================================================= -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Name="DashboardScrollViewer"
                  AutomationProperties.AutomationId="Dashboard_Scroll_Main">
      <StackPanel Spacing="20" Margin="16" AutomationProperties.AutomationId="Dashboard_Panel_MainContent">

        <!-- ============================================================= -->
        <!-- WORKSHOPS (ganz oben auf dem Dashboard)                       -->
        <!-- ============================================================= -->
        <Grid ColumnDefinitions="*,Auto" AutomationProperties.AutomationId="Dashboard_Grid_WorkshopsHeader">
          <TextBlock Text="{loc:Translate Workshops}" FontSize="18" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="Text" Padding="8,4" CornerRadius="12"
                  Background="{StaticResource CraftPrimaryBrush}"
                  Command="{Binding CycleBulkBuyCommand}">
            <TextBlock Text="{Binding BulkBuyLabel}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryContrastBrush}" />
          </Button>
        </Grid>

        <!-- Nächstes Ziel (Empfehlung, nicht klickbar) -->
        <Border Margin="0,4,0,0" Padding="12,10"
                CornerRadius="12"
                Background="#20D97706"
                BorderBrush="#60D97706"
                BorderThickness="1.5"
                IsVisible="{Binding HasCurrentGoal}">
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
            <!-- Icon -->
            <icons:GameIcon Grid.Column="0" Grid.RowSpan="2"
                             Kind="TrendingUp"
                             Width="28" Height="28"
                             Foreground="{StaticResource CraftGoldBrush}"
                             Margin="0,0,10,0"
                             VerticalAlignment="Center" />
            <!-- Beschreibung -->
            <TextBlock Grid.Column="1" Grid.Row="0"
                       Text="{Binding CurrentGoalDescription}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <!-- Belohnung -->
            <TextBlock Grid.Column="1" Grid.Row="1"
                       Text="{Binding CurrentGoalReward}"
                       FontSize="12"
                       Foreground="{StaticResource CraftGoldBrush}" />
          </Grid>
        </Border>

        <!-- Onboarding-Hint -->
        <Border Classes="TutorialHint" IsVisible="{Binding ShowTutorialHint}" Background="#20FFD700"
                BorderBrush="{StaticResource CraftGoldBrush}" BorderThickness="1.5" CornerRadius="10"
                Padding="10,6" Margin="0,0,0,4">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <icons:GameIcon Kind="ArrowDownBold" Width="20" Height="20" Foreground="{StaticResource CraftGoldBrush}" />
            <TextBlock Text="{loc:Translate TutorialUpgradeHint}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource CraftGoldBrush}" />
            <icons:GameIcon Kind="ArrowDownBold" Width="20" Height="20" Foreground="{StaticResource CraftGoldBrush}" />
          </StackPanel>
        </Border>

        <!-- Workshop-Karten Canvas (dynamische Höhe basierend auf Anzahl Workshops) -->
        <skia:SKCanvasView x:Name="WorkshopCardsCanvas" Height="{Binding WorkshopCanvasHeight}"
                           PaintSurface="OnWorkshopCardsPaintSurface"
                           PointerPressed="OnWorkshopCardsPointerPressed"
                           PointerReleased="OnWorkshopCardsPointerReleased"
                           PointerMoved="OnWorkshopCardsPointerMoved" />

        <!-- Banner-Strip (kompakte Chips, ab Lv.3) -->
        <dashboard:BannerStrip Margin="0,8,0,0" IsVisible="{Binding ShowBannerStrip}" />

        <!-- ============================================================= -->
        <!-- AUFTRÄGE + QUICK JOBS (Tab-Umschalter)                       -->
        <!-- ============================================================= -->
        <StackPanel Spacing="8" Margin="0,16,0,0"
                    AutomationProperties.AutomationId="Dashboard_Panel_OrdersQuickJobs">
          <!-- Tab-Header mit Unterstreichung -->
          <Grid ColumnDefinitions="*,*,Auto" RowDefinitions="Auto,2">
            <Button Grid.Column="0" Classes="Text" Padding="8,6"
                    Command="{Binding ShowOrdersTabCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    AutomationProperties.AutomationId="Dashboard_Btn_OrdersTab">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{loc:Translate Orders}" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <Border Background="{StaticResource CraftPrimaryBrush}"
                        CornerRadius="10" Padding="6,2"
                        IsVisible="{Binding AvailableOrders.Count, Converter={StaticResource GreaterThanZero}}">
                  <TextBlock Text="{Binding AvailableOrders.Count}" FontSize="11"
                             FontWeight="Bold" Foreground="{DynamicResource PrimaryContrastBrush}" />
                </Border>
              </StackPanel>
            </Button>
            <Button Grid.Column="1" Classes="Text" Padding="8,6"
                    Command="{Binding ShowQuickJobsTabCommand}"
                    IsVisible="{Binding IsQuickJobsUnlocked}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    AutomationProperties.AutomationId="Dashboard_Btn_QuickJobsTab">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{loc:Translate QuickJobs}" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <Border Background="{StaticResource CraftPrimaryLightBrush}"
                        CornerRadius="10" Padding="6,2">
                  <TextBlock Text="{Binding MissionsVM.QuickJobs.Count}" FontSize="11"
                             FontWeight="Bold" Foreground="{DynamicResource PrimaryContrastBrush}" />
                </Border>
              </StackPanel>
            </Button>
            <Button Grid.Column="2" Classes="Text"
                    MinHeight="44" MinWidth="44"
                    Command="{Binding RefreshOrdersCommand}"
                    IsVisible="{Binding IsOrdersTabActive}"
                    AutomationProperties.AutomationId="Dashboard_Btn_RefreshOrders">
              <icons:GameIcon Kind="Refresh" Width="26" Height="26" />
            </Button>
            <!-- Unterstreichung für aktiven Tab -->
            <Border Grid.Row="1" Grid.Column="0" Height="2"
                    Background="{StaticResource CraftPrimaryBrush}"
                    IsVisible="{Binding IsOrdersTabActive}" />
            <Border Grid.Row="1" Grid.Column="1" Height="2"
                    Background="{StaticResource CraftPrimaryLightBrush}"
                    IsVisible="{Binding IsQuickJobsTabActive}" />
          </Grid>

          <!-- ============ Orders-Liste (wenn Orders-Tab aktiv) ============ -->
          <StackPanel IsVisible="{Binding IsOrdersTabActive}" Spacing="8">
            <!-- Empty State -->
            <Border Classes="Card" Padding="24"
                    IsVisible="{Binding HasNoOrders}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="Dashboard_Border_NoOrders">
              <StackPanel Spacing="8" HorizontalAlignment="Center">
                <icons:GameIcon Kind="ClipboardTextOutline" Width="40" Height="40"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 Opacity="0.5" HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Translate NoOrdersAvailable}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Translate OrdersComingSoon}"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <!-- Virtualisierte Auftrags-Liste -->
            <ListBox ItemsSource="{Binding AvailableOrders}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     AutomationProperties.AutomationId="Dashboard_Items_Orders">
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0" />
                  <Setter Property="MinHeight" Value="0" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent" />
                </Style>
              </ListBox.Styles>
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="Card" Margin="0,0,0,12" Padding="16"
                          AutomationProperties.AutomationId="Dashboard_Border_OrderItem">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto,Auto">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding DisplayTitle}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <Border Background="#20FFD700" CornerRadius="4" Padding="4,1"
                                IsVisible="{Binding IsRegularCustomerOrder}"
                                VerticalAlignment="Center">
                          <StackPanel Orientation="Horizontal" Spacing="2">
                            <icons:GameIcon Kind="Heart" Width="12" Height="12" Foreground="{StaticResource CraftGoldBrush}" />
                            <TextBlock Text="{loc:Translate RegularCustomerBonus}"
                                       FontSize="9" Foreground="{StaticResource CraftGoldBrush}" />
                          </StackPanel>
                        </Border>
                      </StackPanel>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding DisplayWorkshopName}"
                                 FontSize="12"
                                 Foreground="{StaticResource CraftPrimaryLightBrush}"
                                 VerticalAlignment="Center" />
                      <Border Grid.Row="1" Grid.ColumnSpan="2"
                              IsVisible="{Binding ShowOrderTypeBadge}"
                              Background="{Binding OrderTypeBadgeColor, Converter={x:Static coreConv:StringToColorBrushConverter.Instance}}"
                              Opacity="0.9"
                              CornerRadius="4" Padding="6,2"
                              HorizontalAlignment="Left"
                              Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <icons:GameIcon Kind="{Binding OrderTypeIcon, Converter={StaticResource IconKindConverter}}"
                                           Width="12" Height="12"
                                           Foreground="{DynamicResource PrimaryContrastBrush}" />
                          <TextBlock Text="{Binding DisplayOrderType}"
                                     FontSize="11" FontWeight="SemiBold"
                                     Foreground="{DynamicResource PrimaryContrastBrush}" />
                        </StackPanel>
                      </Border>
                      <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 Margin="0,4,0,8">
                        <Run Text="{Binding Tasks.Count}" /><Run Text=" " /><Run Text="{loc:Translate MiniGamesLabel}" />
                      </TextBlock>
                      <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="4">
                        <icons:GameIcon Kind="CashMultiple" Width="24" Height="24"
                                         Foreground="{DynamicResource SuccessBrush}" />
                        <TextBlock Text="{Binding EstimatedReward, Converter={StaticResource MoneyDisplay}, ConverterParameter='~'}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   VerticalAlignment="Center" />
                        <icons:GameIcon Kind="Star" Width="18" Height="18"
                                         Foreground="{StaticResource CraftGoldBrush}"
                                         Margin="8,0,0,0" />
                        <TextBlock Text="{Binding EstimatedXp, StringFormat='~{0} XP'}"
                                   FontSize="12"
                                   Foreground="{StaticResource CraftGoldBrush}"
                                   VerticalAlignment="Center" />
                      </StackPanel>
                      <Button Grid.Row="3" Grid.Column="1"
                              Content="{loc:Translate Start}"
                              Classes="Primary" Padding="16,8"
                              Background="{StaticResource CraftPrimaryBrush}"
                              Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).StartOrderCommand}"
                              CommandParameter="{Binding .}"
                              IsEnabled="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).HasActiveOrder, Converter={x:Static BoolConverters.Not}}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>

          <!-- ============ QuickJobs-Liste (wenn QuickJobs-Tab aktiv) ============ -->
          <StackPanel IsVisible="{Binding IsQuickJobsTabActive}" Spacing="8">
            <!-- Timer-Anzeige -->
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" Margin="0,0,0,4">
              <icons:GameIcon Kind="TimerRefresh" Width="18" Height="18"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding MissionsVM.QuickJobTimerDisplay}" FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- QuickJobs-Liste -->
            <ListBox ItemsSource="{Binding MissionsVM.QuickJobs}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     AutomationProperties.AutomationId="Dashboard_Items_QuickJobs">
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0" />
                  <Setter Property="MinHeight" Value="0" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent" />
                </Style>
              </ListBox.Styles>
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:QuickJob">
                  <Border Margin="0,4" Padding="8" CornerRadius="8"
                          Background="{DynamicResource SurfaceBrush}"
                          AutomationProperties.AutomationId="Dashboard_Border_QuickJobItem">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding DisplayTitle}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding DisplayWorkshopName}" FontSize="11"
                                     Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding RewardDisplay}" FontSize="11"
                                     Foreground="{DynamicResource SuccessBrush}" />
                        </StackPanel>
                      </StackPanel>
                      <Button Grid.Column="1" Classes="Primary" Padding="10,4"
                              Background="{StaticResource CraftPrimaryBrush}"
                              Content="{loc:Translate Start}"
                              IsVisible="{Binding !IsCompleted}"
                              Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).MissionsVM.StartQuickJobCommand}"
                              CommandParameter="{Binding .}" />
                      <icons:GameIcon Grid.Column="1" Kind="Check" Width="24" Height="24"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       IsVisible="{Binding IsCompleted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </StackPanel>

        <!-- AUTOMATISIERUNG (ab Level 15, direkt im Spiel statt in Settings) -->
        <dashboard:AutomationPanel Margin="0,12,0,0"
                                    IsVisible="{Binding IsAutoCollectUnlocked}" />


      </StackPanel>
    </ScrollViewer>

    <!-- FloatingText Overlay: Animierte "+100€" Texte die nach oben fliegen -->
    <controls:FloatingTextOverlay x:Name="FloatingTextCanvas"
                                   Grid.Row="1" ZIndex="10"
                                   IsHitTestVisible="False"
                                   AutomationProperties.AutomationId="Dashboard_Canvas_FloatingText" />

  </Grid>

</UserControl>
