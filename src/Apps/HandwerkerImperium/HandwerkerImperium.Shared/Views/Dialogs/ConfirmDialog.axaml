<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels"
             xmlns:icons="using:HandwerkerImperium.Icons"
             xmlns:models="using:HandwerkerImperium.Models"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             x:Class="HandwerkerImperium.Views.Dialogs.ConfirmDialog"
             x:DataType="vm:DialogViewModel"
             x:CompileBindings="True"
             x:Name="ConfirmDialogRoot">

  <!-- Generic Confirm Dialog (Bottom-Sheet Style) -->
  <Border Background="{StaticResource DialogOverlayBrush}"
          Classes="SheetBackdrop"
          Classes.Open="{Binding IsConfirmDialogVisible}"
          PointerPressed="OnConfirmOverlayPressed"
          AutomationProperties.AutomationId="Main_Overlay_Confirm">
    <Border Classes="ConfirmSheet"
            Classes.Open="{Binding IsConfirmDialogVisible}"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="20,20,0,0"
            Padding="24,12,24,24"
            VerticalAlignment="Bottom"
            BoxShadow="0 -4 16 0 #40000000"
            PointerPressed="OnDialogContentPressed"
            AutomationProperties.AutomationId="Main_Border_ConfirmSheet">
      <StackPanel Spacing="16" HorizontalAlignment="Stretch">
        <!-- v2.1.1 (Audit U-M01): Drag-Handle entfernt — suggerierte Swipe-Dismiss-Funktion
             ohne dass diese implementiert war. Confirm-Dialoge sollten bewusst tap-bestaetigt
             werden (Cancel/Confirm-Buttons), nicht versehentlich weggewischt. -->
        <TextBlock Text="{Binding ConfirmDialogTitle}"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource WarningBrush}"
                   AutomationProperties.AutomationId="Main_Txt_ConfirmTitle" />

        <!-- Prestige Tier-Auswahl-Chips (nur bei mehreren verfügbaren Tiers) -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      IsVisible="{Binding PrestigeConfirmation.IsTierSelectionVisible}"
                      AutomationProperties.AutomationId="Main_Scroll_TierChips">
          <ItemsControl ItemsSource="{Binding PrestigeConfirmation.AvailableTierOptions}"
                        AutomationProperties.AutomationId="Main_Items_TierChips">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:PrestigeTierOption">
                <Button Classes="Text" Padding="12,8" CornerRadius="20"
                        MinHeight="44"
                        CommandParameter="{Binding TierKey}"
                        RenderTransform="scale(1)" RenderTransformOrigin="50%,50%"
                        AutomationProperties.AutomationId="Main_Btn_TierChip">
                  <!-- Command-Binding via $parent zum UserControl-DataContext (MainViewModel) -->
                  <Button.Command>
                    <Binding Path="((vm:DialogViewModel)DataContext).PrestigeConfirmation.SelectTierCommand"
                             ElementName="ConfirmDialogRoot" />
                  </Button.Command>
                  <Button.Background>
                    <SolidColorBrush Color="{Binding Color}" Opacity="0.15" />
                  </Button.Background>
                  <!-- Selektions-Rahmen bei IsSelected -->
                  <Button.Styles>
                    <Style Selector="Button">
                      <Setter Property="BorderThickness" Value="0" />
                    </Style>
                  </Button.Styles>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <icons:GameIcon Kind="{Binding Icon}" Width="18" Height="18">
                      <icons:GameIcon.Foreground>
                        <SolidColorBrush Color="{Binding Color}" />
                      </icons:GameIcon.Foreground>
                    </icons:GameIcon>
                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold">
                      <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding Color}" />
                      </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="{Binding PointsText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <TextBlock Text="{Binding ConfirmDialogMessage}"
                   FontSize="14" TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   AutomationProperties.AutomationId="Main_Txt_ConfirmMessage" />

        <!-- Prestige-Extras: Bonus-PP, Challenge-PP, Speedrun -->
        <StackPanel Spacing="4" IsVisible="{Binding PrestigeConfirmation.IsTierSelectionVisible}"
                    AutomationProperties.AutomationId="Main_Panel_PrestigeExtras">
          <TextBlock Text="{Binding PrestigeConfirmation.BonusPpPreview}" FontSize="12"
                     Foreground="{StaticResource PrestigeGainsBrush}" FontWeight="SemiBold"
                     IsVisible="{Binding PrestigeConfirmation.BonusPpPreview, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <TextBlock Text="{Binding PrestigeConfirmation.ChallengePpPreview}" FontSize="12"
                     Foreground="{StaticResource CraftGoldBrush}" FontWeight="SemiBold"
                     IsVisible="{Binding PrestigeConfirmation.ChallengePpPreview, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <TextBlock Text="{Binding PrestigeConfirmation.CurrentRunDurationText}" FontSize="11"
                     Foreground="{StaticResource TextWhiteMediumBrush}"
                     IsVisible="{Binding PrestigeConfirmation.CurrentRunDurationText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <!-- v2.1.1 (Audit U-C06): Verlust-Liste prominent rot. Frueher waren Verluste nur Teil
             der grauen Confirm-Message und wurden uebersehen — kritisch beim ersten Prestige
             (Spieler verliert 200 Worker etc. ohne klare Vorwarnung). -->
        <Border IsVisible="{Binding PrestigeConfirmation.LossesPreview, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="{StaticResource PrestigeLossesBrush}"
                Opacity="0.18"
                CornerRadius="10"
                Padding="14,10"
                BorderBrush="{StaticResource PrestigeLossesBrush}"
                BorderThickness="1"
                AutomationProperties.AutomationId="Main_Border_PrestigeLosses">
          <StackPanel Spacing="4">
            <TextBlock FontSize="13" FontWeight="Bold"
                       Foreground="{StaticResource PrestigeLossesBrush}"
                       Text="{loc:Translate PrestigeWhatYouLose}"
                       AutomationProperties.AutomationId="Main_Txt_PrestigeLossesHeader" />
            <TextBlock Text="{Binding PrestigeConfirmation.LossesPreview}"
                       FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource PrestigeLossesBrush}"
                       AutomationProperties.AutomationId="Main_Txt_PrestigeLosses" />
          </StackPanel>
        </Border>

        <StackPanel Spacing="8" HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="Main_Panel_ConfirmButtons">
          <Button Classes="Primary" Content="{Binding ConfirmDialogAcceptText}"
                  Command="{Binding ConfirmDialogAcceptCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.AutomationId="Main_Btn_ConfirmAccept" />
          <Button Classes="Secondary" Content="{Binding ConfirmDialogCancelText}"
                  Command="{Binding ConfirmDialogCancelCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  AutomationProperties.AutomationId="Main_Btn_ConfirmCancel" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>

</UserControl>
