<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels"
             xmlns:models="using:HandwerkerImperium.Models"
             xmlns:icons="using:HandwerkerImperium.Icons"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             x:Class="HandwerkerImperium.Views.Guild.GuildAchievementsView"
             x:DataType="vm:GuildViewModel"
             x:CompileBindings="True">

  <Grid RowDefinitions="Auto,*"
        AutomationProperties.AutomationId="GuildAchievements_Grid_Root">

    <!-- ================================================================= -->
    <!-- HEADER                                                            -->
    <!-- ================================================================= -->
    <Border Grid.Row="0" Padding="16,12" CornerRadius="0,0,12,12">
      <Border.Background>
        <StaticResource ResourceKey="CraftHeaderGradientBrush" />
      </Border.Background>
      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
        <!-- Zurück -->
        <Button Grid.Column="0" Classes="Text" Padding="4"
                MinHeight="44" MinWidth="44"
                Command="{Binding NavigateBackCommand}">
          <icons:GameIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource PrimaryContrastBrush}" />
        </Button>
        <!-- Titel -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Center">
          <icons:GameIcon Kind="TrophyOutline" Width="28" Height="28"
                           Foreground="{StaticResource CraftGoldBrush}" />
          <TextBlock Text="{loc:Translate GuildAchievementsTitle}"
                     FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource CraftPrimaryLightBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ================================================================= -->
    <!-- CONTENT                                                           -->
    <!-- ================================================================= -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="8" Margin="16,16,16,80">

        <!-- Leer-Zustand -->
        <StackPanel Spacing="8" HorizontalAlignment="Center"
                    IsVisible="{Binding !HasGuildAchievements}"
                    Margin="0,40,0,0">
          <icons:GameIcon Kind="TrophyBroken" Width="40" Height="40"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Opacity="0.5" />
          <TextBlock Text="{loc:Translate NoGuildAchievements}"
                     FontSize="14"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Achievements-Liste -->
        <ItemsControl ItemsSource="{Binding GuildAchievements}"
                      IsVisible="{Binding HasGuildAchievements}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:GuildAchievementDisplay">
              <Border Classes="Card" Padding="12" Margin="0,0,0,6">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                  <!-- Achievement-Icon -->
                  <Border Width="44" Height="44" CornerRadius="22"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding TierColor}" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="{Binding Icon, Converter={StaticResource IconKindConverter}}"
                                     Width="28" Height="28"
                                     Foreground="{Binding TierColor}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>

                  <!-- Name + Beschreibung + Fortschritt -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Name}"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding Description}"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <!-- Fortschritts-Text -->
                    <TextBlock Text="{Binding ProgressDisplay}"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               IsVisible="{Binding !IsCompleted}" />
                  </StackPanel>

                  <!-- Belohnung / Abgehakt -->
                  <StackPanel Grid.Column="2" VerticalAlignment="Center"
                              HorizontalAlignment="Center" Spacing="2">
                    <icons:GameIcon Kind="CheckCircle" Width="24" Height="24"
                                     Foreground="{DynamicResource SuccessBrush}"
                                     IsVisible="{Binding IsCompleted}"
                                     HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding RewardDisplay}"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource CraftGoldBrush}"
                               HorizontalAlignment="Center" />
                  </StackPanel>

                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>
