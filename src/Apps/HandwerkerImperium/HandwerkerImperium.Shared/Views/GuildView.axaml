<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels"
             xmlns:models="using:HandwerkerImperium.Models"
             xmlns:icons="using:HandwerkerImperium.Icons"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:guildViews="using:HandwerkerImperium.Views.Guild"
             xmlns:auctionViews="using:HandwerkerImperium.Views.Auctions"
             x:Class="HandwerkerImperium.Views.GuildView"
             x:DataType="vm:GuildViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <!-- Tab-Bar aktiver Tab: Hintergrund + Primary-Accent (v2.0.34 Gilde-UX-Refactor) -->
    <Style Selector="Button.Active">
      <Setter Property="Background" Value="{StaticResource CraftPrimaryLightBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.Active icons|GameIcon">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
    </Style>
    <Style Selector="Button.Active TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*"
        AutomationProperties.AutomationId="Guild_Grid_Root">

    <!-- ================================================================= -->
    <!-- HEADER                                                            -->
    <!-- ================================================================= -->
    <Border Grid.Row="0"
            AutomationProperties.AutomationId="Guild_Border_Header"
            Padding="16,12"
            CornerRadius="0,0,12,12">
      <Border.Background>
        <StaticResource ResourceKey="CraftHeaderGradientBrush" />
      </Border.Background>
      <Grid ColumnDefinitions="*,Auto">

        <!-- Titel -->
        <StackPanel
                    AutomationProperties.AutomationId="Guild_Panel_Title"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <icons:GameIcon Kind="AccountGroup" Width="28" Height="28"
                           AutomationProperties.AutomationId="Guild_Icon_Title"
                           Foreground="{StaticResource CraftPrimaryLightBrush}" />
          <TextBlock Text="{Binding Title}"
                     AutomationProperties.AutomationId="Guild_Txt_Title"
                     FontSize="20" FontWeight="Bold"
                     Foreground="{StaticResource CraftPrimaryLightBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Einkommens-Bonus Badge (nur wenn in Gilde) -->
        <Border Grid.Column="1"
                AutomationProperties.AutomationId="Guild_Border_BonusBadge"
                CornerRadius="8" Padding="8,4"
                IsVisible="{Binding IsInGuildState}">
          <Border.Background>
            <SolidColorBrush Color="#D97706" Opacity="0.3" />
          </Border.Background>
          <TextBlock Text="{Binding IncomeBonusDisplay}"
                     AutomationProperties.AutomationId="Guild_Txt_BonusBadge"
                     FontSize="13" FontWeight="Bold"
                     Foreground="{DynamicResource SuccessBrush}" />
        </Border>

      </Grid>
    </Border>

    <!-- ================================================================= -->
    <!-- CONTENT - 6 flache, mutual-exclusive Panels via ViewState         -->
    <!-- ================================================================= -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <!-- Bottom-Margin 84dp: 64dp Tab-Bar + 20dp Abstand -->
      <StackPanel Spacing="16" Margin="16,16,16,84">

        <!-- ============================================================= -->
        <!-- STATE: Loading                                                -->
        <!-- ============================================================= -->
        <StackPanel Spacing="8" HorizontalAlignment="Center"
                    IsVisible="{Binding IsLoadingState}"
                    Margin="0,40,0,0">
          <icons:GameIcon Kind="Loading" Width="32" Height="32"
                           Foreground="{StaticResource CraftPrimaryLightBrush}"
                           HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Translate Loading}"
                     FontSize="14"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ============================================================= -->
        <!-- STATE: Offline                                                -->
        <!-- ============================================================= -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                    MaxWidth="300"
                    IsVisible="{Binding IsOfflineState}"
                    Margin="0,40,0,0"
                    AutomationProperties.AutomationId="Guild_Panel_Offline">
          <icons:GameIcon Kind="WifiOff" Width="48" Height="48" Opacity="0.5"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           AutomationProperties.AutomationId="Guild_Icon_Offline" />
          <TextBlock Text="{loc:Translate GuildOffline}"
                     FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap" TextAlignment="Center"
                     AutomationProperties.AutomationId="Guild_Txt_OfflineTitle" />
          <!-- GUILD-10: Gecachte Gilden-Boni im Offline-State -->
          <TextBlock Text="{Binding CachedBonusInfo}"
                     TextWrapping="Wrap" TextAlignment="Center"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource CraftPrimaryLightBrush}"
                     IsVisible="{Binding CachedBonusInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     AutomationProperties.AutomationId="Guild_Txt_CachedBonus" />
          <TextBlock Text="{loc:Translate GuildOfflineHint}"
                     TextWrapping="Wrap" TextAlignment="Center"
                     Opacity="0.7" FontSize="13"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     AutomationProperties.AutomationId="Guild_Txt_OfflineHint" />
          <Button Classes="Primary"
                  Command="{Binding RetryCommand}"
                  HorizontalAlignment="Center"
                  MinHeight="44" Padding="24,10"
                  Margin="0,8,0,0"
                  AutomationProperties.AutomationId="Guild_Btn_Retry">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <icons:GameIcon Kind="Refresh" Width="20" Height="20" />
              <TextBlock Text="{loc:Translate Retry}" FontSize="14" FontWeight="Bold" />
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- ============================================================= -->
        <!-- STATE: NameDialog                                             -->
        <!-- ============================================================= -->
        <StackPanel Spacing="16"
                    IsVisible="{Binding IsNameDialogState}"
                    Margin="0,20,0,0">

          <!-- Willkommens-Intro: Erklärt warum Gilde und Spielername -->
          <Border Classes="CardElevated" Padding="16">
            <StackPanel Spacing="10">
              <icons:GameIcon Kind="AccountGroup" Width="44" Height="44"
                               Foreground="{StaticResource CraftPrimaryLightBrush}"
                               HorizontalAlignment="Center" />
              <TextBlock Text="{loc:Translate GuildWelcomeTitle}"
                         FontSize="18" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         HorizontalAlignment="Center"
                         TextWrapping="Wrap" TextAlignment="Center" />
              <TextBlock Text="{loc:Translate GuildWelcomeIntro}"
                         FontSize="13" LineHeight="20"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"
                         TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Spielername-Eingabe -->
          <Border Classes="CardElevated" Padding="16">
            <StackPanel Spacing="12">
              <icons:GameIcon Kind="AccountEdit" Width="32" Height="32"
                               Foreground="{StaticResource CraftPrimaryLightBrush}"
                               HorizontalAlignment="Center" />
              <TextBlock Text="{loc:Translate GuildEnterName}"
                         FontSize="16" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         HorizontalAlignment="Center"
                         TextWrapping="Wrap" TextAlignment="Center" />
              <TextBlock Text="{loc:Translate GuildNameHint}"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"
                         TextWrapping="Wrap" TextAlignment="Center" />
              <TextBox Text="{Binding NameInput}"
                       Watermark="{loc:Translate GuildPlayerNamePlaceholder}"
                       MaxLength="20"
                       HorizontalAlignment="Stretch" />
              <Button Classes="Primary"
                      HorizontalAlignment="Center"
                      Command="{Binding ConfirmNameCommand}"
                      Padding="24,8">
                <TextBlock Text="{loc:Translate Confirm}" FontSize="14" FontWeight="Bold" />
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- ============================================================= -->
        <!-- STATE: Browse (Nicht in Gilde, kein Dialog offen)             -->
        <!-- ============================================================= -->
        <StackPanel Spacing="12"
                    IsVisible="{Binding IsBrowseState}">

          <!-- Aktions-Buttons: Gilde gründen + Einladungs-Code -->
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,0,0,4">
            <!-- Gilde gründen Button -->
            <Button Grid.Column="0" Classes="Primary"
                    HorizontalAlignment="Stretch"
                    Command="{Binding ShowCreateDialogCommand}"
                    Padding="12,12">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <icons:GameIcon Kind="Plus" Width="22" Height="22" />
                <TextBlock Text="{loc:Translate GuildCreate}"
                           FontSize="14" FontWeight="Bold" />
              </StackPanel>
            </Button>

            <!-- Einladungs-Code eingeben Button -->
            <Button Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    Command="{Binding ToggleInviteCodeInputCommand}"
                    Padding="12,12">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <icons:GameIcon Kind="EmailPlus" Width="22" Height="22" />
                <TextBlock Text="{loc:Translate EnterInviteCode}"
                           FontSize="14" FontWeight="Bold" />
              </StackPanel>
            </Button>
          </Grid>

          <!-- ── Einladungs-Code-Eingabe (aufklappbar) ── -->
          <Border Classes="Card" Padding="12"
                  IsVisible="{Binding IsInviteCodeInputVisible}" Margin="0,0,0,4">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding JoinCodeInput}"
                       Watermark="{loc:Translate InviteCodePlaceholder}"
                       MaxLength="6"
                       HorizontalAlignment="Stretch" />
              <Button Grid.Column="1" Classes="Primary"
                      Padding="16,8"
                      Command="{Binding JoinByCodeCommand}">
                <TextBlock Text="{loc:Translate JoinGuild}"
                           FontSize="13" FontWeight="Bold" />
              </Button>
            </Grid>
          </Border>

          <!-- ── Einladungs-Inbox (nur sichtbar wenn Einladungen vorhanden) ── -->
          <StackPanel IsVisible="{Binding HasReceivedInvites}" Spacing="8" Margin="0,0,0,4">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
              <icons:GameIcon Kind="EmailPlus" Width="24" Height="24"
                               Foreground="{StaticResource CraftPrimaryLightBrush}" />
              <TextBlock Text="{Binding InvitationsHeaderDisplay}"
                         FontSize="15" FontWeight="Bold"
                         Foreground="{StaticResource CraftPrimaryLightBrush}" />
            </StackPanel>

            <!-- Einladungs-Liste -->
            <ItemsControl ItemsSource="{Binding ReceivedInvites}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:GuildInvitationDisplay">
                  <Border Classes="Card" Padding="12" Margin="0,0,0,8">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="12" RowSpacing="8">

                      <!-- Gilden-Icon -->
                      <Border Grid.RowSpan="2" CornerRadius="12" Width="52" Height="52"
                              VerticalAlignment="Center"
                              Background="{Binding GuildColor, Converter={StaticResource ColorBrushConverter}}">
                        <icons:GameIcon Kind="{Binding GuildIcon, Converter={StaticResource IconKindConverter}}"
                                         Width="28" Height="28"
                                         Foreground="{DynamicResource PrimaryContrastBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>

                      <!-- Name + Info -->
                      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding GuildName}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock FontSize="12"
                                     Foreground="{StaticResource CraftPrimaryLightBrush}">
                            <Run Text="{loc:Translate LevelPrefix}" /><Run Text="{Binding GuildLevel}" />
                          </TextBlock>
                          <TextBlock Text="{Binding MemberDisplay}"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding InvitedByDisplay}"
                                     FontSize="12" FontStyle="Italic"
                                     Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                      </StackPanel>

                      <!-- Annehmen / Ablehnen Buttons -->
                      <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                  HorizontalAlignment="Right">
                        <Button Classes="Primary"
                                Padding="16,6"
                                Command="{Binding $parent[ItemsControl].((vm:GuildViewModel)DataContext).AcceptInviteCommand}"
                                CommandParameter="{Binding .}">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <icons:GameIcon Kind="Check" Width="20" Height="20" />
                            <TextBlock Text="{loc:Translate AcceptInvite}"
                                       FontSize="12" FontWeight="Bold" />
                          </StackPanel>
                        </Button>
                        <Button Padding="16,6"
                                Command="{Binding $parent[ItemsControl].((vm:GuildViewModel)DataContext).DeclineInviteCommand}"
                                CommandParameter="{Binding .}">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <icons:GameIcon Kind="Close" Width="20" Height="20" />
                            <TextBlock Text="{loc:Translate DeclineInvite}"
                                       FontSize="12" />
                          </StackPanel>
                        </Button>
                      </StackPanel>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Trennlinie -->
            <Grid ColumnDefinitions="*,Auto,*" Margin="0,4,0,8">
              <Border Grid.Column="0" Height="1" VerticalAlignment="Center"
                      Background="{DynamicResource TextSecondaryBrush}" Opacity="0.3" />
              <TextBlock Grid.Column="1" Text="{loc:Translate OrSearchGuild}"
                         FontSize="12" Margin="12,0"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                      Background="{DynamicResource TextSecondaryBrush}" Opacity="0.3" />
            </Grid>
          </StackPanel>

          <!-- Offene Gilden Header -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <icons:GameIcon Kind="AccountSearch" Width="22" Height="22"
                             Foreground="{StaticResource CraftPrimaryLightBrush}" />
            <TextBlock Text="{loc:Translate OpenGuilds}"
                       FontSize="15" FontWeight="Bold"
                       Foreground="{StaticResource CraftPrimaryLightBrush}" />
          </StackPanel>

          <!-- Leere Liste -->
          <StackPanel Spacing="8" HorizontalAlignment="Center"
                      IsVisible="{Binding HasNoGuilds}"
                      Margin="0,20,0,0">
            <icons:GameIcon Kind="AccountGroupOutline" Width="40" Height="40"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Translate GuildBrowseEmpty}"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center" />
          </StackPanel>

          <!-- Verfügbare Gilden -->
          <ItemsControl ItemsSource="{Binding AvailableGuilds}"
                        AutomationProperties.AutomationId="Guild_Items_Available">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:GuildListItem">
                <Border Classes="Card"
                        Padding="12" Margin="0,0,0,8">
                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                    <!-- Gilden-Icon -->
                    <Border CornerRadius="12" Width="52" Height="52"
                            VerticalAlignment="Center"
                            Background="{Binding Color, Converter={StaticResource ColorBrushConverter}}">
                      <icons:GameIcon Kind="{Binding Icon, Converter={StaticResource IconKindConverter}}"
                                       Width="28" Height="28"
                                       Foreground="{DynamicResource PrimaryContrastBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <!-- Name + Info + Beschreibung -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="15" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource CraftPrimaryLightBrush}">
                          <Run Text="{loc:Translate LevelPrefix}" /><Run Text="{Binding Level}" />
                        </TextBlock>
                        <TextBlock Text="{Binding MembersDisplay}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <!-- Beschreibung (nur wenn vorhanden) -->
                      <TextBlock Text="{Binding Description}"
                                 FontSize="11" FontStyle="Italic"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextTrimming="CharacterEllipsis"
                                 MaxLines="2" TextWrapping="Wrap"
                                 IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>

                    <!-- Beitreten-Button -->
                    <Button Grid.Column="2"
                            Classes="Primary"
                            Padding="12,8"
                            VerticalAlignment="Center"
                            Command="{Binding $parent[ItemsControl].((vm:GuildViewModel)DataContext).JoinGuildCommand}"
                            CommandParameter="{Binding .}">
                      <TextBlock Text="{loc:Translate JoinGuild}"
                                 FontSize="12" FontWeight="Bold" />
                    </Button>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>

        <!-- ============================================================= -->
        <!-- STATE: CreateDialog                                           -->
        <!-- ============================================================= -->
        <Border Classes="CardElevated"
                IsVisible="{Binding IsCreateDialogState}"
                Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Translate GuildCreateTitle}"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource CraftPrimaryLightBrush}"
                       HorizontalAlignment="Center" />

            <!-- Name -->
            <TextBox Text="{Binding CreateGuildName}"
                     Watermark="{loc:Translate GuildNamePlaceholder}"
                     MaxLength="24"
                     HorizontalAlignment="Stretch" />

            <!-- Vorschau -->
            <Border Width="64" Height="64" CornerRadius="16"
                    HorizontalAlignment="Center" Margin="0,4,0,8"
                    Background="{Binding SelectedColor, Converter={StaticResource ColorBrushConverter}}">
              <icons:GameIcon Kind="{Binding SelectedIcon, Converter={StaticResource IconKindConverter}}"
                               Width="32" Height="32" Foreground="{DynamicResource PrimaryContrastBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <!-- Icon-Auswahl -->
            <TextBlock Text="{loc:Translate GuildSelectIcon}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <ItemsControl ItemsSource="{Binding AvailableIcons}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <Button Padding="8" Margin="4"
                          CornerRadius="8"
                          Command="{Binding $parent[ItemsControl].((vm:GuildViewModel)DataContext).SelectIconCommand}"
                          CommandParameter="{Binding .}">
                    <icons:GameIcon Kind="{Binding ., Converter={StaticResource IconKindConverter}}"
                                     Width="28" Height="28"
                                     Foreground="{StaticResource CraftPrimaryLightBrush}" />
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Farb-Auswahl -->
            <TextBlock Text="{loc:Translate GuildSelectColor}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <ItemsControl ItemsSource="{Binding AvailableColors}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <Button Padding="0" Margin="4"
                          Width="40" Height="40"
                          CornerRadius="20"
                          Command="{Binding $parent[ItemsControl].((vm:GuildViewModel)DataContext).SelectColorCommand}"
                          CommandParameter="{Binding .}">
                    <Border Width="36" Height="36" CornerRadius="18"
                            Background="{Binding ., Converter={StaticResource ColorBrushConverter}}" />
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,16,*" Margin="0,8,0,0">
              <Button Grid.Column="0" Classes="Secondary"
                      HorizontalAlignment="Stretch"
                      Command="{Binding CancelCreateCommand}">
                <TextBlock Text="{loc:Translate Cancel}"
                           FontSize="13" HorizontalAlignment="Center" />
              </Button>
              <Button Grid.Column="2" Classes="Primary"
                      HorizontalAlignment="Stretch"
                      Command="{Binding CreateGuildCommand}">
                <TextBlock Text="{loc:Translate GuildCreate}"
                           FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" />
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <!-- ============================================================= -->
        <!-- STATE: InGuild (Hub-Übersicht mit Navigations-Karten)         -->
        <!-- ============================================================= -->
        <StackPanel Spacing="12"
                    IsVisible="{Binding IsInGuildState}">

          <!-- Gilden-Banner -->
          <Border Classes="CardElevated"
                  AutomationProperties.AutomationId="Guild_Border_CurrentGuild"
                  Padding="16"
                  Background="{Binding CurrentGuildColor, Converter={StaticResource ColorBrushConverter}}">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
              <icons:GameIcon Kind="{Binding CurrentGuildIcon, Converter={StaticResource IconKindConverter}}"
                               Width="40" Height="40"
                               AutomationProperties.AutomationId="Guild_Icon_CurrentGuild"
                               Foreground="{DynamicResource PrimaryContrastBrush}"
                               HorizontalAlignment="Center" />
              <TextBlock Text="{Binding CurrentGuildName}"
                         AutomationProperties.AutomationId="Guild_Txt_CurrentGuildName"
                         FontSize="20" FontWeight="Bold"
                         Foreground="{DynamicResource PrimaryContrastBrush}"
                         HorizontalAlignment="Center" />
              <TextBlock AutomationProperties.AutomationId="Guild_Txt_CurrentGuildLevel"
                         FontSize="14"
                         Foreground="{StaticResource CraftGoldBrush}"
                         HorizontalAlignment="Center">
                <Run Text="{loc:Translate LevelPrefix}" /><Run Text="{Binding GuildLevel}" />
              </TextBlock>
              <TextBlock Text="{Binding IncomeBonusDetailDisplay}"
                         FontSize="12"
                         Foreground="{StaticResource TextWhiteMediumBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- ═══════════════════════════════════════════════════ -->
          <!-- TAB-LEISTE (v2.0.34: 5 Tabs statt 7er Scroll-Liste) -->
          <!-- ═══════════════════════════════════════════════════ -->
          <Border Classes="Card" Padding="4" Margin="0,4,0,4"
                  AutomationProperties.AutomationId="Guild_Border_TabBar">
            <UniformGrid Columns="5" HorizontalAlignment="Stretch">
              <!-- Tab: Übersicht -->
              <Button Classes="Text" Padding="4,8" CornerRadius="8" MinHeight="56"
                      HorizontalAlignment="Stretch" BorderThickness="0"
                      Command="{Binding SelectSubTabCommand}" CommandParameter="Overview"
                      Classes.Active="{Binding IsOverviewTabActive}"
                      AutomationProperties.AutomationId="Guild_Btn_TabOverview">
                <StackPanel Spacing="2" HorizontalAlignment="Center">
                  <icons:GameIcon Kind="Home" Width="22" Height="22"
                                   HorizontalAlignment="Center" />
                  <TextBlock Text="{loc:Translate GuildTabOverview}"
                             FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
              </Button>

              <!-- Tab: Kampf (War + Boss zusammengefasst) -->
              <Button Classes="Text" Padding="4,8" CornerRadius="8" MinHeight="56"
                      HorizontalAlignment="Stretch" BorderThickness="0"
                      Command="{Binding SelectSubTabCommand}" CommandParameter="Combat"
                      Classes.Active="{Binding IsCombatTabActive}"
                      AutomationProperties.AutomationId="Guild_Btn_TabCombat">
                <StackPanel Spacing="2" HorizontalAlignment="Center">
                  <icons:GameIcon Kind="Sword" Width="22" Height="22"
                                   HorizontalAlignment="Center" />
                  <TextBlock Text="{loc:Translate GuildTabCombat}"
                             FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
              </Button>

              <!-- Tab: Forschung -->
              <Button Classes="Text" Padding="4,8" CornerRadius="8" MinHeight="56"
                      HorizontalAlignment="Stretch" BorderThickness="0"
                      Command="{Binding SelectSubTabCommand}" CommandParameter="Research"
                      Classes.Active="{Binding IsResearchTabActive}"
                      AutomationProperties.AutomationId="Guild_Btn_TabResearch">
                <StackPanel Spacing="2" HorizontalAlignment="Center">
                  <icons:GameIcon Kind="FlaskOutline" Width="22" Height="22"
                                   HorizontalAlignment="Center" />
                  <TextBlock Text="{loc:Translate GuildTabResearch}"
                             FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
              </Button>

              <!-- Tab: Chat -->
              <Button Classes="Text" Padding="4,8" CornerRadius="8" MinHeight="56"
                      HorizontalAlignment="Stretch" BorderThickness="0"
                      Command="{Binding SelectSubTabCommand}" CommandParameter="Chat"
                      Classes.Active="{Binding IsChatTabActive}"
                      AutomationProperties.AutomationId="Guild_Btn_TabChat">
                <StackPanel Spacing="2" HorizontalAlignment="Center">
                  <icons:GameIcon Kind="ChatBubble" Width="22" Height="22"
                                   HorizontalAlignment="Center" />
                  <TextBlock Text="{loc:Translate GuildTabChat}"
                             FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
              </Button>

              <!-- Tab: Mitglieder (inkl. Hauptquartier + Erfolge + Einladen) -->
              <Button Classes="Text" Padding="4,8" CornerRadius="8" MinHeight="56"
                      HorizontalAlignment="Stretch" BorderThickness="0"
                      Command="{Binding SelectSubTabCommand}" CommandParameter="Members"
                      Classes.Active="{Binding IsMembersTabActive}"
                      AutomationProperties.AutomationId="Guild_Btn_TabMembers">
                <StackPanel Spacing="2" HorizontalAlignment="Center">
                  <icons:GameIcon Kind="AccountGroup" Width="22" Height="22"
                                   HorizontalAlignment="Center" />
                  <TextBlock Text="{loc:Translate GuildTabMembers}"
                             FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
              </Button>
            </UniformGrid>
          </Border>

          <!-- ═══════════════════════════════════════════════════ -->
          <!-- TAB: Übersicht (Wochen-Ziel + Tipp + Leave)         -->
          <!-- ═══════════════════════════════════════════════════ -->

          <!-- Wochen-Ziel Fortschritt (nur im Overview-Tab) -->
          <Border Classes="Card StatsCard"
                  IsVisible="{Binding IsOverviewTabActive}"
                  AutomationProperties.AutomationId="Guild_Border_WeeklyGoal">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <icons:GameIcon Kind="FlagCheckered" Width="24" Height="24"
                                 Foreground="{StaticResource CraftPrimaryLightBrush}" />
                <TextBlock Text="{loc:Translate WeeklyGoal}"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource CraftPrimaryLightBrush}" />
              </StackPanel>

              <TextBlock Text="{Binding GoalProgressDisplay}"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center" />

              <!-- Beitrag-Slider -->
              <StackPanel Spacing="4" Margin="0,8,0,0">
                <TextBlock Text="{Binding ContributionAmountDisplay}"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource CraftGoldBrush}"
                           HorizontalAlignment="Center" />
                <Slider Minimum="1" Maximum="100"
                        Value="{Binding ContributionPercent}"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="0,4" />
                <Grid ColumnDefinitions="*,*">
                  <TextBlock Text="1%" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Grid.Column="1" Text="100%"
                             FontSize="10" HorizontalAlignment="Right"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </Grid>
              </StackPanel>

              <!-- Beitragen-Button -->
              <Button Classes="Primary" HorizontalAlignment="Center"
                      AutomationProperties.AutomationId="Guild_Btn_Contribute"
                      Command="{Binding ContributeCommand}"
                      Margin="0,6,0,0" MinHeight="44" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <icons:GameIcon Kind="HandCoin" Width="20" Height="20" />
                  <TextBlock Text="{loc:Translate ContributeToGuild}"
                             FontSize="13" FontWeight="Bold" />
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>

          <!-- Kontextueller Tipp (nur im Overview-Tab UND wenn Tipp aktiv) -->
          <Border Classes="Card" Padding="12" Margin="0,0,0,4">
            <Border.IsVisible>
              <MultiBinding Converter="{x:Static BoolConverters.And}">
                <Binding Path="IsOverviewTabActive" />
                <Binding Path="HasActiveTip" />
              </MultiBinding>
            </Border.IsVisible>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
              <icons:GameIcon Kind="LightbulbOnOutline" Width="24" Height="24"
                               Foreground="{StaticResource CraftGoldBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding ActiveTipText}"
                         FontSize="12" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
              <Button Grid.Column="2" Classes="Text" Padding="4"
                      MinHeight="44" MinWidth="44"
                      Command="{Binding DismissTipCommand}">
                <icons:GameIcon Kind="Close" Width="18" Height="18"
                                 Foreground="{DynamicResource TextSecondaryBrush}" />
              </Button>
            </Grid>
          </Border>

          <!-- ═══════════════════════════════════════════════════ -->
          <!-- TAB: KAMPF (Krieg + Boss)                           -->
          <!-- ═══════════════════════════════════════════════════ -->
          <StackPanel Spacing="12" IsVisible="{Binding IsCombatTabActive}">

            <!-- Gilden-Krieg (Saison-Einstieg) -->
            <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{Binding NavigateToWarSeasonCommand}">
              <Border Classes="Card StatsCard" MinHeight="56">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <Border Width="40" Height="40" CornerRadius="10"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="#DC2626" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="Sword" Width="26" Height="26"
                                     Foreground="{DynamicResource ErrorBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{loc:Translate GuildWarTitle}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding WarQuickStatus}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Button>

            <!-- Gilden-Boss -->
            <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{Binding NavigateToBossCommand}">
              <Border Classes="Card StatsCard" MinHeight="56">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <Border Width="40" Height="40" CornerRadius="10"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="#7C3AED" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="Skull" Width="26" Height="26"
                                     Foreground="{StaticResource CraftBossAccentBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{loc:Translate GuildBossTitle}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding BossQuickStatus}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Button>

            <!-- Aktueller Krieg-Detail (nur wenn im War — ersetzt die fruehere doppelte Nav-Karte) -->
            <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{Binding NavigateToWarCommand}"
                    IsVisible="{Binding HasActiveWar}">
              <Border Classes="Card StatsCard" MinHeight="56">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <Border Width="40" Height="40" CornerRadius="10"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="#7F1D1D" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="SwordCross" Width="26" Height="26"
                                     Foreground="{DynamicResource ErrorBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{loc:Translate GuildWarDetailTitle}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding WarSubtitle}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Button>

            <!-- Co-op-Auftraege (v2.1.0) -->
            <guildViews:GuildCoopOrderView DataContext="{Binding CoopOrderVM}"
                                            AutomationProperties.AutomationId="Guild_Combat_CoopOrders" />

            <!-- Worker-Auktion (v2.1.0) -->
            <auctionViews:WorkerAuctionView DataContext="{Binding AuctionVM}"
                                             AutomationProperties.AutomationId="Guild_Combat_Auction" />

            <!-- V7 (Phase 4 Ressourcen-Plan, Plan Section 3.9): Mega-Projekt-Bauplatz -->
            <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{Binding NavigateToBuildSiteCommand}"
                    AutomationProperties.AutomationId="Guild_Combat_BuildSite">
              <Border Classes="Card StatsCard" MinHeight="56">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <Border Width="40" Height="40" CornerRadius="10"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="#D97706" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="OfficeBuilding" Width="26" Height="26"
                                     Foreground="{StaticResource CraftGoldBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{loc:Translate GuildMegaProjectTitle}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{loc:Translate GuildMegaProjectSubtitle}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Button>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════ -->
          <!-- TAB: FORSCHUNG                                      -->
          <!-- ═══════════════════════════════════════════════════ -->
          <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                  IsVisible="{Binding IsResearchTabActive}"
                  Command="{Binding NavigateToResearchCommand}">
            <Border Classes="Card StatsCard" MinHeight="56">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Border Width="40" Height="40" CornerRadius="10"
                        VerticalAlignment="Center">
                  <Border.Background>
                    <SolidColorBrush Color="#EA580C" Opacity="0.15" />
                  </Border.Background>
                  <icons:GameIcon Kind="FlaskOutline" Width="26" Height="26"
                                   Foreground="{StaticResource CraftPrimaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{loc:Translate GuildResearchTitle}"
                             FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding GuildResearchSummary}"
                             FontSize="11" TextTrimming="CharacterEllipsis"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
                <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" />
              </Grid>
            </Border>
          </Button>

          <!-- ═══════════════════════════════════════════════════ -->
          <!-- TAB: CHAT                                           -->
          <!-- ═══════════════════════════════════════════════════ -->
          <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                  IsVisible="{Binding IsChatTabActive}"
                  Command="{Binding NavigateToChatCommand}">
            <Border Classes="Card StatsCard" MinHeight="56">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Border Width="40" Height="40" CornerRadius="10"
                        VerticalAlignment="Center">
                  <Border.Background>
                    <SolidColorBrush Color="{DynamicResource SecondaryColor}" Opacity="0.15" />
                  </Border.Background>
                  <icons:GameIcon Kind="ChatBubble" Width="26" Height="26"
                                   Foreground="{StaticResource CraftChatAccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{loc:Translate GuildChatTitle}"
                             FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ChatSubtitle}"
                             FontSize="11" TextTrimming="CharacterEllipsis"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
                <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" />
              </Grid>
            </Border>
          </Button>

          <!-- ═══════════════════════════════════════════════════ -->
          <!-- TAB: MITGLIEDER (inkl. Hall + Erfolge + Einladen)   -->
          <!-- ═══════════════════════════════════════════════════ -->
          <StackPanel Spacing="12" IsVisible="{Binding IsMembersTabActive}">

            <!-- Mitglieder -->
            <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{Binding NavigateToMembersCommand}">
              <Border Classes="Card StatsCard" MinHeight="56">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <Border Width="40" Height="40" CornerRadius="10"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="{StaticResource CraftPrimaryLightColor}" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="AccountGroup" Width="26" Height="26"
                                     Foreground="{StaticResource CraftPrimaryLightBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding MembersHeaderDisplay}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding MaxMembersDisplay}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Button>

            <!-- Hauptquartier -->
            <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{Binding NavigateToHallCommand}">
              <Border Classes="Card StatsCard" MinHeight="56">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <Border Width="40" Height="40" CornerRadius="10"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="{DynamicResource PrimaryColor}" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="OfficeBuildingCog" Width="26" Height="26"
                                     Foreground="{StaticResource CraftPrimaryBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{loc:Translate GuildHallTitle}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding HallQuickStatus}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Button>

            <!-- Gilden-Erfolge -->
            <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{Binding NavigateToAchievementsCommand}">
              <Border Classes="Card StatsCard" MinHeight="56">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <Border Width="40" Height="40" CornerRadius="10"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="{StaticResource CraftGoldColor}" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="TrophyOutline" Width="26" Height="26"
                                     Foreground="{StaticResource CraftGoldBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{loc:Translate GuildAchievementsTitle}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{loc:Translate GuildAchievementsSubtitle}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Button>

            <!-- Einladen -->
            <Button Classes="Text" Padding="0" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{Binding NavigateToInviteCommand}">
              <Border Classes="Card StatsCard" MinHeight="56">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <Border Width="40" Height="40" CornerRadius="10"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <SolidColorBrush Color="{StaticResource CraftGoldColor}" Opacity="0.15" />
                    </Border.Background>
                    <icons:GameIcon Kind="EmailPlusOutline" Width="26" Height="26"
                                     Foreground="{StaticResource CraftGoldBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{loc:Translate GuildInviteTitle}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{loc:Translate InviteCode}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <icons:GameIcon Grid.Column="2" Kind="ChevronRight" Width="24" Height="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Button>

          </StackPanel>

          <!-- Gilde verlassen (immer sichtbar im InGuild-State) -->
          <Button Classes="Secondary"
                  AutomationProperties.AutomationId="Guild_Btn_Leave"
                  HorizontalAlignment="Center"
                  Command="{Binding LeaveGuildCommand}"
                  Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <icons:GameIcon Kind="ExitToApp" Width="20" Height="20" />
              <TextBlock Text="{loc:Translate LeaveGuild}"
                         FontSize="13" />
            </StackPanel>
          </Button>

        </StackPanel>


      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>
