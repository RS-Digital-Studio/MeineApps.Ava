<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerImperium.ViewModels"
             xmlns:icons="using:HandwerkerImperium.Icons"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:MeineApps.UI.Behaviors"
             xmlns:imp="using:HandwerkerImperium.Views.Imperium"
             x:Class="HandwerkerImperium.Views.ImperiumView"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="True"
             AutomationProperties.AutomationId="Imperium_Root">

  <!-- FadeIn-Animation -->
  <UserControl.Styles>
    <Style Selector="ScrollViewer#ImperiumScrollViewer">
      <Setter Property="(i:Interaction.Behaviors)">
        <i:BehaviorCollection>
          <behaviors:FadeInBehavior Duration="250" SlideFromBottom="True" SlideDistance="12" />
        </i:BehaviorCollection>
      </Setter>
    </Style>
    <!-- Sub-Tab Active-Indication -->
    <Style Selector="Button.SubTabActive">
      <Setter Property="Background" Value="{StaticResource CraftPrimaryLightBrush}" />
    </Style>
    <!-- v2.1.1 (Audit U-C03): Locked-Style fuer Sub-Tabs (Ascension, Warehouse).
         IsEnabled bleibt true (Hint-Tap kommt im Command an), aber visuell gedimmt. -->
    <Style Selector="Button.Locked">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                Name="ImperiumScrollViewer"
                AutomationProperties.AutomationId="Imperium_Scroll_Main">
    <!-- Bottom-Margin 84dp: 64dp Tab-Bar + 20dp Abstand -->
    <StackPanel Spacing="12" Margin="16,16,16,84"
                AutomationProperties.AutomationId="Imperium_Panel_MainContent">

      <!-- HEADER: Titel + Geld-Anzeige -->
      <Grid ColumnDefinitions="*,Auto"
            AutomationProperties.AutomationId="Imperium_Grid_Header">
        <StackPanel Spacing="2">
          <TextBlock Text="{loc:Translate TabImperium}"
                     FontSize="22" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     AutomationProperties.AutomationId="Imperium_Txt_Title" />
          <TextBlock Text="{Binding BuildingsViewModel.BuildingsCountDisplay}"
                     FontSize="12"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     AutomationProperties.AutomationId="Imperium_Txt_BuildingsCount" />
        </StackPanel>
        <Border Grid.Column="1" CornerRadius="16"
                Background="{DynamicResource SurfaceBrush}"
                Padding="12,6" VerticalAlignment="Center"
                AutomationProperties.AutomationId="Imperium_Border_Balance">
          <TextBlock Text="{Binding HeaderVM.MoneyDisplay}"
                     FontSize="13" FontWeight="Bold"
                     Foreground="{DynamicResource SuccessBrush}"
                     AutomationProperties.AutomationId="Imperium_Txt_Balance" />
        </Border>
      </Grid>

      <!-- Sub-Tab-Leiste (Workshops/Lager/Workers/Research/Equipment/Ascension) -->
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="12" Padding="6,6"
              AutomationProperties.AutomationId="Imperium_Border_SubTabs">
        <UniformGrid Columns="6" Rows="1">
          <Button Classes="Text"
                  Classes.SubTabActive="{Binding IsImperiumWorkshopsActive}"
                  Command="{Binding SelectImperiumSubTabCommand}"
                  CommandParameter="Workshops"
                  MinHeight="44" Padding="6,8" CornerRadius="8"
                  AutomationProperties.AutomationId="Imperium_Btn_SubTab_Workshops">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <icons:GameIcon Kind="Hammer" Width="20" Height="20"
                              HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{loc:Translate ImperiumSubTabWorkshops}"
                         FontSize="10" FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Button>
          <!-- V7 (Phase 1 Ressourcen-Plan): Lager-Sub-Tab. Gesperrt bis Spielerlevel 50.
               v2.1.1 (Audit U-C03): IsEnabled=True statt false — der Tap zeigt jetzt einen
               Hint-Toast via SelectImperiumSubTabCommand statt stiller No-Op. -->
          <Button Classes="Text"
                  Classes.SubTabActive="{Binding IsImperiumWarehouseActive}"
                  Classes.Locked="{Binding !IsImperiumWarehouseUnlocked}"
                  Command="{Binding SelectImperiumSubTabCommand}"
                  CommandParameter="Warehouse"
                  MinHeight="44" Padding="6,8" CornerRadius="8"
                  AutomationProperties.AutomationId="Imperium_Btn_SubTab_Warehouse">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <Panel HorizontalAlignment="Center">
                <icons:GameIcon Kind="Warehouse" Width="20" Height="20"
                                HorizontalAlignment="Center"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                <icons:GameIcon Kind="Lock" Width="12" Height="12"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,-4,-4"
                                IsVisible="{Binding !IsImperiumWarehouseUnlocked}"
                                Foreground="{DynamicResource TextSecondaryBrush}" />
              </Panel>
              <TextBlock Text="{loc:Translate ImperiumSubTabWarehouse}"
                         FontSize="10" FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Button>
          <Button Classes="Text"
                  Classes.SubTabActive="{Binding IsImperiumWorkersActive}"
                  Command="{Binding SelectImperiumSubTabCommand}"
                  CommandParameter="Workers"
                  MinHeight="44" Padding="6,8" CornerRadius="8"
                  AutomationProperties.AutomationId="Imperium_Btn_SubTab_Workers">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <icons:GameIcon Kind="AccountGroup" Width="20" Height="20"
                              HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{loc:Translate ImperiumSubTabWorkers}"
                         FontSize="10" FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Button>
          <Button Classes="Text"
                  Classes.SubTabActive="{Binding IsImperiumResearchActive}"
                  Command="{Binding SelectImperiumSubTabCommand}"
                  CommandParameter="Research"
                  MinHeight="44" Padding="6,8" CornerRadius="8"
                  AutomationProperties.AutomationId="Imperium_Btn_SubTab_Research">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <icons:GameIcon Kind="FlaskOutline" Width="20" Height="20"
                              HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{loc:Translate ImperiumSubTabResearch}"
                         FontSize="10" FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Button>
          <Button Classes="Text"
                  Classes.SubTabActive="{Binding IsImperiumEquipmentActive}"
                  Command="{Binding SelectImperiumSubTabCommand}"
                  CommandParameter="Equipment"
                  MinHeight="44" Padding="6,8" CornerRadius="8"
                  AutomationProperties.AutomationId="Imperium_Btn_SubTab_Equipment">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <icons:GameIcon Kind="Wrench" Width="20" Height="20"
                              HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{loc:Translate ImperiumSubTabEquipment}"
                         FontSize="10" FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Button>
          <!-- Ascension-Tab IMMER sichtbar (kein Layout-Sprung beim Unlock). -->
          <!-- Vor Unlock: gedimmt + Lock-Icon, NICHT klickbar. Nach Unlock: voll sichtbar + klickbar. -->
          <!-- v2.1.1 (Audit U-C03): IsEnabled=True lassen, damit der Tap ankommt und der
               SelectImperiumSubTabCommand einen Hint-Toast zeigen kann. Vorher disabled
               + stiller No-Op → Spieler wusste nicht warum nichts passiert.
               Locked-State visuell durch die "Locked"-Klasse + Lock-Icon dargestellt. -->
          <Button Classes="Text"
                  Classes.SubTabActive="{Binding IsImperiumAscensionActive}"
                  Classes.Locked="{Binding !IsImperiumAscensionUnlocked}"
                  Command="{Binding SelectImperiumSubTabCommand}"
                  CommandParameter="Ascension"
                  MinHeight="44" Padding="6,8" CornerRadius="8"
                  AutomationProperties.AutomationId="Imperium_Btn_SubTab_Ascension">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <Panel HorizontalAlignment="Center">
                <icons:GameIcon Kind="Star" Width="20" Height="20"
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource CraftGoldBrush}" />
                <icons:GameIcon Kind="Lock" Width="12" Height="12"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,-4,-4"
                                IsVisible="{Binding !IsImperiumAscensionUnlocked}"
                                Foreground="{DynamicResource TextSecondaryBrush}" />
              </Panel>
              <TextBlock Text="{loc:Translate ImperiumSubTabAscension}"
                         FontSize="10" FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Foreground="{StaticResource CraftGoldBrush}" />
            </StackPanel>
          </Button>
        </UniformGrid>
      </Border>

      <!-- Sub-Tab-Inhalte (eigenständige UserControls) -->
      <imp:WorkshopsSection IsVisible="{Binding IsImperiumWorkshopsActive}" />
      <imp:WarehouseSection IsVisible="{Binding IsImperiumWarehouseActive}" />
      <imp:ResearchSection IsVisible="{Binding IsImperiumResearchActive}" />
      <imp:WorkersSection IsVisible="{Binding IsImperiumWorkersActive}" />
      <imp:EquipmentSection IsVisible="{Binding IsImperiumEquipmentActive}" />
      <imp:AscensionSection IsVisible="{Binding IsImperiumAscensionActive}" />

      <!-- Bottom-Spacer für kleine Screens -->
      <Border Height="24" />

    </StackPanel>
  </ScrollViewer>

</UserControl>
