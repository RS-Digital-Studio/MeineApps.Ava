<Styles xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- HandwerkerRechner - "Blueprint Professional"                           -->
  <!-- Blueprint-Blau Premium-Dark mit Handwerker-Amber-Akzenten             -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->

  <Style>
    <Style.Resources>
      <!-- Primary Colors -->
      <Color x:Key="PrimaryColor">#3B82F6</Color>
      <Color x:Key="PrimaryHoverColor">#60A5FA</Color>
      <Color x:Key="PrimaryPressedColor">#2563EB</Color>
      <Color x:Key="PrimaryContrastColor">#FFFFFF</Color>

      <!-- Secondary Colors -->
      <Color x:Key="SecondaryColor">#F59E0B</Color>
      <Color x:Key="SecondaryHoverColor">#FBBF24</Color>
      <Color x:Key="SecondaryPressedColor">#D97706</Color>

      <!-- Accent Colors -->
      <Color x:Key="AccentColor">#22C55E</Color>
      <Color x:Key="AccentHoverColor">#4ADE80</Color>

      <!-- Background Colors (Premium Dark - deutliche Kontraststufen) -->
      <Color x:Key="BackgroundColor">#182640</Color>
      <Color x:Key="SurfaceColor">#223656</Color>
      <Color x:Key="CardColor">#2E4870</Color>
      <Color x:Key="CardHoverColor">#3A5A88</Color>

      <!-- Text Colors (heller für bessere Lesbarkeit) -->
      <Color x:Key="TextPrimaryColor">#E8F0FA</Color>
      <Color x:Key="TextSecondaryColor">#B0C8E0</Color>
      <Color x:Key="TextMutedColor">#80A0B8</Color>
      <Color x:Key="TextDisabledColor">#607890</Color>

      <!-- Border Colors (deutlich sichtbar) -->
      <Color x:Key="BorderColor">#3C6090</Color>
      <Color x:Key="BorderSubtleColor">#2E4870</Color>
      <Color x:Key="BorderFocusColor">#3B82F6</Color>

      <!-- Semantic Colors -->
      <Color x:Key="SuccessColor">#22C55E</Color>
      <Color x:Key="SuccessBackgroundColor">#14532D</Color>
      <Color x:Key="WarningColor">#F59E0B</Color>
      <Color x:Key="WarningBackgroundColor">#78350F</Color>
      <Color x:Key="ErrorColor">#EF4444</Color>
      <Color x:Key="ErrorBackgroundColor">#7F1D1D</Color>
      <Color x:Key="InfoColor">#3B82F6</Color>
      <Color x:Key="InfoBackgroundColor">#1E3A8A</Color>

      <!-- Shadow / Overlay -->
      <Color x:Key="ShadowColor">#000000</Color>
      <Color x:Key="OverlayColor">#80000000</Color>
      <Color x:Key="RippleColor">#20FFFFFF</Color>

      <!-- Gradient -->
      <Color x:Key="GradientStartColor">#223656</Color>
      <Color x:Key="GradientMidColor">#182640</Color>
      <Color x:Key="GradientEndColor">#141E48</Color>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- BRUSHES                                                        -->
      <!-- ═══════════════════════════════════════════════════════════════ -->

      <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
      <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{DynamicResource PrimaryHoverColor}" />
      <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{DynamicResource PrimaryPressedColor}" />
      <SolidColorBrush x:Key="PrimaryContrastBrush" Color="{DynamicResource PrimaryContrastColor}" />

      <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource SecondaryColor}" />
      <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />

      <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
      <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
      <SolidColorBrush x:Key="CardBrush" Color="{DynamicResource CardColor}" />
      <SolidColorBrush x:Key="CardHoverBrush" Color="{DynamicResource CardHoverColor}" />

      <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
      <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMutedColor}" />
      <SolidColorBrush x:Key="TextDisabledBrush" Color="{DynamicResource TextDisabledColor}" />

      <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="{DynamicResource BorderSubtleColor}" />
      <SolidColorBrush x:Key="BorderFocusBrush" Color="{DynamicResource BorderFocusColor}" />

      <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
      <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="{DynamicResource SuccessBackgroundColor}" />
      <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
      <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{DynamicResource WarningBackgroundColor}" />
      <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}" />
      <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{DynamicResource ErrorBackgroundColor}" />
      <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}" />
      <SolidColorBrush x:Key="InfoBackgroundBrush" Color="{DynamicResource InfoBackgroundColor}" />

      <SolidColorBrush x:Key="OverlayBrush" Color="{DynamicResource OverlayColor}" />
      <SolidColorBrush x:Key="RippleBrush" Color="{DynamicResource RippleColor}" />

      <!-- Box Shadows (sichtbar auf helleren Surfaces) -->
      <BoxShadows x:Key="CardShadow">0 2 8 0 #40000000, 0 1 4 0 #30000000</BoxShadows>
      <BoxShadows x:Key="CardShadowHover">0 4 12 -1 #50000000, 0 2 6 -1 #40000000</BoxShadows>
      <BoxShadows x:Key="ElevatedShadow">0 10 20 -3 #40000000, 0 4 8 -2 #30000000</BoxShadows>
      <BoxShadows x:Key="ModalShadow">0 20 30 -5 #50000000, 0 10 15 -5 #40000000</BoxShadows>

      <!-- Header-Gradient (Blueprint-Blau): zentral für Hero + alle 19 Calculator-Header.
           Eine Stelle ändern → gesamte App-Kopfzeilen folgen (Farbkohärenz). -->
      <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#3B82F6" Offset="0" />
        <GradientStop Color="#2563EB" Offset="0.55" />
        <GradientStop Color="#1E3A8A" Offset="1" />
      </LinearGradientBrush>

      <!-- Premium-Gradient (Gold): hochwertiges, eigenständiges Signal für Kauf-Elemente. -->
      <LinearGradientBrush x:Key="PremiumGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#FBBF24" Offset="0" />
        <GradientStop Color="#F59E0B" Offset="0.5" />
        <GradientStop Color="#D97706" Offset="1" />
      </LinearGradientBrush>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- APP-LOKALE FONT-TOKENS (Lücken der ThemeColors-Skala, Werte exakt) -->
      <!-- ═══════════════════════════════════════════════════════════════ -->

      <!-- 15: hervorgehobene Labels (Premium-Card-Titel, Vorlagen-Namen, Quote-Summen) -->
      <x:Double x:Key="FontSizeLabelXl">15</x:Double>
      <!-- 20: Header-Titel aller Calculator-/Tab-Header -->
      <x:Double x:Key="FontSizeHeadlineSm">20</x:Double>
      <!-- 26: große Ergebnis-Zahl (AreaMeasure Gesamtfläche) -->
      <x:Double x:Key="FontSizeDisplaySm">26</x:Double>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- ON-GRADIENT-FARBEN (weiße Akzente auf Header-/Premium-Gradients) -->
      <!-- ═══════════════════════════════════════════════════════════════ -->

      <!-- Icon-Chip-Hintergrund in allen Headern (rundes Chip hinter Material-Icon) -->
      <Color x:Key="HeaderChipColor">#33FFFFFF</Color>
      <SolidColorBrush x:Key="HeaderChipBrush" Color="{DynamicResource HeaderChipColor}" />

      <!-- Subtext unter Header-Titeln (Calculator-Header, Premium-Card-Preis) -->
      <Color x:Key="OnGradientSubtextColor">#CCFFFFFF</Color>
      <SolidColorBrush x:Key="OnGradientSubtextBrush" Color="{DynamicResource OnGradientSubtextColor}" />

      <!-- Hero-Header App-Beschreibung -->
      <Color x:Key="OnGradientSubtitleColor">#BBFFFFFF</Color>
      <SolidColorBrush x:Key="OnGradientSubtitleBrush" Color="{DynamicResource OnGradientSubtitleColor}" />

      <!-- Icon-Akzent auf Gradient (Premium-Card Chevron) -->
      <Color x:Key="OnGradientIconColor">#AAFFFFFF</Color>
      <SolidColorBrush x:Key="OnGradientIconBrush" Color="{DynamicResource OnGradientIconColor}" />

      <!-- Tertiärtext auf Gradient (Hero-Header Rechner-Anzahl) -->
      <Color x:Key="OnGradientMutedColor">#99FFFFFF</Color>
      <SolidColorBrush x:Key="OnGradientMutedBrush" Color="{DynamicResource OnGradientMutedColor}" />

      <!-- Lila-Akzent (Vorlagen-Badges, MaterialCompare-Chip) -->
      <Color x:Key="PurpleAccentColor">#A855F7</Color>
      <SolidColorBrush x:Key="PurpleAccentBrush" Color="{DynamicResource PurpleAccentColor}" />

      <!-- Tab-Header-Gradients (History/Projects haben eigene Akzent-Gradients) -->
      <LinearGradientBrush x:Key="HistoryHeaderGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#6366F1" Offset="0" />
        <GradientStop Color="#4F46E5" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="ProjectsHeaderGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#10B981" Offset="0" />
        <GradientStop Color="#0891B2" Offset="1" />
      </LinearGradientBrush>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- KACHEL-ICON-GRADIENTS (Kategorie-Farbsystem, je Rechner ein Token) -->
      <!-- Identische Werte = gleiche Kategorie-Farbe; Hero-Value-Boxen in   -->
      <!-- CableSizing/Insulation/Plaster/Screed nutzen dieselben Brushes.   -->
      <!-- ═══════════════════════════════════════════════════════════════ -->

      <LinearGradientBrush x:Key="TileGradientTileBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#F59E0B" Offset="0" />
        <GradientStop Color="#D97706" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientWallpaperBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#8B5CF6" Offset="0" />
        <GradientStop Color="#7C3AED" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientPaintBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#22C55E" Offset="0" />
        <GradientStop Color="#16A34A" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientFlooringBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#3B82F6" Offset="0" />
        <GradientStop Color="#2563EB" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientConcreteBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#78716C" Offset="0" />
        <GradientStop Color="#57534E" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientDrywallBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#EF4444" Offset="0" />
        <GradientStop Color="#DC2626" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientElectricalBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#F97316" Offset="0" />
        <GradientStop Color="#EA580C" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientMetalBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#6B7280" Offset="0" />
        <GradientStop Color="#4B5563" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientGardenBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#10B981" Offset="0" />
        <GradientStop Color="#059669" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientRoofSolarBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#06B6D4" Offset="0" />
        <GradientStop Color="#0891B2" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientStairsBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#A855F7" Offset="0" />
        <GradientStop Color="#9333EA" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientPlasterBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#F97316" Offset="0" />
        <GradientStop Color="#EA580C" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientScreedBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#78716C" Offset="0" />
        <GradientStop Color="#57534E" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientInsulationBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#14B8A6" Offset="0" />
        <GradientStop Color="#0D9488" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientCableSizingBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#F59E0B" Offset="0" />
        <GradientStop Color="#D97706" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientGroutBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#EC4899" Offset="0" />
        <GradientStop Color="#DB2777" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientHourlyRateBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#22C55E" Offset="0" />
        <GradientStop Color="#16A34A" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientMaterialCompareBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#8B5CF6" Offset="0" />
        <GradientStop Color="#7C3AED" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientAreaMeasureBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#3B82F6" Offset="0" />
        <GradientStop Color="#2563EB" Offset="1" />
      </LinearGradientBrush>

      <!-- Business-Schnellzugriff-Kacheln (MainView unten) -->
      <LinearGradientBrush x:Key="TileGradientTemplatesBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#10B981" Offset="0" />
        <GradientStop Color="#059669" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TileGradientQuoteBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#F59E0B" Offset="0" />
        <GradientStop Color="#D97706" Offset="1" />
      </LinearGradientBrush>

      <!-- Theme Identifier -->
      <x:String x:Key="ThemeName">HandwerkerRechner</x:String>
      <x:Boolean x:Key="IsDarkTheme">True</x:Boolean>
    </Style.Resources>
  </Style>

</Styles>
