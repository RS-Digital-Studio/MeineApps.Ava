<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerRechner.ViewModels.Floor"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:skia="using:Avalonia.Labs.Controls"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:MeineApps.UI.Behaviors"
             x:Class="HandwerkerRechner.Views.Floor.TileCalculatorView"
             x:DataType="vm:TileCalculatorViewModel"
             x:CompileBindings="True">

  <Grid AutomationProperties.AutomationId="Tile_RootGrid" RowDefinitions="Auto,*,Auto">

    <!-- ============================================ -->
    <!-- Row 0: Header with Back Button + Title       -->
    <!-- ============================================ -->
    <Border AutomationProperties.AutomationId="Tile_Header"
            Grid.Row="0"
            Background="{DynamicResource HeaderGradientBrush}"
            Padding="16,12,16,20"
            CornerRadius="0,0,24,24">
      <Grid ColumnDefinitions="Auto,*">
        <Button AutomationProperties.AutomationId="Tile_BtnBack"
                Command="{Binding GoBackCommand}"
                Background="{DynamicResource HeaderChipBrush}"
                CornerRadius="20"
                Width="40" Height="40"
                Padding="0">
          <mi:MaterialIcon Kind="ArrowLeft" Width="22" Height="22" Foreground="White" />
        </Button>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                    Margin="12,0,0,0" VerticalAlignment="Center">
          <Border Background="{DynamicResource HeaderChipBrush}" CornerRadius="12" Width="40" Height="40">
            <mi:MaterialIcon Kind="ViewDashboard" Width="22" Height="22"
                             Foreground="White"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock AutomationProperties.AutomationId="Tile_TxtTitle"
                     Text="{loc:Translate CalcTiles}"
                     FontSize="{StaticResource FontSizeHeadlineSm}" FontWeight="Bold" Foreground="White"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ============================================ -->
    <!-- Row 1: Scrollable Content                    -->
    <!-- ============================================ -->
    <ScrollViewer AutomationProperties.AutomationId="Tile_ScrollContent" Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16" Margin="16,16,16,200">

        <!-- Input Section: Room Dimensions -->
        <Border AutomationProperties.AutomationId="Tile_CardRoomDimensions" Classes="Card StatsCard">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Translate RoomDimensions}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- Room Length -->
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Translate RoomLength}"
                         FontSize="{StaticResource FontSizeBodySm}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox AutomationProperties.AutomationId="Tile_TxtBoxRoomLength"
                       Text="{Binding RoomLength}"
                       PlaceholderText="m"
                       Classes="Outlined" />
            </StackPanel>

            <!-- Room Width -->
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Translate RoomWidth}"
                         FontSize="{StaticResource FontSizeBodySm}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox AutomationProperties.AutomationId="Tile_TxtBoxRoomWidth"
                       Text="{Binding RoomWidth}"
                       PlaceholderText="m"
                       Classes="Outlined" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Input Section: Tile Dimensions -->
        <Border AutomationProperties.AutomationId="Tile_CardTileDimensions" Classes="Card StatsCard">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Translate TileDimensions}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- Tile Length -->
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Translate TileLength}"
                         FontSize="{StaticResource FontSizeBodySm}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox AutomationProperties.AutomationId="Tile_TxtBoxTileLength"
                       Text="{Binding TileLength}"
                       PlaceholderText="cm"
                       Classes="Outlined" />
            </StackPanel>

            <!-- Tile Width -->
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Translate TileWidth}"
                         FontSize="{StaticResource FontSizeBodySm}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox AutomationProperties.AutomationId="Tile_TxtBoxTileWidth"
                       Text="{Binding TileWidth}"
                       PlaceholderText="cm"
                       Classes="Outlined" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Input Section: Additional Options -->
        <Border AutomationProperties.AutomationId="Tile_CardCost" Classes="Card StatsCard">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Translate CostCalculation}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- Waste Percentage -->
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Translate Waste}"
                         FontSize="{StaticResource FontSizeBodySm}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox AutomationProperties.AutomationId="Tile_TxtBoxWaste"
                       Text="{Binding WastePercentage}"
                       PlaceholderText="%"
                       Classes="Outlined" />
            </StackPanel>

            <!-- Price Per Tile (optional) -->
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Translate PricePerTile}"
                         FontSize="{StaticResource FontSizeBodySm}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox AutomationProperties.AutomationId="Tile_TxtBoxPrice"
                       Text="{Binding PricePerTile}"
                       PlaceholderText="{loc:Translate CurrencySymbol}"
                       Classes="Outlined" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Fugenbreite -->
        <Border AutomationProperties.AutomationId="Tile_CardGrout" Classes="Card StatsCard">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Translate GroutWidth}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
              <Slider AutomationProperties.AutomationId="Tile_SliderGroutWidth"
                      Minimum="1" Maximum="10"
                      Value="{Binding GroutWidthMm}"
                      TickFrequency="0.5"
                      IsSnapToTickEnabled="True" />
              <TextBlock Grid.Column="1"
                         Text="{Binding GroutWidthMm, StringFormat='{}{0:F1} mm'}"
                         FontSize="{StaticResource FontSizeBodyMd}" FontWeight="SemiBold"
                         Foreground="{DynamicResource PrimaryBrush}"
                         VerticalAlignment="Center"
                         Margin="12,0,0,0"
                         MinWidth="55" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Visualisierung -->
        <Border AutomationProperties.AutomationId="Tile_CardVisualization" Classes="Card" Padding="0" Height="220" Margin="0,0,0,0"
                IsVisible="{Binding HasResult}" ClipToBounds="True" CornerRadius="12">
          <skia:SKCanvasView AutomationProperties.AutomationId="Tile_Canvas" x:Name="TileCanvas" PaintSurface="OnPaintVisualization" />
        </Border>

        <!-- Results Section -->
        <Border AutomationProperties.AutomationId="Tile_CardResult"
                Classes="Card Elevated StatsCard"
                IsVisible="{Binding HasResult}">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Translate Result}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}" />

            <!-- Hero-Value: Fliesen inkl. Verschnitt -->
            <Border Background="{DynamicResource AccentBrush}" CornerRadius="12" Padding="16,12"
                    Margin="0,4,0,8">
              <StackPanel>
                <TextBlock Text="{loc:Translate TilesWithWaste}" FontSize="{StaticResource FontSizeLabelMd}"
                           Foreground="{DynamicResource OnGradientSubtextBrush}" />
                <TextBlock AutomationProperties.AutomationId="Tile_TxtTilesWithWaste"
                           Text="{Binding TilesWithWasteDisplay}" FontSize="{StaticResource FontSizeHeadlineMd}" FontWeight="Bold"
                           Foreground="White">
                  <i:Interaction.Behaviors>
                    <behaviors:CountUpBehavior TargetValue="{Binding Result.TilesWithWaste}" Format="F0" Duration="500" />
                  </i:Interaction.Behaviors>
                </TextBlock>
              </StackPanel>
            </Border>

            <!-- Area -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{loc:Translate TotalArea}"
                         FontSize="{StaticResource FontSizeBodyMd}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock AutomationProperties.AutomationId="Tile_TxtArea"
                         Grid.Column="1"
                         Text="{Binding AreaDisplay}"
                         FontSize="{StaticResource FontSizeBodyMd}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </Grid>

            <!-- Tiles Needed -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{loc:Translate TilesNeeded}"
                         FontSize="{StaticResource FontSizeBodyMd}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock AutomationProperties.AutomationId="Tile_TxtTilesNeeded"
                         Grid.Column="1"
                         Text="{Binding TilesNeededDisplay}"
                         FontSize="{StaticResource FontSizeBodyMd}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </Grid>

            <!-- Total Cost (only when ShowCost) -->
            <Grid ColumnDefinitions="*,Auto"
                  IsVisible="{Binding ShowCost}">
              <TextBlock Grid.Column="0"
                         Text="{loc:Translate TotalCost}"
                         FontSize="{StaticResource FontSizeBodyMd}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock AutomationProperties.AutomationId="Tile_TxtTotalCost"
                         Grid.Column="1"
                         Text="{Binding TotalCostDisplay}"
                         FontSize="{StaticResource FontSizeBodyMd}" FontWeight="SemiBold"
                         Foreground="{DynamicResource PrimaryBrush}" />
            </Grid>

            <!-- Fugenmasse -->
            <Grid ColumnDefinitions="*,Auto"
                  IsVisible="{Binding GroutMassDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Grid.Column="0"
                         Text="{loc:Translate GroutMass}"
                         FontSize="{StaticResource FontSizeBodyMd}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock AutomationProperties.AutomationId="Tile_TxtGroutMass"
                         Grid.Column="1"
                         Text="{Binding GroutMassDisplay}"
                         FontSize="{StaticResource FontSizeBodyMd}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </Grid>

            <!-- Aktions-Buttons: Share + PDF Export -->
            <Grid ColumnDefinitions="*,8,*,8,Auto" Margin="0,4,0,0">
              <Button AutomationProperties.AutomationId="Tile_BtnShare"
                      Grid.Column="0"
                      Command="{Binding ShareResultCommand}"
                      Classes="Outlined"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <mi:MaterialIcon Kind="ContentCopy" Width="16" Height="16"
                                   Foreground="{DynamicResource AccentBrush}" />
                  <TextBlock Text="{loc:Translate ShareResult}"
                             FontSize="{StaticResource FontSizeLabelMd}" TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button AutomationProperties.AutomationId="Tile_BtnExport"
                      Grid.Column="2"
                      Command="{Binding ExportMaterialListCommand}"
                      Classes="Outlined"
                      IsEnabled="{Binding !IsExporting}"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <mi:MaterialIcon Kind="FilePdfBox" Width="16" Height="16"
                                   Foreground="{DynamicResource AccentBrush}" />
                  <TextBlock Text="{loc:Translate ExportMaterialList}"
                             FontSize="{StaticResource FontSizeLabelMd}" TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="4" Command="{Binding ExportCsvCommand}" Classes="Text" Padding="8"
                      AutomationProperties.AutomationId="Tile_BtnExportCsv">
                <mi:MaterialIcon Kind="FileDelimited" Width="20" Height="20"
                                 Foreground="{DynamicResource AccentBrush}" />
              </Button>
            </Grid>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- ============================================ -->
    <!-- Row 2: Action Buttons                        -->
    <!-- ============================================ -->
    <Border AutomationProperties.AutomationId="Tile_ActionBar" Grid.Row="2" Padding="16,12" Background="{DynamicResource BackgroundBrush}">
      <Grid ColumnDefinitions="*,8,*,8,*">
        <!-- Reset -->
        <Button AutomationProperties.AutomationId="Tile_BtnReset"
                Grid.Column="0"
                Classes="Outlined"
                Command="{Binding ResetCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="Refresh" Width="16" Height="16"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="{loc:Translate Reset}"
                       FontSize="{StaticResource FontSizeLabelMd}" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Calculate -->
        <Button AutomationProperties.AutomationId="Tile_BtnCalculate"
                Grid.Column="2"
                Classes="Primary"
                Command="{Binding CalculateCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="Calculator" Width="16" Height="16" />
            <TextBlock Text="{loc:Translate Calculate}"
                       FontSize="{StaticResource FontSizeLabelMd}" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Save Project -->
        <Button AutomationProperties.AutomationId="Tile_BtnSave"
                Grid.Column="4"
                Classes="Secondary"
                Command="{Binding SaveProjectCommand}"
                IsVisible="{Binding HasResult}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16" />
            <TextBlock Text="{loc:Translate Save}"
                       FontSize="{StaticResource FontSizeLabelMd}" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Save Project Dialog Overlay -->
    <Border AutomationProperties.AutomationId="Tile_SaveOverlay"
            Grid.Row="0" Grid.RowSpan="3"
            ZIndex="100"
            Background="{DynamicResource OverlayBrush}"
            IsVisible="{Binding ShowSaveDialog}">
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="16"
              Padding="24"
              MaxWidth="340"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="16">
          <TextBlock Text="{loc:Translate SaveProject}"
                     FontSize="{StaticResource FontSizeTitleSm}" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     HorizontalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="Tile_TxtBoxProjectName"
                   Text="{Binding SaveProjectName}"
                   PlaceholderText="{loc:Translate ProjectName}"
                   Classes="Outlined" />
          <Grid ColumnDefinitions="*,12,*">
            <Button AutomationProperties.AutomationId="Tile_BtnCancelSave"
                    Grid.Column="0"
                    Classes="Outlined"
                    Command="{Binding CancelSaveProjectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{loc:Translate Cancel}" />
            <Button AutomationProperties.AutomationId="Tile_BtnConfirmSave"
                    Grid.Column="2"
                    Classes="Primary"
                    Command="{Binding ConfirmSaveProjectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{loc:Translate Save}" />
          </Grid>
        </StackPanel>
      </Border>
    </Border>

  </Grid>

</UserControl>
