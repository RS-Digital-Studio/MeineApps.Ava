                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavHourlyRate}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavHourlyRate}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>

                  <!-- Material-Vergleich -->
                  <Button AutomationProperties.AutomationId="Main_BtnMaterialCompare"
                          Grid.Row="6" Grid.Column="0"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToMaterialCompareCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="510" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <Panel>
                      <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Border CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                              <GradientStop Color="#8B5CF6" Offset="0" />
                              <GradientStop Color="#7C3AED" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <mi:MaterialIcon Kind="ScaleBalance" Width="24" Height="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding CalcMaterialCompareLabel}"
                                   FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CalcMaterialCompareDescLabel}"
                                   FontSize="11" TextAlignment="Center" MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <Button Classes="Text" Padding="0" MinWidth="44" MinHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                              Command="{Binding ToggleFavoriteCommand}" CommandParameter="MaterialComparePage">
                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavMaterialCompare}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavMaterialCompare}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>

                  <!-- Aufmaß-Rechner -->
                  <Button AutomationProperties.AutomationId="Main_BtnAreaMeasure"
                          Grid.Row="6" Grid.Column="1"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToAreaMeasureCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="540" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <Panel>
                      <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Border CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                              <GradientStop Color="#3B82F6" Offset="0" />
                              <GradientStop Color="#2563EB" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <mi:MaterialIcon Kind="RulerSquare" Width="24" Height="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding CalcAreaMeasureLabel}"
                                   FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CalcAreaMeasureDescLabel}"
                                   FontSize="11" TextAlignment="Center" MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <Button Classes="Text" Padding="0" MinWidth="44" MinHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                              Command="{Binding ToggleFavoriteCommand}" CommandParameter="AreaMeasurePage">
                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavAreaMeasure}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavAreaMeasure}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>
                </Grid>
              </StackPanel>

              <!-- ========== Section: Business-Werkzeuge ========== -->
              <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Background="#10B981" CornerRadius="6" Padding="8,4">
                    <TextBlock Text="{Binding SectionBusinessText}" FontSize="11" FontWeight="Bold" Foreground="White" />
                  </Border>
                </StackPanel>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                  <!-- Vorlagen -->
                  <Button Grid.Column="0" CornerRadius="12" Height="100" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToTemplatesCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="570" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                      <Border CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Center">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#10B981" Offset="0" />
                            <GradientStop Color="#059669" Offset="1" />
                          </LinearGradientBrush>
                        </Border.Background>
                        <mi:MaterialIcon Kind="FileDocumentMultipleOutline" Width="22" Height="22"
                                         Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Text="{Binding TemplatesLabel}" FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                  </Button>

                  <!-- Angebote -->
                  <Button Grid.Column="1" CornerRadius="12" Height="100" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToQuotesCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="600" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                      <Border CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Center">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#F59E0B" Offset="0" />
                            <GradientStop Color="#D97706" Offset="1" />
                          </LinearGradientBrush>
                        </Border.Background>
                        <mi:MaterialIcon Kind="FileDocumentEditOutline" Width="22" Height="22"
                                         Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Text="{Binding QuotesLabel}" FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                  </Button>
                </Grid>
              </StackPanel>



            </StackPanel>

            <!-- Abstand unten (200dp fuer Ad-Banner Overlay + Scroll-Komfort) -->
            <Border Height="200" />

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Tab 1: Projects -->
      <Border AutomationProperties.AutomationId="Main_TabProjects"
              Classes="TabContent"
              Classes.Active="{Binding IsProjectsTab}">
        <ContentControl Content="{Binding ProjectsViewModel}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Tab 2: History -->
      <Border AutomationProperties.AutomationId="Main_TabHistory"
              Classes="TabContent"
              Classes.Active="{Binding IsHistoryTab}">
        <ContentControl Content="{Binding HistoryViewModel}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Tab 3: Settings -->
      <Border AutomationProperties.AutomationId="Main_TabSettings"
              Classes="TabContent"
              Classes.Active="{Binding IsSettingsTab}">
        <ContentControl Content="{Binding SettingsViewModel}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
      </Border>

      <!-- Calculator Overlay -->
      <Panel AutomationProperties.AutomationId="Main_CalculatorOverlay"
             IsVisible="{Binding IsCalculatorOpen}"
             ZIndex="50"
             Background="{DynamicResource BackgroundBrush}">
        <ContentControl AutomationProperties.AutomationId="Main_CalculatorContent" Content="{Binding CurrentCalculatorVm}" />
      </Panel>

    </Panel>

    <!-- Ad Banner Spacer (64dp fuer adaptive Banner) -->
    <Border AutomationProperties.AutomationId="Main_AdSpacer" Grid.Row="1" Height="64"
            IsVisible="{Binding IsAdBannerVisible}" />

    <!-- Ersatz-Spacer wenn Tab-Bar versteckt (Calculator offen) -->
    <!-- Gleiche Hoehe wie Tab-Bar, damit Buttons ueber der nativen Ad bleiben -->
    <Border Grid.Row="2" Height="60"
            IsVisible="{Binding IsCalculatorOpen}" />

    <!-- Bottom Tab Bar -->
    <Border AutomationProperties.AutomationId="Main_TabBar"
            Grid.Row="2"
            Background="{DynamicResource SurfaceBrush}"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource CardBorderBrush}"
            IsVisible="{Binding !IsCalculatorOpen}">
      <Grid ColumnDefinitions="*,*,*,*" Margin="0,2">
        <!-- Home Tab -->
        <Button AutomationProperties.AutomationId="Main_BtnTabHome"
                Grid.Column="0" Classes="Text"
                Command="{Binding SelectHomeTabCommand}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="0" Height="56">
          <StackPanel Spacing="2">
            <Border Height="3" CornerRadius="2" Margin="12,0"
                    IsVisible="{Binding IsHomeTab}">
              <Border.Background>
                <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
              </Border.Background>
            </Border>
            <Border Height="3" IsVisible="{Binding !IsHomeTab}" />
            <Panel>
              <mi:MaterialIcon Kind="Home" Width="24" Height="24"
                               Foreground="{DynamicResource PrimaryBrush}"
                               IsVisible="{Binding IsHomeTab}" />
              <mi:MaterialIcon Kind="HomeOutline" Width="24" Height="24"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding !IsHomeTab}" />
            </Panel>
            <Panel>
              <TextBlock Text="{Binding TabHomeText}" FontSize="11"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}"
                         FontWeight="Medium"
                         IsVisible="{Binding IsHomeTab}" />
              <TextBlock Text="{Binding TabHomeText}" FontSize="11"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextMutedBrush}"
                         IsVisible="{Binding !IsHomeTab}" />
            </Panel>
          </StackPanel>
        </Button>

        <!-- Projects Tab -->
        <Button AutomationProperties.AutomationId="Main_BtnTabProjects"
                Grid.Column="1" Classes="Text"
                Command="{Binding SelectProjectsTabCommand}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="0" Height="56">
          <StackPanel Spacing="2">
            <Border Height="3" CornerRadius="2" Margin="12,0"
                    IsVisible="{Binding IsProjectsTab}">
              <Border.Background>
                <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
              </Border.Background>
            </Border>
            <Border Height="3" IsVisible="{Binding !IsProjectsTab}" />
            <Panel>
              <mi:MaterialIcon Kind="FolderOpen" Width="24" Height="24"
                               Foreground="{DynamicResource PrimaryBrush}"
                               IsVisible="{Binding IsProjectsTab}" />
              <mi:MaterialIcon Kind="FolderOutline" Width="24" Height="24"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding !IsProjectsTab}" />
            </Panel>
            <Panel>
              <TextBlock Text="{Binding TabProjectsText}" FontSize="11"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}"
                         FontWeight="Medium"
                         IsVisible="{Binding IsProjectsTab}" />
              <TextBlock Text="{Binding TabProjectsText}" FontSize="11"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextMutedBrush}"
                         IsVisible="{Binding !IsProjectsTab}" />
            </Panel>
          </StackPanel>
        </Button>

        <!-- History Tab -->
        <Button AutomationProperties.AutomationId="Main_BtnTabHistory"
                Grid.Column="2" Classes="Text"
                Command="{Binding SelectHistoryTabCommand}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="0" Height="56">
          <StackPanel Spacing="2">
            <Border Height="3" CornerRadius="2" Margin="12,0"
                    IsVisible="{Binding IsHistoryTab}">
              <Border.Background>
                <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
              </Border.Background>
            </Border>
            <Border Height="3" IsVisible="{Binding !IsHistoryTab}" />
            <Panel>
              <mi:MaterialIcon Kind="Clock" Width="24" Height="24"
                               Foreground="{DynamicResource PrimaryBrush}"
                               IsVisible="{Binding IsHistoryTab}" />
              <mi:MaterialIcon Kind="ClockOutline" Width="24" Height="24"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding !IsHistoryTab}" />
            </Panel>
            <Panel>
              <TextBlock Text="{Binding TabHistoryText}" FontSize="11"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}"
                         FontWeight="Medium"
                         IsVisible="{Binding IsHistoryTab}" />
              <TextBlock Text="{Binding TabHistoryText}" FontSize="11"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextMutedBrush}"
                         IsVisible="{Binding !IsHistoryTab}" />
            </Panel>
          </StackPanel>
        </Button>

        <!-- Settings Tab -->
        <Button AutomationProperties.AutomationId="Main_BtnTabSettings"
                Grid.Column="3" Classes="Text"
                Command="{Binding SelectSettingsTabCommand}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="0" Height="56">
          <StackPanel Spacing="2">
            <Border Height="3" CornerRadius="2" Margin="12,0"
                    IsVisible="{Binding IsSettingsTab}">
              <Border.Background>
                <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
              </Border.Background>
            </Border>
            <Border Height="3" IsVisible="{Binding !IsSettingsTab}" />
            <Panel>
              <mi:MaterialIcon Kind="Cog" Width="24" Height="24"
                               Foreground="{DynamicResource PrimaryBrush}"
                               IsVisible="{Binding IsSettingsTab}" />
              <mi:MaterialIcon Kind="CogOutline" Width="24" Height="24"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding !IsSettingsTab}" />
            </Panel>
            <Panel>
              <TextBlock Text="{Binding TabSettingsText}" FontSize="11"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}"
                         FontWeight="Medium"
                         IsVisible="{Binding IsSettingsTab}" />
              <TextBlock Text="{Binding TabSettingsText}" FontSize="11"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextMutedBrush}"
                         IsVisible="{Binding !IsSettingsTab}" />
            </Panel>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Game Juice Overlays -->
    <controls:FloatingTextOverlay AutomationProperties.AutomationId="Main_FloatingText"
                                  x:Name="FloatingTextCanvas"
                                  Grid.RowSpan="3" ZIndex="15"
                                  IsHitTestVisible="False" />

  </Grid>

  <!-- Splash Overlay mit echtem Preloading -->
  <controls:SplashOverlay x:Name="Splash"
                           AppName="HandwerkerRechner" />
  </Panel>

</UserControl>
