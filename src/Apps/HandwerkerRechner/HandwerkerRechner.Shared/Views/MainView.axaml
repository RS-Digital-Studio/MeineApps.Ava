<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerRechner.ViewModels"
             xmlns:floorVm="using:HandwerkerRechner.ViewModels.Floor"
             xmlns:premVm="using:HandwerkerRechner.ViewModels.Premium"
             xmlns:floorViews="using:HandwerkerRechner.Views.Floor"
             xmlns:premViews="using:HandwerkerRechner.Views.Premium"
             xmlns:views="using:HandwerkerRechner.Views"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:controls="using:MeineApps.UI.Controls"
             xmlns:behaviors="using:MeineApps.UI.Behaviors"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:skia="using:Avalonia.Labs.Controls"
             x:Class="HandwerkerRechner.Views.MainView"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="True"
             Background="Transparent">

  <UserControl.Styles>
    <Style Selector="Border.TabContent">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.TabContent:not(.Active)">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="Border.TabContent.Active">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
      <Setter Property="IsVisible" Value="True" />
    </Style>

    <!-- Premium-Card Shimmer (subtil) -->
    <Style Selector="Border.PremiumShimmer">
      <Style.Animations>
        <Animation Duration="0:0:2.5" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.88"/></KeyFrame>
          <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.88"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Export-Icon Spin-Animation (RotateTransform.Angle statt RenderTransform - KeyFrame hat keinen Animator fuer RenderTransform) -->
    <Style Selector="mi|MaterialIcon.Spinning">
      <Setter Property="RenderTransformOrigin" Value="50%,50%" />
      <Setter Property="RenderTransform">
        <RotateTransform />
      </Setter>
      <Style.Animations>
        <Animation Duration="0:0:1" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <!--
    DataTemplates entfernt: Globaler ViewLocator (App.axaml) löst alle Calculator-VMs per Konvention auf
    (HandwerkerRechner.ViewModels.Floor.TileCalculatorViewModel → HandwerkerRechner.Views.Floor.TileCalculatorView).
    Spart Boilerplate + Wartungslast bei neuen Calculatoren.
  -->

  <Panel>
  <Grid AutomationProperties.AutomationId="Main_RootGrid" RowDefinitions="*,Auto,Auto">

    <!-- Animierter Blueprint-Hintergrund (alle Rows, hinter Content) -->
    <skia:SKCanvasView x:Name="BackgroundCanvas"
                        Grid.RowSpan="3"
                        IsHitTestVisible="False"
                        PaintSurface="OnBackgroundPaintSurface" />

    <!-- Content Area -->
    <Panel Grid.Row="0">

      <!-- Tab 0: Home -->
      <Border AutomationProperties.AutomationId="Main_TabHome"
              Classes="TabContent"
              Classes.Active="{Binding IsHomeTab}">
        <ScrollViewer AutomationProperties.AutomationId="Main_ScrollHome">
          <StackPanel Spacing="0">

            <!-- ========== Hero-Header (Blueprint-Blau Gradient = Marken-Identität) ========== -->
            <Border AutomationProperties.AutomationId="Main_HeroHeader" CornerRadius="0,0,16,16" Padding="20,20,20,16"
                    Background="{DynamicResource HeaderGradientBrush}">
              <StackPanel Spacing="8" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                  <Border Width="36" Height="36" CornerRadius="18" Background="#33FFFFFF">
                    <mi:MaterialIcon Kind="RulerSquareCompass" Width="20" Height="20"
                                     Foreground="White"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock AutomationProperties.AutomationId="Main_TxtAppTitle"
                             Text="{Binding AppTitle}"
                             FontSize="20" FontWeight="Bold" Foreground="White"
                             VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock AutomationProperties.AutomationId="Main_TxtAppDescription"
                           Text="{Binding AppDescription}"
                           FontSize="13" Foreground="#BBFFFFFF"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="300" />
                <TextBlock AutomationProperties.AutomationId="Main_TxtCalculatorCount"
                           Text="{Binding CalculatorCountText}"
                           FontSize="12" Foreground="#99FFFFFF"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <!-- ========== Content ========== -->
            <StackPanel Spacing="16" Margin="16,16,16,0">

              <!-- ========== Favoriten Schnellzugriff ========== -->
              <Border IsVisible="{Binding HasFavorites}" Padding="0,4,0,0">
                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding FavoritesTitleText}" FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FavoriteCalculators}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="10" /></ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Background="Transparent" Padding="0"
                                  Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).OpenFavoriteCommand}"
                                  CommandParameter="{Binding Route}">
                            <Border CornerRadius="12" Padding="12,8" MinWidth="90">
                              <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                  <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                                  <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                                </LinearGradientBrush>
                              </Border.Background>
                              <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <mi:MaterialIcon Kind="Star" Width="20" Height="20"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Label}" FontSize="11" TextAlignment="Center"
                                           MaxWidth="80" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                              </StackPanel>
                            </Border>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

              <!-- ========== Premium-Card (direkt unter Hero) ========== -->
              <Button AutomationProperties.AutomationId="Main_BtnPremiumCard"
                      Background="Transparent" Padding="0"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      IsVisible="{Binding !IsPremium}"
                      Command="{Binding PurchaseRemoveAdsCommand}">
                <i:Interaction.Behaviors>
                  <behaviors:TapScaleBehavior PressedScale="0.97"/>
                  <behaviors:FadeInBehavior Duration="300"/>
                </i:Interaction.Behaviors>
                <Border Classes="PremiumShimmer" CornerRadius="16" Padding="18" ClipToBounds="True"
                        Background="{DynamicResource PremiumGradientBrush}">
                  <Panel>
                    <Ellipse Width="100" Height="100"
                             Opacity="0.1" Fill="White"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             Margin="0,0,-20,0" />
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Border Grid.Column="0" Width="44" Height="44"
                              CornerRadius="22" Background="#33FFFFFF"
                              Classes="GoldGlow"
                              Margin="0,0,14,0">
                        <mi:MaterialIcon Kind="Star" Width="24" Height="24"
                                         Foreground="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock AutomationProperties.AutomationId="Main_TxtGetPremium"
                                   Text="{Binding GetPremiumText}"
                                   FontSize="15" FontWeight="Bold" Foreground="White" />
                        <TextBlock AutomationProperties.AutomationId="Main_TxtPremiumPrice"
                                   Text="{Binding PremiumPriceText}"
                                   FontSize="12" Foreground="#CCFFFFFF" />
                      </StackPanel>
                      <mi:MaterialIcon Grid.Column="2"
                                       Kind="ChevronRight" Width="20" Height="20"
                                       Foreground="#AAFFFFFF" VerticalAlignment="Center" />
                    </Grid>
                  </Panel>
                </Border>
              </Button>

              <!-- ========== Section: Boden & Wand ========== -->
              <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Background="#F59E0B" CornerRadius="6" Padding="8,4">
                    <TextBlock AutomationProperties.AutomationId="Main_TxtSectionFloorWall" Text="{Binding SectionFloorWallText}" FontSize="11" FontWeight="Bold" Foreground="White" />
                  </Border>
                  <TextBlock AutomationProperties.AutomationId="Main_TxtCategoryFloorWall"
                             Text="{Binding CategoryFloorWallLabel}"
                             FontSize="18" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                  <!-- Fliesen -->
                  <Button AutomationProperties.AutomationId="Main_BtnTiles"
                          Grid.Row="0" Grid.Column="0"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToTilesCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="0" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <Panel>
                      <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Border CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                              <GradientStop Color="#F59E0B" Offset="0" />
                              <GradientStop Color="#D97706" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <mi:MaterialIcon Kind="ViewGrid" Width="24" Height="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock AutomationProperties.AutomationId="Main_TxtTilesLabel"
                                   Text="{Binding CalcTilesLabel}"
                                   FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CalcTilesDescLabel}"
                                   FontSize="11" TextAlignment="Center" MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <!-- Favoriten-Stern: gefüllt (Gold) wenn Favorit, Outline sonst -->
                      <Button Classes="Text" Padding="0" MinWidth="44" MinHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                              Command="{Binding ToggleFavoriteCommand}" CommandParameter="TileCalculatorPage">
                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavTileCalculator}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavTileCalculator}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>

                  <!-- Tapete -->
                  <Button AutomationProperties.AutomationId="Main_BtnWallpaper"
                          Grid.Row="0" Grid.Column="1"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToWallpaperCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="30" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <Panel>
                      <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Border CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                              <GradientStop Color="#8B5CF6" Offset="0" />
                              <GradientStop Color="#7C3AED" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <mi:MaterialIcon Kind="Wallpaper" Width="24" Height="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock AutomationProperties.AutomationId="Main_TxtWallpaperLabel"
                                   Text="{Binding CalcWallpaperLabel}"
                                   FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CalcWallpaperDescLabel}"
                                   FontSize="11" TextAlignment="Center" MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <Button Classes="Text" Padding="0" MinWidth="44" MinHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                              Command="{Binding ToggleFavoriteCommand}" CommandParameter="WallpaperCalculatorPage">
                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavWallpaper}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavWallpaper}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>

                  <!-- Farbe -->
                  <Button AutomationProperties.AutomationId="Main_BtnPaint"
                          Grid.Row="1" Grid.Column="0"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToPaintCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="60" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <Panel>
                      <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Border CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                              <GradientStop Color="#22C55E" Offset="0" />
                              <GradientStop Color="#16A34A" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <mi:MaterialIcon Kind="FormatPaint" Width="24" Height="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock AutomationProperties.AutomationId="Main_TxtPaintLabel"
                                   Text="{Binding CalcPaintLabel}"
                                   FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CalcPaintDescLabel}"
                                   FontSize="11" TextAlignment="Center" MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <Button Classes="Text" Padding="0" MinWidth="44" MinHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                              Command="{Binding ToggleFavoriteCommand}" CommandParameter="PaintCalculatorPage">
                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavPaint}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavPaint}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>

                  <!-- Boden -->
                  <Button AutomationProperties.AutomationId="Main_BtnFlooring"
                          Grid.Row="1" Grid.Column="1"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToFlooringCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="90" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <Panel>
                      <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Border CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                              <GradientStop Color="#3B82F6" Offset="0" />
                              <GradientStop Color="#2563EB" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <mi:MaterialIcon Kind="Layers" Width="24" Height="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock AutomationProperties.AutomationId="Main_TxtFlooringLabel"
                                   Text="{Binding CalcFlooringLabel}"
                                   FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CalcFlooringDescLabel}"
                                   FontSize="11" TextAlignment="Center" MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <Button Classes="Text" Padding="0" MinWidth="44" MinHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                              Command="{Binding ToggleFavoriteCommand}" CommandParameter="FlooringCalculatorPage">
                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavFlooring}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavFlooring}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>
                  <!-- Beton -->
                  <Button AutomationProperties.AutomationId="Main_BtnConcrete"
                          Grid.Row="2" Grid.Column="0"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToConcreteCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="120" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <Panel>
                      <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Border CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                              <GradientStop Color="#78716C" Offset="0" />
                              <GradientStop Color="#57534E" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <mi:MaterialIcon Kind="CubeOutline" Width="24" Height="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock AutomationProperties.AutomationId="Main_TxtConcreteLabel"
                                   Text="{Binding CalcConcreteLabel}"
                                   FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CalcConcreteDescLabel}"
                                   FontSize="11" TextAlignment="Center" MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <Button Classes="Text" Padding="0" MinWidth="44" MinHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                              Command="{Binding ToggleFavoriteCommand}" CommandParameter="ConcretePage">
                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavConcrete}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavConcrete}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>
                </Grid>
              </StackPanel>

              <!-- ========== Section: Profi-Werkzeuge ========== -->
              <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Background="{DynamicResource AccentBrush}" CornerRadius="6" Padding="8,4">
                    <TextBlock AutomationProperties.AutomationId="Main_TxtSectionPremiumTools" Text="{Binding SectionPremiumToolsText}" FontSize="11" FontWeight="Bold" Foreground="White" />
                  </Border>
                  <TextBlock AutomationProperties.AutomationId="Main_TxtMoreCategories"
                             Text="{Binding MoreCategoriesLabel}"
                             FontSize="18" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                  <!-- Trockenbau -->
                  <Button AutomationProperties.AutomationId="Main_BtnDrywall"
                          Grid.Row="0" Grid.Column="0"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToDrywallCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="150" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource CardColor}" Offset="0" />
                        <GradientStop Color="{DynamicResource CardHoverColor}" Offset="1" />
                      </LinearGradientBrush>
                    </Button.Background>
                    <Panel>
                      <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Border CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                              <GradientStop Color="#EF4444" Offset="0" />
                              <GradientStop Color="#DC2626" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <mi:MaterialIcon Kind="Wall" Width="24" Height="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock AutomationProperties.AutomationId="Main_TxtDrywallLabel"
                                   Text="{Binding CategoryDrywallLabel}"
                                   FontSize="13" FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CategoryDrywallDescLabel}"
                                   FontSize="11" TextAlignment="Center" MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                      <!-- Favoriten-Stern: gefüllt (Gold) wenn Favorit, Outline sonst -->
                      <Button Classes="Text" Padding="0" MinWidth="44" MinHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                              Command="{Binding ToggleFavoriteCommand}" CommandParameter="DrywallPage">
                        <Panel>
                          <mi:MaterialIcon Kind="Star" Width="16" Height="16" Foreground="#F59E0B"
                                           IsVisible="{Binding IsFavDrywall}" />
                          <mi:MaterialIcon Kind="StarOutline" Width="16" Height="16"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding !IsFavDrywall}" />
                        </Panel>
                      </Button>
                    </Panel>
                  </Button>

                  <!-- Elektro -->
                  <Button AutomationProperties.AutomationId="Main_BtnElectrical"
                          Grid.Row="0" Grid.Column="1"
                          CornerRadius="12" Height="140" Padding="8"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding NavigateToElectricalCommand}">
                    <i:Interaction.Behaviors>
                      <behaviors:TapScaleBehavior PressedScale="0.96"/>
                      <behaviors:FadeInBehavior Delay="180" Duration="250"/>
                    </i:Interaction.Behaviors>
                    <Button.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
