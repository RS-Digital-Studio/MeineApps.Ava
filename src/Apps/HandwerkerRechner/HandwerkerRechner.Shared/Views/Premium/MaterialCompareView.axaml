<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerRechner.ViewModels.Premium"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:skia="using:Avalonia.Labs.Controls"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:MeineApps.UI.Behaviors"
             x:Class="HandwerkerRechner.Views.Premium.MaterialCompareView"
             x:DataType="vm:MaterialCompareViewModel"
             Background="Transparent">

  <Grid RowDefinitions="Auto,*,Auto"
        AutomationProperties.AutomationId="MatCompare_RootGrid">

    <!-- Zeile 0: Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource AccentBrush}"
            Padding="16,12,16,20"
            CornerRadius="0,0,24,24"
            AutomationProperties.AutomationId="MatCompare_HeaderBorder">
      <Grid ColumnDefinitions="Auto,*">
        <Button Command="{Binding GoBackCommand}"
                Background="#33FFFFFF"
                CornerRadius="20"
                Width="40" Height="40"
                Padding="0"
                AutomationProperties.Name="Zurück"
                AutomationProperties.AutomationId="MatCompare_BtnBack">
          <mi:MaterialIcon Kind="ArrowLeft" Width="22" Height="22" Foreground="White" />
        </Button>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                    Margin="12,0,0,0" VerticalAlignment="Center">
          <Border Background="#33FFFFFF" CornerRadius="12" Width="40" Height="40">
            <mi:MaterialIcon Kind="SwapHorizontal" Width="22" Height="22"
                             Foreground="White"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="{Binding PageTitle}"
                     FontSize="20" FontWeight="Bold" Foreground="White"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap"
                     AutomationProperties.AutomationId="MatCompare_TxtTitle" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Zeile 1: Scrollbarer Inhalt -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                  AutomationProperties.AutomationId="MatCompare_ScrollViewer">
      <StackPanel Spacing="16" Margin="16,16,16,120">

        <!-- Gemeinsame Eingabe: Fläche -->
        <Border Classes="Card StatsCard"
                AutomationProperties.AutomationId="MatCompare_CardArea">
          <i:Interaction.Behaviors>
            <behaviors:FadeInBehavior Duration="250" />
          </i:Interaction.Behaviors>
          <StackPanel Spacing="8">
            <TextBlock Text="{loc:Translate CommonSettings}"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding AreaLabel}"
                         FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox Text="{Binding Area}" Watermark="m²" Classes="Outlined"
                       AutomationProperties.AutomationId="MatCompare_TxtBoxArea" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- A/B Produkt-Cards nebeneinander -->
        <Grid ColumnDefinitions="*,12,*">

          <!-- Produkt A -->
          <Border Grid.Column="0" Classes="Card StatsCard"
                  AutomationProperties.AutomationId="MatCompare_CardProductA">
            <i:Interaction.Behaviors>
              <behaviors:FadeInBehavior Duration="300" />
            </i:Interaction.Behaviors>
            <StackPanel Spacing="10">
              <!-- A-Header mit blauem Akzent -->
              <Border Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="8,6">
                <TextBlock Text="{Binding ProductALabel}"
                           FontSize="14" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" />
              </Border>

              <!-- Bezeichnung -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding ProductNameLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBox Text="{Binding ProductAName}" Classes="Outlined"
                         AutomationProperties.AutomationId="MatCompare_TxtBoxProductAName" />
              </StackPanel>

              <!-- Preis -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding PricePerUnitLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBox Text="{Binding PriceA}" Watermark="€" Classes="Outlined"
                         AutomationProperties.AutomationId="MatCompare_TxtBoxPriceA" />
              </StackPanel>

              <!-- Verbrauch -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding ConsumptionLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBox Text="{Binding ConsumptionA}" Watermark="je m²" Classes="Outlined"
                         AutomationProperties.AutomationId="MatCompare_TxtBoxConsumptionA" />
              </StackPanel>

              <!-- Verschnitt -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding WasteLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBox Text="{Binding WasteA}" Watermark="%" Classes="Outlined"
                         AutomationProperties.AutomationId="MatCompare_TxtBoxWasteA" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Produkt B -->
          <Border Grid.Column="2" Classes="Card StatsCard"
                  AutomationProperties.AutomationId="MatCompare_CardProductB">
            <i:Interaction.Behaviors>
              <behaviors:FadeInBehavior Duration="350" />
            </i:Interaction.Behaviors>
            <StackPanel Spacing="10">
              <!-- B-Header mit lila Akzent -->
              <Border Background="#A855F7" CornerRadius="8" Padding="8,6">
                <TextBlock Text="{Binding ProductBLabel}"
                           FontSize="14" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" />
              </Border>

              <!-- Bezeichnung -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding ProductNameLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBox Text="{Binding ProductBName}" Classes="Outlined"
                         AutomationProperties.AutomationId="MatCompare_TxtBoxProductBName" />
              </StackPanel>

              <!-- Preis -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding PricePerUnitLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBox Text="{Binding PriceB}" Watermark="€" Classes="Outlined"
                         AutomationProperties.AutomationId="MatCompare_TxtBoxPriceB" />
              </StackPanel>

              <!-- Verbrauch -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding ConsumptionLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBox Text="{Binding ConsumptionB}" Watermark="je m²" Classes="Outlined"
                         AutomationProperties.AutomationId="MatCompare_TxtBoxConsumptionB" />
              </StackPanel>

              <!-- Verschnitt -->
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding WasteLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBox Text="{Binding WasteB}" Watermark="%" Classes="Outlined"
                         AutomationProperties.AutomationId="MatCompare_TxtBoxWasteB" />
              </StackPanel>
            </StackPanel>
          </Border>

        </Grid>

        <!-- Visualisierung -->
        <Border Classes="Card" Padding="0" Height="220"
                IsVisible="{Binding HasResult}" ClipToBounds="True" CornerRadius="12"
                AutomationProperties.AutomationId="MatCompare_CardVisualization">
          <skia:SKCanvasView x:Name="MaterialCompareCanvas" PaintSurface="OnPaintVisualization"
                             AutomationProperties.AutomationId="MatCompare_Canvas" />
        </Border>

        <!-- Ergebnis-Card -->
        <Border Classes="Card Elevated StatsCard"
                IsVisible="{Binding HasResult}"
                AutomationProperties.AutomationId="MatCompare_CardResult">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Translate Result}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}" />

            <!-- Hero: Günstigere Option -->
            <Border Background="#16A34A" CornerRadius="12" Padding="16,12"
                    Margin="0,4,0,8">
              <StackPanel>
                <TextBlock Text="{Binding CheaperOptionLabel}" FontSize="12" Foreground="#CCFFFFFF" />
                <TextBlock Text="{Binding CheaperProduct}"
                           FontSize="22" FontWeight="Bold" Foreground="White"
                           AutomationProperties.AutomationId="MatCompare_TxtCheaperProduct" />
              </StackPanel>
            </Border>

            <!-- Kosten A -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding ProductAName}"
                         FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding TotalCostA, StringFormat='{}{0:F2} €'}"
                         FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         AutomationProperties.AutomationId="MatCompare_TxtCostA" />
            </Grid>

            <!-- Kosten B -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding ProductBName}"
                         FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding TotalCostB, StringFormat='{}{0:F2} €'}"
                         FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         AutomationProperties.AutomationId="MatCompare_TxtCostB" />
            </Grid>

            <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,4" />

            <!-- Ersparnis -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding SavingsLabel}"
                         FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Grid.Column="1"
                         Text="{Binding SavingsAmount, StringFormat='{}{0:F2} €'}"
                         FontSize="16" FontWeight="Bold"
                         Foreground="#22C55E"
                         AutomationProperties.AutomationId="MatCompare_TxtSavings" />
            </Grid>

            <!-- Aktions-Buttons -->
            <Grid ColumnDefinitions="*,8,*" Margin="0,4,0,0">
              <Button Grid.Column="0"
                      Command="{Binding CopyResultCommand}"
                      Classes="Outlined"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      AutomationProperties.Name="Ergebnis kopieren"
                      AutomationProperties.AutomationId="MatCompare_BtnCopy">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="ContentCopy" Width="18" Height="18"
                                   Foreground="{DynamicResource AccentBrush}" />
                  <TextBlock Text="{loc:Translate ShareResult}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="2"
                      Command="{Binding ExportPdfCommand}"
                      Classes="Outlined"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      AutomationProperties.Name="PDF exportieren"
                      AutomationProperties.AutomationId="MatCompare_BtnExport">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="FilePdfBox" Width="18" Height="18"
                                   Foreground="{DynamicResource AccentBrush}" />
                  <TextBlock Text="{loc:Translate ExportMaterialList}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
                      <Button Command="{Binding ExportCsvCommand}" Classes="Text" Padding="8">
                        <mi:MaterialIcon Kind="FileDelimited" Width="20" Height="20"
                                         Foreground="{DynamicResource AccentBrush}" />
                      </Button>
            </Grid>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Zeile 2: Aktions-Buttons unten -->
    <Border Grid.Row="2" Padding="16,12" Background="{DynamicResource BackgroundBrush}"
            AutomationProperties.AutomationId="MatCompare_BottomBar">
      <Grid ColumnDefinitions="*,8,*">
        <Button Grid.Column="0"
                Classes="Outlined"
                Command="{Binding CalculateCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                AutomationProperties.Name="Berechnen"
                AutomationProperties.AutomationId="MatCompare_BtnCalculate">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="Calculator" Width="18" Height="18"
                             Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="{loc:Translate Calculate}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Grid.Column="2"
                Classes="Primary"
                Command="{Binding OpenSaveDialogCommand}"
                IsVisible="{Binding HasResult}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                AutomationProperties.Name="Projekt speichern"
                AutomationProperties.AutomationId="MatCompare_BtnSave">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="ContentSave" Width="18" Height="18" />
            <TextBlock Text="{loc:Translate Save}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Speichern-Dialog Overlay -->
    <Border Grid.Row="0" Grid.RowSpan="3"
            Background="#80000000"
            IsVisible="{Binding ShowSaveDialog}"
            AutomationProperties.AutomationId="MatCompare_SaveDialogOverlay">
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="16"
              Padding="24"
              MaxWidth="340"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              AutomationProperties.AutomationId="MatCompare_SaveDialogCard">
        <StackPanel Spacing="16">
          <TextBlock Text="{loc:Translate SaveProject}"
                     FontSize="18" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     HorizontalAlignment="Center" />
          <TextBox Text="{Binding SaveProjectName}"
                   Watermark="{loc:Translate ProjectName}"
                   Classes="Outlined"
                   AutomationProperties.AutomationId="MatCompare_TxtBoxProjectName" />
          <Grid ColumnDefinitions="*,12,*">
            <Button Grid.Column="0"
                    Classes="Outlined"
                    Command="{Binding CancelSaveDialogCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{loc:Translate Cancel}"
                    AutomationProperties.AutomationId="MatCompare_BtnCancelSave" />
            <Button Grid.Column="2"
                    Classes="Primary"
                    Command="{Binding ConfirmSaveProjectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{loc:Translate Save}"
                    AutomationProperties.AutomationId="MatCompare_BtnConfirmSave" />
          </Grid>
        </StackPanel>
      </Border>
    </Border>

  </Grid>

</UserControl>
