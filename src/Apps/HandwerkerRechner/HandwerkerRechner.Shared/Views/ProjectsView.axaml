<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerRechner.ViewModels"
             xmlns:models="using:HandwerkerRechner.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:controls="using:MeineApps.UI.Controls"
             xmlns:behaviors="using:MeineApps.UI.Behaviors"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             x:Class="HandwerkerRechner.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel"
             x:CompileBindings="True">

  <!-- Panel-Wrapper: Overlays als letzte Kinder ohne ZIndex - Android Hit-Testing funktioniert korrekt -->
  <Panel>

    <Grid AutomationProperties.AutomationId="Projects_RootGrid" RowDefinitions="Auto,*">

    <!-- Header (farbiger Gradient analog Calculator-Views: Smaragd-Cyan) -->
    <Border Grid.Row="0"
            Padding="16,12,16,20"
            CornerRadius="0,0,24,24"
            Background="{DynamicResource ProjectsHeaderGradientBrush}"
            AutomationProperties.AutomationId="Projects_HeaderBorder">
      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
        <Border Background="{DynamicResource HeaderChipBrush}" CornerRadius="12" Width="40" Height="40">
          <mi:MaterialIcon Kind="FolderMultiple" Width="22" Height="22"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock AutomationProperties.AutomationId="Projects_TxtTitle"
                   Text="{loc:Translate MyProjects}"
                   FontSize="{StaticResource FontSizeHeadlineSm}" FontWeight="Bold" Foreground="White"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- Content -->
    <Panel Grid.Row="1" Margin="16,16,16,0">

      <!-- Loading Indicator -->
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                  IsVisible="{Binding IsLoading}">
        <ProgressBar AutomationProperties.AutomationId="Projects_ProgressLoading"
                     IsIndeterminate="True"
                     Width="120"
                     HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Empty State -->
      <controls:EmptyStateView
          AutomationProperties.AutomationId="Projects_EmptyState"
          IsVisible="{Binding ShowEmptyState}"
          Icon="FolderOpen"
          Title="{loc:Translate NoProjectsSaved}"
          Subtitle="{loc:Translate SaveProjectsDescription}" />

      <!-- Project List -->
      <ScrollViewer AutomationProperties.AutomationId="Projects_ScrollList"
                    IsVisible="{Binding HasProjects}">
        <ItemsControl ItemsSource="{Binding Projects}"
                      Margin="0,0,0,200">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:Project">
              <Border Classes="Card" Margin="0,0,0,12" CornerRadius="12">
                <i:Interaction.Behaviors>
                  <behaviors:TapScaleBehavior PressedScale="0.97"/>
                  <behaviors:FadeInBehavior Duration="250"/>
                </i:Interaction.Behaviors>
                <Grid ColumnDefinitions="*,Auto">

                  <!-- Project Info (Clickable) -->
                  <Button AutomationProperties.AutomationId="Projects_BtnOpenProject"
                          Grid.Column="0"
                          Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).LoadProjectCommand}"
                          CommandParameter="{Binding}"
                          Background="Transparent" BorderThickness="0"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Padding="16" CornerRadius="12">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="{StaticResource FontSizeTitleMd}" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                      <TextBlock Text="{Binding DisplayName}"
                                 FontSize="{StaticResource FontSizeBodySm}"
                                 Foreground="{DynamicResource PrimaryBrush}" />
                      <TextBlock Text="{Binding Description}"
                                 FontSize="{StaticResource FontSizeBodySm}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextTrimming="CharacterEllipsis"
                                 MaxLines="2" />
                      <!-- Notizen-Vorschau (falls vorhanden) -->
                      <StackPanel Orientation="Horizontal" Spacing="4"
                                  IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <mi:MaterialIcon Kind="NoteTextOutline" Width="12" Height="12"
                                         Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="{Binding Notes}" FontSize="{StaticResource FontSizeCaption}" MaxLines="1"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource AccentBrush}" />
                      </StackPanel>
                      <TextBlock Text="{Binding LastModifiedDisplay}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                  </Button>

                  <!-- Aktion-Buttons (Export + Delete) -->
                  <StackPanel Grid.Column="1" Spacing="0"
                              VerticalAlignment="Top"
                              Margin="0,4,4,0">
                    <!-- Notizen bearbeiten -->
                    <Button AutomationProperties.AutomationId="Projects_BtnEditNotes"
                            Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).EditNotesCommand}"
                            CommandParameter="{Binding}"
                            Classes="Text"
                            Padding="12">
                      <mi:MaterialIcon Kind="NoteEditOutline" Width="20" Height="20"
                                       Foreground="{DynamicResource AccentBrush}" />
                    </Button>
                    <!-- Export als PDF -->
                    <Button AutomationProperties.AutomationId="Projects_BtnExportPdf"
                            Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).ExportProjectCommand}"
                            CommandParameter="{Binding}"
                            Classes="Text"
                            Padding="12">
                      <mi:MaterialIcon Kind="FilePdfBox" Width="20" Height="20"
                                       Foreground="{DynamicResource AccentBrush}" />
                    </Button>
                    <!-- Loeschen -->
                    <Button AutomationProperties.AutomationId="Projects_BtnDeleteProject"
                            Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).DeleteProjectCommand}"
                            CommandParameter="{Binding}"
                            Classes="Text"
                            Padding="12">
                      <mi:MaterialIcon Kind="Delete" Width="20" Height="20"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                    </Button>
                  </StackPanel>

                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </Panel>

    </Grid>

    <!-- Delete Confirmation Dialog Overlay -->
    <!-- Kein ZIndex: Als letztes Panel-Kind liegt es automatisch oben (Android-kompatibel) -->
    <Border AutomationProperties.AutomationId="Projects_DeleteOverlay"
            Background="{DynamicResource OverlayBrush}"
            IsVisible="{Binding ShowDeleteConfirmation}">
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="16"
              Padding="24"
              MaxWidth="340"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="16">
          <mi:MaterialIcon AutomationProperties.AutomationId="Projects_IconDeleteAlert"
                           Kind="AlertCircleOutline" Width="48" Height="48"
                           Foreground="{DynamicResource ErrorBrush}"
                           HorizontalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="Projects_TxtDeleteTitle"
                     Text="{loc:Translate DeleteProjectTitle}"
                     FontSize="{StaticResource FontSizeTitleSm}" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="Projects_TxtDeleteMessage"
                     Text="{loc:Translate DeleteProjectMessage}"
                     FontSize="{StaticResource FontSizeBodyMd}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextAlignment="Center"
                     TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,12,*">
            <Button AutomationProperties.AutomationId="Projects_BtnCancelDelete"
                    Grid.Column="0"
                    Classes="Outlined"
                    Command="{Binding CancelDeleteProjectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{loc:Translate Cancel}" />
            <Button AutomationProperties.AutomationId="Projects_BtnConfirmDelete"
                    Grid.Column="2"
                    Classes="Primary"
                    Command="{Binding ConfirmDeleteProjectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{loc:Translate Delete}" />
          </Grid>
        </StackPanel>
      </Border>
    </Border>

    <!-- Notizen-Editor Overlay -->
    <!-- Kein ZIndex: Als letztes Panel-Kind liegt es automatisch oben (Android-kompatibel) -->
    <Border Background="{DynamicResource OverlayBrush}"
            IsVisible="{Binding ShowNotesEditor}">
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="16"
              Padding="24"
              MaxWidth="380"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="NoteEditOutline" Width="24" Height="24"
                             Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="{loc:Translate ProjectNotes}"
                       FontSize="{StaticResource FontSizeTitleSm}" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>

          <TextBox AutomationProperties.AutomationId="Projects_TxtBoxNotes"
                   Text="{Binding EditingNotes, Mode=TwoWay}"
                   PlaceholderText="{loc:Translate ProjectNotesPlaceholder}"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   MinHeight="120" MaxHeight="200" />

          <!-- Foto-Galerie -->
          <TextBlock Text="{loc:Translate ProjectPhotos}"
                     FontSize="{StaticResource FontSizeBodySm}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Margin="0,8,0,4" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled"
                        MaxHeight="100">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <ItemsControl ItemsSource="{Binding CurrentProjectPhotos}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Border CornerRadius="8" ClipToBounds="True"
                            Width="80" Height="80"
                            Background="{DynamicResource CardBrush}">
                      <Grid>
                        <Image Source="{Binding}" Stretch="UniformToFill"
                               Width="80" Height="80" />
                        <!-- Löschen-Button oben rechts -->
                        <Button AutomationProperties.AutomationId="Projects_BtnDeletePhoto"
                                Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).DeletePhotoCommand}"
                                CommandParameter="{Binding}"
                                Background="#AA000000" CornerRadius="0,8,0,8"
                                Padding="4" MinWidth="36" MinHeight="36"
                                HorizontalAlignment="Right" VerticalAlignment="Top">
                          <mi:MaterialIcon Kind="Close" Width="14" Height="14"
                                           Foreground="White" />
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <!-- Foto hinzufügen (Plus-Button) -->
              <Button AutomationProperties.AutomationId="Projects_BtnAddPhoto"
                      Command="{Binding AddPhotoCommand}"
                      CommandParameter="{Binding NotesProject}"
                      Background="{DynamicResource CardBrush}"
                      CornerRadius="8"
                      Width="80" Height="80"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">
                <mi:MaterialIcon Kind="CameraPlus" Width="28" Height="28"
                                 Foreground="{DynamicResource AccentBrush}" />
              </Button>
            </StackPanel>
          </ScrollViewer>

          <Grid ColumnDefinitions="*,12,*">
            <Button AutomationProperties.AutomationId="Projects_BtnCancelNotes"
                    Grid.Column="0"
                    Classes="Outlined"
                    Command="{Binding CancelNotesEditCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{loc:Translate Cancel}" />
            <Button AutomationProperties.AutomationId="Projects_BtnSaveNotes"
                    Grid.Column="2"
                    Classes="Primary"
                    Command="{Binding SaveNotesCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16" />
                <TextBlock Text="{loc:Translate Save}" />
              </StackPanel>
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Border>

  </Panel>

</UserControl>
