<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HandwerkerRechner.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="HandwerkerRechner.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <!-- Sprach-Buttons: EIN Button pro Sprache, Selected-Optik wie Classes="Primary"
         (ersetzt das frühere Doppel-Button-Pattern mit IsVisible/!IsVisible) -->
    <Style Selector="Button.LangButton.Selected">
      <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryContrastBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.LangButton.Selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
    </Style>
    <Style Selector="Button.LangButton.Selected:pressed">
      <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer AutomationProperties.AutomationId="Settings_ScrollRoot" VerticalScrollBarVisibility="Auto">
    <!-- Bottom-Margin 120dp: Content darf nicht hinter dem Ad-Banner verschwinden (Pattern wie QuoteView/ProjectTemplatesView) -->
    <StackPanel Margin="16,16,16,120" Spacing="12">

      <!-- Header -->
      <TextBlock AutomationProperties.AutomationId="Settings_TxtTitle"
                 Text="{Binding SettingsTitleText}"
                 FontSize="{StaticResource FontSizeTitleLg}" FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 Margin="0,4,0,4" />

      <!-- ==================== Language Selection Card ==================== -->
      <Border AutomationProperties.AutomationId="Settings_CardLanguage" Classes="SettingsCard">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="Translate" Width="24" Height="24"
                             Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock AutomationProperties.AutomationId="Settings_TxtLanguageTitle"
                       Text="{Binding LanguageTitleText}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <WrapPanel Orientation="Horizontal">
            <!-- Deutsch -->
            <Button AutomationProperties.AutomationId="Settings_BtnLangGerman"
                    Classes.Selected="{Binding IsGermanSelected}"
                    Classes="Outlined Small LangButton" Content="Deutsch"
                    MinHeight="{StaticResource MinTouchTarget}"
                    Command="{Binding SelectLanguageCommand}" CommandParameter="de"
                    Margin="0,0,8,8" />

            <!-- English -->
            <Button AutomationProperties.AutomationId="Settings_BtnLangEnglish"
                    Classes.Selected="{Binding IsEnglishSelected}"
                    Classes="Outlined Small LangButton" Content="English"
                    MinHeight="{StaticResource MinTouchTarget}"
                    Command="{Binding SelectLanguageCommand}" CommandParameter="en"
                    Margin="0,0,8,8" />

            <!-- Espanol -->
            <Button AutomationProperties.AutomationId="Settings_BtnLangSpanish"
                    Classes.Selected="{Binding IsSpanishSelected}"
                    Classes="Outlined Small LangButton" Content="Espa&#241;ol"
                    MinHeight="{StaticResource MinTouchTarget}"
                    Command="{Binding SelectLanguageCommand}" CommandParameter="es"
                    Margin="0,0,8,8" />

            <!-- Francais -->
            <Button AutomationProperties.AutomationId="Settings_BtnLangFrench"
                    Classes.Selected="{Binding IsFrenchSelected}"
                    Classes="Outlined Small LangButton" Content="Fran&#231;ais"
                    MinHeight="{StaticResource MinTouchTarget}"
                    Command="{Binding SelectLanguageCommand}" CommandParameter="fr"
                    Margin="0,0,8,8" />

            <!-- Italiano -->
            <Button AutomationProperties.AutomationId="Settings_BtnLangItalian"
                    Classes.Selected="{Binding IsItalianSelected}"
                    Classes="Outlined Small LangButton" Content="Italiano"
                    MinHeight="{StaticResource MinTouchTarget}"
                    Command="{Binding SelectLanguageCommand}" CommandParameter="it"
                    Margin="0,0,8,8" />

            <!-- Portugues -->
            <Button AutomationProperties.AutomationId="Settings_BtnLangPortuguese"
                    Classes.Selected="{Binding IsPortugueseSelected}"
                    Classes="Outlined Small LangButton" Content="Portugu&#234;s"
                    MinHeight="{StaticResource MinTouchTarget}"
                    Command="{Binding SelectLanguageCommand}" CommandParameter="pt"
                    Margin="0,0,8,8" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- ==================== Unit System Card ==================== -->
      <Border AutomationProperties.AutomationId="Settings_CardUnitSystem" Classes="SettingsCard">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="Ruler" Width="24" Height="24"
                             Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock AutomationProperties.AutomationId="Settings_TxtUnitSystemTitle"
                       Text="{Binding UnitSystemTitleText}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <!-- Metric -->
            <Panel Grid.Column="0">
              <Button AutomationProperties.AutomationId="Settings_BtnMetric"
                      Classes="Primary"
                      IsVisible="{Binding IsMetricSelected}"
                      Command="{Binding SelectUnitSystemCommand}" CommandParameter="Metric"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16" />
                  <TextBlock Text="{Binding MetricText}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button AutomationProperties.AutomationId="Settings_BtnMetricInactive"
                      Classes="Outlined"
                      IsVisible="{Binding !IsMetricSelected}"
                      Command="{Binding SelectUnitSystemCommand}" CommandParameter="Metric"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      CornerRadius="8">
                <TextBlock Text="{Binding MetricText}" />
              </Button>
            </Panel>

            <!-- Imperial -->
            <Panel Grid.Column="1">
              <Button AutomationProperties.AutomationId="Settings_BtnImperial"
                      Classes="Primary"
                      IsVisible="{Binding IsImperialSelected}"
                      Command="{Binding SelectUnitSystemCommand}" CommandParameter="Imperial"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16" />
                  <TextBlock Text="{Binding ImperialText}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button AutomationProperties.AutomationId="Settings_BtnImperialInactive"
                      Classes="Outlined"
                      IsVisible="{Binding !IsImperialSelected}"
                      Command="{Binding SelectUnitSystemCommand}" CommandParameter="Imperial"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      CornerRadius="8">
                <TextBlock Text="{Binding ImperialText}" />
              </Button>
            </Panel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ==================== Premium Section (mit Shimmer) ==================== -->
      <Border AutomationProperties.AutomationId="Settings_CardPremium"
              Classes="SettingsCard PremiumShimmer"
              IsVisible="{Binding ShowPurchaseSection}">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="Crown" Width="24" Height="24"
                             Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock AutomationProperties.AutomationId="Settings_TxtPremiumTitle"
                       Text="{Binding PremiumTitleText}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="Settings_TxtRemoveAdsDesc"
                     Text="{Binding RemoveAdsDescText}"
                     FontSize="{StaticResource FontSizeBodyMd}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />

          <Button AutomationProperties.AutomationId="Settings_BtnRemoveAds"
                  Content="{Binding RemoveAdsText}"
                  Command="{Binding PurchaseRemoveAdsCommand}"
                  Classes="Primary"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  CornerRadius="8" />

          <Button AutomationProperties.AutomationId="Settings_BtnRestorePurchases"
                  Content="{Binding RestorePurchasesText}"
                  Command="{Binding RestorePurchasesCommand}"
                  Classes="Secondary"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  CornerRadius="8" />
        </StackPanel>
      </Border>

      <!-- Ad-Free Confirmation -->
      <Border AutomationProperties.AutomationId="Settings_CardAdFree"
              Classes="SettingsCard"
              IsVisible="{Binding ShowAdFreeInfo}">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="CheckCircle" Width="24" Height="24"
                             Foreground="{DynamicResource AccentBrush}" />
            <TextBlock AutomationProperties.AutomationId="Settings_TxtAdFreeTitle"
                       Text="{Binding AdFreeTitleText}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="Settings_TxtAdFreeConfirmation"
                     Text="{Binding AdFreeConfirmationText}"
                     FontSize="{StaticResource FontSizeBodyMd}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
      </Border>

      <!-- ==================== About Section ==================== -->
      <Border AutomationProperties.AutomationId="Settings_CardAbout" Classes="SettingsCard">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="InformationOutline" Width="24" Height="24"
                             Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock AutomationProperties.AutomationId="Settings_TxtAboutTitle"
                       Text="{Binding AboutTitleText}"
                       FontSize="{StaticResource FontSizeTitleMd}" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock Text="HandwerkerRechner" FontSize="{StaticResource FontSizeTitleMd}" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock AutomationProperties.AutomationId="Settings_TxtAppVersion"
                     Text="{Binding AppVersion}"
                     FontSize="{StaticResource FontSizeBodyMd}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />

          <Button AutomationProperties.AutomationId="Settings_BtnFeedback"
                  Command="{Binding SendFeedbackCommand}"
                  Classes="Outlined"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  CornerRadius="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="EmailOutline" Width="18" Height="18"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding SendFeedbackText}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button AutomationProperties.AutomationId="Settings_BtnPrivacyPolicy"
                  Command="{Binding OpenPrivacyPolicyCommand}"
                  Classes="Text"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="ShieldCheck" Width="20" Height="20" />
              <TextBlock Text="{Binding PrivacyPolicyText}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

</UserControl>
