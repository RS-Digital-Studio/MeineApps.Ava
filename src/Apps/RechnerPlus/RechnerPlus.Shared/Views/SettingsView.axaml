<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RechnerPlus.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="RechnerPlus.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer AutomationProperties.AutomationId="Settings_ScrollViewer">
    <StackPanel AutomationProperties.AutomationId="Settings_RootPanel" Margin="16" Spacing="12">

      <!-- Header -->
      <TextBlock Text="{Binding SettingsTitle}"
                 AutomationProperties.AutomationId="Settings_Title"
                 FontSize="22" FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 Margin="0,4,0,4" />

      <!-- ==================== Language Selection Card ==================== -->
      <Border AutomationProperties.AutomationId="Settings_LanguageCard" Classes="SettingsCard">
        <StackPanel Spacing="16">
          <!-- Card Header -->
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="Translate" Width="24" Height="24"
                             Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock Text="{Binding LanguageText}" AutomationProperties.AutomationId="Settings_LanguageLabel" Classes="TitleMedium"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Language Buttons -->
          <WrapPanel Orientation="Horizontal">

            <!-- English -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangEn" Classes="Primary Small" Content="English"
                      IsVisible="{Binding IsEnglishSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="en"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangEnInactive" Classes="Outlined Small" Content="English"
                      IsVisible="{Binding !IsEnglishSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="en"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Deutsch -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangDe" Classes="Primary Small" Content="Deutsch"
                      IsVisible="{Binding IsGermanSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="de"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangDeInactive" Classes="Outlined Small" Content="Deutsch"
                      IsVisible="{Binding !IsGermanSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="de"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Espanol -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangEs" Classes="Primary Small" Content="Español"
                      IsVisible="{Binding IsSpanishSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="es"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangEsInactive" Classes="Outlined Small" Content="Español"
                      IsVisible="{Binding !IsSpanishSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="es"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Francais -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangFr" Classes="Primary Small" Content="Français"
                      IsVisible="{Binding IsFrenchSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="fr"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangFrInactive" Classes="Outlined Small" Content="Français"
                      IsVisible="{Binding !IsFrenchSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="fr"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Italiano -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangIt" Classes="Primary Small" Content="Italiano"
                      IsVisible="{Binding IsItalianSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="it"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangItInactive" Classes="Outlined Small" Content="Italiano"
                      IsVisible="{Binding !IsItalianSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="it"
                      Margin="0,0,8,8" />
            </Panel>

            <!-- Portugues -->
            <Panel>
              <Button AutomationProperties.AutomationId="Settings_BtnLangPt" Classes="Primary Small" Content="Português"
                      IsVisible="{Binding IsPortugueseSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="pt"
                      Margin="0,0,8,8" />
              <Button AutomationProperties.AutomationId="Settings_BtnLangPtInactive" Classes="Outlined Small" Content="Português"
                      IsVisible="{Binding !IsPortugueseSelected}"
                      Command="{Binding SelectLanguageCommand}" CommandParameter="pt"
                      Margin="0,0,8,8" />
            </Panel>

          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- ==================== Decimal Places Card ==================== -->
      <Border AutomationProperties.AutomationId="Settings_DecimalPlacesCard" Classes="SettingsCard">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="DecimalIncrease" Width="24" Height="24"
                             Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock Text="{Binding DecimalPlacesText}" AutomationProperties.AutomationId="Settings_DecimalPlacesLabel" Classes="TitleMedium"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Stepper: - [Wert] + -->
          <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0">
            <Button Grid.Column="0"
                    AutomationProperties.AutomationId="Settings_BtnDecimalMinus"
                    Classes="Outlined Small"
                    Content="−"
                    FontSize="18" FontWeight="Bold"
                    MinWidth="44" MinHeight="40"
                    Command="{Binding DecrementDecimalPlacesCommand}"/>
            <TextBlock Grid.Column="1"
                       AutomationProperties.AutomationId="Settings_DecimalPlacesValue"
                       Text="{Binding DecimalPlacesDisplayText}"
                       FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="2"
                    AutomationProperties.AutomationId="Settings_BtnDecimalPlus"
                    Classes="Outlined Small"
                    Content="+"
                    FontSize="18" FontWeight="Bold"
                    MinWidth="44" MinHeight="40"
                    Command="{Binding IncrementDecimalPlacesCommand}"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ==================== Number Format Card ==================== -->
      <Border AutomationProperties.AutomationId="Settings_NumberFormatCard" Classes="SettingsCard">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="Numeric" Width="24" Height="24"
                             Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock Text="{Binding NumberFormatText}" AutomationProperties.AutomationId="Settings_NumberFormatLabel" Classes="TitleMedium"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- US / EU Toggle -->
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <!-- US Format -->
            <Panel Grid.Column="0">
              <Button AutomationProperties.AutomationId="Settings_BtnFormatUS" Classes="Primary Small" Content="1,234.56"
                      IsVisible="{Binding IsUSFormat}"
                      Command="{Binding SetNumberFormatCommand}" CommandParameter="0"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      FontSize="16" FontWeight="SemiBold" />
              <Button AutomationProperties.AutomationId="Settings_BtnFormatUSInactive" Classes="Outlined Small" Content="1,234.56"
                      IsVisible="{Binding !IsUSFormat}"
                      Command="{Binding SetNumberFormatCommand}" CommandParameter="0"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      FontSize="16" FontWeight="SemiBold" />
            </Panel>
            <!-- EU Format -->
            <Panel Grid.Column="1">
              <Button AutomationProperties.AutomationId="Settings_BtnFormatEU" Classes="Primary Small" Content="1.234,56"
                      IsVisible="{Binding IsEUFormat}"
                      Command="{Binding SetNumberFormatCommand}" CommandParameter="1"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      FontSize="16" FontWeight="SemiBold" />
              <Button AutomationProperties.AutomationId="Settings_BtnFormatEUInactive" Classes="Outlined Small" Content="1.234,56"
                      IsVisible="{Binding !IsEUFormat}"
                      Command="{Binding SetNumberFormatCommand}" CommandParameter="1"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      FontSize="16" FontWeight="SemiBold" />
            </Panel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ==================== Haptic Feedback Card ==================== -->
      <Border AutomationProperties.AutomationId="Settings_HapticCard" Classes="SettingsCard">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <mi:MaterialIcon Grid.Column="0" Kind="Vibrate" Width="24" Height="24"
                           Foreground="{DynamicResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
          <TextBlock Grid.Column="1"
                     AutomationProperties.AutomationId="Settings_HapticLabel"
                     Text="{Binding HapticText}" Classes="TitleMedium"
                     VerticalAlignment="Center" />
          <!-- Toggle-Button -->
          <ToggleSwitch Grid.Column="2"
                        AutomationProperties.AutomationId="Settings_HapticToggle"
                        IsChecked="{Binding HapticEnabled}"
                        OnContent="" OffContent=""
                        VerticalAlignment="Center" />
        </Grid>
      </Border>

      <!-- ==================== About Card ==================== -->
      <Border AutomationProperties.AutomationId="Settings_AboutCard" Classes="SettingsCard">
        <StackPanel Spacing="16">
          <!-- Card Header -->
          <StackPanel Orientation="Horizontal" Spacing="12">
            <mi:MaterialIcon Kind="InformationOutline" Width="24" Height="24"
                             Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock Text="{Binding AboutAppText}" AutomationProperties.AutomationId="Settings_AboutLabel" Classes="TitleMedium"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- App Info -->
          <StackPanel Spacing="8">
            <TextBlock AutomationProperties.AutomationId="Settings_AppName" Text="RechnerPlus" Classes="TitleLarge" />
            <TextBlock AutomationProperties.AutomationId="Settings_VersionText" Text="{Binding VersionText}" Classes="BodyMedium"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock AutomationProperties.AutomationId="Settings_AppDescription" Text="{Binding AppDescriptionText}" Classes="BodyMedium"
                       TextWrapping="Wrap" />
            <TextBlock AutomationProperties.AutomationId="Settings_Copyright" Text="© 2026 RS Digital" Classes="Caption"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ==================== Action Buttons ==================== -->
      <Button AutomationProperties.AutomationId="Settings_BtnFeedback"
              Classes="Outlined" HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Command="{Binding SendFeedbackCommand}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <mi:MaterialIcon Kind="Email" Width="20" Height="20" />
          <TextBlock Text="{Binding FeedbackText}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>

      <Button AutomationProperties.AutomationId="Settings_BtnPrivacyPolicy"
              Classes="Text" HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Command="{Binding OpenPrivacyPolicyCommand}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <mi:MaterialIcon Kind="ShieldCheck" Width="20" Height="20" />
          <TextBlock Text="{Binding PrivacyPolicyText}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>

      <!-- Bottom Spacer -->
      <Border Height="60" />

    </StackPanel>
  </ScrollViewer>

</UserControl>
