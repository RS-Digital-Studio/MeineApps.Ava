<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet (Karten-Tiles, Geospatial/VPS) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- GPS (Handy-Position fuer Karte + AR-Georeferenzierung) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Kamera (AR-Capture) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Galerie-Speicherung (Screenshots/Aufnahmen via MediaStore). Ab Android 10 (API 29)
         braucht das Schreiben eigener Medien KEINE Permission — daher maxSdkVersion=28, nur
         fuer aeltere Geraete (minSdk 26). -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
                     android:maxSdkVersion="28" />

    <!-- ARCore Hardware-Feature (optional, damit App auch ohne AR-Support installierbar ist) -->
    <uses-feature android:name="android.hardware.camera.ar" android:required="false" />

    <!-- Keine Werbe-ID (rein privat) -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"
                     tools:node="remove" />

    <application
        android:allowBackup="false"
        android:largeHeap="true"
        android:icon="@mipmap/appicon"
        android:roundIcon="@mipmap/appicon_round"
        android:label="SmartMeasure"
        android:theme="@style/MyTheme.NoActionBar">

        <!-- ARCore Required (Google Play Services for AR wird automatisch installiert) -->
        <meta-data android:name="com.google.ar.core" android:value="required" />

        <!-- ARCore Geospatial API API-Key. Restriktiert auf SHA1 des Keystores +
             Package com.rsdigital.smartmeasure. Privat, funktioniert nur mit signierter App. -->
        <meta-data android:name="com.google.android.ar.API_KEY"
                   android:value="AIzaSyAwiV05cpoj1Pcz5Z_2MReAtiHcywgrOQk" />

        <!-- FileProvider für Export-Share (DXF, KMZ, PDF, CSV, GeoJSON, OBJ) -->
        <provider android:name="androidx.core.content.FileProvider"
                  android:authorities="${applicationId}.fileprovider"
                  android:exported="false"
                  android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS"
                       android:resource="@xml/provider_paths" />
        </provider>
    </application>
</manifest>
