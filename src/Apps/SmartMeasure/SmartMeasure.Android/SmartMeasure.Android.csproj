<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-android</TargetFramework>
    <OutputType>Exe</OutputType>
    <ApplicationId>com.rsdigital.smartmeasure</ApplicationId>
    <ApplicationTitle>SmartMeasure</ApplicationTitle>
    <ApplicationVersion>12</ApplicationVersion>
    <ApplicationDisplayVersion>1.1.8</ApplicationDisplayVersion>
    <Version>1.1.8</Version>

    <!-- Min-API 26 (Android 8.0) — deckt NotificationChannel, FileProvider, PendingIntent.Immutable ab.
         BLE-Scan (API 31+) und ForegroundServiceType (API 29+) werden zur Laufzeit via
         Build.VERSION.SdkInt-Check abgesichert. -->
    <SupportedOSPlatformVersion>26</SupportedOSPlatformVersion>

    <!-- Mapsui + NetTopologySuite nutzen Reflection die unter AOT/Trimmer fehlschlagen.
         AOT deaktivieren: Kein JIT-Crash, kein Trimmer-Problem mit NTS-Geometrien -->
    <RunAOTCompilation>false</RunAOTCompilation>
    <AndroidEnableProguard>false</AndroidEnableProguard>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SmartMeasure.Shared\SmartMeasure.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Android" />
    <PackageReference Include="Vapolia.Google.ARCore" />
  </ItemGroup>
</Project>
