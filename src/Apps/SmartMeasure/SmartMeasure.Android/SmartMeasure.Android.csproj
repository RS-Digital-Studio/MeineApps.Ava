<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-android</TargetFramework>
    <OutputType>Exe</OutputType>
    <ApplicationId>com.rsdigital.smartmeasure</ApplicationId>
    <ApplicationTitle>SmartMeasure</ApplicationTitle>
    <ApplicationVersion>3</ApplicationVersion>
    <ApplicationDisplayVersion>1.0.2</ApplicationDisplayVersion>
    <Version>1.0.2</Version>

    <!-- Mapsui + NetTopologySuite nutzen Reflection die unter AOT/Trimmer fehlschlagen.
         AOT deaktivieren: Kein JIT-Crash, kein Trimmer-Problem mit NTS-Geometrien -->
    <RunAOTCompilation>false</RunAOTCompilation>
    <AndroidEnableProguard>false</AndroidEnableProguard>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SmartMeasure.Shared\SmartMeasure.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Android" />
    <PackageReference Include="Vapolia.Google.ARCore" />
  </ItemGroup>
</Project>
