<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartMeasure.Shared.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:models="using:SmartMeasure.Shared.Models"
             xmlns:labs="using:Avalonia.Labs.Controls"
             x:Class="SmartMeasure.Shared.Views.GardenPlanView"
             x:CompileBindings="True"
             x:DataType="vm:GardenPlanViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Werkzeug-Toolbar oben -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" Padding="8,4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Padding="8,6" CornerRadius="6" ToolTip.Tip="Weg"
                            Background="{DynamicResource BgCardBrush}"
                            Command="{Binding SelectToolCommand}" CommandParameter="Weg">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="Road" Width="16" Height="16" Foreground="#78909C" />
                            <TextBlock Text="Weg" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" CornerRadius="6" ToolTip.Tip="Beet"
                            Background="{DynamicResource BgCardBrush}"
                            Command="{Binding SelectToolCommand}" CommandParameter="Beet">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="Flower" Width="16" Height="16" Foreground="#6D4C41" />
                            <TextBlock Text="Beet" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" CornerRadius="6" ToolTip.Tip="Rasen"
                            Background="{DynamicResource BgCardBrush}"
                            Command="{Binding SelectToolCommand}" CommandParameter="Rasen">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="Grass" Width="16" Height="16" Foreground="#66BB6A" />
                            <TextBlock Text="Rasen" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" CornerRadius="6" ToolTip.Tip="Mauer"
                            Background="{DynamicResource BgCardBrush}"
                            Command="{Binding SelectToolCommand}" CommandParameter="Mauer">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="Wall" Width="16" Height="16" Foreground="#EF5350" />
                            <TextBlock Text="Mauer" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" CornerRadius="6" ToolTip.Tip="Zaun"
                            Background="{DynamicResource BgCardBrush}"
                            Command="{Binding SelectToolCommand}" CommandParameter="Zaun">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="Fence" Width="16" Height="16" Foreground="#EF5350" />
                            <TextBlock Text="Zaun" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" CornerRadius="6" ToolTip.Tip="Terrasse"
                            Background="{DynamicResource BgCardBrush}"
                            Command="{Binding SelectToolCommand}" CommandParameter="Terrasse">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="ViewDashboard" Width="16" Height="16" Foreground="#D7CCC8" />
                            <TextBlock Text="Terrasse" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- Separator -->
                    <Border Width="1" Background="{DynamicResource BgCardBrush}" Margin="4,2" />

                    <!-- Undo letztes Element -->
                    <Button Padding="8,6" CornerRadius="6" Command="{Binding UndoCommand}"
                            IsEnabled="{Binding CanUndo}" Background="{DynamicResource BgCardBrush}"
                            ToolTip.Tip="Letztes Element entfernen">
                        <mi:MaterialIcon Kind="Undo" Width="16" Height="16"
                                         Foreground="{DynamicResource TextSecondaryBrush}" />
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Zeichnungsmodus-Leiste (nur sichtbar wenn gezeichnet wird) -->
        <Border Grid.Row="1" Background="#2C2C3E" Padding="8,4"
                IsVisible="{Binding IsDrawing}">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <!-- Aktives Werkzeug + Punktzahl -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding SelectedTool}" FontSize="11" FontWeight="SemiBold"
                               Foreground="#FFEB3B" VerticalAlignment="Center" />
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center">
                        <Run Text="{Binding DrawingPointCount}" />
                        <Run Text=" Punkte" />
                    </TextBlock>
                </StackPanel>

                <!-- Letzten Punkt entfernen -->
                <Button Grid.Column="2" Padding="8,4" CornerRadius="6" Margin="4,0"
                        Command="{Binding UndoDrawPointCommand}"
                        IsEnabled="{Binding IsDrawing}" Background="#3A3A4E"
                        ToolTip.Tip="Letzten Punkt entfernen">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="UndoVariant" Width="14" Height="14" Foreground="#FFEB3B" />
                        <TextBlock Text="Punkt" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Button>

                <!-- Fertig -->
                <Button Grid.Column="3" Padding="10,4" CornerRadius="6" Margin="4,0"
                        Command="{Binding FinishDrawingCommand}" Background="#2E7D32"
                        ToolTip.Tip="Element fertigstellen">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="Check" Width="14" Height="14" Foreground="White" />
                        <TextBlock Text="Fertig" FontSize="10" FontWeight="SemiBold" Foreground="White" />
                    </StackPanel>
                </Button>

                <!-- Abbrechen -->
                <Button Grid.Column="4" Padding="8,4" CornerRadius="6" Margin="4,0"
                        Command="{Binding CancelDrawingCommand}" Background="#C62828"
                        ToolTip.Tip="Zeichnung abbrechen">
                    <mi:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="White" />
                </Button>
            </Grid>
        </Border>

        <!-- SkiaSharp Canvas -->
        <Panel Grid.Row="2">
            <labs:SKCanvasView x:Name="PlanCanvas" PaintSurface="OnPaintSurface" />
        </Panel>

        <!-- Materialliste unten -->
        <Border Grid.Row="3" Background="{DynamicResource BgSecondaryBrush}"
                Padding="12,6" MaxHeight="120">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="Materialliste" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <ItemsControl ItemsSource="{Binding Materials}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:MaterialEstimate">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Text="{Binding Material}" FontSize="11"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1" FontSize="11" FontWeight="Bold" Margin="8,0"
                                               Foreground="{DynamicResource PrimaryBrush}">
                                        <Run Text="{Binding QuantityWithSafety, StringFormat='{}{0:F1}'}" />
                                    </TextBlock>
                                    <TextBlock Grid.Column="2" Text="{Binding Unit}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock FontSize="11" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextMutedBrush}">
                        <Run Text="Werte inkl. 15% Sicherheitszuschlag" />
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
