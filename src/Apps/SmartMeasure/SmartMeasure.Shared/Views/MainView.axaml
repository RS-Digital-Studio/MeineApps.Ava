<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartMeasure.Shared.ViewModels"
             xmlns:views="using:SmartMeasure.Shared.Views"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="SmartMeasure.Shared.Views.MainView"
             x:CompileBindings="True"
             x:DataType="vm:MainViewModel"
             Background="{DynamicResource BgPrimaryBrush}">

    <UserControl.Styles>
        <!-- Tab-Content Fade -->
        <Style Selector="Border.TabContent">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.TabContent:not(.Active)">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Border.TabContent.Active">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

        <!-- Tab-Buttons -->
        <Style Selector="Button.TabBtn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Padding" Value="0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="MinWidth" Value="48" />
        </Style>
        <Style Selector="Button.TabBtn.Active">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="Ellipse.TabDot">
            <Setter Property="Width" Value="4" />
            <Setter Property="Height" Value="4" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="Ellipse.TabDot.Active">
            <Setter Property="Fill" Value="{DynamicResource PrimaryBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Status-Bar oben (adaptiv: AR-Modus schlank, RTK-Modus voll mit Hardware-Werten) -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" Padding="12,6">
            <Panel>
                <!-- AR-Modus: schlanke Marken-Leiste + dezenter Modus-Chip -->
                <Grid ColumnDefinitions="Auto,*,Auto" IsVisible="{Binding !ShowRtkUi}">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="TapeMeasure" Width="18" Height="18"
                                         Foreground="{DynamicResource PrimaryBrush}" />
                        <TextBlock Text="SmartMeasure" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                            Background="{DynamicResource BgCardBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <mi:MaterialIcon Kind="CubeScan" Width="13" Height="13"
                                             Foreground="{DynamicResource ArContourBrush}"
                                             VerticalAlignment="Center" />
                            <TextBlock Text="AR-Modus" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RTK-Modus: volle Hardware-Statusleiste -->
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" IsVisible="{Binding ShowRtkUi}">
                    <!-- BLE-Status -->
                    <mi:MaterialIcon Grid.Column="0" Kind="Bluetooth"
                                     IsVisible="{Binding IsBleConnected}"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Width="16" Height="16" />
                    <mi:MaterialIcon Grid.Column="0" Kind="BluetoothOff"
                                     IsVisible="{Binding !IsBleConnected}"
                                     Foreground="{DynamicResource DangerBrush}"
                                     Width="16" Height="16" />

                    <!-- Fix-Status -->
                    <Border Grid.Column="1" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                            Background="{DynamicResource BgCardBrush}">
                        <TextBlock Text="{Binding FixStatusText}"
                                   FontWeight="Bold" FontSize="11"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </Border>

                    <!-- Spacer -->
                    <Panel Grid.Column="2" />

                    <!-- Genauigkeit -->
                    <TextBlock Grid.Column="3" VerticalAlignment="Center"
                               FontSize="10" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="±" /><Run Text="{Binding HorizontalAccuracy, StringFormat='{}{0:F1}'}" /><Run Text="cm" />
                    </TextBlock>

                    <!-- Satelliten -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="3" Margin="0,0,8,0">
                        <mi:MaterialIcon Kind="Satellite" Width="12" Height="12"
                                         Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding SatelliteCount}" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>

                    <!-- Akku -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="3">
                        <mi:MaterialIcon Kind="Battery80" Width="12" Height="12"
                                         Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}">
                            <Run Text="{Binding BatteryLevel}" /><Run Text="%" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Panel>
        </Border>

        <!-- Content (alle Views per Opacity umgeschaltet, MapView lazy) -->
        <Panel Grid.Row="1">
            <Border Classes="TabContent" Classes.Active="{Binding IsSurveyActive}">
                <views:SurveyView DataContext="{Binding SurveyVm}" />
            </Border>
            <Border Classes="TabContent" Classes.Active="{Binding IsTerrainActive}">
                <views:TerrainView DataContext="{Binding TerrainVm}" />
            </Border>
            <Border Classes="TabContent" Classes.Active="{Binding IsGardenActive}">
                <views:GardenPlanView DataContext="{Binding GardenPlanVm}" />
            </Border>
            <!-- MapView wird NICHT im XAML erstellt - Mapsui MapControl crasht auf Android
                 wenn GL-Kontext noch nicht bereit ist. Wird per Code-Behind lazy erzeugt. -->
            <Border x:Name="MapContainer" Classes="TabContent" Classes.Active="{Binding IsMapActive}" />
            <Border Classes="TabContent" Classes.Active="{Binding IsProjectsActive}">
                <views:ProjectsView DataContext="{Binding ProjectsVm}" />
            </Border>
            <Border Classes="TabContent" Classes.Active="{Binding IsStakeoutActive}">
                <views:StakeoutView DataContext="{Binding StakeoutVm}" />
            </Border>
            <Border Classes="TabContent" Classes.Active="{Binding IsConnectActive}">
                <views:ConnectView DataContext="{Binding ConnectVm}" />
            </Border>
            <Border Classes="TabContent" Classes.Active="{Binding IsSettingsActive}">
                <views:SettingsView DataContext="{Binding SettingsVm}" />
            </Border>

            <!-- Export-Banner: Schwebt unten rechts über dem Content -->
            <Border IsVisible="{Binding IsExportBannerVisible}"
                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                    Margin="12,0,12,12"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="12,10" Opacity="0.97">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                    <mi:MaterialIcon Grid.Column="0" Kind="FileDownloadOutline" Width="22" Height="22"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource PrimaryBrush}" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Export erstellt" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding LastExportFileName}" FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="2" Padding="10,8" MinHeight="36"
                            CornerRadius="6" FontSize="11"
                            Command="{Binding OpenLastExportCommand}"
                            Background="{DynamicResource BgElevatedBrush}"
                            Foreground="{DynamicResource AccentBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="OpenInNew" Width="14" Height="14" />
                            <TextBlock Text="Öffnen" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Padding="10,8" MinHeight="36"
                            CornerRadius="6" FontSize="11"
                            Command="{Binding ShareLastExportCommand}"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="White">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="ShareVariant" Width="14" Height="14" />
                            <TextBlock Text="Teilen" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Padding="8" MinHeight="36" MinWidth="36"
                            CornerRadius="6"
                            Command="{Binding DismissExportBannerCommand}"
                            Background="Transparent"
                            Foreground="{DynamicResource TextMutedBrush}">
                        <mi:MaterialIcon Kind="Close" Width="14" Height="14" />
                    </Button>
                </Grid>
            </Border>
        </Panel>

        <!-- Tab-Bar unten (adaptiv: AR-Modus 6 Tabs, RTK-Modus 8 Tabs).
             UniformGrid verteilt nur die SICHTBAREN Buttons gleichmaessig — Abstecken + BLE
             sind im reinen AR-Modus ausgeblendet (Hardware-only), Optionen bleibt letzter Tab. -->
        <Border Grid.Row="2" Background="{DynamicResource TabBarGradientBrush}"
                BorderBrush="{DynamicResource BgCardBrush}" BorderThickness="0,1,0,0">
            <UniformGrid Rows="1" Height="56">
                <!-- Messung -->
                <Button Classes="TabBtn" Classes.Active="{Binding IsSurveyActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Survey">
                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="MapMarkerRadius" Width="22" Height="22" />
                        <TextBlock Text="Messen" FontSize="9" HorizontalAlignment="Center" />
                        <Ellipse Classes="TabDot" Classes.Active="{Binding IsSurveyActive}" />
                    </StackPanel>
                </Button>
                <!-- 3D-Gelände -->
                <Button Classes="TabBtn" Classes.Active="{Binding IsTerrainActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Terrain">
                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="Terrain" Width="22" Height="22" />
                        <TextBlock Text="3D" FontSize="9" HorizontalAlignment="Center" />
                        <Ellipse Classes="TabDot" Classes.Active="{Binding IsTerrainActive}" />
                    </StackPanel>
                </Button>
                <!-- Gartenplan -->
                <Button Classes="TabBtn" Classes.Active="{Binding IsGardenActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Garden">
                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="FlowerOutline" Width="22" Height="22" />
                        <TextBlock Text="Garten" FontSize="9" HorizontalAlignment="Center" />
                        <Ellipse Classes="TabDot" Classes.Active="{Binding IsGardenActive}" />
                    </StackPanel>
                </Button>
                <!-- Karte -->
                <Button Classes="TabBtn" Classes.Active="{Binding IsMapActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Map">
                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="Map" Width="22" Height="22" />
                        <TextBlock Text="Karte" FontSize="9" HorizontalAlignment="Center" />
                        <Ellipse Classes="TabDot" Classes.Active="{Binding IsMapActive}" />
                    </StackPanel>
                </Button>
                <!-- Projekte -->
                <Button Classes="TabBtn" Classes.Active="{Binding IsProjectsActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Projects">
                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="FolderMultiple" Width="22" Height="22" />
                        <TextBlock Text="Projekte" FontSize="9" HorizontalAlignment="Center" />
                        <Ellipse Classes="TabDot" Classes.Active="{Binding IsProjectsActive}" />
                    </StackPanel>
                </Button>
                <!-- Absteckung (nur RTK-Modus — braucht cm-genaue Live-Position) -->
                <Button Classes="TabBtn" Classes.Active="{Binding IsStakeoutActive}"
                        IsVisible="{Binding ShowRtkUi}"
                        Command="{Binding NavigateCommand}" CommandParameter="Stakeout">
                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="TargetVariant" Width="22" Height="22" />
                        <TextBlock Text="Abstecken" FontSize="9" HorizontalAlignment="Center" />
                        <Ellipse Classes="TabDot" Classes.Active="{Binding IsStakeoutActive}" />
                    </StackPanel>
                </Button>
                <!-- Verbinden (nur RTK-Modus) -->
                <Button Classes="TabBtn" Classes.Active="{Binding IsConnectActive}"
                        IsVisible="{Binding ShowRtkUi}"
                        Command="{Binding NavigateCommand}" CommandParameter="Connect">
                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="BluetoothConnect" Width="22" Height="22" />
                        <TextBlock Text="BLE" FontSize="9" HorizontalAlignment="Center" />
                        <Ellipse Classes="TabDot" Classes.Active="{Binding IsConnectActive}" />
                    </StackPanel>
                </Button>
                <!-- Optionen -->
                <Button Classes="TabBtn" Classes.Active="{Binding IsSettingsActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Settings">
                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="Cog" Width="22" Height="22" />
                        <TextBlock Text="Optionen" FontSize="9" HorizontalAlignment="Center" />
                        <Ellipse Classes="TabDot" Classes.Active="{Binding IsSettingsActive}" />
                    </StackPanel>
                </Button>
            </UniformGrid>
        </Border>
    </Grid>
</UserControl>
