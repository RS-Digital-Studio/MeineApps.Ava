<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartMeasure.Shared.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:mapsui="using:Mapsui.UI.Avalonia"
             x:Class="SmartMeasure.Shared.Views.MapView"
             x:DataType="vm:MapViewModel">

    <Grid RowDefinitions="*,Auto">
        <!-- Mapsui Karten-Control -->
        <mapsui:MapControl x:Name="MapControl" Grid.Row="0" />

        <!-- Overlay: Statistiken -->
        <Border Grid.Row="0" Background="#80000000" CornerRadius="8" Padding="10,6"
                HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="VectorPolygon" Width="14" Height="14"
                                     Foreground="{DynamicResource SecondaryBrush}" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run Text="Fläche: " /><Run Text="{Binding AreaText}" FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="RulerSquare" Width="14" Height="14"
                                     Foreground="{DynamicResource SecondaryBrush}" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run Text="Umfang: " /><Run Text="{Binding PerimeterText}" FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
                <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}">
                    <Run Text="{Binding PointCount}" /><Run Text=" Punkte" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Aktualisieren-Button -->
        <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
                Command="{Binding UpdateMapCommand}"
                Background="#80000000" CornerRadius="8" Padding="8">
            <mi:MaterialIcon Kind="Refresh" Width="20" Height="20"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
        </Button>
    </Grid>
</UserControl>
