<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartMeasure.Shared.ViewModels"
             xmlns:models="using:SmartMeasure.Shared.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="SmartMeasure.Shared.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Neues Projekt erstellen -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding NewProjectName}"
                         Watermark="Neues Projekt..." FontSize="14"
                         Background="{DynamicResource BgCardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
                <Button Grid.Column="1" Command="{Binding CreateProjectCommand}"
                        CornerRadius="{DynamicResource ButtonRadius}"
                        Background="{DynamicResource PrimaryGradientBrush}"
                        Foreground="White" Padding="16,8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Kind="Plus" Width="18" Height="18" />
                        <TextBlock Text="Erstellen" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Projektliste -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Projects}" Margin="12,8,12,60">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:SurveyProject">
                        <Border Background="{DynamicResource CardGradientBrush}"
                                CornerRadius="{DynamicResource CardRadius}"
                                Padding="{DynamicResource CardPadding}"
                                Margin="0,4"
                                BorderBrush="{DynamicResource BgCardBrush}"
                                BorderThickness="1">
                            <Grid RowDefinitions="Auto,Auto,Auto">
                                <!-- Kopfzeile: Name + Typ -->
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <Border Grid.Column="1" Background="{DynamicResource BgElevatedBrush}"
                                            CornerRadius="4" Padding="8,2">
                                        <TextBlock Text="{Binding ProjectType}" FontSize="10"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </Border>
                                </Grid>

                                <!-- Info: Punkte, Fläche, Datum -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,6,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <mi:MaterialIcon Kind="MapMarker" Width="14" Height="14"
                                                         Foreground="{DynamicResource PrimaryBrush}" />
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run Text="{Binding PointCount}" /><Run Text=" Punkte" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <mi:MaterialIcon Kind="VectorPolygon" Width="14" Height="14"
                                                         Foreground="{DynamicResource SecondaryBrush}" />
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run Text="{Binding AreaSquareMeters, StringFormat='{}{0:F0}'}" /><Run Text=" m²" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Text="{Binding ModifiedAt, StringFormat='{}{0:dd.MM.yy}'}" />
                                </StackPanel>

                                <!-- Aktionen -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
                                    <Button Padding="8,4" CornerRadius="6" FontSize="11"
                                            Background="{DynamicResource BgElevatedBrush}"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            Command="{Binding $parent[ItemsControl].((vm:ProjectsViewModel)DataContext).OpenProjectCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <mi:MaterialIcon Kind="FolderOpen" Width="14" Height="14" />
                                            <TextBlock Text="Öffnen" />
                                        </StackPanel>
                                    </Button>
                                    <Button Padding="8,4" CornerRadius="6" FontSize="11"
                                            Background="{DynamicResource BgElevatedBrush}"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Command="{Binding $parent[ItemsControl].((vm:ProjectsViewModel)DataContext).DuplicateProjectCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <mi:MaterialIcon Kind="ContentCopy" Width="14" Height="14" />
                                            <TextBlock Text="Kopieren" />
                                        </StackPanel>
                                    </Button>
                                    <Button Padding="8,4" CornerRadius="6" FontSize="11"
                                            Background="{DynamicResource BgElevatedBrush}"
                                            Foreground="{DynamicResource SecondaryBrush}"
                                            Command="{Binding $parent[ItemsControl].((vm:ProjectsViewModel)DataContext).ExportCsvCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="CSV" />
                                    </Button>
                                    <Button Padding="8,4" CornerRadius="6" FontSize="11"
                                            Background="{DynamicResource BgElevatedBrush}"
                                            Foreground="{DynamicResource SecondaryBrush}"
                                            Command="{Binding $parent[ItemsControl].((vm:ProjectsViewModel)DataContext).ExportGeoJsonCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="GeoJSON" />
                                    </Button>
                                    <Button Padding="8,4" CornerRadius="6" FontSize="11"
                                            Background="Transparent"
                                            Foreground="{DynamicResource DangerBrush}"
                                            Command="{Binding $parent[ItemsControl].((vm:ProjectsViewModel)DataContext).DeleteProjectCommand}"
                                            CommandParameter="{Binding}">
                                        <mi:MaterialIcon Kind="Delete" Width="14" Height="14" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
