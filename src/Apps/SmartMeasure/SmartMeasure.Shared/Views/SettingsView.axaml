<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartMeasure.Shared.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="SmartMeasure.Shared.Views.SettingsView"
             x:CompileBindings="True"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Margin="16,12,16,80">

            <!-- Titel -->
            <TextBlock Text="Einstellungen" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="4,0,0,4" />

            <!-- AR-Modus: RTK-Stab als optionale Hardware bewerben -->
            <Border IsVisible="{Binding !ShowRtkUi}"
                    Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="{DynamicResource CardPadding}"
                    BorderBrush="{DynamicResource BgCardBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Bluetooth" Width="20" Height="20"
                                         Foreground="{DynamicResource SecondaryBrush}" />
                        <TextBlock Text="RTK-Vermessungsstab (optional)" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="Du misst aktuell mit der AR-Kamera (±5–50 cm). Für zentimetergenaue Grenz- und Höhenpunkte kannst du optional einen RTK-GPS-Stab per Bluetooth verbinden."
                               FontSize="12.5" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <Button Command="{Binding ConnectRtkStickCommand}"
                            HorizontalAlignment="Left" Padding="16,11" MinHeight="44"
                            CornerRadius="{DynamicResource ButtonRadius}"
                            Background="{DynamicResource BgElevatedBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="BluetoothConnect" Width="18" Height="18"
                                             Foreground="{DynamicResource SecondaryBrush}" />
                            <TextBlock Text="RTK-Stab verbinden" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- RTK-Modus: Vermessungsstab-Einstellungen -->
            <Border IsVisible="{Binding ShowRtkUi}"
                    Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="{DynamicResource CardPadding}"
                    BorderBrush="{DynamicResource BgCardBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="RulerSquare" Width="20" Height="20"
                                         Foreground="{DynamicResource PrimaryBrush}" />
                        <TextBlock Text="Vermessungsstab" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>

                    <TextBlock Text="Stablänge (Antenne bis Spitze)" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding StabHeight}"
                                 Background="{DynamicResource BgElevatedBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Grid.Column="1" Text="m" FontSize="14" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Grid>

                    <TextBlock Text="Minimale Fix-Quality für Punktaufnahme" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding MinFixQuality}"
                                 Background="{DynamicResource BgElevatedBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Grid.Column="1" Text="(4=Fix, 5=Float)" FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Grid>

                    <Button Command="{Binding ResetToArModeCommand}"
                            HorizontalAlignment="Left" Padding="14,10" MinHeight="44" Margin="0,4,0,0"
                            CornerRadius="{DynamicResource SmallRadius}"
                            Background="Transparent"
                            Foreground="{DynamicResource TextMutedBrush}"
                            ToolTip.Tip="Blendet die Hardware-Ansicht aus und startet wieder im reinen AR-Modus.">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="CubeScan" Width="16" Height="16" />
                            <TextBlock Text="Zurück zum AR-Modus" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Anzeige -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="{DynamicResource CardPadding}"
                    BorderBrush="{DynamicResource BgCardBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Cog" Width="20" Height="20"
                                         Foreground="{DynamicResource SecondaryBrush}" />
                        <TextBlock Text="Anzeige" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Metrisches System (m, m²)" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding UseMetric}"
                                      OnContent="m" OffContent="ft" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Daten -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="{DynamicResource CardPadding}"
                    BorderBrush="{DynamicResource BgCardBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Database" Width="20" Height="20"
                                         Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="Daten" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>

                    <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="Datenbank: " /><Run Text="{Binding DatabaseInfo}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Info -->
            <Border Background="{DynamicResource CardGradientBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="{DynamicResource CardPadding}"
                    BorderBrush="{DynamicResource BgCardBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="InformationOutline" Width="20" Height="20"
                                         Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="SmartMeasure" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13">
                        <Run Text="Version " /><Run Text="{Binding AppVersion}" />
                    </TextBlock>
                    <TextBlock Text="3D-Grundstücksvermessung + Gartenplanung" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    <TextBlock Text="AR-Kamera (±5–50 cm) · RTK-GPS optional (±2 cm)" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="Export: CSV, GeoJSON, OBJ (Blender), PDF" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
