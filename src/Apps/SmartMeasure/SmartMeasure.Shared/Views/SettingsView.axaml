<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartMeasure.Shared.ViewModels"
             x:Class="SmartMeasure.Shared.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Margin="16">
            <Border Background="{DynamicResource BgCardBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="{DynamicResource CardPadding}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Einstellungen" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Text="Stablänge (Antenne → Spitze, in m)" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding StabHeight}"
                             Background="{DynamicResource BgElevatedBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Text="Minimale Fix-Quality" FontSize="13" Margin="0,12,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="5 = Float (empfohlen), 4 = nur RTK Fix" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBox Text="{Binding MinFixQuality}"
                             Background="{DynamicResource BgElevatedBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource BgCardBrush}"
                    CornerRadius="{DynamicResource CardRadius}"
                    Padding="{DynamicResource CardPadding}"
                    Margin="0,0,0,60">
                <StackPanel Spacing="4">
                    <TextBlock Text="SmartMeasure" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13">
                        <Run Text="Version " /><Run Text="{Binding AppVersion}" />
                    </TextBlock>
                    <TextBlock Text="3D-Grundstücksvermessung + Gartenplanung" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    <TextBlock Text="RTK-GPS Vermessungsstab mit ±2cm Genauigkeit" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
