<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartMeasure.Shared.ViewModels"
             xmlns:models="using:SmartMeasure.Shared.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:labs="using:Avalonia.Labs.Controls"
             x:Class="SmartMeasure.Shared.Views.StakeoutView"
             x:CompileBindings="True"
             x:DataType="vm:StakeoutViewModel">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Background="{DynamicResource BgPrimaryBrush}">

        <!-- Status-Zeile oben -->
        <Border Grid.Row="0" Background="{DynamicResource BgCardBrush}"
                Padding="12,8">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <mi:MaterialIcon Grid.Column="0" Kind="TargetVariant" Width="18" Height="18"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource PrimaryBrush}" />
                <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="12"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                    <Button Padding="10,6" MinHeight="36" FontSize="11"
                            Command="{Binding LoadTargetsCommand}"
                            Background="{DynamicResource BgElevatedBrush}"
                            Foreground="{DynamicResource SecondaryBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="Refresh" Width="14" Height="14" />
                            <TextBlock Text="Ziele laden" />
                        </StackPanel>
                    </Button>
                    <Button Padding="10,6" MinHeight="36" FontSize="11"
                            Command="{Binding StartArStakeoutCommand}"
                            Background="{DynamicResource BgElevatedBrush}"
                            Foreground="{DynamicResource PrimaryBrush}"
                            ToolTip.Tip="Absteckung in AR-Kamera anzeigen">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="AugmentedReality" Width="14" Height="14" />
                            <TextBlock Text="AR" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Kompass-Pfeil (SkiaSharp) -->
        <Panel Grid.Row="1">
            <labs:SKCanvasView x:Name="StakeoutCanvas" PaintSurface="OnPaintSurface" />
        </Panel>

        <!-- Markiert-Button nur bei aktivem Ziel -->
        <Button Grid.Row="2" IsVisible="{Binding HasActiveTarget}"
                Command="{Binding MarkReachedCommand}"
                HorizontalAlignment="Stretch" Margin="12,4,12,8" Height="56"
                CornerRadius="{DynamicResource ButtonRadius}"
                Background="{DynamicResource AccentBrush}"
                Foreground="White" FontSize="15" FontWeight="Bold">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <mi:MaterialIcon Kind="CheckBold" Width="22" Height="22" />
                <TextBlock Text="PUNKT MARKIEREN" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <!-- Ziel-Liste -->
        <Border Grid.Row="3" Background="{DynamicResource BgCardBrush}"
                Padding="10,8" MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Targets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:StakeoutTarget">
                            <Button HorizontalAlignment="Stretch" Padding="10,8" Margin="0,2"
                                    MinHeight="44"
                                    Command="{Binding $parent[ItemsControl].((vm:StakeoutViewModel)DataContext).SelectTargetCommand}"
                                    CommandParameter="{Binding}"
                                    Background="{DynamicResource BgElevatedBrush}"
                                    CornerRadius="6">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <mi:MaterialIcon Grid.Column="0" Kind="CheckCircle" Width="16" Height="16"
                                                     IsVisible="{Binding IsReached}"
                                                     Foreground="{DynamicResource AccentBrush}"
                                                     VerticalAlignment="Center" />
                                    <mi:MaterialIcon Grid.Column="0" Kind="MapMarkerOutline" Width="16" Height="16"
                                                     IsVisible="{Binding !IsReached}"
                                                     Foreground="{DynamicResource SecondaryBrush}"
                                                     VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="2" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center">
                                        <Run Text="{Binding Source}" />
                                    </TextBlock>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
