<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:labs="using:Avalonia.Labs.Controls"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:vm="using:SunSeeker.Shared.ViewModels"
             xmlns:models="using:SunSeeker.Shared.Models"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="900"
             x:Class="SunSeeker.Shared.Views.AlignView"
             x:CompileBindings="True" x:DataType="vm:AlignViewModel"
             Background="{DynamicResource BgPrimaryBrush}">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardGradientBrush}" />
            <Setter Property="CornerRadius" Value="{DynamicResource CardRadius}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="{DynamicResource PagePadding}">

            <TextBlock Text="{loc:Translate Key=CardAlignTitle}" FontSize="14" FontWeight="Bold" Margin="0,4,0,12"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- Panel + Ziel -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,0,0,12">
                <ComboBox Grid.Column="0" ItemsSource="{Binding Panels}" SelectedItem="{Binding SelectedPanel}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:PanelProfile">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Goals}" SelectedItem="{Binding SelectedGoal}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:GoalOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <!-- Kompass -->
            <labs:SKCanvasView x:Name="CompassCanvas" Height="320" Margin="0,0,0,8" />

            <!-- Haupt-Anweisung -->
            <Border Classes="card">
                <StackPanel>
                    <TextBlock Text="{Binding AzimuthGuidance}" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding TiltGuidance}" FontSize="16" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding QualityText}" FontSize="13" Margin="0,8,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Kalibrier-Warnung -->
            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource SmallRadius}"
                    Padding="12,8" Margin="0,0,0,12" IsVisible="{Binding ShowCalibrationWarning}">
                <Grid ColumnDefinitions="Auto,*">
                    <materialIcons:MaterialIcon Grid.Column="0" Kind="CompassOffOutline" Width="18" Height="18"
                                                Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource WarningBrush}" FontSize="12"
                               Text="{loc:Translate Key=WarnCalibration}" />
                </Grid>
            </Border>

            <!-- Ist vs Soll -->
            <Border Classes="card">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{loc:Translate Key=LabelPanelDirection}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Classes="label" Text="{loc:Translate Key=LabelTargetDirection}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="value" Text="{Binding PanelAzimuthText}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Classes="value"
                               Foreground="{DynamicResource AccentLightBrush}" Text="{Binding TargetAzimuthText}" />
                    <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                        <TextBlock Classes="label" Text="{loc:Translate Key=LabelTiltCurrent}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Classes="value" FontSize="15" Text="{Binding PanelTiltText}" />
                    </Grid>
                    <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                        <TextBlock Classes="label" Text="{loc:Translate Key=LabelTargetShort}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Classes="value" FontSize="15"
                                   Foreground="{DynamicResource AccentLightBrush}" Text="{Binding TargetTiltText}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Classes="card" IsVisible="{Binding ShowKickstandHint}">
                <TextBlock Text="{Binding KickstandHint}" Foreground="{DynamicResource PrimaryLightBrush}"
                           FontWeight="SemiBold" TextWrapping="Wrap" />
            </Border>

            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,4">
                <materialIcons:MaterialIcon Grid.Column="0" Kind="SolarPower" Width="18" Height="18"
                                            Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding GainText}" Margin="8,0,0,0"
                           Foreground="{DynamicResource AccentLightBrush}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Grid>
            <TextBlock Text="{Binding SunInfoText}" Classes="label" Margin="26,0,0,8" />

            <TextBlock Text="{loc:Translate Key=HintHoldPhone}"
                       Classes="label" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,0,0,12" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
