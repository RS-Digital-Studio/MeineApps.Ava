<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:labs="using:Avalonia.Labs.Controls"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:vm="using:SunSeeker.Shared.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="900"
             x:Class="SunSeeker.Shared.Views.LivePowerView"
             x:CompileBindings="True" x:DataType="vm:LivePowerViewModel"
             Background="{DynamicResource BgPrimaryBrush}">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardGradientBrush}" />
            <Setter Property="CornerRadius" Value="{DynamicResource CardRadius}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="{DynamicResource PagePadding}">

            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,12">
                <TextBlock Grid.Column="0" Text="{loc:Translate Key=CardPower}" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding StateText}" Classes="label" VerticalAlignment="Center" />
            </Grid>

            <!-- Anker-Verbindung (echte Live-Watt-Anbindung) -->
            <Border Classes="card">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="PowerPlugOutline" Width="18" Height="18"
                                                    Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{loc:Translate Key=AnkerCardTitle}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Command="{Binding ToggleAnkerSettingsCommand}" Background="Transparent"
                                Padding="6" IsVisible="{Binding IsConfigured}"
                                AutomationProperties.AutomationId="AnkerSettingsToggleButton"
                                ToolTip.Tip="{loc:Translate Key=AnkerSettings}">
                            <materialIcons:MaterialIcon Kind="Cog" Width="20" Height="20"
                                                        Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Button>
                    </Grid>

                    <StackPanel IsVisible="{Binding ShowAnkerSettings}" Margin="0,10,0,0" Spacing="8">
                        <TextBlock Text="{loc:Translate Key=AnkerHintGoogle}" Classes="label" TextWrapping="Wrap" />
                        <TextBox Text="{Binding AnkerEmail}" PlaceholderText="{loc:Translate Key=AnkerEmail}"
                                 AutomationProperties.AutomationId="AnkerEmailTextBox" />
                        <TextBox Text="{Binding AnkerPassword}" PasswordChar="●"
                                 PlaceholderText="{loc:Translate Key=AnkerPassword}"
                                 AutomationProperties.AutomationId="AnkerPasswordTextBox" />
                        <TextBox Text="{Binding AnkerCountry}" MaxLength="2"
                                 PlaceholderText="{loc:Translate Key=AnkerCountry}"
                                 AutomationProperties.AutomationId="AnkerCountryTextBox" />
                        <TextBlock Text="{Binding AnkerErrorText}" Foreground="{DynamicResource DangerBrush}"
                                   FontSize="12" TextWrapping="Wrap" IsVisible="{Binding HasAnkerError}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="{loc:Translate Key=AnkerConnect}"
                                    Command="{Binding ConnectAnkerCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    AutomationProperties.AutomationId="AnkerConnectButton" />
                            <Button Grid.Column="1" Content="{loc:Translate Key=AnkerForget}"
                                    Command="{Binding ForgetAnkerCommand}" IsVisible="{Binding IsConfigured}"
                                    AutomationProperties.AutomationId="AnkerForgetButton" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Aktuelle Leistung groß -->
            <Border Classes="card">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Translate Key=LabelCurrent}" Classes="label" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentWattsText}" FontSize="48" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Demo-Hinweis -->
            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource SmallRadius}"
                    Padding="12,8" Margin="0,0,0,12" IsVisible="{Binding IsSimulated}">
                <Grid ColumnDefinitions="Auto,*">
                    <materialIcons:MaterialIcon Grid.Column="0" Kind="FlaskOutline" Width="18" Height="18"
                                                Foreground="{DynamicResource InfoBrush}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{loc:Translate Key=HintDemo}" />
                </Grid>
            </Border>

            <!-- Trend-Chart -->
            <Border Classes="card">
                <StackPanel>
                    <TextBlock Text="{loc:Translate Key=CardTrend}" Classes="label" Margin="0,0,0,8" />
                    <labs:SKCanvasView x:Name="ChartCanvas" Height="180" />
                </StackPanel>
            </Border>

            <!-- Kennzahlen -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0" Classes="card" Margin="0">
                    <StackPanel>
                        <TextBlock Text="{loc:Translate Key=LabelDailyYield}" Classes="label" />
                        <TextBlock Text="{Binding TodayEnergyText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentLightBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Margin="0">
                    <StackPanel>
                        <TextBlock Text="{loc:Translate Key=LabelPeak}" Classes="label" />
                        <TextBlock Text="{Binding PeakWattsText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
