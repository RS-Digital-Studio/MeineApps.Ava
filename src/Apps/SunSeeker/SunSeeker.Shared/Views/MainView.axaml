<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:loc="using:MeineApps.Core.Ava.Localization"
             xmlns:vm="using:SunSeeker.Shared.ViewModels"
             xmlns:views="using:SunSeeker.Shared.Views"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="900"
             x:Class="SunSeeker.Shared.Views.MainView"
             x:CompileBindings="True" x:DataType="vm:MainViewModel"
             Background="{DynamicResource BgPrimaryBrush}">

    <UserControl.Styles>
        <Style Selector="Button.tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto">

        <!-- Tab-Inhalte: Wrapper-Panel traegt IsVisible (geerbter MainViewModel-DataContext),
             die Child-View setzt ihren eigenen DataContext. -->
        <Grid Grid.Row="0">
            <Panel IsVisible="{Binding IsAlignActive}">
                <views:AlignView DataContext="{Binding Align}" />
            </Panel>
            <Panel IsVisible="{Binding IsDashboardActive}">
                <views:DashboardView DataContext="{Binding Dashboard}" />
            </Panel>
            <Panel IsVisible="{Binding IsPowerActive}">
                <views:LivePowerView DataContext="{Binding Power}" />
            </Panel>
        </Grid>

        <!-- Tab-Bar -->
        <Border Grid.Row="1" Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BgElevatedBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,*,*">
                <Button Grid.Column="0" Classes="tab" Command="{Binding ShowAlignCommand}">
                    <Grid RowDefinitions="3,Auto">
                        <Border Grid.Row="0" Height="3" Width="40" CornerRadius="2"
                                Background="{DynamicResource PrimaryBrush}"
                                IsVisible="{Binding IsAlignActive}" />
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <materialIcons:MaterialIcon Kind="CompassOutline" Width="24" Height="24"
                                                        HorizontalAlignment="Center"
                                                        Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{loc:Translate Key=TabAlign}" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Grid.Column="1" Classes="tab" Command="{Binding ShowPowerCommand}">
                    <Grid RowDefinitions="3,Auto">
                        <Border Grid.Row="0" Height="3" Width="40" CornerRadius="2"
                                Background="{DynamicResource PrimaryBrush}"
                                IsVisible="{Binding IsPowerActive}" />
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <materialIcons:MaterialIcon Kind="FlashOutline" Width="24" Height="24"
                                                        HorizontalAlignment="Center"
                                                        Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{loc:Translate Key=TabPower}" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Grid.Column="2" Classes="tab" Command="{Binding ShowDashboardCommand}">
                    <Grid RowDefinitions="3,Auto">
                        <Border Grid.Row="0" Height="3" Width="40" CornerRadius="2"
                                Background="{DynamicResource PrimaryBrush}"
                                IsVisible="{Binding IsDashboardActive}" />
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <materialIcons:MaterialIcon Kind="ViewDashboardOutline" Width="24" Height="24"
                                                        HorizontalAlignment="Center"
                                                        Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{loc:Translate Key=TabDashboard}" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
