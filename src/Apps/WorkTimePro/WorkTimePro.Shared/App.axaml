<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:WorkTimePro"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:core="using:MeineApps.Core.Ava"
             x:Class="WorkTimePro.App">

  <Application.DataTemplates>
    <core:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <!-- Avalonia Fluent Theme as base -->
    <FluentTheme />

    <!-- Material Icons -->
    <materialIcons:MaterialIconStyles />

    <!-- Core Theme Colors (design tokens) -->
    <StyleInclude Source="avares://MeineApps.Core.Ava/Themes/ThemeColors.axaml" />

    <!-- App-spezifische Farbpalette -->
    <StyleInclude Source="/Themes/AppPalette.axaml" />

    <!-- UI Styles -->
    <StyleInclude Source="avares://MeineApps.UI/Styles/ButtonStyles.axaml" />
    <StyleInclude Source="avares://MeineApps.UI/Styles/TextStyles.axaml" />
    <StyleInclude Source="avares://MeineApps.UI/Styles/InputStyles.axaml" />
    <StyleInclude Source="avares://MeineApps.UI/Controls/Card.axaml" />
    <StyleInclude Source="avares://MeineApps.UI/Controls/FloatingActionButton.axaml" />
    <StyleInclude Source="avares://MeineApps.UI/Styles/ModernCardStyles.axaml" />

    <!-- Dezenter Fade-in für Modal-Overlays (Backdrop + Karte gemeinsam, 180 ms).
         Nutzung: Classes="ModalOverlay" plus Classes.open an das IstOffen-Flag binden,
         auf dem Overlay-Root-Border (IsVisible bleibt zusätzlich gebunden). Beim Schließen
         wird sofort ausgeblendet (IsVisible=false) — bewusst nur Einblend-Animation. -->
    <Style Selector="Border.ModalOverlay">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.ModalOverlay.open">
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Application.Styles>

</Application>
