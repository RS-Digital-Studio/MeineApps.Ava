<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════════════
       APP ICONS — Geteilte SVG-Path-Geometrien fuer alle Apps.
       Verwendung:
         <Path Data="{StaticResource Icon_ChevronDown}" Fill="..." Width="16" Height="16"/>
       Oder via Helper-Control SvgIcon:
         <ui:SvgIcon Kind="ChevronDown" Width="16"/>

       Konvention (siehe MeineApps.UI/CLAUDE.md "Icon-Strategie"):
         - Keine Unicode-Zeichen (▼ ▲ ★ ←) in UI-Text.
         - BomberBlast/RebornSaga: eigene GameIcon-Pfade (Neon-Arcade / Anime).
         - Andere Apps: Material.Icons.Avalonia ODER diese geteilte Lib.
       ═══════════════════════════════════════════════════════════════════════ -->

