<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BomberBlast.Tests.Ui"
             x:Class="BomberBlast.Tests.Ui.BrokenContextControl"
             x:DataType="vm:OuterTestViewModel"
             x:CompileBindings="True"
             IsVisible="{Binding IsModalVisible}">
  <!-- Reproduziert das fehlerhafte WhatsNewOverlay-Muster (Stand v2.0.62):
       In-Place-DataContext-Wechsel ueber GETRENNTE Ebenen. Aeusserer Border setzt
       den DataContext (kein x:DataType), innerer Border setzt x:DataType (kein DataContext). -->
  <Border DataContext="{Binding Inner}">
    <Border x:DataType="vm:InnerTestViewModel">
      <Button x:Name="InnerButton"
              Command="{Binding PressCommand}"
              Content="{Binding ButtonText}" />
    </Border>
  </Border>
</UserControl>
